---
// Marauder's Map — a parchment unfolds to reveal a footprint trail
// crossing it, with ink strokes fading in to draw the map as it unfolds.
// Pure SVG + CSS, no JS.
---

<div class="map-stage">
  <svg viewBox="0 0 900 520" preserveAspectRatio="xMidYMid meet" aria-labelledby="map-title">
    <title id="map-title">The Marauder's Map: parchment unfolds with footprints tracing a path across the halls of Hogwarts</title>

    <defs>
      <linearGradient id="parchment" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#e9d7a6" />
        <stop offset="40%" stop-color="#dcc58b" />
        <stop offset="100%" stop-color="#b89658" />
      </linearGradient>
      <radialGradient id="parchment-vignette" cx="50%" cy="50%" r="55%">
        <stop offset="55%" stop-color="rgba(0,0,0,0)" />
        <stop offset="100%" stop-color="rgba(60,30,0,0.35)" />
      </radialGradient>
      <filter id="rough" x="0" y="0">
        <feTurbulence baseFrequency="0.9" numOctaves="2" seed="3" />
        <feDisplacementMap in="SourceGraphic" scale="1.2" />
      </filter>
      <filter id="ink-soft">
        <feGaussianBlur stdDeviation="0.4" />
      </filter>
      <!-- Footprint shape: stylized sole + toes, works as <use> -->
      <symbol id="footprint" viewBox="-8 -14 16 28">
        <ellipse cx="0" cy="0" rx="5" ry="8" />
        <circle cx="-3" cy="-10" r="1.5" />
        <circle cx="-1" cy="-11.5" r="1.5" />
        <circle cx="1.5" cy="-12" r="1.5" />
        <circle cx="4" cy="-11" r="1.2" />
      </symbol>
    </defs>

    <!-- Unfolding parchment — 3 panels that rotate in from closed state -->
    <g class="parchment-group">
      <!-- Left panel -->
      <g class="panel panel-left" style="transform-origin: 300px 260px">
        <rect x="0" y="40" width="300" height="440" fill="url(#parchment)" rx="2" />
        <rect x="0" y="40" width="300" height="440" fill="url(#parchment-vignette)" rx="2" />
        <!-- Corridor ink lines -->
        <path class="ink ink-1" d="M 40 100 L 260 100 L 260 200 L 100 200 L 100 340 L 240 340" />
        <path class="ink ink-2" d="M 40 400 L 220 400 L 220 440" />
        <text class="map-label" x="150" y="75" text-anchor="middle">Gryffindor Tower</text>
        <text class="map-label small" x="260" y="220" text-anchor="end">Staircase</text>
      </g>

      <!-- Center panel -->
      <g class="panel panel-center">
        <rect x="300" y="20" width="300" height="480" fill="url(#parchment)" rx="2" />
        <rect x="300" y="20" width="300" height="480" fill="url(#parchment-vignette)" rx="2" />
        <!-- Title banner -->
        <text class="map-title-text" x="450" y="80" text-anchor="middle">Marauder's Map</text>
        <text class="map-oath" x="450" y="108" text-anchor="middle">I solemnly swear I am up to no good</text>
        <!-- Great Hall, Library, Dungeons outlines -->
        <path class="ink ink-3" d="M 340 160 L 560 160 L 560 240 L 420 240 L 420 320 L 560 320 L 560 420 L 340 420 Z" />
        <path class="ink ink-4" d="M 340 280 L 400 280" />
        <path class="ink ink-5" d="M 480 240 L 480 320" />
        <text class="map-label" x="500" y="185" text-anchor="middle">Great Hall</text>
        <text class="map-label" x="370" y="300" text-anchor="middle">Library</text>
        <text class="map-label" x="520" y="395" text-anchor="middle">Dungeons</text>
      </g>

      <!-- Right panel -->
      <g class="panel panel-right" style="transform-origin: 600px 260px">
        <rect x="600" y="40" width="300" height="440" fill="url(#parchment)" rx="2" />
        <rect x="600" y="40" width="300" height="440" fill="url(#parchment-vignette)" rx="2" />
        <path class="ink ink-6" d="M 640 100 L 840 100 L 840 180 L 700 180 L 700 280 L 860 280" />
        <path class="ink ink-7" d="M 640 380 L 800 380 L 800 440" />
        <text class="map-label" x="740" y="75" text-anchor="middle">Astronomy</text>
        <text class="map-label small" x="730" y="310" text-anchor="middle">Owlery</text>
      </g>
    </g>

    <!-- Footprint trail: 8 prints appearing in sequence along a path through Hogwarts -->
    <g class="footsteps">
      <use href="#footprint" class="step step-1"  transform="translate(140, 130) rotate(90)"  width="16" height="28" />
      <use href="#footprint" class="step step-2"  transform="translate(200, 200) rotate(90)"  width="16" height="28" />
      <use href="#footprint" class="step step-3"  transform="translate(260, 200) rotate(110)" width="16" height="28" />
      <use href="#footprint" class="step step-4"  transform="translate(330, 190) rotate(85)"  width="16" height="28" />
      <use href="#footprint" class="step step-5"  transform="translate(390, 220) rotate(95)"  width="16" height="28" />
      <use href="#footprint" class="step step-6"  transform="translate(450, 260) rotate(120)" width="16" height="28" />
      <use href="#footprint" class="step step-7"  transform="translate(510, 330) rotate(135)" width="16" height="28" />
      <use href="#footprint" class="step step-8"  transform="translate(580, 400) rotate(145)" width="16" height="28" />
      <use href="#footprint" class="step step-9"  transform="translate(660, 400) rotate(90)"  width="16" height="28" />
      <use href="#footprint" class="step step-10" transform="translate(740, 340) rotate(70)"  width="16" height="28" />
    </g>

    <!-- Name label that appears with the footprints ("Harry Potter") -->
    <g class="name-tag">
      <rect x="700" y="305" width="96" height="20" rx="3" />
      <text x="748" y="319" text-anchor="middle">Harry Potter</text>
    </g>
  </svg>
</div>

<style>
  .map-stage {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    background:
      radial-gradient(circle at 30% 30%, rgba(180, 130, 60, 0.08) 0%, transparent 55%),
      radial-gradient(circle at 70% 70%, rgba(94, 106, 210, 0.04) 0%, transparent 50%),
      #0b0d0e;
  }
  svg { width: 100%; height: 100%; display: block; }

  /* Unfolding parchment — side panels rotate in from folded-closed */
  .parchment-group {
    animation: parchment-glow 6s ease-in-out infinite;
  }
  @keyframes parchment-glow {
    0%, 100% { filter: drop-shadow(0 4px 14px rgba(0,0,0,0.45)); }
    50%      { filter: drop-shadow(0 6px 22px rgba(212, 160, 42, 0.18)); }
  }

  .panel-center {
    animation: center-fade 8s ease-in-out infinite;
    transform-origin: 450px 260px;
  }
  .panel-left  { animation: unfold-left  8s ease-in-out infinite; }
  .panel-right { animation: unfold-right 8s ease-in-out infinite; }

  @keyframes center-fade {
    0%, 8%    { opacity: 0; transform: scale(0.92); }
    18%, 92%  { opacity: 1; transform: scale(1); }
    100%      { opacity: 0; transform: scale(0.92); }
  }
  @keyframes unfold-left {
    0%, 12%   { transform: rotateY(95deg); opacity: 0; }
    28%, 92%  { transform: rotateY(0deg);  opacity: 1; }
    100%      { transform: rotateY(95deg); opacity: 0; }
  }
  @keyframes unfold-right {
    0%, 12%   { transform: rotateY(-95deg); opacity: 0; }
    28%, 92%  { transform: rotateY(0deg);   opacity: 1; }
    100%      { transform: rotateY(-95deg); opacity: 0; }
  }

  /* Ink strokes draw themselves in sequence */
  .ink {
    fill: none;
    stroke: #3a2912;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 600;
    stroke-dashoffset: 600;
    filter: url(#ink-soft);
    animation: draw-ink 8s ease-out infinite;
  }
  .ink-1 { animation-delay: -7.0s; }
  .ink-2 { animation-delay: -6.6s; }
  .ink-3 { animation-delay: -6.3s; }
  .ink-4 { animation-delay: -6.0s; }
  .ink-5 { animation-delay: -5.8s; }
  .ink-6 { animation-delay: -5.5s; }
  .ink-7 { animation-delay: -5.2s; }

  @keyframes draw-ink {
    0%, 32%  { stroke-dashoffset: 600; }
    48%, 92% { stroke-dashoffset: 0; }
    100%     { stroke-dashoffset: 600; }
  }

  /* Text labels */
  .map-label {
    font-family: "Luminari", "IM Fell English", serif;
    font-size: 11px;
    fill: #2a1a08;
    opacity: 0;
    animation: label-fade 8s ease-out infinite;
  }
  .map-label.small { font-size: 9px; }
  .map-title-text {
    font-family: "Luminari", "IM Fell English", serif;
    font-size: 22px;
    font-weight: 700;
    fill: #2a1a08;
    letter-spacing: 0.08em;
    opacity: 0;
    animation: label-fade 8s ease-out infinite;
    animation-delay: -6.2s;
  }
  .map-oath {
    font-family: "IM Fell English", serif;
    font-size: 9px;
    font-style: italic;
    fill: rgba(42, 26, 8, 0.7);
    opacity: 0;
    animation: label-fade 8s ease-out infinite;
    animation-delay: -6s;
  }
  @keyframes label-fade {
    0%, 42%  { opacity: 0; }
    58%, 90% { opacity: 1; }
    100%     { opacity: 0; }
  }

  /* Footsteps appear one at a time after the map is drawn */
  .step {
    fill: #3a2912;
    opacity: 0;
    animation: step-fade 8s ease-out infinite;
  }
  .step-1  { animation-delay: -3.6s; }
  .step-2  { animation-delay: -3.3s; }
  .step-3  { animation-delay: -3.0s; }
  .step-4  { animation-delay: -2.7s; }
  .step-5  { animation-delay: -2.4s; }
  .step-6  { animation-delay: -2.1s; }
  .step-7  { animation-delay: -1.8s; }
  .step-8  { animation-delay: -1.5s; }
  .step-9  { animation-delay: -1.2s; }
  .step-10 { animation-delay: -0.9s; }

  @keyframes step-fade {
    0%   { opacity: 0; transform: scale(0.6); }
    6%   { opacity: 1; transform: scale(1.25); }
    14%  { opacity: 1; transform: scale(1);    }
    60%  { opacity: 1; }
    80%  { opacity: 0.25; }
    100% { opacity: 0; }
  }

  /* "Harry Potter" name tag rides with the front-most footprint */
  .name-tag {
    opacity: 0;
    animation: tag-fade 8s ease-out infinite;
    animation-delay: -1.0s;
  }
  .name-tag rect {
    fill: rgba(58, 41, 18, 0.9);
    stroke: #2a1a08;
    stroke-width: 0.5;
  }
  .name-tag text {
    font-family: "Luminari", "IM Fell English", serif;
    font-size: 10px;
    fill: #e9d7a6;
  }
  @keyframes tag-fade {
    0%, 70%   { opacity: 0; transform: translateY(5px); }
    78%, 92%  { opacity: 1; transform: translateY(0); }
    100%      { opacity: 0; transform: translateY(5px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .parchment-group, .panel-left, .panel-right, .panel-center,
    .ink, .map-label, .map-title-text, .map-oath, .step, .name-tag {
      animation: none;
    }
    .panel-left, .panel-right, .panel-center { opacity: 1; transform: none; }
    .ink { stroke-dashoffset: 0; }
    .map-label, .map-title-text, .map-oath, .step, .name-tag { opacity: 1; }
    .step { transform: scale(1); }
  }
</style>
