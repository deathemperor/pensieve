---
// src/pages/hol/search.astro
import HolLayout from "../../components/hol/HolLayout.astro";
import { getHolDb } from "../../lib/hol/db";
import { searchPosts } from "../../lib/hol/queries";

const url = new URL(Astro.request.url);
const q = (url.searchParams.get("q") ?? "").trim();
const db = getHolDb();

// FTS5 syntax: quote phrases + require tokens; user text is safest as a
// prefix/phrase query. Strip FTS5 metacharacters to avoid syntax errors.
const safeQ = q.replace(/["'()*:^-]/g, " ").trim();
const hits = safeQ ? await searchPosts(db, safeQ, 50) : [];

const crumbs = [
  { label: "Search" },
];
---
<HolLayout title={q ? `Search: ${q}` : "Search"} crumbs={crumbs}>
  <h1>Search the archive</h1>
  <form method="get" class="hol-search-form">
    <input type="search" name="q" value={q}
           placeholder="Search posts…" autofocus required />
    <button type="submit">Search</button>
  </form>

  {q && (
    <p class="hol-search-meta">
      {hits.length} result{hits.length === 1 ? "" : "s"} for <em>{q}</em>
    </p>
  )}

  <ul class="hol-search-hits">
    {hits.map((h) => {
      const posted = h.posted_at
        ? new Date(h.posted_at * 1000).toISOString().slice(0, 10)
        : null;
      return (
        <li>
          <a href={`/hol/t/${h.thread_id}-${h.thread_slug}/#post-${h.post_id}`}>
            <strong>{h.thread_title}</strong>
          </a>
          <div class="hol-search-byline">
            {h.author_username ?? "unknown"}
            {posted && <>, <time datetime={posted}>{posted}</time></>}
          </div>
          <div class="hol-search-snippet" set:html={h.snippet} />
        </li>
      );
    })}
  </ul>
</HolLayout>
