---
// src/pages/hol/classic/t/[thread]/[...page].astro
// Matches: /hol/classic/t/1-nhat-ki-thuong-ngay/ and .../p/839/
import ClassicLayout from "../../../../../components/hol/ClassicLayout.astro";
import ClassicPostbit from "../../../../../components/hol/ClassicPostbit.astro";
import ClassicPager from "../../../../../components/hol/ClassicPager.astro";
import ClassicNotFound from "../../../../../components/hol/ClassicNotFound.astro";
import { getHolDb } from "../../../../../lib/hol/db";
import {
  countPostsInThread, getForum, getThread, getThreadPosts,
} from "../../../../../lib/hol/queries";
import { viSlug } from "../../../../../lib/hol/slug";

const PAGE_SIZE = 10;  // matches vB3 default "Posts Per Page" for showthread

const { thread: threadParam = "", page: pagePath } = Astro.params as {
  thread?: string; page?: string;
};
const idMatch = threadParam.match(/^(\d+)/);
if (!idMatch) return Astro.redirect("/hol/classic/", 302);
const threadId = parseInt(idMatch[1], 10);

let pageNum = 1;
let pageParseFailed = false;
if (pagePath) {
  const m = pagePath.match(/^p\/(\d+)\/?$/);
  if (!m) pageParseFailed = true;
  else pageNum = parseInt(m[1], 10);
}

const db = getHolDb();
// getThread filters is_hidden=0 — spam-hidden AND truly-missing both land
// in this null branch. Rather than returning a bare plain-text Response
// (ugly) we render a styled 404 inside the ClassicLayout.
const thread = pageParseFailed ? null : await getThread(db, threadId);
const notFound = thread == null;

let forum = null as Awaited<ReturnType<typeof getForum>>;
let total = 0;
let totalPages = 1;
let outOfRange = false;
let posts: Awaited<ReturnType<typeof getThreadPosts>> = [];
let crumbs: { label: string; href?: string }[] = [];
let basePath = "";
let modernHref = "/hol/";
let title = "Chủ đề không tồn tại";

if (thread) {
  forum = await getForum(db, thread.forum_id);
  total = await countPostsInThread(db, threadId);
  totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
  outOfRange = pageNum < 1 || pageNum > totalPages;
  if (!outOfRange) {
    posts = await getThreadPosts(db, threadId, { page: pageNum, pageSize: PAGE_SIZE });
  }
  const forumSlug = forum ? viSlug(forum.name) : "";
  basePath = `/hol/classic/t/${thread.id}-${thread.title_slug}/`;
  modernHref = `/hol/t/${thread.id}-${thread.title_slug}/${pageNum > 1 ? `p/${pageNum}/` : ""}`;
  crumbs = [
    ...(forum ? [{ label: forum.name, href: `/hol/classic/f/${forum.id}-${forumSlug}/` }] : []),
    { label: thread.title },
  ];
  title = thread.title;
}

if (notFound || outOfRange) Astro.response.status = 404;
---
<ClassicLayout title={title} modernHref={modernHref} crumbs={crumbs}>
  {notFound && (
    <ClassicNotFound
      kind="thread"
      reason="missing"
      backHref="/hol/classic/"
      backLabel="Về trang chính"
    />
  )}

  {thread && outOfRange && (
    <ClassicNotFound
      kind="page"
      reason="out_of_range"
      backHref={basePath}
      backLabel="Về trang 1 của chủ đề này"
    />
  )}

  {thread && !outOfRange && (
    <>
      <!-- thread title bar (thead-style banner) -->
      <table class="tborder" cellpadding="6" cellspacing="1">
        <tr>
          <td class="tcat">
            <strong>{thread.title}</strong>
            <span class="smallfont"> — {total.toLocaleString()} bài</span>
          </td>
        </tr>
      </table>

      <!-- top pager -->
      <ClassicPager basePath={basePath} page={pageNum} totalPages={totalPages} pageParam="p" />

      <!-- posts -->
      {posts.map((p) => <ClassicPostbit post={p} />)}

      <!-- bottom pager -->
      <ClassicPager basePath={basePath} page={pageNum} totalPages={totalPages} pageParam="p" />

      <div class="smallfont hol-classic-note">
        Trang {pageNum} / {totalPages} · hiển thị {PAGE_SIZE} bài / trang · theo chuẩn vBulletin 3
      </div>
    </>
  )}
</ClassicLayout>
