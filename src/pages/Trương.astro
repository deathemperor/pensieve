	@keyframes flare-sweep {
		0%, 85%, 100% { opacity: 0; transform: translate(0, 0); }
		90% { opacity: 1; transform: translate(400px, 500px); }
	}

	@keyframes flare-beam-sweep {
		0%, 80%, 100% { opacity: 0; }
		90% { opacity: 1; top: 50%; left: 0; }
	}

	/* Growing vines that creep around frame */
	.portrait-vines {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: 5;
