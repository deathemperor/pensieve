---
export const prerender = false;

import Base from "../layouts/Base.astro";
import { Image } from "astro:assets";
import profilePhoto from "../assets/truong-profile.jpg";
import { link } from "../utils/link";
import { getCurrentLang } from "../utils/lang";
const isVi = getCurrentLang(Astro) === "vi";

// GitHub API — authenticated when GITHUB_TOKEN is set (5000 req/hr),
// falls back to unauthenticated (60 req/hr) otherwise.
const ghToken = import.meta.env.GITHUB_TOKEN;

interface GitHubUser {
	public_repos: number;
	total_private_repos?: number;
	owned_private_repos?: number;
	followers: number;
	following: number;
	created_at: string;
}

interface GitHubEvent {
	type: string;
	repo: { name: string };
	created_at: string;
	payload: {
		commits?: { message: string; sha: string }[];
		action?: string;
		ref?: string;
		ref_type?: string;
	};
}

interface GitHubRepo {
	name: string;
	description: string | null;
	html_url: string;
	language: string | null;
	stargazers_count: number;
	updated_at: string;
	fork: boolean;
	private: boolean;
}

let ghUser: GitHubUser | null = null;
let ghEvents: GitHubEvent[] = [];
let ghRepos: GitHubRepo[] = [];

// Cache GitHub API responses at Cloudflare's edge (1 hour).
// Visitors never hit GitHub directly — only one request per hour per edge PoP.
const ghHeaders: Record<string, string> = {
	"User-Agent": "pensieve-site",
	Accept: "application/vnd.github.v3+json",
};
if (ghToken) ghHeaders.Authorization = `Bearer ${ghToken}`;

const ghFetchOpts = {
	headers: ghHeaders,
	cf: { cacheTtl: 3600, cacheEverything: true },
} as RequestInit;

// When authenticated, /user returns private repo counts; /events (no /public) includes private activity
const userEndpoint = ghToken
	? "https://api.github.com/user"
	: "https://api.github.com/users/deathemperor";
const eventsEndpoint = ghToken
	? "https://api.github.com/users/deathemperor/events?per_page=30"
	: "https://api.github.com/users/deathemperor/events/public?per_page=30";
const reposEndpoint = ghToken
	? "https://api.github.com/user/repos?sort=pushed&per_page=10&affiliation=owner"
	: "https://api.github.com/users/deathemperor/repos?sort=pushed&per_page=6&type=owner";

// GraphQL query for accurate commit count (last 30 days, all repos)
let recentCommitCount = 0;

try {
	const fetches: Promise<Response>[] = [
		fetch(userEndpoint, ghFetchOpts),
		fetch(eventsEndpoint, ghFetchOpts),
		fetch(reposEndpoint, ghFetchOpts),
	];
	// GraphQL for commit stats (requires auth)
	if (ghToken) {
		const since = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString();
		fetches.push(
			fetch("https://api.github.com/graphql", {
				method: "POST",
				headers: { ...ghHeaders, "Content-Type": "application/json" },
				body: JSON.stringify({
					query: `{ viewer { contributionsCollection(from: "${since}") { totalCommitContributions restrictedContributionsCount } } }`,
				}),
				cf: { cacheTtl: 3600, cacheEverything: true },
			} as RequestInit),
		);
	}
	const results = await Promise.all(fetches);
	const [userRes, eventsRes, reposRes] = results;
	if (userRes.ok) ghUser = await userRes.json();
	if (eventsRes.ok) ghEvents = await eventsRes.json();
	if (reposRes.ok) ghRepos = (await reposRes.json() as GitHubRepo[]).filter((r) => !r.fork);
	if (results[3]?.ok) {
		const gql = await results[3].json();
		const cc = gql?.data?.viewer?.contributionsCollection;
		recentCommitCount = (cc?.totalCommitContributions ?? 0) + (cc?.restrictedContributionsCount ?? 0);
	}
} catch {
	// GitHub API unavailable — render without stats
}

// Fallback: count push events if GraphQL unavailable
const commitEvents = ghEvents.filter((e) => e.type === "PushEvent");
if (!recentCommitCount) {
	const hasCommitDetails = commitEvents.some((e) => e.payload.commits && e.payload.commits.length > 0);
	recentCommitCount = hasCommitDetails
		? commitEvents.reduce((sum, e) => sum + (e.payload.commits?.length ?? 0), 0)
		: commitEvents.length;
}

// Activity by day of week
const dayNames = isVi
	? ["CN", "T2", "T3", "T4", "T5", "T6", "T7"]
	: ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
const dayActivity = new Array(7).fill(0);
for (const e of ghEvents) {
	const day = new Date(e.created_at).getDay();
	dayActivity[day]++;
}
const maxDayActivity = Math.max(...dayActivity, 1);

// Recent activity feed (last 10 meaningful events)
const activityFeed = ghEvents
	.filter((e) => ["PushEvent", "CreateEvent", "PullRequestEvent", "IssuesEvent"].includes(e.type))
	.slice(0, 10)
	.map((e) => {
		// Check if this event is from a private repo (not in public repos list)
		const repoFullName = e.repo.name;
		const repo = repoFullName.replace("deathemperor/", "");
		const isPrivateRepo = ghToken && !ghRepos.some((r) => !r.private && r.name === repo);
		const displayRepo = isPrivateRepo ? (isVi ? "kho riêng" : "private repo") : repo;
		const date = new Date(e.created_at);
		const timeAgo = formatTimeAgo(date);
		let action = e.type;
		if (e.type === "PushEvent") {
			const commits = e.payload.commits;
			if (commits && commits.length > 0) {
				action = isVi
					? `${commits.length} commit tới ${displayRepo}`
					: `${commits.length} commit${commits.length !== 1 ? "s" : ""} to ${displayRepo}`;
			} else {
				action = isVi
					? `đẩy mã tới ${displayRepo}`
					: `pushed to ${displayRepo}`;
			}
		} else if (e.type === "CreateEvent") {
			action = isVi
				? `tạo ${e.payload.ref_type ?? "repo"} ${e.payload.ref && !isPrivateRepo ? `${e.payload.ref} trong ` : ""}${displayRepo}`
				: `created ${e.payload.ref_type ?? "repo"} ${e.payload.ref && !isPrivateRepo ? `${e.payload.ref} in ` : ""}${displayRepo}`;
		} else if (e.type === "PullRequestEvent") {
			action = isVi
				? `${e.payload.action} PR trong ${displayRepo}`
				: `${e.payload.action} PR in ${displayRepo}`;
		} else if (e.type === "IssuesEvent") {
			action = isVi
				? `${e.payload.action} issue trong ${displayRepo}`
				: `${e.payload.action} issue in ${displayRepo}`;
		}
		return { action, timeAgo, date };
	});

const langColors: Record<string, string> = {
	TypeScript: "#3178c6",
	JavaScript: "#f1e05a",
	Python: "#3572a5",
	HTML: "#e34c26",
	CSS: "#563d7c",
	Go: "#00add8",
	Rust: "#dea584",
	Shell: "#89e051",
	Astro: "#ff5a03",
};

function formatTimeAgo(date: Date) {
	const seconds = Math.floor((Date.now() - date.getTime()) / 1000);
	if (seconds < 60) return isVi ? "vừa xong" : "just now";
	const minutes = Math.floor(seconds / 60);
	if (minutes < 60) return isVi ? `${minutes} ph trước` : `${minutes}m ago`;
	const hours = Math.floor(minutes / 60);
	if (hours < 24) return isVi ? `${hours} giờ trước` : `${hours}h ago`;
	const days = Math.floor(hours / 24);
	if (days < 7) return isVi ? `${days} ngày trước` : `${days}d ago`;
	return date.toLocaleDateString(isVi ? "vi-VN" : "en-US", { month: "short", day: "numeric" });
}

function formatGHDate(iso: string) {
	return new Date(iso).toLocaleDateString(isVi ? "vi-VN" : "en-US", { year: "numeric", month: "long" });
}
---

<Base title="Trương Hữu Lộc" description={isVi ? "Trương Hữu Lộc — kỹ sư, nhà văn, người nuôi cá" : "Trương Hữu Lộc — engineer, writer, fishkeeper"} breadcrumbs={[{ label: "Trương" }]}>
