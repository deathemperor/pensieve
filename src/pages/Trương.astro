						<circle cx="12" cy="90" r="2" fill="url(#flourishGrad)" opacity="0.8" />
					</g>
				</svg>

				{/* Magical sigil / pentagram rotating behind */}
				<svg class="portrait-sigil" viewBox="0 0 200 200" aria-hidden="true">
					<g fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round">
						<circle cx="100" cy="100" r="90" />
						<circle cx="100" cy="100" r="70" stroke-dasharray="3 3" />
						<polygon points="100,20 157,165 18,70 182,70 43,165" opacity="0.6" />
