						<line x1="20" y1="20" x2="20" y2="2" />
						<line x1="20" y1="20" x2="2" y2="20" />
						<line x1="10" y1="8" x2="14" y2="4" />
						<line x1="10" y1="8" x2="8" y2="4" />
