---
export const prerender = false;

import Base from "../layouts/Base.astro";
import { Image } from "astro:assets";
import profilePhoto from "../assets/truong-profile.jpg";
import { link } from "../utils/link";
import { getCurrentLang } from "../utils/lang";
import { env } from "cloudflare:workers";
import { setCachePolicy } from "../lib/cachePolicy";
setCachePolicy(Astro, "static");
const isVi = getCurrentLang(Astro) === "vi";

// GitHub API — authenticated when GITHUB_TOKEN is set (5000 req/hr),
// falls back to unauthenticated (60 req/hr) otherwise.
// Secret lives in Cloudflare (`wrangler secret`); `import.meta.env` only
// sees build-time vars, so it never sees this. Must read from the runtime
// `env` binding exposed by the Cloudflare adapter.
const ghToken = (env as { GITHUB_TOKEN?: string }).GITHUB_TOKEN;

interface GitHubUser {
	public_repos: number;
	total_private_repos?: number;
	owned_private_repos?: number;
	followers: number;
	following: number;
	created_at: string;
}

interface GitHubEvent {
	type: string;
	repo: { name: string };
	created_at: string;
	payload: {
		commits?: { message: string; sha: string }[];
		action?: string;
		ref?: string;
		ref_type?: string;
	};
}

interface GitHubRepo {
	name: string;
	description: string | null;
	html_url: string;
	language: string | null;
	stargazers_count: number;
	updated_at: string;
	fork: boolean;
	private: boolean;
}

let ghUser: GitHubUser | null = null;
let ghEvents: GitHubEvent[] = [];
let ghRepos: GitHubRepo[] = [];

// Cache GitHub API responses at Cloudflare's edge (1 hour).
// Visitors never hit GitHub directly — only one request per hour per edge PoP.
const ghHeaders: Record<string, string> = {
	"User-Agent": "pensieve-site",
	Accept: "application/vnd.github.v3+json",
};
if (ghToken) ghHeaders.Authorization = `Bearer ${ghToken}`;

const ghFetchOpts = {
	headers: ghHeaders,
	cf: { cacheTtl: 3600, cacheEverything: true },
} as RequestInit;

// When authenticated, /user returns private repo counts; /events (no /public) includes private activity
const userEndpoint = ghToken
	? "https://api.github.com/user"
	: "https://api.github.com/users/deathemperor";
const eventsEndpoint = ghToken
	? "https://api.github.com/users/deathemperor/events?per_page=30"
	: "https://api.github.com/users/deathemperor/events/public?per_page=30";
const reposEndpoint = ghToken
	? "https://api.github.com/user/repos?sort=pushed&per_page=10&affiliation=owner"
	: "https://api.github.com/users/deathemperor/repos?sort=pushed&per_page=6&type=owner";

let recentCommitCount = 0;
let claudeEraCommitCount: number | null = null;

// Pre-squash PR + commit totals, populated nightly by worker cron and
// written to KV at `stats:claude-era`. Recovers commits that would
// otherwise be lost to admin-squash-merge (one landed commit on main
// swallowing a whole branch of Claude-authored commits).
interface ClaudeEraStats { prCount: number; preSquashCommits: number; updatedAt: string }
let eraStats: ClaudeEraStats | null = null;
try {
	const kv = (env as { SESSION?: { get: (k: string) => Promise<string | null> } }).SESSION;
	const cached = await kv?.get?.("stats:claude-era");
	if (cached) {
		const parsed = JSON.parse(cached) as ClaudeEraStats;
		if (parsed.preSquashCommits > 0) eraStats = parsed;
	}
} catch { /* KV unavailable — fall through to live search count */ }

try {
	const fetches: Promise<Response>[] = [
		fetch(userEndpoint, ghFetchOpts),
		fetch(eventsEndpoint, ghFetchOpts),
		fetch(reposEndpoint, ghFetchOpts),
	];
	if (ghToken) {
		// GraphQL: total commit contributions in the last 30 days (Loc as author)
		const since = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString();
		fetches.push(
			fetch("https://api.github.com/graphql", {
				method: "POST",
				headers: { ...ghHeaders, "Content-Type": "application/json" },
				body: JSON.stringify({
					query: `{ viewer { contributionsCollection(from: "${since}") { totalCommitContributions restrictedContributionsCount } } }`,
				}),
				cf: { cacheTtl: 3600, cacheEverything: true },
			} as RequestInit),
		);
		// REST search: all commits in Loc's repos (public + private) since
		// adopting Claude Code. We don't filter by author — on his personal
		// repos the only committers are him (squash-merges), Claude (branch
		// commits), and renovate (deps). Filtering by author:deathemperor
		// would collapse to just squash-merges and severely undercount.
		// `user:deathemperor` scopes to repos he owns, so the shared Anthropic
		// noreply email can't leak in commits from other users' projects.
		const era = "user:deathemperor author-date:>=2026-01-29";
		fetches.push(
			fetch(
				`https://api.github.com/search/commits?q=${encodeURIComponent(era)}&per_page=1`,
				ghFetchOpts,
			),
		);
	}
	const results = await Promise.all(fetches);
	const [userRes, eventsRes, reposRes] = results;
	if (userRes.ok) ghUser = await userRes.json();
	if (eventsRes.ok) ghEvents = await eventsRes.json();
	if (reposRes.ok) ghRepos = (await reposRes.json() as GitHubRepo[]).filter((r) => !r.fork);
	if (results[3]?.ok) {
		const gql = await results[3].json() as { data?: { viewer?: { contributionsCollection?: { totalCommitContributions?: number; restrictedContributionsCount?: number } } } };
		const last30 = gql?.data?.viewer?.contributionsCollection;
		recentCommitCount = (last30?.totalCommitContributions ?? 0) + (last30?.restrictedContributionsCount ?? 0);
	}
	if (results[4]?.ok) {
		const search = await results[4].json() as { total_count?: number };
		if (typeof search.total_count === "number") claudeEraCommitCount = search.total_count;
	}
} catch {
	// GitHub API unavailable — render without stats
}

// Fallback: count push events if GraphQL unavailable
const commitEvents = ghEvents.filter((e) => e.type === "PushEvent");
if (!recentCommitCount) {
	const hasCommitDetails = commitEvents.some((e) => e.payload.commits && e.payload.commits.length > 0);
	recentCommitCount = hasCommitDetails
		? commitEvents.reduce((sum, e) => sum + (e.payload.commits?.length ?? 0), 0)
		: commitEvents.length;
}

const langColors: Record<string, string> = {
	TypeScript: "#3178c6",
	JavaScript: "#f1e05a",
	Python: "#3572a5",
	HTML: "#e34c26",
	CSS: "#563d7c",
	Go: "#00add8",
	Rust: "#dea584",
	Shell: "#89e051",
	Astro: "#ff5a03",
};

function formatGHDate(iso: string) {
	return new Date(iso).toLocaleDateString(isVi ? "vi-VN" : "en-US", { year: "numeric", month: "long" });
}
---

<Base title="Trương Hữu Lộc" description={isVi ? "Trương Hữu Lộc — kỹ sư, nhà văn, người nuôi cá" : "Trương Hữu Lộc — engineer, writer, fishkeeper"} breadcrumbs={[{ label: "Trương" }]}>
	<section id="about" class="about-hero">
		<div class="about-hero-inner">
			<div class="about-hero-text">
				<div class="about-rule" />
				<span class="about-label">{isVi ? "Giới Thiệu" : "About"}</span>
				<h1 class="about-title about-title-shimmer">
				{"Trương Hữu Lộc".split("").map((ch, i) => (
					ch === " " ? <span>&nbsp;</span> : <span class="title-char" style={`--lc: ${i};`}>{ch}</span>
				))}
			</h1>
				<p class="about-subtitle">
					{isVi
						? "Cha · Kỹ sư · Giáo viên · Nhà văn · Nhà truyền bá công nghệ · Người phục vụ · Người nuôi cá · Nhà thám hiểm."
						: "Father · Engineer · Teacher · Writer · Tech Evangelist · Servant · Fishkeeper · Explorer."}
				</p>
				<dl class="about-meta">
					<div class="about-meta-row">
						<dt>{isVi ? "Biệt danh" : "Nickname"}</dt>
						<dd><code class="about-meta-handle">deathemperor</code> {isVi ? "— danh xưng tôi tự đặt và tự dựng từ đầu những năm 2000" : "— a handle I coined and built from scratch since the early 2000s"}</dd>
					</div>
					<div class="about-meta-row">
						<dt>{isVi ? "Vai trò" : "Role"}</dt>
						<dd>{isVi ? "Giám đốc Công nghệ / Giám đốc Vận hành · Kỹ sư phần mềm" : "Chief Technology Officer / Chief Operating Officer · Software Engineer"}</dd>
					</div>
					<div class="about-meta-row">
						<dt>{isVi ? "Nơi ở" : "Based"}</dt>
						<dd>{isVi ? "Sài Gòn, Việt Nam" : "Saigon, Vietnam"}</dd>
					</div>
					<div class="about-meta-row">
						<dt>{isVi ? "Hiện tại" : "Currently"}</dt>
						<dd>{isVi ? "Xây hạ tầng bảo hiểm quy mô lớn ở Papaya" : "Building hyperscale insurance infrastructure at Papaya"}</dd>
					</div>
					<div class="about-meta-row">
						<dt>{isVi ? "Trên GitHub" : "GitHub"}</dt>
						<dd>
							{ghUser ? (
								isVi
									? `Từ ${new Date(ghUser.created_at).getFullYear()} · ${ghUser.public_repos + (ghUser.owned_private_repos ?? 0)} kho mã · ∞ AI agent`
									: `Since ${new Date(ghUser.created_at).getFullYear()} · ${ghUser.public_repos + (ghUser.owned_private_repos ?? 0)} repos · ∞ AI agents`
							) : (
								isVi ? "Từ 2013 · ∞ AI agent" : "Since 2013 · ∞ AI agents"
							)}
						</dd>
					</div>
				</dl>
				{/* Compact profile links in the hero. */}
				<nav class="hero-profile-links" aria-label={isVi ? "Liên kết cá nhân" : "Profile links"}>
					<a href="https://github.com/deathemperor" class="hero-profile-link" target="_blank" rel="noopener" aria-label="GitHub">
						<svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
							<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
						</svg>
					</a>
					<a href="https://linkedin.com/in/deathemperor" class="hero-profile-link" target="_blank" rel="noopener" aria-label="LinkedIn">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
						</svg>
					</a>
					<a href="https://facebook.com/deathemperor" class="hero-profile-link" target="_blank" rel="noopener" aria-label="Facebook">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
						</svg>
					</a>
					<a href="mailto:me@huuloc.com" class="hero-profile-link" aria-label="Email">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<rect x="2" y="4" width="20" height="16" rx="2" />
							<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
						</svg>
					</a>
					<a href="https://zalo.me/0978733777" class="hero-profile-link" target="_blank" rel="noopener" aria-label="Zalo">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M12.49 10.272v-.45h1.347v6.322h-.77a.576.576 0 0 1-.577-.573v.001a3.13 3.13 0 0 1-1.846.589 3.179 3.179 0 1 1 0-6.358c.677 0 1.31.21 1.846.572zm-5.05-1.005H2.55a.582.582 0 1 1 0-1.165h5.527c.32 0 .61.117.83.357.197.21.305.49.305.78 0 .227-.06.435-.176.624l-.022.027-.005.006-.024.04-3.91 4.812h3.602c.42 0 .76.34.76.76v.39H2.367c-.32 0-.62-.18-.77-.5a.86.86 0 0 1 .096-.937l3.99-4.91c.235-.04.47-.025.704-.058l.052-.218zm9.937 6.871a3.179 3.179 0 1 1 0-6.358 3.179 3.179 0 0 1 0 6.358zm.022-1.346a1.84 1.84 0 1 0 0-3.679 1.84 1.84 0 0 0 0 3.679zm-5.95 0a1.84 1.84 0 1 0 0-3.679 1.84 1.84 0 0 0 0 3.679z" />
						</svg>
					</a>
				</nav>
			</div>
			<figure class="about-hero-photo" id="hero-photo" aria-hidden="false">
				{/* Lotus petals unfurling */}
				<svg class="portrait-lotus" viewBox="0 0 200 200" aria-hidden="true">
					<g fill="url(#flourishGrad)" opacity="0.6" stroke="rgba(240, 199, 94, 0.8)" stroke-width="0.6">
						{Array.from({ length: 8 }).map((_, i) => (
							<g transform={`rotate(${i * 45} 100 100)`}>
								<path class="lotus-petal" d="M100 100 Q115 70 110 45 Q100 40 90 45 Q85 70 100 100 Z" style={`animation-delay: ${i * 0.3}s;`} />
							</g>
						))}
						<circle cx="100" cy="100" r="6" fill="#fff0c2" />
					</g>
				</svg>

				{/* Rose window cathedral pattern behind */}
				<svg class="portrait-rose-window" viewBox="0 0 400 400" aria-hidden="true">
					<g fill="none" stroke="currentColor" stroke-width="0.8">
						<circle cx="200" cy="200" r="190" />
						<circle cx="200" cy="200" r="160" />
						<circle cx="200" cy="200" r="120" />
						{Array.from({ length: 16 }).map((_, i) => (
							<g transform={`rotate(${i * 22.5} 200 200)`}>
								<path d="M200 40 Q220 80 200 120 Q180 80 200 40 Z" opacity="0.5" />
								<circle cx="200" cy="70" r="4" fill="currentColor" opacity="0.7" />
							</g>
						))}
						<circle cx="200" cy="200" r="20" fill="currentColor" opacity="0.4" />
					</g>
				</svg>

				{/* Summoning circle — inner runes + outer invention years, counter-rotating */}
				<div class="portrait-summoning-circle" aria-hidden="true">
					<div class="sc-ring sc-ring-runes">
						{"ᚠᚢᚦᚨᚱᚲᚷᚹᚺᚾᛁᛃᛇᛈᛉᛊᛏᛒᛖᛗᛚᛜᛞᛟ".split("").map((r, i) => (
							<span class="sc-rune" style={`--sc-angle: ${i * (360 / 24)}deg;`}>{r}</span>
						))}
					</div>
					<div class="sc-ring sc-ring-years">
						{["2007", "·", "2008", "·", "2009", "·", "2024", "·"].map((y, i, a) => (
							<span class="sc-year" style={`--sc-angle: ${i * (360 / a.length)}deg;`}>{y}</span>
						))}
					</div>
				</div>

				{/* Grimoire — three translucent parchment pages drifting with faint sigil diagrams */}
				<div class="portrait-grimoire-pages" aria-hidden="true">
					{[0, 1, 2].map((i) => (
						<svg class={`grimoire-page grimoire-page-${i + 1}`} viewBox="0 0 120 160" aria-hidden="true">
							<rect x="2" y="2" width="116" height="156" rx="2" fill="rgba(255, 245, 215, 0.05)" stroke="rgba(240, 199, 94, 0.3)" stroke-width="0.6" />
							<g stroke="rgba(240, 199, 94, 0.35)" stroke-width="0.4" fill="none">
								<line x1="16" y1={18 + i * 4} x2="104" y2={18 + i * 4} />
								<line x1="16" y1={28 + i * 4} x2="96" y2={28 + i * 4} />
								<circle cx="60" cy={74 + i * 6} r={18 - i * 2} />
								<path d={`M60 ${60 - i * 2} L${52 + i * 2} 74 L60 ${88 + i * 2} L${68 - i * 2} 74 Z`} />
								<circle cx="60" cy={74 + i * 6} r={8 - i} opacity="0.6" />
								<line x1="16" y1={120 + i * 2} x2="104" y2={120 + i * 2} />
								<line x1="16" y1={130 + i * 2} x2="88" y2={130 + i * 2} />
							</g>
						</svg>
					))}
				</div>

				{/* Light threads — a 3D-looking lattice drawing itself in light beside the portrait */}
				<svg class="portrait-light-threads" viewBox="0 0 200 260" aria-hidden="true">
					<g stroke="url(#flourishGrad)" stroke-width="0.8" fill="none" stroke-linecap="round">
						<path class="lt-stroke lt-1" d="M20 40 L100 20 L180 40 L180 140 L100 160 L20 140 Z" />
						<path class="lt-stroke lt-2" d="M100 20 L100 160" />
						<path class="lt-stroke lt-3" d="M20 40 L100 80 L180 40" />
						<path class="lt-stroke lt-4" d="M20 140 L100 100 L180 140" />
						<path class="lt-stroke lt-5" d="M100 80 L100 100" />
						<circle class="lt-node" cx="100" cy="20" r="2" />
						<circle class="lt-node" cx="100" cy="160" r="2" />
						<circle class="lt-node" cx="100" cy="80" r="1.5" />
						<circle class="lt-node" cx="100" cy="100" r="1.5" />
					</g>
				</svg>

				{/* Circuit-runes — Futhark glyphs that morph into PCB traces in four corners */}
				<div class="portrait-circuit-runes" aria-hidden="true">
					{[
						{ rune: "ᚠ", pos: "tl" },
						{ rune: "ᚱ", pos: "tr" },
						{ rune: "ᛏ", pos: "bl" },
						{ rune: "ᛗ", pos: "br" },
					].map(({ rune, pos }) => (
						<div class={`cr cr-${pos}`}>
							<svg viewBox="0 0 50 50" aria-hidden="true">
								<text x="25" y="32" text-anchor="middle" font-family="serif" font-size="22" fill="url(#flourishGrad)">{rune}</text>
								<g stroke="url(#flourishGrad)" stroke-width="0.6" fill="none" stroke-linecap="round">
									<path class="cr-trace cr-trace-1" d="M25 40 L25 48 L14 48 L14 44" />
									<path class="cr-trace cr-trace-2" d="M25 40 L25 48 L36 48 L36 44" />
									<circle cx="14" cy="44" r="1" fill="url(#flourishGrad)" />
									<circle cx="36" cy="44" r="1" fill="url(#flourishGrad)" />
								</g>
							</svg>
						</div>
					))}
				</div>

				{/* Ancient runes scrolling in a circle around portrait */}
