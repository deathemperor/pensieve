					</svg>
				</div>

				{/* Patronus burst — 12 rays explode from center every 15s */}
				<div class="portrait-patronus" aria-hidden="true">
					<div class="patronus-core" />
					{[...Array(12)].map((_, i) => (
						<span class="patronus-ray" style={`--pray-angle: ${i * 30}deg;`} />
					))}
				</div>

				{/* Random sparkles that twinkle into existence */}
				<div class="portrait-sparkles" aria-hidden="true">
					<span class="sparkle" style="--sx: 8%; --sy: 15%; --sd: 0s;" />
					<span class="sparkle" style="--sx: 92%; --sy: 22%; --sd: 1.7s;" />
					<span class="sparkle" style="--sx: 14%; --sy: 72%; --sd: 3.2s;" />
					<span class="sparkle" style="--sx: 88%; --sy: 80%; --sd: 4.8s;" />
					<span class="sparkle" style="--sx: 50%; --sy: 10%; --sd: 2.5s;" />
					<span class="sparkle" style="--sx: 5%; --sy: 45%; --sd: 6.2s;" />
					<span class="sparkle" style="--sx: 95%; --sy: 52%; --sd: 7.5s;" />
				</div>

				{/* Pensieve-vortex conic gradient slowly spinning behind */}
				<div class="portrait-vortex" aria-hidden="true" />

				{/* Pulsing halo behind card */}
				<div class="portrait-halo" aria-hidden="true" />

				{/* Pensieve wisps — silvery horizontal lines drifting past */}
				<div class="portrait-wisps" aria-hidden="true">
					<span class="wisp" style="--wt: 20%; --wl: -10%; --wd: 0s; --wr: -8deg;" />
					<span class="wisp" style="--wt: 48%; --wl: -20%; --wd: 3s; --wr: 4deg;" />
					<span class="wisp" style="--wt: 72%; --wl: -15%; --wd: 5.5s; --wr: -3deg;" />
					<span class="wisp" style="--wt: 32%; --wl: -25%; --wd: 7s; --wr: 6deg;" />
				</div>

				<div class="portrait-card">
					{/* Continuously drawing SVG trace around frame (like Door Trace spell) */}
					<svg class="portrait-trace" viewBox="0 0 280 350" preserveAspectRatio="none" aria-hidden="true">
						<defs>
							<linearGradient id="traceGrad" x1="0%" y1="0%" x2="100%" y2="100%">
								<stop offset="0%" stop-color="#f0c75e" />
								<stop offset="30%" stop-color="#ffe6a8" />
								<stop offset="60%" stop-color="#d4a843" />
								<stop offset="100%" stop-color="#f0c75e" />
							</linearGradient>
						</defs>
						<rect class="trace-path" x="2" y="2" width="276" height="346" rx="3" ry="3"
							fill="none" stroke="url(#traceGrad)" stroke-width="2"
							stroke-dasharray="1248" stroke-dashoffset="1248"
							vector-effect="non-scaling-stroke" />
					</svg>

					<Image
						src={profilePhoto}
						alt={isVi ? "Ảnh chân dung Trương Hữu Lộc" : "Portrait of Trương Hữu Lộc"}
						width={720}
						height={900}
						format="webp"
						quality={90}
						loading="eager"
						class="profile-photo"
					/>
					<div class="portrait-vignette" aria-hidden="true" />
					<div class="portrait-sheen" aria-hidden="true" />

					{/* Twinkling stars at corners */}
					<span class="portrait-star portrait-star-tl" aria-hidden="true" />
					<span class="portrait-star portrait-star-tr" aria-hidden="true" />
					<span class="portrait-star portrait-star-bl" aria-hidden="true" />
					<span class="portrait-star portrait-star-br" aria-hidden="true" />
				</div>

				{/* Rising gold bubbles (8 looped) */}
				<div class="portrait-bubbles" aria-hidden="true">
					<span class="bubble" style="--bx: 8%; --bsz: 10px; --bd: 0s; --bdx: 12px;" />
					<span class="bubble" style="--bx: 22%; --bsz: 6px; --bd: 1.2s; --bdx: -8px;" />
					<span class="bubble" style="--bx: 38%; --bsz: 12px; --bd: 2.4s; --bdx: 18px;" />
					<span class="bubble" style="--bx: 52%; --bsz: 5px; --bd: 3.6s; --bdx: -14px;" />
