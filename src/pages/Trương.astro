	/* Crystalline geometric pattern overlay on photo */
	.portrait-crystal {
		position: absolute;
		top: 14px;
		left: 14px;
		right: 14px;
		bottom: 14px;
		width: auto;
		height: auto;
		pointer-events: none;
		z-index: 4;
		color: rgba(240, 199, 94, 0.18);
