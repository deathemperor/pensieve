						<span style="--ex: 45%; --ed: 4.8s; --eh: 200px; --edx: 8px;" />
						<span style="--ex: 62%; --ed: 1.1s; --eh: 170px; --edx: -12px;" />
						<span style="--ex: 78%; --ed: 3.7s; --eh: 190px; --edx: 18px;" />
						<span style="--ex: 90%; --ed: 5.5s; --eh: 150px; --edx: -10px;" />
						<span style="--ex: 20%; --ed: 6.9s; --eh: 170px; --edx: -16px;" />
