						<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
					</svg>
					Facebook
				</a>
				<a href="mailto:me@huuloc.com" class="profile-link">
					<svg class="profile-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="2" y="4" width="20" height="16" rx="2" />
						<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
					</svg>
					me@huuloc.com
				</a>
			</div>
		</div>
	</section>

	{ghUser && (
		<section class="about-section">
			<div class="about-inner">
				<h2 class="section-heading">{isVi ? "Hoạt Động GitHub" : "GitHub Activity"}</h2>
				<p class="section-desc">
					{isVi ? "Dữ liệu trực tiếp từ GitHub API." : "Live data from the GitHub API."}
					{isVi ? `Trên GitHub từ ${formatGHDate(ghUser.created_at)}.` : `On GitHub since ${formatGHDate(ghUser.created_at)}.`}
				</p>

				{/* Coding Eras Timeline */}
				<div class="eras-timeline">
					<h3 class="chart-title">{isVi ? "Các thời kỳ lập trình" : "Coding eras"}</h3>
					<div class="eras-track">
						<div class="era" style="--era-color: var(--color-muted);">
							<span class="era-bar" style="flex: 16;" />
							<div class="era-info">
								<span class="era-label">{isVi ? "Tự lực" : "Solo"}</span>
								<span class="era-commits">{isVi ? "1.755 commit" : "1,755 commits"}</span>
								<span class="era-dates">2006 — {isVi ? "Th6 2022" : "Jun 2022"}</span>
								<span class="era-note">{isVi ? "Lập trình thủ công, không AI hỗ trợ" : "Manual coding, no AI assist"}</span>
							</div>
						</div>
						<div class="era" style="--era-color: #7c3aed;">
							<span class="era-bar" style="flex: 3.5;" />
							<div class="era-info">
								<span class="era-label">GitHub Copilot</span>
								<span class="era-commits">{isVi ? "8.106 commit" : "8,106 commits"}</span>
								<span class="era-dates">{isVi ? "Th6 2022 — Th1 2026" : "Jun 2022 — Jan 2026"}</span>
								<span class="era-note">{isVi ? "Lập trình có AI hỗ trợ (bản xem trước công khai)" : "AI-assisted coding (public preview)"}</span>
							</div>
						</div>
						<div class="era era-current" style="--era-color: #e8784d;">
							<span class="era-bar" style="flex: 0.5;" />
							<div class="era-info">
								<span class="era-label">Claude Code</span>
								<span class="era-commits">232 commit{isVi ? "" : "s"}</span>
								<span class="era-dates">{isVi ? "29 Th1, 2026 — nay" : "Jan 29, 2026 — now"}</span>
								<span class="era-note">{isVi ? "Không có mã người viết — hoàn toàn do AI tạo" : "Zero human code — fully AI-generated"}</span>
							</div>
						</div>
					</div>
				</div>

				<div class="gh-stats">
					<div class="gh-stat">
						<span class="gh-stat-value">{ghUser.public_repos + (ghUser.owned_private_repos ?? 0)}</span>
						<span class="gh-stat-label">{isVi ? "kho mã" : "repos"}</span>
					</div>
					<div class="gh-stat">
						<span class="gh-stat-value">{recentCommitCount}</span>
						<span class="gh-stat-label">{isVi ? "commit 30 ngày" : "commits (30d)"}</span>
					</div>
					<div class="gh-stat">
						<span class="gh-stat-value">{ghUser.followers}</span>
						<span class="gh-stat-label">{isVi ? "người theo dõi" : "followers"}</span>
					</div>
				</div>

				{/* Day-of-week activity chart */}
				<div class="activity-chart">
					<h3 class="chart-title">{isVi ? "Hoạt động theo ngày" : "Activity by day"}</h3>
					<div class="chart-bars">
						{dayNames.map((name, i) => (
							<div class="chart-col">
								<div class="chart-bar-wrap">
									<div
										class="chart-bar"
										style={`height: ${(dayActivity[i] / maxDayActivity) * 100}%;`}
									/>
								</div>
								<span class="chart-label">{name}</span>
							</div>
						))}
					</div>
				</div>

				{/* Recent repos */}
				{ghRepos.filter((r) => !r.private).length > 0 && (
					<div class="repos-section">
						<h3 class="chart-title">{isVi ? "Kho mã gần đây" : "Recent repositories"}</h3>
						<div class="repos-grid">
							{ghRepos.filter((r) => !r.private).slice(0, 6).map((repo) => (
								<a href={repo.html_url} class="repo-card" target="_blank" rel="noopener">
									<span class="repo-name">{repo.name}</span>
									{repo.description && (
										<span class="repo-desc">{repo.description}</span>
									)}
									<span class="repo-meta">
										{repo.language && (
											<span class="repo-lang">
												<span
													class="repo-lang-dot"
													style={`background: ${langColors[repo.language] ?? "var(--color-muted)"};`}
												/>
												{repo.language}
											</span>
										)}
										{repo.stargazers_count > 0 && (
											<span class="repo-stars">
												&#9733; {repo.stargazers_count}
											</span>
										)}
									</span>
								</a>
							))}
						</div>
					</div>
				)}

				{/* Activity feed */}
				{activityFeed.length > 0 && (
					<div class="feed-section">
						<h3 class="chart-title">{isVi ? "Hoạt động gần đây" : "Recent activity"}</h3>
						<div class="feed-list">
							{activityFeed.map((item) => (
								<div class="feed-item">
									<span class="feed-dot" />
									<span class="feed-action">{item.action}</span>
									<span class="feed-time">{item.timeAgo}</span>
								</div>
							))}
						</div>
					</div>
				)}
			</div>
		</section>
	)}
</Base>

<style>
	/* Hero */
	.about-hero {
		border-bottom: 1px solid var(--color-border);
	}

	.about-hero-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-24) var(--spacing-8) var(--spacing-16);
		display: grid;
		grid-template-columns: minmax(0, 1fr) 280px;
		gap: var(--spacing-12);
