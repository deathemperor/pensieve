	/* Camera aperture (iris) blades */
	.portrait-aperture {
		position: absolute;
		top: 175px;
		left: 50%;
		width: 0;
		height: 0;
		pointer-events: none;
		z-index: 8;
	}

	.aperture-blade {
		position: absolute;
		left: 0;
		top: 0;
