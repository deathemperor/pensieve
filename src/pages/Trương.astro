		background: linear-gradient(
			to bottom,
			transparent 0%,
			rgba(255, 240, 200, 0.6) 50%,
			rgba(240, 199, 94, 0.9) 100%
		);
		filter: blur(0.5px) drop-shadow(0 0 3px rgba(240, 199, 94, 0.7));
		opacity: 0;
		animation: rain-fall 5.6s linear infinite;
		animation-delay: var(--rd);
	}

	@keyframes rain-fall {
		0% { opacity: 0; transform: translateY(-100px); }
		10% { opacity: 1; }
		90% { opacity: 1; }
		100% { opacity: 0; transform: translateY(600px); }
	}

	/* Constellation lines connecting corner stars */
	.portrait-constellation {
		position: absolute;
		top: 165px;
		left: 50%;
		width: 300px;
		height: 370px;
		margin-left: -150px;
