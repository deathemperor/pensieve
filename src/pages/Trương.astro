	}

	.about-hero-text {
		min-width: 0;
	}

	.about-hero-photo {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-5);
		margin: 0;
		padding: 0;
		width: 280px;
	}

	/* Conic-gradient vortex behind portrait — pensieve-like rotation */
	.portrait-vortex {
		position: absolute;
		top: -40px;
		left: 50%;
		transform: translateX(-50%);
		width: 380px;
		height: 460px;
		pointer-events: none;
		z-index: 0;
		border-radius: 50%;
		background: conic-gradient(
			from 0deg,
			transparent 0deg,
			rgba(240, 199, 94, 0.12) 45deg,
			transparent 90deg,
			rgba(240, 199, 94, 0.18) 135deg,
			transparent 180deg,
			rgba(240, 199, 94, 0.12) 225deg,
			transparent 270deg,
			rgba(240, 199, 94, 0.15) 315deg,
			transparent 360deg
		);
		filter: blur(30px);
		opacity: 0.8;
		animation: vortex-slow-spin 30s linear infinite;
	}

	@keyframes vortex-slow-spin {
		to { transform: translateX(-50%) rotate(360deg); }
	}

	/* Silvery memory wisps drifting horizontally across portrait */
	.portrait-wisps {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 4;
		overflow: visible;
	}

	.wisp {
		position: absolute;
		top: var(--wt);
		left: var(--wl);
		width: 120px;
		height: 2px;
		background: linear-gradient(
			90deg,
			transparent 0%,
			rgba(255, 240, 200, 0.5) 30%,
			rgba(255, 230, 160, 0.85) 50%,
			rgba(255, 240, 200, 0.5) 70%,
			transparent 100%
		);
		filter: blur(1.5px);
		opacity: 0;
		transform: rotate(var(--wr)) translateX(0);
		animation: wisp-drift 9s ease-in-out infinite;
		animation-delay: var(--wd);
	}

	@keyframes wisp-drift {
		0% { opacity: 0; transform: rotate(var(--wr)) translateX(0) scaleX(0.3); }
		20% { opacity: 0.85; transform: rotate(var(--wr)) translateX(160px) scaleX(1); }
		70% { opacity: 0.6; transform: rotate(var(--wr)) translateX(380px) scaleX(1.2); }
		100% { opacity: 0; transform: rotate(var(--wr)) translateX(500px) scaleX(1.8); }
	}

	/* Rising gold bubbles — looped */
	.portrait-bubbles {
		position: absolute;
		bottom: -20px;
		left: 0;
		right: 0;
		height: 260px;
		pointer-events: none;
		z-index: 3;
		overflow: visible;
	}

	.bubble {
		position: absolute;
		bottom: 0;
		left: var(--bx);
		width: var(--bsz);
		height: var(--bsz);
		border-radius: 50%;
		background: radial-gradient(
			circle at 30% 30%,
			rgba(255, 240, 200, 0.95) 0%,
			rgba(240, 199, 94, 0.7) 40%,
			rgba(180, 140, 60, 0.4) 80%
		);
		box-shadow:
			0 0 8px rgba(240, 199, 94, 0.8),
			0 0 16px rgba(240, 199, 94, 0.4),
			inset 0 0 4px rgba(255, 255, 255, 0.5);
		border: 1px solid rgba(255, 240, 200, 0.4);
		opacity: 0;
		animation: bubble-rise 6s ease-out infinite;
		animation-delay: var(--bd);
	}

	@keyframes bubble-rise {
		0% { opacity: 0.9; transform: translate(0, 0) scale(0.3); }
		10% { opacity: 1; transform: translate(calc(var(--bdx) * 0.2), -30px) scale(1); }
		50% { opacity: 1; transform: translate(calc(var(--bdx) * 0.7), -140px) scale(0.85); }
		100% { opacity: 0; transform: translate(var(--bdx), -260px) scale(0.5); }
	}

	/* Pulsing gold halo behind portrait */
	.portrait-halo {
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		width: 340px;
		height: 420px;
		pointer-events: none;
		z-index: 0;
		background: radial-gradient(
			ellipse at 50% 45%,
			rgba(240, 199, 94, 0.38) 0%,
			rgba(240, 199, 94, 0.18) 30%,
			rgba(240, 199, 94, 0.06) 55%,
			transparent 75%
		);
		filter: blur(20px);
		animation: halo-pulse 4s ease-in-out infinite;
	}

	@keyframes halo-pulse {
		0%, 100% { opacity: 0.7; transform: translateX(-50%) scale(1); }
		50% { opacity: 1; transform: translateX(-50%) scale(1.08); }
	}

	/* Portrait card — the frame + image */
	.portrait-card {
		position: relative;
		width: 280px;
		aspect-ratio: 4 / 5;
		border-radius: 4px;
		overflow: hidden;
		z-index: 2;
		padding: 8px;
		background: linear-gradient(
			135deg,
			rgba(240, 199, 94, 0.5) 0%,
			rgba(180, 140, 60, 0.2) 40%,
			rgba(240, 199, 94, 0.35) 60%,
			rgba(180, 140, 60, 0.15) 100%
		);
		box-shadow:
			inset 0 0 0 1px rgba(255, 230, 170, 0.7),
			0 1px 0 rgba(240, 199, 94, 0.3),
			0 30px 80px -20px rgba(0, 0, 0, 0.7),
			0 0 60px -10px rgba(240, 199, 94, 0.4);
	}

		/* Caption */
	.photo-caption {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-2);
		margin-top: var(--spacing-3);
