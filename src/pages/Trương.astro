	.feather-1 {
		top: 0;
		left: 10%;
		animation: feather-drift 14s ease-in-out infinite;
	}

	.feather-2 {
		top: 30%;
		right: 5%;
		animation: feather-drift 16s ease-in-out 4s infinite;
	}

	.feather-3 {
		top: 60%;
		left: 5%;
		animation: feather-drift 12s ease-in-out 8s infinite;
	}

	@keyframes feather-drift {
		0% { opacity: 0; transform: translate(0, -40px) rotate(-10deg) scale(0.8); }
		15% { opacity: 0.9; transform: translate(10px, 40px) rotate(5deg) scale(1); }
		35% { opacity: 0.8; transform: translate(-15px, 120px) rotate(-12deg) scale(0.95); }
		60% { opacity: 0.7; transform: translate(20px, 220px) rotate(18deg) scale(1.05); }
		85% { opacity: 0.3; transform: translate(-8px, 320px) rotate(-8deg) scale(0.9); }
		100% { opacity: 0; transform: translate(15px, 420px) rotate(10deg) scale(0.7); }
	}

	/* Gold rain falling from above the portrait */
	.portrait-rain {
		position: absolute;
		top: -120px;
		left: 0;
		right: 0;
		height: 500px;
		pointer-events: none;
		z-index: 5;
		overflow: visible;
