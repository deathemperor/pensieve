	.flame {
		position: absolute;
		bottom: 20px;
		left: var(--fx);
		width: 18px;
		height: 40px;
		margin-left: -9px;
		border-radius: 50% 50% 45% 45% / 60% 60% 40% 40%;
		background: radial-gradient(
			ellipse at center bottom,
			rgba(255, 240, 200, 0.95) 0%,
			rgba(240, 199, 94, 0.8) 30%,
