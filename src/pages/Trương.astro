</style>

<script is:inline>
	// Mouse parallax on the portrait
	(function() {
		const fig = document.getElementById('hero-photo');
		if (!fig) return;
		const rect = () => fig.getBoundingClientRect();
		fig.classList.add('parallax-active');

		function handleMove(e) {
			const r = rect();
			const cx = r.left + r.width / 2;
			const cy = r.top + r.height / 2;
			const mx = Math.max(-1, Math.min(1, (e.clientX - cx) / 400));
			const my = Math.max(-1, Math.min(1, (e.clientY - cy) / 300));
			fig.style.setProperty('--mx', mx);
			fig.style.setProperty('--my', my);
		}

		function reset() {
			fig.style.setProperty('--mx', 0);
			fig.style.setProperty('--my', 0);
		}

		window.addEventListener('mousemove', handleMove, { passive: true });
		window.addEventListener('mouseleave', reset);
	})();

	// Lộc sigil — bloom when the name-meaning paragraph enters view,
	// then settle into a faint always-on presence. One-shot.
	(function() {
		const seal = document.getElementById('portrait-loc-seal');
		const firstProse = document.querySelector('.about-prose p');
		if (!seal || !firstProse) return;

		function bloom() {
			seal.classList.add('is-bloomed', 'is-blooming');
			window.setTimeout(() => seal.classList.remove('is-blooming'), 2400);
		}

		if (!('IntersectionObserver' in window)) {
			// Fallback: no observer → just settle in without the flash.
			seal.classList.add('is-bloomed');
			return;
		}

		const io = new IntersectionObserver((entries, obs) => {
			for (const e of entries) {
				if (e.isIntersecting) {
					bloom();
					obs.disconnect();
					break;
				}
			}
		}, { threshold: 0.35 });

		io.observe(firstProse);
	})();
</script>
