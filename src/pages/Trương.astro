		opacity: 0;
		transform-origin: bottom center;
		pointer-events: none;
		transition: height 620ms cubic-bezier(0.22, 1, 0.36, 1),
		            opacity 320ms,
		            transform 620ms cubic-bezier(0.22, 1, 0.36, 1);
		z-index: 0;
	}
	.wrap-card:not(.wrap-hero):hover::before {
		height: 48%;
		opacity: 0.72;
		transform: rotate(-6deg);
