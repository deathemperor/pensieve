	/* Gold dust — 24 tiny particles floating everywhere */
	.portrait-dust {
		position: absolute;
		inset: -60px;
		pointer-events: none;
		z-index: 6;
		overflow: visible;
	}

	.portrait-dust span {
		position: absolute;
		left: var(--dx);
		top: var(--dy);
		width: var(--dsz);
		height: var(--dsz);
		border-radius: 50%;
		background: rgba(255, 230, 160, 0.9);
		box-shadow: 0 0 4px rgba(240, 199, 94, 0.8), 0 0 8px rgba(240, 199, 94, 0.4);
		opacity: 0;
		animation: dust-float 8s ease-in-out infinite;
		animation-delay: var(--dd);
	}

	@keyframes dust-float {
		0%, 100% { opacity: 0; transform: translate(0, 0); }
		25% { opacity: 0.9; transform: translate(-8px, -12px); }
		50% { opacity: 1; transform: translate(10px, -20px); }
		75% { opacity: 0.6; transform: translate(-5px, -8px); }
