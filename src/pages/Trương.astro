	}

	/* Portkey vortex — dual conic spirals rotating opposite directions */
	.portrait-portkey {
		position: absolute;
		top: 175px;
		left: 50%;
		width: 300px;
		height: 300px;
		margin-left: -150px;
		margin-top: -150px;
		pointer-events: none;
		z-index: 1;
	}

	.portkey-spiral {
		position: absolute;
		inset: 0;
		border-radius: 50%;
		opacity: 0.3;
		mix-blend-mode: screen;
	}

	.portkey-spiral-1 {
		background: conic-gradient(
			from 0deg,
			transparent 0deg,
			rgba(240, 199, 94, 0.5) 30deg,
			transparent 80deg,
			rgba(240, 199, 94, 0.35) 160deg,
			transparent 220deg,
			rgba(240, 199, 94, 0.6) 290deg,
			transparent 360deg
		);
		filter: blur(24px);
		animation: portkey-spin-1 16s linear infinite;
	}

	.portkey-spiral-2 {
		background: conic-gradient(
			from 180deg,
			transparent 0deg,
			rgba(255, 240, 200, 0.45) 45deg,
			transparent 90deg,
			rgba(240, 199, 94, 0.3) 180deg,
			transparent 270deg,
			rgba(255, 240, 200, 0.4) 340deg,
			transparent 360deg
		);
		filter: blur(28px);
		animation: portkey-spin-2 24s linear infinite reverse;
	}

	@keyframes portkey-spin-1 {
		to { transform: rotate(360deg); }
	}
	@keyframes portkey-spin-2 {
		to { transform: rotate(-360deg); }
	}

	/* Individual letter float on the title */
	.title-char {
		display: inline-block;
		animation: title-char-float 4s ease-in-out infinite;
		animation-delay: calc(var(--lc) * 0.15s);
	}

	@keyframes title-char-float {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-3px); }
	}

	/* Name shimmer — gold gradient sliding across the title */
	.about-title-shimmer {
		background: linear-gradient(
			100deg,
			#f7f8f8 0%,
			#f7f8f8 40%,
			#ffe6a8 50%,
			#fff0c2 52%,
			#ffe6a8 54%,
			#f7f8f8 64%,
			#f7f8f8 100%
		);
		background-size: 300% 100%;
		background-position: 100% 50%;
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		color: transparent;
		animation: title-shimmer 6s ease-in-out infinite;
	}

	@keyframes title-shimmer {
		0%, 40%, 100% { background-position: 100% 50%; }
		60%, 80% { background-position: 0% 50%; }
	}


	/* Shooting stars streaking across */
	.portrait-shooting-stars {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 7;
		overflow: hidden;
	}

	.shooting-star {
		position: absolute;
		left: var(--ss-x);
		top: var(--ss-y);
		width: 80px;
		height: 2px;
		transform: rotate(var(--ss-rot));
		background: linear-gradient(to right, transparent 0%, rgba(255, 240, 200, 0.9) 50%, #fff 95%, transparent 100%);
		filter: blur(0.5px) drop-shadow(0 0 4px rgba(255, 240, 200, 0.9)) drop-shadow(0 0 10px rgba(240, 199, 94, 0.7));
		opacity: 0;
		animation: shooting-star-fly 12s ease-out infinite;
		animation-delay: var(--ss-d);
	}

	.shooting-star::after {
		content: "";
		position: absolute;
		right: 0;
		top: 50%;
		transform: translateY(-50%);
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: #fff;
		box-shadow: 0 0 10px #fff, 0 0 20px rgba(240, 199, 94, 0.9);
	}

	@keyframes shooting-star-fly {
		0%, 88% { opacity: 0; transform: rotate(var(--ss-rot)) translateX(-100px) scaleX(0.3); }
		92% { opacity: 1; transform: rotate(var(--ss-rot)) translateX(0) scaleX(1); }
		100% { opacity: 0; transform: rotate(var(--ss-rot)) translateX(200px) scaleX(1.5); }
	}

	/* Floo-style rising gold mist plumes at bottom */
	.portrait-mist {
		position: absolute;
		bottom: -40px;
		left: 0;
		right: 0;
		height: 200px;
		pointer-events: none;
		z-index: 3;
	}

	.mist-plume {
		position: absolute;
		bottom: 0;
		left: var(--mx);
		width: 80px;
		height: 80px;
		margin-left: -40px;
		border-radius: 50%;
		background: radial-gradient(
			circle at center,
			rgba(240, 199, 94, 0.6) 0%,
			rgba(255, 230, 170, 0.3) 40%,
			transparent 70%
		);
		filter: blur(8px);
		opacity: 0;
		animation: mist-bloom 7s ease-out infinite;
		animation-delay: var(--md);
	}

	@keyframes mist-bloom {
		0% { opacity: 0; transform: translate(0, 40px) scale(0.3); }
		30% { opacity: 1; transform: translate(0, 0) scale(1); }
		100% { opacity: 0; transform: translate(var(--mdx, 10px), -120px) scale(2.5); }
	}


	/* Apparition-style lightning bolts firing from above */
	.portrait-lightning {
		position: absolute;
		top: -20px;
		left: 50%;
		transform: translateX(-50%);
		width: 100px;
		height: 400px;
		pointer-events: none;
		z-index: 8;
	}

	.lightning-bolt {
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		width: 100%;
		height: 100%;
		filter: drop-shadow(0 0 6px rgba(240, 199, 94, 1)) drop-shadow(0 0 14px rgba(240, 199, 94, 0.6));
		opacity: 0;
		stroke-dasharray: 400;
		stroke-dashoffset: 400;
	}

	.lightning-1 {
		animation: lightning-strike 18s ease-out infinite;
	}

	.lightning-2 {
		animation: lightning-strike 18s ease-out 9s infinite;
	}

	@keyframes lightning-strike {
		0%, 92% { opacity: 0; stroke-dashoffset: 400; }
		93% { opacity: 1; stroke-dashoffset: 0; }
		95% { opacity: 1; }
		98% { opacity: 0.3; }
		100% { opacity: 0; }
	}

	/* Patronus burst — 12 rays explode from center periodically */
	.portrait-patronus {
		position: absolute;
		top: 175px;
		left: 50%;
		width: 0;
		height: 0;
		pointer-events: none;
		z-index: 7;
	}

	.patronus-core {
		position: absolute;
		left: 0;
		top: 0;
		width: 40px;
		height: 40px;
		margin: -20px 0 0 -20px;
		border-radius: 50%;
		background: radial-gradient(circle, #fff 0%, rgba(255, 240, 200, 0.9) 30%, rgba(240, 199, 94, 0.5) 60%, transparent 80%);
		box-shadow:
			0 0 40px rgba(255, 240, 200, 0.9),
			0 0 80px rgba(240, 199, 94, 0.6);
		transform: scale(0);
		opacity: 0;
		animation: patronus-core-flash 12s ease-out infinite;
	}

	@keyframes patronus-core-flash {
		0%, 85% { transform: scale(0); opacity: 0; }
		88% { transform: scale(0.3); opacity: 1; }
		92% { transform: scale(2); opacity: 1; }
		100% { transform: scale(5); opacity: 0; }
	}

	.patronus-ray {
		position: absolute;
		left: 0;
		top: 0;
		width: 3px;
		height: 180px;
		margin-left: -1.5px;
		transform-origin: 50% 0%;
		transform: rotate(var(--pray-angle)) scaleY(0);
		background: linear-gradient(
			to bottom,
			rgba(255, 240, 200, 1),
			rgba(240, 199, 94, 0.7) 50%,
			transparent 100%
		);
		filter: blur(1.5px) drop-shadow(0 0 6px rgba(240, 199, 94, 0.9));
		opacity: 0;
		animation: patronus-ray-burst 12s ease-out infinite;
	}

	@keyframes patronus-ray-burst {
		0%, 85% { opacity: 0; transform: rotate(var(--pray-angle)) scaleY(0); }
		90% { opacity: 1; transform: rotate(var(--pray-angle)) scaleY(1.1); }
		100% { opacity: 0; transform: rotate(var(--pray-angle)) scaleY(2.5) translateY(30px); }
	}

	/* Twinkling sparkles scattered around portrait */
	.portrait-sparkles {
		position: absolute;
		inset: -40px;
		pointer-events: none;
		z-index: 6;
	}

	.sparkle {
		position: absolute;
		left: var(--sx);
		top: var(--sy);
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: #fff0c2;
		box-shadow:
			0 0 6px #fff0c2,
			0 0 14px rgba(240, 199, 94, 0.9),
			0 0 26px rgba(240, 199, 94, 0.5);
		opacity: 0;
		animation: sparkle-twinkle 4.5s ease-in-out infinite;
		animation-delay: var(--sd);
	}

	.sparkle::before, .sparkle::after {
		content: "";
		position: absolute;
		background: rgba(255, 240, 200, 0.9);
		filter: blur(0.5px);
	}
	.sparkle::before {
		width: 22px; height: 1.5px;
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
	}
	.sparkle::after {
		width: 1.5px; height: 22px;
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
	}

	@keyframes sparkle-twinkle {
		0%, 70%, 100% { opacity: 0; transform: scale(0.3) rotate(0deg); }
		80% { opacity: 1; transform: scale(1.2) rotate(45deg); }
		90% { opacity: 0.6; transform: scale(0.9) rotate(90deg); }
	}

	/* Conic-gradient vortex behind portrait — pensieve-like rotation */
	.portrait-vortex {
		position: absolute;
		top: -40px;
		left: 50%;
		transform: translateX(-50%);
		width: 380px;
		height: 460px;
		pointer-events: none;
		z-index: 0;
		border-radius: 50%;
		background: conic-gradient(
			from 0deg,
			transparent 0deg,
			rgba(240, 199, 94, 0.12) 45deg,
			transparent 90deg,
			rgba(240, 199, 94, 0.18) 135deg,
			transparent 180deg,
			rgba(240, 199, 94, 0.12) 225deg,
			transparent 270deg,
			rgba(240, 199, 94, 0.15) 315deg,
			transparent 360deg
		);
		filter: blur(30px);
		opacity: 0.8;
		animation: vortex-slow-spin 30s linear infinite;
	}

	@keyframes vortex-slow-spin {
		to { transform: translateX(-50%) rotate(360deg); }
	}

	/* Silvery memory wisps drifting horizontally across portrait */
	.portrait-wisps {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 4;
		overflow: visible;
	}

	.wisp {
		position: absolute;
		top: var(--wt);
		left: var(--wl);
		width: 120px;
		height: 2px;
		background: linear-gradient(
			90deg,
			transparent 0%,
			rgba(255, 240, 200, 0.5) 30%,
			rgba(255, 230, 160, 0.85) 50%,
			rgba(255, 240, 200, 0.5) 70%,
			transparent 100%
		);
		filter: blur(1.5px);
		opacity: 0;
		transform: rotate(var(--wr)) translateX(0);
		animation: wisp-drift 9s ease-in-out infinite;
		animation-delay: var(--wd);
	}

	@keyframes wisp-drift {
		0% { opacity: 0; transform: rotate(var(--wr)) translateX(0) scaleX(0.3); }
		20% { opacity: 0.85; transform: rotate(var(--wr)) translateX(160px) scaleX(1); }
		70% { opacity: 0.6; transform: rotate(var(--wr)) translateX(380px) scaleX(1.2); }
		100% { opacity: 0; transform: rotate(var(--wr)) translateX(500px) scaleX(1.8); }
	}


	/* Pulsing gold halo behind portrait */
	.portrait-halo {
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		width: 340px;
		height: 420px;
		pointer-events: none;
		z-index: 0;
		background: radial-gradient(
			ellipse at 50% 45%,
			rgba(240, 199, 94, 0.38) 0%,
			rgba(240, 199, 94, 0.18) 30%,
			rgba(240, 199, 94, 0.06) 55%,
			transparent 75%
		);
		filter: blur(20px);
		animation: halo-pulse 4s ease-in-out infinite;
	}

	@keyframes halo-pulse {
		0%, 100% { opacity: 0.7; transform: translateX(-50%) scale(1); }
		50% { opacity: 1; transform: translateX(-50%) scale(1.08); }
	}

	/* Portrait card — the frame + image */
	.portrait-card {
		position: relative;
		width: 280px;
		aspect-ratio: 4 / 5;
		border-radius: 4px;
		overflow: hidden;
		z-index: 2;
		padding: 8px;
		background: linear-gradient(
			135deg,
			rgba(240, 199, 94, 0.5) 0%,
			rgba(180, 140, 60, 0.2) 40%,
			rgba(240, 199, 94, 0.35) 60%,
			rgba(180, 140, 60, 0.15) 100%
		);
		box-shadow:
			inset 0 0 0 1px rgba(255, 230, 170, 0.7),
			0 1px 0 rgba(240, 199, 94, 0.3),
			0 30px 80px -20px rgba(0, 0, 0, 0.7),
			0 0 60px -10px rgba(240, 199, 94, 0.4);
	}

		/* Caption */
	.photo-caption {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-2);
		margin-top: var(--spacing-3);
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
	}

	.photo-caption-dot {
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: rgba(240, 199, 94, 0.9);
		box-shadow:
			0 0 8px rgba(240, 199, 94, 0.8),
			0 0 16px rgba(240, 199, 94, 0.4);
		animation: caption-blink 2.5s ease-in-out infinite;
	}

	@keyframes caption-blink {
		0%, 100% { opacity: 0.4; transform: scale(1); }
		50% { opacity: 1; transform: scale(1.3); }
	}

	/* Continuously drawing gold trace around the frame border (Door Trace spell) */
	.portrait-trace {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: 5;
		overflow: visible;
		filter: drop-shadow(0 0 6px rgba(240, 199, 94, 0.8)) drop-shadow(0 0 14px rgba(240, 199, 94, 0.4));
	}

	.trace-path {
		animation: trace-draw 6s ease-in-out infinite;
	}

	@keyframes trace-draw {
		0% { stroke-dashoffset: 1248; opacity: 0; }
		10% { opacity: 1; }
		50% { stroke-dashoffset: 0; opacity: 1; }
		90% { stroke-dashoffset: -1248; opacity: 0.6; }
		100% { stroke-dashoffset: -1248; opacity: 0; }
	}

	/* Twinkling stars at each corner */
	.portrait-star {
		position: absolute;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: #fff0c2;
		box-shadow:
			0 0 4px #fff0c2,
			0 0 12px rgba(240, 199, 94, 1),
			0 0 24px rgba(240, 199, 94, 0.7),
			0 0 40px rgba(240, 199, 94, 0.4);
		z-index: 6;
		pointer-events: none;
	}

	.portrait-star::before {
		content: "";
		position: absolute;
		inset: -50%;
		background: radial-gradient(circle, rgba(255, 255, 255, 0.8) 0%, transparent 60%);
		filter: blur(2px);
	}

	.portrait-star-tl { top: -4px; left: -4px; animation: star-twinkle 2.4s ease-in-out infinite; }
	.portrait-star-tr { top: -4px; right: -4px; animation: star-twinkle 2.4s ease-in-out 0.6s infinite; }
	.portrait-star-bl { bottom: -4px; left: -4px; animation: star-twinkle 2.4s ease-in-out 1.2s infinite; }
	.portrait-star-br { bottom: -4px; right: -4px; animation: star-twinkle 2.4s ease-in-out 1.8s infinite; }

	@keyframes star-twinkle {
		0%, 100% { opacity: 0.4; transform: scale(0.8); }
		50% { opacity: 1; transform: scale(1.4); }
	}

	/* Photo: soft warm treatment + breathing + Ken Burns pan/zoom + turbulence shimmer */
	.profile-photo {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 2px;
		filter:
			contrast(1.05) brightness(1.02) saturate(1.05)
			url(#magicalShimmer);
		animation: photo-ken-burns 24s ease-in-out infinite;
	}

	@keyframes photo-ken-burns {
		0% { transform: scale(1) translate(0, 0); }
		25% { transform: scale(1.06) translate(-2%, -1%); }
		50% { transform: scale(1.08) translate(1%, 2%); }
		75% { transform: scale(1.06) translate(2%, -1%); }
		100% { transform: scale(1) translate(0, 0); }
	}

	/* Hidden SVG filter container */
	.portrait-filters {
		position: absolute;
		width: 0;
		height: 0;
		overflow: hidden;
	}

	/* Vignette on photo */
	.portrait-vignette {
		position: absolute;
		inset: 8px;
		border-radius: 2px;
		pointer-events: none;
		background:
			radial-gradient(ellipse at 50% 50%, transparent 55%, rgba(0, 0, 0, 0.25) 95%, rgba(0, 0, 0, 0.4) 100%),
			linear-gradient(180deg, rgba(240, 199, 94, 0.08) 0%, transparent 25%);
	}

	/* Diagonal sheen that sweeps periodically */
	.portrait-sheen {
		position: absolute;
		inset: 8px;
		border-radius: 2px;
		pointer-events: none;
		overflow: hidden;
	}

	.portrait-sheen::before {
		content: "";
		position: absolute;
		inset: -50% -80%;
		background: linear-gradient(
			115deg,
			transparent 40%,
			rgba(255, 230, 170, 0.3) 50%,
			transparent 60%
		);
		animation: sheen-sweep 7s ease-in-out infinite;
		animation-delay: 2s;
	}

	@keyframes sheen-sweep {
		0%, 15% { transform: translateX(-70%); opacity: 0; }
		30% { opacity: 1; }
		60%, 100% { transform: translateX(70%); opacity: 0; }
	}

	.portrait-candle-glow {
		position: absolute;
		inset: 0;
		z-index: 2;
		pointer-events: none;
		background: radial-gradient(ellipse at 30% 40%, rgba(255, 186, 110, 0.14) 0%, rgba(255, 186, 110, 0.06) 35%, transparent 70%);
		mix-blend-mode: screen;
		animation: candle-flicker 4.7s ease-in-out infinite;
	}

	@keyframes candle-flicker {
		0%, 100% { opacity: 0.9; transform: scale(1); }
		20% { opacity: 1; transform: scale(1.01); }
		40% { opacity: 0.85; transform: scale(0.99); }
		60% { opacity: 0.95; transform: scale(1.005); }
		80% { opacity: 0.9; transform: scale(0.995); }
	}

	.about-meta {
		margin: var(--spacing-8) 0 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
		border-top: 1px solid var(--color-border);
		padding-top: var(--spacing-6);
	}

	.about-meta-row {
		display: grid;
		grid-template-columns: 100px 1fr;
		gap: var(--spacing-4);
		align-items: baseline;
	}

	.about-meta-row dt {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-muted);
		margin: 0;
	}

	.about-meta-row dd {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-text);
		margin: 0;
		line-height: 1.5;
	}

	.about-meta-handle {
		font-family: var(--font-mono);
		color: var(--color-text);
		background: rgba(201, 169, 97, 0.1);
		padding: 1px 6px;
		border-radius: 2px;
		font-size: 0.95em;
	}

	.about-rule {
		width: 24px;
		height: 1px;
		background: var(--color-accent);
		margin-bottom: var(--spacing-5);
	}

	.about-label {
		display: block;
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-muted);
		margin-bottom: var(--spacing-4);
	}

	.about-title {
		font-family: var(--font-display);
		font-size: clamp(1.875rem, 3.5vw, 3rem);
		font-weight: var(--font-weight-display);
		line-height: 1.1;
		letter-spacing: -0.022em;
		color: var(--color-text);
		margin: 0 0 var(--spacing-3);
	}

	.about-subtitle {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin: 0;
		text-wrap: pretty;
	}

	/* Hero profile links — compact icon row, one reach from the top. */
	.hero-profile-links {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-top: var(--spacing-6, 1.5rem);
	}
	.hero-profile-link {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.4rem;
		height: 2.4rem;
		border-radius: 50%;
		border: 1px solid rgba(240, 199, 94, 0.25);
		background: radial-gradient(circle at 32% 28%,
			rgba(240, 199, 94, 0.12) 0%,
			rgba(240, 199, 94, 0.04) 65%,
			rgba(240, 199, 94, 0.02) 100%);
		color: var(--color-muted);
		text-decoration: none;
		transition: color 220ms, border-color 220ms, background 220ms, transform 220ms, box-shadow 260ms;
	}
	/* Dashed sigil ring — hidden by default, orbits on hover/focus.
	   Matches the chronology's major-milestone sigil but tighter. */
	.hero-profile-link::before {
		content: "";
		position: absolute;
		inset: -0.32rem;
		border-radius: 50%;
		border: 1px dashed rgba(240, 199, 94, 0);
		pointer-events: none;
		transition: border-color 240ms;
	}
	.hero-profile-link:hover,
	.hero-profile-link:focus-visible {
		color: var(--color-accent, #f0c75e);
		border-color: rgba(240, 199, 94, 0.65);
		background: radial-gradient(circle at 32% 28%,
			rgba(240, 199, 94, 0.22) 0%,
			rgba(240, 199, 94, 0.08) 65%,
			rgba(240, 199, 94, 0.03) 100%);
		transform: translateY(-1px);
		box-shadow:
			0 0 14px rgba(240, 199, 94, 0.22),
			0 0 28px rgba(240, 199, 94, 0.1);
	}
	.hero-profile-link:hover::before,
	.hero-profile-link:focus-visible::before {
		border-color: rgba(240, 199, 94, 0.5);
		animation: hero-link-sigil 9s linear infinite;
	}
	@keyframes hero-link-sigil {
		to { transform: rotate(360deg); }
	}
	/* Idle aura — gentle outward pulse, staggered per sigil so the row
	   breathes asynchronously. Sits beneath the sigil with z-index: -1. */
	.hero-profile-link::after {
		content: "";
		position: absolute;
		inset: -6px;
		border-radius: 50%;
		background: radial-gradient(circle,
			rgba(240, 199, 94, 0.12) 0%,
			rgba(240, 199, 94, 0.04) 45%,
			transparent 70%);
		opacity: 0.7;
		animation: hero-link-aura 5.5s ease-in-out infinite;
		pointer-events: none;
		z-index: -1;
	}
	.hero-profile-link:nth-child(2)::after { animation-delay: -1.1s; }
	.hero-profile-link:nth-child(3)::after { animation-delay: -2.2s; }
	.hero-profile-link:nth-child(4)::after { animation-delay: -3.3s; }
	.hero-profile-link:nth-child(5)::after { animation-delay: -4.4s; }
	@keyframes hero-link-aura {
		0%, 100% { transform: scale(0.92); opacity: 0.55; }
		50%      { transform: scale(1.12); opacity: 0.85; }
	}
	.hero-profile-link:hover::after,
	.hero-profile-link:focus-visible::after {
		animation-duration: 2.2s;
	}
	/* Sections */
	.about-section {
		border-bottom: 1px solid var(--color-border);
		/* Offset anchor-scroll so #community etc. don't land with the
		   heading pressed against the top edge. */
		scroll-margin-top: 1.5rem;
	}
	.about-hero {
		scroll-margin-top: 1.5rem;
	}

	.about-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-8);
	}

	.section-heading {
		font-family: var(--font-display);
		font-size: var(--font-size-lg);
		font-weight: var(--font-weight-display);
		letter-spacing: -0.012em;
		color: var(--color-text);
		margin: 0 0 var(--spacing-2);
		/* Contain the anchor-link so it sits on the heading baseline. */
		display: inline-flex;
		align-items: baseline;
		gap: 0.5rem;
	}
	/* Runic sigil prefix on every section heading — matches the chronology
	   timeline's rune markers. Dim gold at rest, brighter on hover. Ambient
	   glow via text-shadow so it reads as carved, not flat. */
	.section-heading[data-rune]::before {
		content: attr(data-rune);
		font-family: "IBM Plex Serif", "Iowan Old Style", serif;
		font-weight: 400;
		font-size: 0.68em;
		color: rgba(240, 199, 94, 0.45);
		text-shadow: 0 0 10px rgba(240, 199, 94, 0.22);
		transform: translateY(-0.08em);
		transition: color 240ms, text-shadow 240ms;
	}
	.section-heading[data-rune]:hover::before {
		color: rgba(240, 199, 94, 0.85);
		text-shadow: 0 0 14px rgba(240, 199, 94, 0.4);
	}

	/* "Life in Dates" tile — entry point to /pensieve/chronicle */
	.life-tile {
		display: block;
		text-decoration: none;
		border-radius: 14px;
		overflow: hidden;
		border: 1px solid rgba(212, 168, 67, 0.18);
		background:
			radial-gradient(ellipse at 20% 30%, rgba(94, 106, 210, 0.12) 0%, transparent 55%),
			radial-gradient(ellipse at 80% 70%, rgba(212, 168, 67, 0.08) 0%, transparent 60%),
			linear-gradient(180deg, #0a0b10 0%, #050608 100%);
		transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
	}
	.life-tile:hover,
	.life-tile:focus-visible {
		border-color: rgba(212, 168, 67, 0.4);
		transform: translateY(-2px);
		box-shadow: 0 10px 40px rgba(212, 168, 67, 0.08);
		outline: none;
	}
	.life-tile-inner {
		position: relative;
		padding: 32px 36px;
		min-height: 180px;
		display: flex;
		align-items: center;
	}
	.life-tile-stars {
		position: absolute;
		inset: 0;
		pointer-events: none;
		overflow: hidden;
	}
	.life-star {
		position: absolute;
		width: 4px; height: 4px;
		border-radius: 50%;
		background: #d4a843;
		box-shadow: 0 0 6px #d4a843, 0 0 12px rgba(212, 168, 67, 0.4);
	}
	.life-star-a { top: 18%; left: 14%; opacity: 0.8; }
	.life-star-b { top: 68%; left: 28%; background: #5e6ad2; box-shadow: 0 0 6px #5e6ad2, 0 0 12px rgba(94, 106, 210, 0.4); opacity: 0.7; }
	.life-star-c { top: 30%; right: 22%; background: #c678dd; box-shadow: 0 0 6px #c678dd, 0 0 12px rgba(198, 120, 221, 0.4); opacity: 0.6; }
	.life-star-d { bottom: 20%; right: 12%; background: #b54b3c; box-shadow: 0 0 6px #b54b3c, 0 0 12px rgba(181, 75, 60, 0.4); opacity: 0.5; }
	.life-tile-body {
		position: relative;
		max-width: 640px;
	}
	.life-tile-kicker {
		font-family: "JetBrains Mono", monospace;
		font-size: 11px;
		letter-spacing: 0.25em;
		text-transform: uppercase;
		color: rgba(212, 168, 67, 0.7);
		margin: 0 0 8px;
	}
	.life-tile-title {
		font-family: "Inter Tight", sans-serif;
		font-size: clamp(22px, 2.5vw, 30px);
		font-weight: 600;
		color: #f7f8f8;
		margin: 0 0 10px;
	}
	.life-tile-desc {
		color: #8a8f98;
		font-size: 14px;
		line-height: 1.55;
		margin: 0 0 14px;
	}
	.life-tile-cta {
		font-family: "Inter Tight", sans-serif;
		font-size: 13px;
		color: #d4a843;
		letter-spacing: 0.05em;
		transition: letter-spacing 0.2s;
	}
	.life-tile:hover .life-tile-cta {
		letter-spacing: 0.12em;
	}

	/* Pilcrow-style anchor, appears on heading hover. Click copies the
	   URL fragment into history — native browser behavior, no JS. */
	.anchor-link {
		color: var(--color-muted);
		font-family: var(--font-mono, "JetBrains Mono", monospace);
		font-weight: 400;
		font-size: 0.7em;
		text-decoration: none;
		opacity: 0;
		transform: translateX(-0.2rem);
		transition: opacity 180ms, transform 180ms, color 180ms;
		line-height: 1;
	}
	.section-heading:hover .anchor-link,
	.anchor-link:focus-visible {
		opacity: 1;
		transform: translateX(0);
		color: var(--color-accent, var(--color-text));
	}

	.section-desc {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin: 0 0 var(--spacing-8);
	}

	/* Prose */
	.about-prose {
		/* max-width moved to direct <p> children so .prose-intro can
		   span wider with its 2-column seal layout. */
	}

	.about-prose > p {
		max-width: 62ch;
	}

	.about-prose p {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0 0 var(--spacing-5);
	}


	.about-prose p:last-child {
		margin-bottom: 0;
	}

	.about-prose em {
		color: var(--color-text);
		font-style: italic;
	}

	.prose-link {
		color: var(--color-accent);
		text-decoration: none;
		font-weight: 500;
	}

	.prose-link:hover {
		text-decoration: underline;
	}

	/* Profile links */
	.links-row {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-3);
		margin-top: var(--spacing-5);
	}

	.profile-link {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-2);
		padding: var(--spacing-2) var(--spacing-4);
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-text);
		text-decoration: none;
		background: var(--color-surface-elevated);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		transition:
			border-color var(--transition-fast),
			transform var(--transition-fast);
	}

	.profile-link:hover {
		border-color: var(--color-accent);
		transform: translateY(-1px);
	}

	.profile-icon {
		flex-shrink: 0;
		opacity: 0.7;
	}

	/* Coding eras */
	.eras-timeline {
		margin-bottom: var(--spacing-10);
	}

	.eras-track {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
	}

	.era {
		display: flex;
		align-items: center;
		gap: var(--spacing-4);
	}

	.era-bar {
		height: 6px;
		background: var(--era-color);
		border-radius: 3px;
		opacity: 0.5;
		min-width: 20px;
	}

	.era-current .era-bar {
		opacity: 1;
		box-shadow: 0 0 8px color-mix(in srgb, var(--era-color) 40%, transparent);
	}

	.era-info {
		display: flex;
		align-items: baseline;
		gap: var(--spacing-3);
		flex-shrink: 0;
	}

	.era-label {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 600;
		color: var(--era-color);
		white-space: nowrap;
	}

	.era-commits {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--color-text-secondary);
		font-weight: 500;
		white-space: nowrap;
	}

	.era-dates {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--color-muted);
		white-space: nowrap;
	}

	.era-note {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		color: var(--color-text-secondary);
		white-space: nowrap;
	}

	/* GitHub stats */
	.gh-stats {
		display: flex;
		gap: var(--spacing-8);
		margin-bottom: var(--spacing-10);
	}

	.gh-stat {
		display: flex;
		flex-direction: column;
	}

	.gh-stat-value {
		font-family: var(--font-display);
		font-size: var(--font-size-2xl);
		font-weight: var(--font-weight-display);
		color: var(--color-text);
		letter-spacing: -0.02em;
	}

	.gh-stat-label {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	/* Section title (shared by Coding Eras + Recent Repositories) */
	.chart-title {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 600;
		color: var(--color-text);
		margin: 0 0 var(--spacing-4);
	}

	/* Repos */
	.repos-section {
		margin-bottom: var(--spacing-10);
	}

	.repos-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: var(--spacing-3);
	}

	.repo-card {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-1);
		padding: var(--spacing-4) var(--spacing-5);
		background: var(--color-surface-elevated);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		text-decoration: none;
		color: inherit;
		transition:
			border-color var(--transition-fast),
			transform var(--transition-fast);
	}

	.repo-card:hover {
		border-color: color-mix(in srgb, var(--color-accent) 50%, var(--color-border));
		transform: translateY(-1px);
	}

	.community-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1rem;
		margin-top: 1rem;
	}

	.community-card {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 1rem;
		border: 1px solid var(--color-border, rgba(240, 199, 94, 0.2));
		border-radius: 0.5rem;
		background: rgba(240, 199, 94, 0.03);
		color: inherit;
	}

	.community-name {
		font-family: var(--font-display, "Inter Tight", sans-serif);
		font-size: 1.05rem;
		font-weight: 600;
		color: var(--color-accent, #f0c75e);
	}

	.community-role {
		font-size: 0.75rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--color-muted, rgba(255, 255, 255, 0.55));
	}

	.community-stats {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1rem;
		margin: 0.25rem 0 0.15rem;
		padding: 0.5rem 0;
		border-top: 1px dashed rgba(240, 199, 94, 0.18);
		border-bottom: 1px dashed rgba(240, 199, 94, 0.18);
	}
	.community-stats > div {
		display: flex;
		flex-direction: column;
		gap: 1px;
	}
	.community-stats dt {
		font-family: var(--font-mono, ui-monospace, "SF Mono", Menlo, monospace);
		font-size: 0.65rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-muted, rgba(255, 255, 255, 0.45));
		font-weight: 400;
	}
	.community-stats dd {
		font-family: var(--font-mono, ui-monospace, "SF Mono", Menlo, monospace);
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--color-accent, #f0c75e);
		margin: 0;
		line-height: 1.2;
	}

	.community-desc {
		font-size: 0.9rem;
		line-height: 1.45;
		color: var(--color-text-dim, rgba(255, 255, 255, 0.75));
	}

	/* ─ Pensieve Dives — Wrapped flashcard grid ────────────────────── */
	/* Asymmetric grid: big hero card up top, three mid-size stat cards
	   below it on one row, two "tall" interpretive cards, one wide
	   sentimental card at the bottom. Silver palette matches the
	   Pensieve canon; oversized numeric typography does the Spotify-
	   Wrapped lift while the copy stays HP-flavored underneath. */
	.wrapped-grid {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		gap: 0.875rem;
		margin-top: 1rem;
	}

	.wrap-card {
		grid-column: span 2;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 1.1rem 1.1rem 1.2rem;
		border: 1px solid rgba(200, 210, 225, 0.14);
		border-top: 2px solid rgba(200, 210, 225, 0.32);
		border-radius: 0.5rem;
		background: linear-gradient(
			180deg,
			rgba(200, 210, 225, 0.045) 0%,
			rgba(200, 210, 225, 0.015) 100%
		);
		transition: border-color 200ms, background 200ms, transform 200ms;
		min-height: 150px;
	}

	.wrap-card:hover {
		border-color: rgba(200, 210, 225, 0.32);
		border-top-color: rgba(200, 210, 225, 0.55);
		background: linear-gradient(
			180deg,
			rgba(200, 210, 225, 0.07) 0%,
			rgba(200, 210, 225, 0.025) 100%
		);
		transform: translateY(-1px);
	}

	/* Hero — full-width headline card */
	.wrap-hero {
		position: relative;
		grid-column: span 6;
		flex-direction: row;
		align-items: center;
		gap: 1.5rem;
		padding: 1.4rem 1.6rem;
		min-height: unset;
		overflow: hidden; /* clip the memory-swirl to the card */
	}
	/* Silvery filigree rim — top + bottom double-line with center gem.
	   Vertical echo of the portrait's baroque frame, scaled to card size. */
	.wrap-hero::before,
	.wrap-hero::after {
		content: "";
		position: absolute;
		left: 50%;
		width: 70%;
		max-width: 360px;
		height: 1px;
		background: linear-gradient(90deg,
			transparent 0%,
			rgba(200, 210, 225, 0.0) 6%,
			rgba(200, 210, 225, 0.4) 50%,
			rgba(200, 210, 225, 0.0) 94%,
			transparent 100%);
		transform: translateX(-50%);
		pointer-events: none;
	}
	.wrap-hero::before { top: 6px; }
	.wrap-hero::after  { bottom: 6px; }

	.wrap-hero .wrap-stat {
		position: relative;
		font-size: 4.5rem;
		line-height: 1;
		flex-shrink: 0;
		isolation: isolate; /* so the swirl sits behind the number cleanly */
	}
	/* Slow silvery memory-swirl behind the "1,064" — mimics Dumbledore's
	   silver substance drifting inside the Pensieve. 32s rotation is slow
	   enough to be ambient, never distracting. Conic gradient + blur. */
	.wrap-hero .wrap-stat::before {
		content: "";
		position: absolute;
		inset: -30% -25%;
		background: conic-gradient(from 0deg,
			rgba(200, 210, 225, 0) 0%,
			rgba(200, 210, 225, 0.16) 18%,
			rgba(200, 210, 225, 0) 40%,
			rgba(200, 210, 225, 0.10) 62%,
			rgba(200, 210, 225, 0) 82%,
			rgba(200, 210, 225, 0.14) 100%);
		filter: blur(22px);
		animation: pensieve-swirl 32s linear infinite;
		z-index: -1;
		pointer-events: none;
	}
	@keyframes pensieve-swirl {
		to { transform: rotate(360deg); }
	}
	.wrap-hero .wrap-label {
		font-size: 0.75rem;
		margin-bottom: 0.4rem;
	}
	.wrap-hero .wrap-note {
		margin-top: 0;
	}

	/* Tall cards — more room for multi-line lists/context */
	.wrap-tall {
		grid-column: span 3;
	}

	/* Wide card — sentimental shelf full-width */
	.wrap-wide {
		grid-column: span 6;
	}

	.wrap-stat {
		font-family: var(--font-display, "Inter Tight", sans-serif);
		font-size: 2.25rem;
		font-weight: 700;
		letter-spacing: -0.035em;
		line-height: 1;
		color: rgba(230, 235, 245, 0.98);
		margin: 0.1rem 0 0.35rem;
		font-variant-numeric: tabular-nums;
	}
	.wrap-stat-pct {
		font-size: 0.55em;
		font-weight: 500;
		color: rgba(200, 210, 225, 0.55);
		letter-spacing: -0.01em;
	}
	.wrap-stat-delta {
		font-family: var(--font-mono, "JetBrains Mono", monospace);
		font-size: 1.6rem;
		letter-spacing: -0.015em;
	}
	.wrap-stat-warn {
		color: rgba(255, 170, 150, 0.92);
	}

	.wrap-label {
		font-family: var(--font-mono, "JetBrains Mono", monospace);
		font-size: 0.68rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: rgba(200, 210, 225, 0.72);
		margin: 0;
	}
	.wrap-label-top {
		margin-bottom: 0.75rem;
	}

	.wrap-note {
		font-size: 0.88rem;
		line-height: 1.5;
		color: var(--color-text-dim, rgba(255, 255, 255, 0.72));
		margin: auto 0 0 0; /* push to bottom of the card */
	}
	.wrap-hero .wrap-note {
		font-size: 0.92rem;
		flex: 1;
	}

	/* Directors-list card */
	.wrap-list {
		list-style: none;
		padding: 0;
		margin: 0.5rem 0 0;
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
	}
	.wrap-list li {
		display: flex;
		gap: 0.75rem;
		align-items: baseline;
		font-size: 0.88rem;
		line-height: 1.35;
		color: rgba(230, 235, 245, 0.92);
	}
	.wrap-list li em {
		font-style: normal;
		color: rgba(200, 210, 225, 0.55);
		font-size: 0.8rem;
	}
	.wrap-list-score {
		font-family: var(--font-mono, "JetBrains Mono", monospace);
		font-size: 0.85rem;
		font-weight: 600;
		color: rgba(200, 210, 225, 0.88);
		min-width: 2.2rem;
		font-variant-numeric: tabular-nums;
	}

	/* Thematic fingerprint — horizontal bar chart, the plot-content reveal */
	.wrap-fingerprint .wrap-note-top {
		margin: 0 0 1rem;
	}
	.fingerprint-bars {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.4rem 2rem;
	}
	.fingerprint-bars > li {
		font-size: 0.85rem;
	}
	.fp-item {
		border: none;
	}
	.fp-item > summary {
		display: grid;
		grid-template-columns: 10rem 1fr 3rem;
		align-items: center;
		gap: 0.75rem;
		list-style: none;
		cursor: pointer;
		padding: 0.15rem 0;
		border-radius: 0.25rem;
		transition: background 180ms;
	}
	.fp-item > summary::-webkit-details-marker {
		display: none;
	}
	.fp-item > summary::marker {
		display: none;
		content: '';
	}
	.fp-item:hover > summary,
	.fp-item[open] > summary {
		background: rgba(200, 210, 225, 0.04);
	}
	.fp-titles {
		list-style: none;
		margin: 0.3rem 0 0.6rem 0;
		padding: 0.3rem 0.5rem 0.3rem 1.1rem;
		border-left: 1px solid rgba(200, 210, 225, 0.14);
	}
	.fp-titles li {
		font-size: 0.78rem;
		line-height: 1.5;
		color: rgba(230, 235, 245, 0.82);
		padding: 0.1rem 0;
	}
	.fp-titles em {
		font-style: normal;
		color: rgba(200, 210, 225, 0.45);
		font-size: 0.72rem;
		margin-left: 0.25rem;
		font-family: var(--font-mono, "JetBrains Mono", monospace);
	}
	.fp-name {
		color: rgba(230, 235, 245, 0.88);
		font-weight: 500;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.fp-bar {
		position: relative;
		height: 6px;
		background: rgba(200, 210, 225, 0.07);
		border-radius: 3px;
		overflow: hidden;
	}
	.fp-fill {
		position: relative;
		display: block;
		height: 100%;
		width: calc(var(--fp) * 5);
		max-width: 100%;
		background: linear-gradient(90deg,
			rgba(200, 210, 225, 0.55) 0%,
			rgba(200, 210, 225, 0.35) 100%);
		border-radius: 3px;
		overflow: hidden;
	}
	/* Slow silver shimmer pass — echoes the Pensieve's moving memory
	   substance. ~9s cycle with a long "rest" so it reads as ambient,
	   not a loading bar. Staggered per-bar via CSS variable --fp (the
	   theme percent) so the shimmer waves don't lock-step. */
	.fp-fill::after {
		content: "";
		position: absolute;
		inset: 0;
		background: linear-gradient(90deg,
			transparent 0%,
			rgba(255, 255, 255, 0.45) 50%,
			transparent 100%);
		transform: translateX(-100%);
		animation: fp-shimmer 9s ease-in-out infinite;
		animation-delay: calc(var(--fp, 10) * -0.12s);
		pointer-events: none;
	}
	@keyframes fp-shimmer {
		0%        { transform: translateX(-120%); }
		55%, 100% { transform: translateX(220%); }
	}
	.fp-pct {
		font-family: var(--font-mono, "JetBrains Mono", monospace);
		font-size: 0.75rem;
		color: rgba(200, 210, 225, 0.75);
		font-variant-numeric: tabular-nums;
		text-align: right;
	}
	@media (max-width: 720px) {
		.fingerprint-bars {
			grid-template-columns: 1fr;
		}
		.fingerprint-bars li {
			grid-template-columns: 8rem 1fr 3rem;
		}
	}

	/* Sentimental 10s — three-column subgrid */
	.wrap-sentimental {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 0.9rem;
		margin-bottom: 0.75rem;
	}
	.wrap-senti-item {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding: 0.7rem 0.85rem;
		background: rgba(200, 210, 225, 0.04);
		border-left: 2px solid rgba(200, 210, 225, 0.38);
		border-radius: 0 0.35rem 0.35rem 0;
	}
	.wrap-senti-title {
		font-family: var(--font-display, "Inter Tight", sans-serif);
		font-size: 1rem;
		font-weight: 600;
		color: rgba(230, 235, 245, 0.96);
	}
	.wrap-senti-meta {
		font-family: var(--font-mono, "JetBrains Mono", monospace);
		font-size: 0.72rem;
		color: rgba(200, 210, 225, 0.55);
	}

	/* Responsive — collapse asymmetric grid on narrow viewports */
	@media (max-width: 900px) {
		.wrapped-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.wrap-card { grid-column: span 1; }
		.wrap-hero { grid-column: span 2; flex-direction: column; align-items: flex-start; gap: 0.4rem; }
		.wrap-hero .wrap-stat { font-size: 3.5rem; }
		.wrap-tall { grid-column: span 2; }
		.wrap-wide { grid-column: span 2; }
	}
	@media (max-width: 520px) {
		.wrapped-grid { grid-template-columns: 1fr; }
		.wrap-card { grid-column: span 1; }
		.wrap-hero, .wrap-tall, .wrap-wide { grid-column: span 1; }
		.wrap-stat { font-size: 2rem; }
		.wrap-hero .wrap-stat { font-size: 3rem; }
	}

	.vial-footer {
		margin-top: 1.5rem;
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
	}
	.vial-footer a {
		color: var(--color-muted);
		text-decoration: none;
		transition: color 200ms;
	}
	.vial-footer a:hover {
		color: rgba(200, 210, 225, 0.9);
	}

	.repo-name {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
	}

	.repo-desc {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		color: var(--color-text-secondary);
		line-height: var(--leading-relaxed);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.repo-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-3);
		margin-top: var(--spacing-1);
	}

	.repo-lang {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-1);
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--color-muted);
	}

	.repo-lang-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
	}

	.repo-stars {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--color-muted);
	}

	/* Responsive */
	@media (max-width: 900px) {
		.about-hero-inner {
			padding: var(--spacing-16) var(--spacing-6) var(--spacing-12);
			grid-template-columns: 1fr;
			gap: var(--spacing-8);
		}

		.about-hero-photo {
			grid-row: 1;
			align-items: center;
			justify-self: center;
			width: 240px;
		}

		.portrait-card {
			width: 240px;
		}

		.portrait-halo {
			width: 280px;
			height: 340px;
		}

		.about-meta-row {
			grid-template-columns: 84px 1fr;
			gap: var(--spacing-3);
		}

		.about-inner {
			padding: var(--spacing-12) var(--spacing-6);
		}

		.gh-stats {
			gap: var(--spacing-6);
		}
	}

	@media (max-width: 600px) {
		.about-hero-inner {
			padding: var(--spacing-12) var(--spacing-5);
		}

		.about-inner {
			padding: var(--spacing-10) var(--spacing-5);
		}

		.gh-stats {
			flex-wrap: wrap;
			gap: var(--spacing-4);
		}

		.links-row {
			flex-direction: column;
		}
	}

	/* Ink bleed corner rune droplets */
	.portrait-ink-bleed { position: absolute; inset: 0; pointer-events: none; z-index: 2; }
	.portrait-ink-bleed .ink-drop { position: absolute; width: 28px; height: 28px; display: grid; place-items: center; }
	.portrait-ink-bleed .ink-drop-tl { top: 8%; left: 8%; }
	.portrait-ink-bleed .ink-drop-tr { top: 8%; right: 8%; }
	.portrait-ink-bleed .ink-drop-bl { bottom: 8%; left: 8%; }
	.portrait-ink-bleed .ink-drop-br { bottom: 8%; right: 8%; }
	.portrait-ink-bleed .ink-blob {
		position: absolute;
		inset: 0;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(60, 30, 12, 0.85) 0%, rgba(60, 30, 12, 0.4) 50%, transparent 75%);
		transform: scale(0);
		animation: ink-bloom 10s ease-in-out infinite;
	}
	.portrait-ink-bleed .ink-rune {
		position: relative;
		z-index: 1;
		font-family: serif;
		font-size: 0.9rem;
		color: rgba(240, 199, 94, 0.9);
		opacity: 0;
		animation: ink-rune-appear 10s ease-in-out infinite;
	}
	.ink-drop-tr .ink-blob, .ink-drop-tr .ink-rune { animation-delay: 2.5s; }
	.ink-drop-bl .ink-blob, .ink-drop-bl .ink-rune { animation-delay: 5s; }
	.ink-drop-br .ink-blob, .ink-drop-br .ink-rune { animation-delay: 7.5s; }
	@keyframes ink-bloom {
		0%, 10% { transform: scale(0); }
		40%, 70% { transform: scale(1); }
		90%, 100% { transform: scale(1.4); opacity: 0; }
	}
	@keyframes ink-rune-appear {
		0%, 30% { opacity: 0; }
		50%, 70% { opacity: 1; }
		90%, 100% { opacity: 0; }
	}

	/* Incantation — handwritten line rises on hover */
	.portrait-incantation {
		position: absolute;
		left: 50%;
		bottom: 2%;
		transform: translate(-50%, 16px);
		width: max-content;
		max-width: 90%;
		font-family: "Caveat", "Homemade Apple", cursive;
		font-size: 1.1rem;
		color: rgba(240, 199, 94, 0.95);
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.7);
		opacity: 0;
		transition: opacity 450ms ease-out, transform 450ms ease-out;
		pointer-events: none;
		z-index: 4;
		text-align: center;
		white-space: nowrap;
	}
	.about-hero-photo:hover .portrait-incantation {
		opacity: 1;
		transform: translate(-50%, 0);
	}
	@media (max-width: 600px) {
		.portrait-incantation { font-size: 0.9rem; white-space: normal; }
	}

	/* Lộc sigil — 祿, the "blessing" character. Painter's-seal on the
	   portrait. Starts nearly invisible; first bloom fires when the
	   name-meaning paragraph enters the viewport, then the sigil settles
	   into a faint always-on presence and brightens on hover. */
	.portrait-loc-seal {
		position: absolute;
		right: 16px;
		bottom: 64px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		pointer-events: auto;
		z-index: 6;
		opacity: 0;
		transform: scale(0.94);
		transition: opacity 2.2s ease, transform 2.2s ease;
	}
	.loc-glyph {
		font-family: "Noto Serif SC", "Songti SC", "STSong", "SimSun", serif;
		font-size: 28px;
		font-weight: 400;
		color: #d4a843;
		line-height: 1;
		text-shadow: 0 0 0 rgba(212, 168, 67, 0);
		transition: text-shadow 1.6s ease, color 1.6s ease, transform 400ms ease;
	}
	.loc-caption {
		font-family: var(--font-mono, "SF Mono", ui-monospace, monospace);
		font-size: 10px;
		letter-spacing: 0.08em;
		color: rgba(212, 168, 67, 0.0);
		white-space: nowrap;
		transition: color 600ms ease;
	}
	/* First-bloom state — added by IntersectionObserver when the
	   name-meaning paragraph enters view. */
	.portrait-loc-seal.is-bloomed {
		opacity: 0.35;
		transform: scale(1);
	}
	.portrait-loc-seal.is-blooming .loc-glyph {
		animation: locBloom 2.4s ease-out 1;
	}
	@keyframes locBloom {
		0%   { color: #d4a843; text-shadow: 0 0 0 rgba(212, 168, 67, 0); transform: scale(0.98); }
		30%  { color: #ffe38a; text-shadow: 0 0 18px rgba(255, 227, 138, 0.95), 0 0 4px rgba(255, 227, 138, 0.7); transform: scale(1.14); }
		100% { color: #d4a843; text-shadow: 0 0 0 rgba(212, 168, 67, 0); transform: scale(1); }
	}
	/* Settled hover — once bloomed, hover brightens and reveals caption. */
	.portrait-loc-seal.is-bloomed:hover {
		opacity: 0.9;
	}
	.portrait-loc-seal.is-bloomed:hover .loc-glyph {
		color: #ffe38a;
		text-shadow: 0 0 10px rgba(255, 227, 138, 0.6);
	}
	.portrait-loc-seal.is-bloomed:hover .loc-caption {
		color: rgba(212, 168, 67, 0.9);
	}
	@media (prefers-reduced-motion: reduce) {
		.portrait-loc-seal { transition: opacity 0.3s ease; }
		.portrait-loc-seal.is-blooming .loc-glyph { animation: none; }
	}
	@media (max-width: 600px) {
		.portrait-loc-seal { right: 8px; bottom: 48px; }
		.loc-glyph { font-size: 22px; }
		.loc-caption { font-size: 9px; }
	}

	/* Origin Seal — natal chart (rat + Aries) and heritage (Huỳnh · Võ ·
	   Phạm) float-right inside the prose so paragraphs wrap around it.
	   Gold = Eastern lineage, pink = Western horoscope. */
	.origin-seal {
		float: right;
		width: 360px;
		margin: 4px 0 var(--spacing-5, 20px) var(--spacing-8, 32px);
		padding: var(--spacing-4, 16px) var(--spacing-5, 20px);
		border: 1px solid var(--color-border, rgba(233, 230, 220, 0.14));
		border-left: 2px solid #d4a843;
		background: linear-gradient(180deg, rgba(212, 168, 67, 0.03), transparent);
		border-radius: 3px;
	}
	.origin-seal-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-3, 12px) var(--spacing-6, 24px);
	}
	.origin-col-title {
		font-family: var(--font-mono, ui-monospace, "SF Mono", Menlo, monospace);
		font-size: 10px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-muted, #8e877c);
		margin: 0 0 6px;
		font-weight: 500;
	}
	.origin-row {
		display: flex;
		align-items: baseline;
		gap: 10px;
		margin-bottom: 4px;
		font-size: var(--font-size-sm, 14px);
	}
	.origin-glyph {
		color: #d4a843;
		flex-shrink: 0;
		line-height: 1;
	}
	.origin-glyph-cjk {
		font-family: "Noto Serif SC", "Songti SC", "STSong", "SimSun", serif;
		font-size: 22px;
		min-width: 28px;
	}
	.origin-glyph-astro {
		font-family: "Apple Symbols", "Segoe UI Symbol", "Noto Sans Symbols 2", "Symbola", sans-serif;
		font-size: 16px;
		letter-spacing: 0.05em;
		min-width: 48px;
		color: #e8a5b5;
	}
	.origin-glyph-rat,
	.origin-glyph-lotus,
	.origin-glyph-spire { display: inline-block; }
	.origin-glyph-rat { width: 38px; height: 22px; }
	.origin-glyph-lotus,
	.origin-glyph-spire { width: 30px; height: 20px; }
	.origin-label {
		font-family: var(--font-sans, "Inter Tight", -apple-system, sans-serif);
		color: var(--color-text, #e9e6dc);
		font-size: var(--font-size-sm, 14px);
		letter-spacing: 0.01em;
		white-space: nowrap;
	}
	/* Classic footnote dagger — sits inline with the Huỳnh label, links
	   down to the name-story paragraph. Subtle by default, gold on hover
	   so readers know it's interactive rather than decoration. */
	.origin-note-marker {
		color: rgba(240, 199, 94, 0.65);
		text-decoration: none;
		font-family: var(--font-mono, "JetBrains Mono", monospace);
		font-size: 0.85em;
		margin-left: 0.15em;
		vertical-align: super;
		line-height: 1;
		transition: color 180ms;
	}
	.origin-note-marker:hover,
	.origin-note-marker:focus-visible {
		color: rgb(240, 199, 94);
	}
	/* Receiving paragraph: mirror the dagger to the left margin so the
	   footnote relationship reads visually. Briefly lights up gold when
	   targeted by the anchor jump. */
	#huynh-note {
		position: relative;
		scroll-margin-top: 2rem;
	}
	.huynh-marker {
		position: absolute;
		left: -1.2rem;
		top: 0;
		font-family: var(--font-mono, "JetBrains Mono", monospace);
		color: rgba(240, 199, 94, 0.55);
		font-size: 0.9em;
		line-height: inherit;
	}
	#huynh-note:target {
		animation: huynh-pulse 2.4s ease-out 1;
	}
	@keyframes huynh-pulse {
		0%   { background: rgba(240, 199, 94, 0.14); }
		100% { background: transparent; }
	}
	.origin-caption {
		font-family: var(--font-mono, ui-monospace, "SF Mono", Menlo, monospace);
		font-size: 10px;
		letter-spacing: 0.06em;
		color: var(--color-muted, #8e877c);
		text-align: center;
		margin: 10px 0 0;
		padding-top: 10px;
		border-top: 1px dashed var(--color-border, rgba(233, 230, 220, 0.14));
		transition: color 320ms;
	}

	/* ── Origin Seal magical polish ──────────────────────────────────
	   Animate the gold left bar, scatter star-dust behind the grid,
	   give each glyph a subtle drop-shadow glow, lift+brighten on row
	   hover. All non-destructive (existing layout/spacing intact). */
	.origin-seal {
		position: relative;
		overflow: hidden;
		transition: border-color 320ms, box-shadow 320ms;
	}
	.origin-seal:hover {
		border-color: rgba(240, 199, 94, 0.32);
		box-shadow:
			inset 0 0 18px rgba(240, 199, 94, 0.05),
			0 0 22px rgba(240, 199, 94, 0.07);
	}
	/* Slow shimmer travels up/down the gold spine — overrides the static
	   border-left while preserving the same width + gold tone. */
	.origin-seal::before {
		content: "";
		position: absolute;
		left: -2px;
		top: 0;
		width: 2px;
		height: 100%;
		background: linear-gradient(180deg,
			rgba(240, 199, 94, 0.18) 0%,
			#d4a843 35%,
			#ffdc80 50%,
			#d4a843 65%,
			rgba(240, 199, 94, 0.18) 100%);
		background-size: 100% 220%;
		animation: origin-spine-flow 7s ease-in-out infinite alternate;
		pointer-events: none;
	}
	@keyframes origin-spine-flow {
		from { background-position: 0 0%; }
		to   { background-position: 0 100%; }
	}
	/* Star-dust overlay — four tiny twinkling specks of mixed gold,
	   silver, and astro-pink, drifting slowly. */
	.origin-seal::after {
		content: "";
		position: absolute;
		inset: 0;
		pointer-events: none;
		background:
			radial-gradient(2px 2px at 18% 22%, rgba(240, 199, 94, 0.55) 0%, transparent 60%),
			radial-gradient(1.5px 1.5px at 72% 36%, rgba(232, 165, 181, 0.5) 0%, transparent 60%),
			radial-gradient(2px 2px at 84% 76%, rgba(200, 210, 225, 0.45) 0%, transparent 60%),
			radial-gradient(1.5px 1.5px at 32% 86%, rgba(240, 199, 94, 0.5) 0%, transparent 60%);
		animation: origin-stardust-drift 11s ease-in-out infinite alternate;
		mix-blend-mode: screen;
	}
	@keyframes origin-stardust-drift {
		from { opacity: 0.55; transform: translateY(0); }
		to   { opacity: 0.95; transform: translateY(-3px); }
	}

	/* Glyph glows — gold for lineage, astro-pink for sun/moon. */
	.origin-glyph,
	.origin-glyph-cjk {
		filter: drop-shadow(0 0 4px rgba(240, 199, 94, 0.25));
		transition: filter 320ms, transform 320ms;
	}
	.origin-glyph-astro {
		filter: drop-shadow(0 0 4px rgba(232, 165, 181, 0.3));
	}

	/* Row interaction: subtle nudge + brighter glow on hover. */
	.origin-row {
		transition: transform 220ms ease-out;
	}
	.origin-row:hover .origin-glyph,
	.origin-row:hover .origin-glyph-cjk {
		filter: drop-shadow(0 0 9px rgba(240, 199, 94, 0.65));
		transform: scale(1.08);
	}
	.origin-row:hover .origin-glyph-astro {
		filter: drop-shadow(0 0 9px rgba(232, 165, 181, 0.7));
		transform: scale(1.08);
	}
	.origin-row .origin-label { transition: color 220ms; }
	.origin-row:hover .origin-label { color: #f5f1e6; }

	/* Column titles get a tiny dashed gold tail under the label. */
	.origin-col-title {
		position: relative;
		padding-bottom: 6px;
	}
	.origin-col-title::after {
		content: "";
		position: absolute;
		left: 0;
		bottom: 0;
		width: 1.4rem;
		height: 1px;
		background-image: linear-gradient(90deg,
			rgba(240, 199, 94, 0.65) 0%,
			transparent 100%);
		mask-image: repeating-linear-gradient(90deg, #000 0, #000 3px, transparent 3px, transparent 6px);
		-webkit-mask-image: repeating-linear-gradient(90deg, #000 0, #000 3px, transparent 3px, transparent 6px);
	}

	/* Caption brightens slightly when the card is hovered. */
	.origin-seal:hover .origin-caption {
		color: rgba(240, 199, 94, 0.7);
	}

	@media (prefers-reduced-motion: reduce) {
		.origin-seal::before,
		.origin-seal::after,
		.origin-row,
		.origin-glyph,
		.origin-glyph-cjk,
		.origin-glyph-astro {
			animation: none !important;
			transition: none !important;
		}
	}

	/* ──────────────────────────────────────────────────────────────
	   Spellwork Chronology — career arc as a vertical gold-filigree
	   spine with runestone nodes. Major milestones get a portrait-style
	   sigil glow; the current "now" node pulses like a snitch.
	   Inspired by the summoning-circle + grimoire motifs on the hero
	   portrait, scaled down into a readable reading-rhythm timeline.
	   ────────────────────────────────────────────────────────────── */
	.chronology {
		position: relative;
		list-style: none;
		padding: 1.5rem 0 2rem;
		margin: 2rem 0 2rem 0.75rem;
		counter-reset: chron;
	}
	/* The gold filigree spine runs top→bottom at the left edge. */
	.chronology::before {
		content: "";
		position: absolute;
		left: 1.1rem;
		top: 0;
		bottom: 0;
		width: 1px;
		background: linear-gradient(
			180deg,
			rgba(240, 199, 94, 0) 0%,
			rgba(240, 199, 94, 0.35) 6%,
