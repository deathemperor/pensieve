	/* Vignette on photo */
	.portrait-vignette {
		position: absolute;
		inset: 8px;
		border-radius: 2px;
		pointer-events: none;
		background:
			radial-gradient(ellipse at 50% 50%, transparent 55%, rgba(0, 0, 0, 0.25) 95%, rgba(0, 0, 0, 0.4) 100%),
			linear-gradient(180deg, rgba(240, 199, 94, 0.08) 0%, transparent 25%);
	}

	/* Diagonal sheen that sweeps periodically */
	.portrait-sheen {
		position: absolute;
		inset: 8px;
		border-radius: 2px;
		pointer-events: none;
		overflow: hidden;
	}

	.portrait-sheen::before {
		content: "";
		position: absolute;
		inset: -50% -80%;
		background: linear-gradient(
			115deg,
			transparent 40%,
			rgba(255, 230, 170, 0.3) 50%,
