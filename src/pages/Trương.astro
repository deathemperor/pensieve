		width: 24px;
		height: 24px;
		color: rgba(255, 230, 160, 0.9);
		filter: drop-shadow(0 0 4px rgba(240, 199, 94, 0.9)) drop-shadow(0 0 10px rgba(240, 199, 94, 0.5));
		animation: rune-pulse 3.5s ease-in-out infinite;
	}

	.rune-tl { top: 10px; left: 10px; }
	.rune-tr { top: 10px; right: 10px; animation-delay: 0.9s; }
	.rune-bl { bottom: 10px; left: 10px; animation-delay: 1.8s; }
	.rune-br { bottom: 10px; right: 10px; animation-delay: 2.7s; }

	@keyframes rune-pulse {
		0%, 100% { opacity: 0.4; transform: scale(0.85) rotate(0deg); }
		50% { opacity: 1; transform: scale(1.15) rotate(10deg); }
	}

	/* Deathly Hallows symbol watermark */
	.portrait-hallows {
		position: absolute;
		top: 100px;
		left: 50%;
		width: 500px;
		height: 500px;
		margin-left: -250px;
		pointer-events: none;
		z-index: 0;
		color: rgba(240, 199, 94, 0.12);
		filter: blur(0.5px);
		animation: hallows-rotate 60s linear infinite;
	}

	@keyframes hallows-rotate {
		to { transform: rotate(360deg); }
	}

	/* Animated aurora background — shifting gold/purple bands */
	.portrait-aurora {
		position: absolute;
		top: -40px;
		left: 50%;
		width: 400px;
		height: 480px;
		margin-left: -200px;
		pointer-events: none;
		z-index: 0;
		border-radius: 50%;
		overflow: hidden;
		opacity: 0.6;
	}

	.aurora-band {
		position: absolute;
		inset: 0;
		mix-blend-mode: screen;
		filter: blur(40px);
	}

	.aurora-band-1 {
		background: linear-gradient(120deg, rgba(240, 199, 94, 0.5) 0%, transparent 40%, rgba(240, 199, 94, 0.4) 60%, transparent 100%);
		animation: aurora-shift-1 14s ease-in-out infinite;
	}

	.aurora-band-2 {
		background: linear-gradient(60deg, transparent 0%, rgba(255, 230, 170, 0.4) 40%, transparent 70%, rgba(180, 140, 60, 0.5) 100%);
		animation: aurora-shift-2 18s ease-in-out infinite;
	}

	.aurora-band-3 {
		background: linear-gradient(90deg, transparent 0%, rgba(240, 199, 94, 0.35) 30%, transparent 60%, rgba(255, 240, 200, 0.3) 90%);
		animation: aurora-shift-3 22s ease-in-out infinite;
	}

	@keyframes aurora-shift-1 {
		0%, 100% { transform: translate(0, 0) rotate(0deg); }
		50% { transform: translate(-20px, 20px) rotate(15deg); }
	}
	@keyframes aurora-shift-2 {
		0%, 100% { transform: translate(0, 0) rotate(0deg); }
		50% { transform: translate(25px, -15px) rotate(-20deg); }
	}
	@keyframes aurora-shift-3 {
		0%, 100% { transform: translate(0, 0) scale(1); }
		50% { transform: translate(-10px, -25px) scale(1.1); }
