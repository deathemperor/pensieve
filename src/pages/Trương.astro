					</svg>
					me@huuloc.com
				</a>
			</div>
		</div>
	</section>

	{ghUser && (
		<section class="about-section">
			<div class="about-inner">
				<h2 class="section-heading">{isVi ? "Hoạt Động GitHub" : "GitHub Activity"}</h2>
				<p class="section-desc">
					{isVi ? "Dữ liệu trực tiếp từ GitHub API." : "Live data from the GitHub API."}
					{isVi ? `Trên GitHub từ ${formatGHDate(ghUser.created_at)}.` : `On GitHub since ${formatGHDate(ghUser.created_at)}.`}
				</p>

				{/* Coding Eras Timeline */}
				<div class="eras-timeline">
					<h3 class="chart-title">{isVi ? "Các thời kỳ lập trình" : "Coding eras"}</h3>
					<div class="eras-track">
						<div class="era" style="--era-color: var(--color-muted);">
							<span class="era-bar" style="flex: 16;" />
							<div class="era-info">
								<span class="era-label">{isVi ? "Tự lực" : "Solo"}</span>
								<span class="era-commits">{isVi ? "1.755 commit" : "1,755 commits"}</span>
								<span class="era-dates">2006 — {isVi ? "Th6 2022" : "Jun 2022"}</span>
								<span class="era-note">{isVi ? "Lập trình thủ công, không AI hỗ trợ" : "Manual coding, no AI assist"}</span>
							</div>
						</div>
						<div class="era" style="--era-color: #7c3aed;">
							<span class="era-bar" style="flex: 3.5;" />
							<div class="era-info">
								<span class="era-label">GitHub Copilot</span>
								<span class="era-commits">{isVi ? "8.106 commit" : "8,106 commits"}</span>
								<span class="era-dates">{isVi ? "Th6 2022 — Th1 2026" : "Jun 2022 — Jan 2026"}</span>
								<span class="era-note">{isVi ? "Lập trình có AI hỗ trợ (bản xem trước công khai)" : "AI-assisted coding (public preview)"}</span>
							</div>
						</div>
						<div class="era era-current" style="--era-color: #e8784d;">
							<span class="era-bar" style="flex: 0.5;" />
							<div class="era-info">
								<span class="era-label">Claude Code</span>
								<span class="era-commits">232 commit{isVi ? "" : "s"}</span>
								<span class="era-dates">{isVi ? "29 Th1, 2026 — nay" : "Jan 29, 2026 — now"}</span>
								<span class="era-note">{isVi ? "Không có mã người viết — hoàn toàn do AI tạo" : "Zero human code — fully AI-generated"}</span>
							</div>
						</div>
					</div>
				</div>

				<div class="gh-stats">
					<div class="gh-stat">
						<span class="gh-stat-value">{ghUser.public_repos + (ghUser.owned_private_repos ?? 0)}</span>
						<span class="gh-stat-label">{isVi ? "kho mã" : "repos"}</span>
					</div>
					<div class="gh-stat">
						<span class="gh-stat-value">{recentCommitCount}</span>
						<span class="gh-stat-label">{isVi ? "commit 30 ngày" : "commits (30d)"}</span>
					</div>
					<div class="gh-stat">
						<span class="gh-stat-value">{ghUser.followers}</span>
						<span class="gh-stat-label">{isVi ? "người theo dõi" : "followers"}</span>
					</div>
				</div>

				{/* Day-of-week activity chart */}
				<div class="activity-chart">
					<h3 class="chart-title">{isVi ? "Hoạt động theo ngày" : "Activity by day"}</h3>
					<div class="chart-bars">
						{dayNames.map((name, i) => (
							<div class="chart-col">
								<div class="chart-bar-wrap">
									<div
										class="chart-bar"
										style={`height: ${(dayActivity[i] / maxDayActivity) * 100}%;`}
									/>
								</div>
								<span class="chart-label">{name}</span>
							</div>
						))}
					</div>
				</div>

				{/* Recent repos */}
				{ghRepos.filter((r) => !r.private).length > 0 && (
					<div class="repos-section">
						<h3 class="chart-title">{isVi ? "Kho mã gần đây" : "Recent repositories"}</h3>
						<div class="repos-grid">
							{ghRepos.filter((r) => !r.private).slice(0, 6).map((repo) => (
								<a href={repo.html_url} class="repo-card" target="_blank" rel="noopener">
									<span class="repo-name">{repo.name}</span>
									{repo.description && (
										<span class="repo-desc">{repo.description}</span>
									)}
									<span class="repo-meta">
										{repo.language && (
											<span class="repo-lang">
												<span
													class="repo-lang-dot"
													style={`background: ${langColors[repo.language] ?? "var(--color-muted)"};`}
												/>
												{repo.language}
											</span>
										)}
										{repo.stargazers_count > 0 && (
											<span class="repo-stars">
												&#9733; {repo.stargazers_count}
											</span>
										)}
									</span>
								</a>
							))}
						</div>
					</div>
				)}

				{/* Activity feed */}
				{activityFeed.length > 0 && (
					<div class="feed-section">
						<h3 class="chart-title">{isVi ? "Hoạt động gần đây" : "Recent activity"}</h3>
						<div class="feed-list">
							{activityFeed.map((item) => (
								<div class="feed-item">
									<span class="feed-dot" />
									<span class="feed-action">{item.action}</span>
									<span class="feed-time">{item.timeAgo}</span>
								</div>
							))}
						</div>
					</div>
				)}
			</div>
		</section>
	)}
</Base>

<style>
	/* Hero */
	.about-hero {
		border-bottom: 1px solid var(--color-border);
	}

	.about-hero-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-24) var(--spacing-8) var(--spacing-16);
		display: grid;
		grid-template-columns: 1fr minmax(280px, 360px);
		gap: var(--spacing-12);
		align-items: center;
	}

	.about-hero-text {
		min-width: 0;
	}

	.about-hero-photo {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-5);
		margin: 0;
		padding: 0;
	}

	/* Stage — contains atmospheric effects outside the frame */
	.portrait-stage {
		position: relative;
		width: 100%;
		max-width: 340px;
		aspect-ratio: 4 / 5;
		/* Generous padding so rays/embers can extend well beyond the frame */
		padding: 40px;
		margin: -40px;
		overflow: visible;
	}

	/* Radial light rays — thicker, brighter, more visible */
	.portrait-rays {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		animation: rays-rotate 40s linear infinite;
	}

	.portrait-rays span {
		position: absolute;
		left: 50%;
		top: 50%;
		width: 4px;
		height: 110%;
		margin-left: -2px;
		margin-top: -55%;
		transform-origin: 50% 50%;
		transform: rotate(var(--ray-angle));
		background: linear-gradient(
			to top,
			transparent 0%,
			rgba(240, 199, 94, 0.15) 30%,
			rgba(255, 220, 150, 0.75) 50%,
			rgba(240, 199, 94, 0.15) 70%,
			transparent 100%
		);
		filter: blur(4px);
		opacity: 0;
		mix-blend-mode: screen;
		animation: ray-breathe 6s ease-in-out infinite;
		animation-delay: var(--ray-delay);
	}

	@keyframes ray-breathe {
		0%, 75%, 100% { opacity: 0; }
		15%, 50% { opacity: 1; }
	}

	@keyframes rays-rotate {
		to { transform: rotate(360deg); }
	}

	/* Expanding ripples — golden waves emanating outward, brighter */
	.portrait-ripples {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}

	.portrait-ripples span {
		position: absolute;
		left: 50%;
		top: 50%;
		width: 80%;
		height: 80%;
		transform: translate(-50%, -50%) scale(0);
		border: 2px solid rgba(240, 199, 94, 0.7);
		border-radius: 50%;
		opacity: 0;
		box-shadow:
			0 0 24px rgba(240, 199, 94, 0.3),
			inset 0 0 24px rgba(240, 199, 94, 0.2);
		animation: ripple-expand 6s ease-out infinite;
		animation-delay: var(--ripple-delay);
	}

	@keyframes ripple-expand {
		0% { transform: translate(-50%, -50%) scale(0.3); opacity: 0; border-width: 3px; }
		10% { opacity: 1; }
		100% { transform: translate(-50%, -50%) scale(1.8); opacity: 0; border-width: 0.5px; }
	}

	/* Embers — larger, brighter, more visible floating gold particles */
	.portrait-embers {
		position: absolute;
		inset: -10%;
		pointer-events: none;
		z-index: 1;
		overflow: visible;
	}

	.portrait-embers span {
		position: absolute;
		bottom: 5%;
		left: var(--ex);
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: rgba(255, 230, 160, 1);
		box-shadow:
			0 0 4px rgba(255, 230, 160, 1),
			0 0 10px rgba(240, 199, 94, 0.9),
			0 0 20px rgba(240, 199, 94, 0.6),
			0 0 30px rgba(240, 199, 94, 0.3);
		opacity: 0;
		animation: ember-rise 8s ease-in-out infinite;
		animation-delay: var(--ed);
	}

	@keyframes ember-rise {
		0% { opacity: 0; transform: translate(0, 0) scale(0.2); }
		8% { opacity: 1; transform: translate(calc(var(--edx) * 0.15), calc(var(--eh) * -0.1)) scale(1.2); }
		40% { opacity: 1; transform: translate(calc(var(--edx) * 0.55), calc(var(--eh) * -0.5)) scale(1); }
		75% { opacity: 0.5; transform: translate(calc(var(--edx) * 0.85), calc(var(--eh) * -0.85)) scale(0.7); }
		100% { opacity: 0; transform: translate(var(--edx), calc(var(--eh) * -1.1)) scale(0.3); }
	}

	/* Main portrait frame — anchored inside the stage (accounts for stage padding) */
	.portrait-frame {
		position: absolute;
		inset: 40px;
		padding: 14px;
		color: #f0c75e;
		border-radius: 3px;
		background:
			linear-gradient(
				135deg,
				rgba(255, 230, 170, 0.4) 0%,
				rgba(180, 140, 60, 0.1) 30%,
				rgba(240, 199, 94, 0.2) 50%,
				rgba(180, 140, 60, 0.1) 70%,
				rgba(255, 230, 170, 0.4) 100%
			);
		box-shadow:
			inset 0 0 0 1px rgba(255, 230, 170, 0.6),
			inset 0 0 0 9px rgba(10, 10, 12, 0.6),
			inset 0 0 0 10px rgba(240, 199, 94, 0.4),
			inset 0 2px 0 rgba(255, 240, 200, 0.5),
			0 0 0 1px rgba(240, 199, 94, 0.3),
			0 40px 100px -20px rgba(0, 0, 0, 0.7),
			0 0 140px -20px rgba(240, 199, 94, 0.55);
		z-index: 2;
	}

	/* Pulsing halo aura — much larger and brighter */
	.portrait-aura {
		position: absolute;
		inset: -60px;
		border-radius: inherit;
		background: radial-gradient(
			ellipse at 50% 45%,
			rgba(240, 199, 94, 0.5) 0%,
			rgba(240, 199, 94, 0.22) 30%,
			rgba(240, 199, 94, 0.08) 55%,
			transparent 75%
		);
		filter: blur(32px);
		opacity: 0.9;
		z-index: -1;
		animation: portrait-pulse 4s ease-in-out infinite;
	}

	@keyframes portrait-pulse {
		0%, 100% { opacity: 0.7; transform: scale(1); }
		50% { opacity: 1; transform: scale(1.1); }
	}

	/* Diagonal sheen sweeping across the frame */
	.portrait-sheen {
		position: absolute;
		inset: 16px;
		border-radius: 2px;
		overflow: hidden;
		pointer-events: none;
		z-index: 4;
		opacity: 0.7;
	}

	.portrait-sheen::before {
		content: "";
		position: absolute;
		inset: -40% -80%;
		background: linear-gradient(
			115deg,
			transparent 35%,
			rgba(255, 230, 170, 0.18) 47%,
			rgba(255, 245, 210, 0.4) 50%,
			rgba(255, 230, 170, 0.18) 53%,
			transparent 65%
		);
		animation: portrait-sheen-sweep 9s ease-in-out infinite;
		animation-delay: 2s;
	}

	@keyframes portrait-sheen-sweep {
		0%, 10% { transform: translateX(-80%); opacity: 0; }
		20%, 35% { opacity: 1; }
		60%, 100% { transform: translateX(80%); opacity: 0; }
	}

	/* Inner image wrap with pensieve-like glow */
	.portrait-image-wrap {
		position: relative;
		width: 100%;
		height: 100%;
		border-radius: 2px;
		overflow: hidden;
		background: #0a0a0c;
		box-shadow:
			inset 0 0 0 1px rgba(0, 0, 0, 0.7),
			inset 0 0 40px rgba(0, 0, 0, 0.5);
	}

	.profile-photo {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		filter: contrast(1.06) brightness(1.02) saturate(1.05);
		transition:
			filter 700ms ease,
			transform 900ms cubic-bezier(0.2, 0.8, 0.2, 1);
	}

	.about-hero-photo:hover .profile-photo {
		filter: contrast(1.1) brightness(1.08) saturate(1.15);
		transform: scale(1.04);
	}

	/* Subtle vignette — just darkens far corners, lets photo breathe */
	.portrait-vignette {
		position: absolute;
		inset: 0;
		pointer-events: none;
		background:
			radial-gradient(
				ellipse at 50% 50%,
				transparent 55%,
				rgba(0, 0, 0, 0.2) 90%,
				rgba(0, 0, 0, 0.35) 100%
			),
			linear-gradient(
				180deg,
				rgba(240, 199, 94, 0.08) 0%,
				transparent 20%,
				transparent 80%,
				rgba(0, 0, 0, 0.12) 100%
			);
	}

	/* Ornate SVG corner filigrees — larger, brighter */
	.portrait-corner {
		position: absolute;
		width: 36px;
		height: 36px;
		color: rgba(255, 230, 160, 1);
		filter:
			drop-shadow(0 0 6px rgba(240, 199, 94, 0.8))
			drop-shadow(0 0 14px rgba(240, 199, 94, 0.5));
		z-index: 5;
		animation: corner-glow 3.5s ease-in-out infinite;
	}

	.portrait-corner circle { filter: drop-shadow(0 0 4px rgba(255, 230, 160, 1)); }
	.portrait-corner-tl { top: 2px; left: 2px; }
	.portrait-corner-tr { top: 2px; right: 2px; animation-delay: 0.9s; }
	.portrait-corner-bl { bottom: 2px; left: 2px; animation-delay: 1.8s; }
	.portrait-corner-br { bottom: 2px; right: 2px; animation-delay: 2.7s; }

	@keyframes corner-glow {
		0%, 100% { filter: drop-shadow(0 0 4px rgba(240, 199, 94, 0.5)) drop-shadow(0 0 8px rgba(240, 199, 94, 0.3)); }
		50% { filter: drop-shadow(0 0 12px rgba(240, 199, 94, 1)) drop-shadow(0 0 20px rgba(240, 199, 94, 0.6)); }
	}

	/* Bottom plaque - decorative engraving below image */
	.portrait-plaque {
		position: absolute;
		bottom: -22px;
		left: 50%;
		transform: translateX(-50%);
		width: 70%;
		height: 24px;
		color: rgba(255, 220, 140, 0.95);
		filter:
			drop-shadow(0 3px 8px rgba(0, 0, 0, 0.7))
			drop-shadow(0 0 8px rgba(240, 199, 94, 0.7));
		z-index: 6;
	}

	/* Caption */
	.photo-caption {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-2);
		margin-top: var(--spacing-3);
