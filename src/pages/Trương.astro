		animation: crystal-shimmer 10s ease-in-out infinite;
	}

	@keyframes crystal-shimmer {
		0%, 100% { opacity: 0.5; transform: scale(1) rotate(0deg); }
		50% { opacity: 0.9; transform: scale(1.02) rotate(1deg); }
	}

	/* Phoenix feathers drifting slowly */
	.portrait-feathers {
		position: absolute;
		inset: -60px;
		pointer-events: none;
		z-index: 5;
		overflow: visible;
