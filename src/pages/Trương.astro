	/* Holographic rainbow shimmer overlay */
	.portrait-holo {
		position: absolute;
		top: 14px;
		left: 14px;
		right: 14px;
		bottom: 14px;
		pointer-events: none;
		z-index: 5;
		border-radius: 2px;
		background: linear-gradient(
			135deg,
			rgba(255, 0, 150, 0.08) 0%,
			rgba(255, 200, 0, 0.12) 20%,
			rgba(0, 255, 200, 0.08) 40%,
			rgba(100, 100, 255, 0.08) 60%,
			rgba(255, 100, 200, 0.08) 80%,
			rgba(255, 200, 100, 0.1) 100%
		);
		background-size: 400% 400%;
		mix-blend-mode: overlay;
		animation: holo-shift 15s ease-in-out infinite;
	}

	@keyframes holo-shift {
		0%, 100% { background-position: 0% 0%; filter: hue-rotate(0deg); }
		50% { background-position: 100% 100%; filter: hue-rotate(30deg); }
