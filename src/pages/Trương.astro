								<path d="M-3 -3 L3 3 M-3 3 L3 -3" stroke-width="1.2" />
							</g>
						))}
					</g>
				</svg>

				{/* Lightning branch network — forked lightning that splits */}
				<svg class="portrait-lightning-fork" viewBox="0 0 300 400" preserveAspectRatio="none" aria-hidden="true">
					<defs>
						<linearGradient id="forkGrad" x1="50%" y1="0%" x2="50%" y2="100%">
							<stop offset="0%" stop-color="#fff" />
							<stop offset="50%" stop-color="#ffe6a8" />
							<stop offset="100%" stop-color="#f0c75e" stop-opacity="0" />
						</linearGradient>
					</defs>
					<g class="fork-group" stroke="url(#forkGrad)" stroke-width="1.8" stroke-linecap="round" fill="none" filter="drop-shadow(0 0 6px rgba(240,199,94,0.9)) drop-shadow(0 0 14px rgba(240,199,94,0.5))">
						<path class="fork-main" d="M150 0 L145 50 L155 90 L140 130 L160 170 L145 220 L155 280 L148 340 L152 400" />
						<path class="fork-branch-1" d="M155 90 L180 110 L195 125 L215 150" />
						<path class="fork-branch-2" d="M140 130 L115 155 L95 180 L80 200" />
						<path class="fork-branch-3" d="M155 280 L180 305 L205 320 L230 340" />
					</g>
				</svg>

