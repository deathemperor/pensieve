	.soundwave {
		position: absolute;
		left: 0;
		top: 0;
		width: 280px;
		height: 280px;
		margin: -140px 0 0 -140px;
		border-radius: 50%;
		border: 2px solid rgba(240, 199, 94, 0.6);
		box-shadow: 0 0 20px rgba(240, 199, 94, 0.4), inset 0 0 16px rgba(240, 199, 94, 0.2);
		transform: scale(0.3);
