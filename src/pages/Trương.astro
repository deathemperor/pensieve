	/* Flowing ribbon weaving around */
	.portrait-ribbon {
		position: absolute;
		top: -50px;
		left: 50%;
		width: 400px;
		height: 500px;
		margin-left: -200px;
		pointer-events: none;
		z-index: 3;
		filter: drop-shadow(0 0 4px rgba(240, 199, 94, 0.7));
	}

	.ribbon-path {
