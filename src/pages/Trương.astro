								<text x="20" y="25" text-anchor="middle" font-size="14" fill="#6a4e20" font-family="serif" font-weight="bold">T</text>
							</svg>
						</div>
						<div class="coin-face coin-back">
							<svg viewBox="0 0 40 40" aria-hidden="true">
								<circle cx="20" cy="20" r="18" fill="url(#snitchGrad)" stroke="#b48c3c" stroke-width="1" />
								<polygon points="20,8 24,17 33,17 26,23 29,32 20,27 11,32 14,23 7,17 16,17" fill="#b48c3c" />
							</svg>
						</div>
					</div>
				</div>

