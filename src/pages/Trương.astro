						{dayNames.map((name, i) => (
							<div class="chart-col">
								<div class="chart-bar-wrap">
									<div
										class="chart-bar"
										style={`height: ${(dayActivity[i] / maxDayActivity) * 100}%;`}
									/>
								</div>
								<span class="chart-label">{name}</span>
							</div>
						))}
					</div>
				</div>

				{/* Recent repos */}
				{ghRepos.filter((r) => !r.private).length > 0 && (
					<div class="repos-section">
						<h3 class="chart-title">{isVi ? "Kho mã gần đây" : "Recent repositories"}</h3>
						<div class="repos-grid">
							{ghRepos.filter((r) => !r.private).slice(0, 6).map((repo) => (
								<a href={repo.html_url} class="repo-card" target="_blank" rel="noopener">
									<span class="repo-name">{repo.name}</span>
									{repo.description && (
										<span class="repo-desc">{repo.description}</span>
									)}
									<span class="repo-meta">
										{repo.language && (
											<span class="repo-lang">
												<span
													class="repo-lang-dot"
													style={`background: ${langColors[repo.language] ?? "var(--color-muted)"};`}
												/>
												{repo.language}
											</span>
										)}
										{repo.stargazers_count > 0 && (
											<span class="repo-stars">
												&#9733; {repo.stargazers_count}
											</span>
										)}
									</span>
								</a>
							))}
						</div>
					</div>
				)}

				{/* Activity feed */}
				{activityFeed.length > 0 && (
					<div class="feed-section">
						<h3 class="chart-title">{isVi ? "Hoạt động gần đây" : "Recent activity"}</h3>
						<div class="feed-list">
							{activityFeed.map((item) => (
								<div class="feed-item">
									<span class="feed-dot" />
									<span class="feed-action">{item.action}</span>
									<span class="feed-time">{item.timeAgo}</span>
								</div>
							))}
						</div>
					</div>
				)}
			</div>
		</section>
	)}
</Base>

<style>
	/* Hero */
	.about-hero {
		border-bottom: 1px solid var(--color-border);
	}

	.about-hero-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-24) var(--spacing-8) var(--spacing-16);
		display: grid;
		grid-template-columns: minmax(0, 1fr) 280px;
		gap: var(--spacing-12);
		align-items: center;
	}

	.about-hero-text {
		min-width: 0;
	}

	.about-hero-photo {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-5);
		margin: 0;
		padding: 0;
		width: 280px;
	}

	/* Dreamcatcher/spider web */
	.portrait-web {
		position: absolute;
		top: 175px;
		left: 50%;
		width: 340px;
		height: 340px;
		margin-left: -170px;
		margin-top: -170px;
		pointer-events: none;
		z-index: 1;
		color: rgba(240, 199, 94, 0.12);
		filter: drop-shadow(0 0 2px rgba(240, 199, 94, 0.3));
		animation: web-shimmer 6s ease-in-out infinite;
	}

	@keyframes web-shimmer {
		0%, 100% { opacity: 0.5; }
		50% { opacity: 1; }
	}

	/* Chromatic aberration ghost lines */
	.portrait-chromatic {
		position: absolute;
		top: 14px;
		left: 14px;
		right: 14px;
		bottom: 14px;
		pointer-events: none;
		z-index: 4;
		overflow: hidden;
	}

	.chromatic-r, .chromatic-b {
		position: absolute;
		inset: 0;
		border: 1px solid transparent;
		animation: chromatic-shift 3s ease-in-out infinite;
	}

	.chromatic-r {
		box-shadow: inset 2px 0 0 rgba(255, 50, 50, 0.15);
	}

	.chromatic-b {
		box-shadow: inset -2px 0 0 rgba(50, 100, 255, 0.15);
		animation-delay: 1.5s;
	}

	@keyframes chromatic-shift {
		0%, 100% { transform: translateX(0); }
		50% { transform: translateX(1px); }
	}

	/* Ocean wave silhouette at bottom */
	.portrait-waves {
		position: absolute;
		bottom: -50px;
		left: 0;
		right: 0;
		height: 60px;
		pointer-events: none;
		z-index: 2;
		filter: drop-shadow(0 -2px 4px rgba(240, 199, 94, 0.5));
	}

	.wave-path {
		animation: wave-rise 6s ease-in-out infinite;
	}

	.wave-2 { animation-delay: 1.5s; }

	@keyframes wave-rise {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-6px); }
	}

	/* Frost crystals forming at corners */
	.portrait-frost {
		position: absolute;
		width: 44px;
		height: 44px;
		pointer-events: none;
		z-index: 5;
		filter: drop-shadow(0 0 3px rgba(200, 220, 255, 0.9));
		opacity: 0;
		animation: frost-form 9s ease-in-out infinite;
	}

	.portrait-frost-tl { top: -10px; left: -10px; }
	.portrait-frost-br { bottom: -10px; right: -10px; animation-delay: 4.5s; }

	@keyframes frost-form {
		0%, 10% { opacity: 0; transform: scale(0.3) rotate(0deg); }
		20% { opacity: 0.9; transform: scale(1) rotate(30deg); }
		60% { opacity: 0.9; transform: scale(1) rotate(30deg); }
		80%, 100% { opacity: 0; transform: scale(1.3) rotate(60deg); }
	}

	/* Diffraction rainbow sweep */
	.portrait-diffraction {
		position: absolute;
		top: 14px;
		left: 14px;
		right: 14px;
		bottom: 14px;
		pointer-events: none;
		z-index: 5;
		background: linear-gradient(
			105deg,
			transparent 40%,
			rgba(255, 0, 120, 0.12) 45%,
			rgba(255, 180, 0, 0.12) 48%,
			rgba(0, 255, 180, 0.12) 51%,
			rgba(100, 100, 255, 0.12) 54%,
			rgba(255, 100, 200, 0.12) 57%,
			transparent 62%
		);
		background-size: 300% 100%;
