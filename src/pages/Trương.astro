	.stars-mid span {
		position: absolute;
		left: var(--sx);
		top: var(--sy);
		width: 2px;
		height: 2px;
		border-radius: 50%;
		background: rgba(240, 199, 94, 0.95);
		box-shadow: 0 0 3px rgba(240, 199, 94, 0.7);
		animation: star-bg-twinkle 3s ease-in-out infinite;
		animation-delay: var(--sd);
