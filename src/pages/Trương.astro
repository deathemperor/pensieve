		89% { opacity: 1; stroke-dashoffset: 0; }
		92% { opacity: 1; }
		93% { opacity: 0.3; }
		94% { opacity: 1; }
		97% { opacity: 0.2; }
		100% { opacity: 0; stroke-dashoffset: 0; }
