	.mercury-3 { bottom: 15%; left: 45%; animation-delay: 5s; }

	@keyframes mercury-morph {
		0%, 100% { border-radius: 50%; transform: translate(0, 0) scale(1); }
		33% { border-radius: 40% 60% 55% 45% / 50% 45% 55% 50%; transform: translate(5px, -5px) scale(1.1); }
		66% { border-radius: 55% 45% 40% 60% / 45% 55% 50% 50%; transform: translate(-3px, 6px) scale(0.9); }
	}

	/* Zodiac wheel in deep background */
	.portrait-zodiac {
		position: absolute;
