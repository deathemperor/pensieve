	.constellation-line {
		stroke: rgba(240, 199, 94, 0.5);
		stroke-width: 0.8;
		stroke-dasharray: 400;
		stroke-dashoffset: 400;
		filter: drop-shadow(0 0 3px rgba(240, 199, 94, 0.7));
		animation: constellation-draw 14s ease-in-out infinite;
	}

	.c-line-1 { animation-delay: 0s; }
	.c-line-2 { animation-delay: 1s; }
	.c-line-3 { animation-delay: 2s; }
	.c-line-4 { animation-delay: 3s; }
	.c-line-5 { animation-delay: 4.5s; }
	.c-line-6 { animation-delay: 6s; }

	@keyframes constellation-draw {
		0%, 5% { stroke-dashoffset: 400; opacity: 0; }
		15% { stroke-dashoffset: 0; opacity: 0.8; }
		40% { opacity: 0.6; }
		60% { stroke-dashoffset: -400; opacity: 0; }
		100% { stroke-dashoffset: -400; opacity: 0; }
	}

	/* Magical runes at corners */
	.portrait-runes {
		position: absolute;
		top: 175px;
		left: 50%;
		width: 360px;
		height: 430px;
		margin-left: -180px;
		margin-top: -215px;
		pointer-events: none;
