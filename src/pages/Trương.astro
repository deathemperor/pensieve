	@keyframes flame-flicker {
		0% { opacity: 0; transform: translateY(0) scale(0.6) rotate(-3deg); }
		20% { opacity: 1; transform: translateY(-20px) scale(1.2) rotate(4deg); }
		60% { opacity: 0.8; transform: translateY(-60px) scale(0.9) rotate(-5deg); }
		100% { opacity: 0; transform: translateY(-120px) scale(0.3) rotate(6deg); }
	}

	/* Mirror reflection pool below portrait */
	.portrait-pool {
		position: absolute;
		bottom: -140px;
		left: 50%;
		width: 280px;
		height: 120px;
		margin-left: -140px;
		pointer-events: none;
		z-index: 1;
		overflow: hidden;
		mask-image: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, transparent 100%);
		-webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, transparent 100%);
	}

	.pool-reflection {
		position: absolute;
		inset: 0;
		background: linear-gradient(
