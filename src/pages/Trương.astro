		stroke-dashoffset: 2400;
		animation: ribbon-flow 20s linear infinite;
	}

	@keyframes ribbon-flow {
		0% { stroke-dashoffset: 2400; }
		100% { stroke-dashoffset: -2400; }
	}

	/* Gold liquid drips from top edge of frame */
	.portrait-drips {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 140px;
		pointer-events: none;
		z-index: 5;
		overflow: hidden;
	}

	.drip {
		position: absolute;
		top: 0;
		left: var(--drx);
		width: 3px;
		height: var(--drh);
		background: linear-gradient(
			to bottom,
			transparent 0%,
			rgba(255, 240, 200, 0.5) 20%,
			rgba(240, 199, 94, 0.9) 60%,
			rgba(240, 199, 94, 1) 100%
		);
		border-radius: 0 0 50% 50%;
		filter: blur(0.5px) drop-shadow(0 0 4px rgba(240, 199, 94, 0.7));
		transform-origin: 0 0;
		transform: scaleY(0);
		animation: drip-fall 7s ease-in infinite;
		animation-delay: var(--drd);
	}

	.drip::after {
		content: "";
		position: absolute;
		left: -3px;
		bottom: -4px;
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: radial-gradient(circle at 30% 30%, #fff0c2, #f0c75e);
		box-shadow: 0 0 6px rgba(240, 199, 94, 0.8);
	}

	@keyframes drip-fall {
		0% { transform: scaleY(0); opacity: 1; }
		30% { transform: scaleY(1); opacity: 1; }
		70% { transform: scaleY(1) translateY(0); opacity: 1; }
		100% { transform: scaleY(1) translateY(80px); opacity: 0; }
	}

	/* Soundwave pulsing rings */
	.portrait-soundwaves {
		position: absolute;
		top: 175px;
		left: 50%;
		width: 0;
		height: 0;
		pointer-events: none;
		z-index: 1;
