		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
	}

	.photo-caption-dot {
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: rgba(240, 199, 94, 0.9);
		box-shadow:
			0 0 8px rgba(240, 199, 94, 0.8),
			0 0 16px rgba(240, 199, 94, 0.4);
		animation: caption-blink 2.5s ease-in-out infinite;
	}

	@keyframes caption-blink {
		0%, 100% { opacity: 0.4; transform: scale(1); }
		50% { opacity: 1; transform: scale(1.3); }
	}

	/* Continuously drawing gold trace around the frame border (Door Trace spell) */
	.portrait-trace {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: 5;
		overflow: visible;
		filter: drop-shadow(0 0 6px rgba(240, 199, 94, 0.8)) drop-shadow(0 0 14px rgba(240, 199, 94, 0.4));
	}

	.trace-path {
		animation: trace-draw 6s ease-in-out infinite;
	}

	@keyframes trace-draw {
		0% { stroke-dashoffset: 1248; opacity: 0; }
		10% { opacity: 1; }
		50% { stroke-dashoffset: 0; opacity: 1; }
		90% { stroke-dashoffset: -1248; opacity: 0.6; }
		100% { stroke-dashoffset: -1248; opacity: 0; }
	}

	/* Twinkling stars at each corner */
	.portrait-star {
		position: absolute;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: #fff0c2;
		box-shadow:
			0 0 4px #fff0c2,
			0 0 12px rgba(240, 199, 94, 1),
			0 0 24px rgba(240, 199, 94, 0.7),
			0 0 40px rgba(240, 199, 94, 0.4);
		z-index: 6;
		pointer-events: none;
	}

	.portrait-star::before {
		content: "";
		position: absolute;
		inset: -50%;
		background: radial-gradient(circle, rgba(255, 255, 255, 0.8) 0%, transparent 60%);
		filter: blur(2px);
	}

	.portrait-star-tl { top: -4px; left: -4px; animation: star-twinkle 2.4s ease-in-out infinite; }
	.portrait-star-tr { top: -4px; right: -4px; animation: star-twinkle 2.4s ease-in-out 0.6s infinite; }
	.portrait-star-bl { bottom: -4px; left: -4px; animation: star-twinkle 2.4s ease-in-out 1.2s infinite; }
	.portrait-star-br { bottom: -4px; right: -4px; animation: star-twinkle 2.4s ease-in-out 1.8s infinite; }

	@keyframes star-twinkle {
		0%, 100% { opacity: 0.4; transform: scale(0.8); }
		50% { opacity: 1; transform: scale(1.4); }
