							<span class="rune-letter" style={`--rl-angle: ${i * (360 / 24)}deg;`}>{r}</span>
						))}
					</div>
				</div>

				{/* Growing vines that creep around the frame */}
				<svg class="portrait-vines" viewBox="0 0 300 370" preserveAspectRatio="none" aria-hidden="true">
					<g stroke="url(#flourishGrad)" stroke-width="1.5" fill="none" stroke-linecap="round">
						<path class="vine vine-1" d="M10 350 Q30 300 20 250 Q10 200 30 150 Q50 100 40 60 Q30 30 50 10" />
						<path class="vine vine-2" d="M290 10 Q270 50 280 100 Q290 150 270 200 Q250 250 260 300 Q270 340 250 360" />
						<path class="vine-leaf vine-leaf-1" d="M25 200 Q15 195 20 190 Q30 185 30 195 Q32 210 25 200 Z" fill="url(#flourishGrad)" />
						<path class="vine-leaf vine-leaf-2" d="M275 170 Q285 165 280 160 Q270 155 270 165 Q268 180 275 170 Z" fill="url(#flourishGrad)" />
					</g>
