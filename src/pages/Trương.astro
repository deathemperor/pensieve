				<p class="section-desc">
					{isVi ? "Dữ liệu trực tiếp từ GitHub API." : "Live data from the GitHub API."}
					{isVi ? `Trên GitHub từ ${formatGHDate(ghUser.created_at)}.` : `On GitHub since ${formatGHDate(ghUser.created_at)}.`}
				</p>

				{/* Coding Eras Timeline */}
				<div class="eras-timeline">
					<h3 class="chart-title">{isVi ? "Các thời kỳ lập trình" : "Coding eras"}</h3>
					<div class="eras-track">
						<div class="era" style="--era-color: var(--color-muted);">
							<span class="era-bar" style="flex: 16;" />
							<div class="era-info">
								<span class="era-label">{isVi ? "Tự lực" : "Solo"}</span>
								<span class="era-commits">{isVi ? "1.755 commit" : "1,755 commits"}</span>
								<span class="era-dates">2006 — {isVi ? "Th6 2022" : "Jun 2022"}</span>
								<span class="era-note">{isVi ? "Lập trình thủ công, không AI hỗ trợ" : "Manual coding, no AI assist"}</span>
							</div>
						</div>
						<div class="era" style="--era-color: #7c3aed;">
							<span class="era-bar" style="flex: 3.5;" />
							<div class="era-info">
								<span class="era-label">GitHub Copilot</span>
								<span class="era-commits">{isVi ? "8.106 commit" : "8,106 commits"}</span>
								<span class="era-dates">{isVi ? "Th6 2022 — Th1 2026" : "Jun 2022 — Jan 2026"}</span>
								<span class="era-note">{isVi ? "Lập trình có AI hỗ trợ (bản xem trước công khai)" : "AI-assisted coding (public preview)"}</span>
							</div>
						</div>
						<div class="era era-current" style="--era-color: #e8784d;">
							<span class="era-bar" style="flex: 0.5;" />
							<div class="era-info">
								<span class="era-label">Claude Code</span>
								<span class="era-commits">{isVi ? `${claudeEraCommitCount.toLocaleString("vi-VN")} commit` : `${claudeEraCommitCount.toLocaleString("en-US")} commit${claudeEraCommitCount !== 1 ? "s" : ""}`}</span>
								<span class="era-dates">{isVi ? "29 Th1, 2026 — nay" : "Jan 29, 2026 — now"}</span>
								<span class="era-note">{isVi ? "Không có mã người viết — hoàn toàn do AI tạo" : "Zero human code — fully AI-generated"}</span>
							</div>
						</div>
					</div>
				</div>

				<div class="gh-stats">
					<div class="gh-stat">
						<span class="gh-stat-value">{ghUser.public_repos + (ghUser.owned_private_repos ?? 0)}</span>
						<span class="gh-stat-label">{isVi ? "kho mã" : "repos"}</span>
					</div>
					<div class="gh-stat">
						<span class="gh-stat-value">{recentCommitCount}</span>
						<span class="gh-stat-label">{isVi ? "commit 30 ngày" : "commits (30d)"}</span>
					</div>
					<div class="gh-stat">
						<span class="gh-stat-value">{ghUser.followers}</span>
						<span class="gh-stat-label">{isVi ? "người theo dõi" : "followers"}</span>
					</div>
				</div>

				{/* Day-of-week activity chart */}
				<div class="activity-chart">
					<h3 class="chart-title">{isVi ? "Hoạt động theo ngày" : "Activity by day"}</h3>
					<div class="chart-bars">
						{dayNames.map((name, i) => (
							<div class="chart-col">
								<div class="chart-bar-wrap">
									<div
										class="chart-bar"
										style={`height: ${(dayActivity[i] / maxDayActivity) * 100}%;`}
									/>
								</div>
								<span class="chart-label">{name}</span>
							</div>
						))}
					</div>
				</div>

				{/* Recent repos */}
				{ghRepos.filter((r) => !r.private).length > 0 && (
					<div class="repos-section">
						<h3 class="chart-title">{isVi ? "Kho mã gần đây" : "Recent repositories"}</h3>
						<div class="repos-grid">
							{ghRepos.filter((r) => !r.private).slice(0, 6).map((repo) => (
								<a href={repo.html_url} class="repo-card" target="_blank" rel="noopener">
									<span class="repo-name">{repo.name}</span>
									{repo.description && (
										<span class="repo-desc">{repo.description}</span>
									)}
									<span class="repo-meta">
										{repo.language && (
											<span class="repo-lang">
												<span
													class="repo-lang-dot"
													style={`background: ${langColors[repo.language] ?? "var(--color-muted)"};`}
												/>
												{repo.language}
											</span>
										)}
										{repo.stargazers_count > 0 && (
											<span class="repo-stars">
												&#9733; {repo.stargazers_count}
											</span>
										)}
									</span>
								</a>
							))}
						</div>
					</div>
				)}

				{/* Activity feed */}
				{activityFeed.length > 0 && (
					<div class="feed-section">
						<h3 class="chart-title">{isVi ? "Hoạt động gần đây" : "Recent activity"}</h3>
						<div class="feed-list">
							{activityFeed.map((item) => (
								<div class="feed-item">
									<span class="feed-dot" />
									<span class="feed-action">{item.action}</span>
									<span class="feed-time">{item.timeAgo}</span>
								</div>
							))}
						</div>
					</div>
				)}
			</div>
		</section>
	)}
</Base>

<style>
	/* Hero */
	.about-hero {
		border-bottom: 1px solid var(--color-border);
	}

	.about-hero-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-24) var(--spacing-8) var(--spacing-16);
		display: grid;
		grid-template-columns: minmax(0, 1fr) 280px;
		gap: var(--spacing-12);
		align-items: center;
	}

	.about-hero-text {
		min-width: 0;
	}

	.about-hero-photo {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-5);
		margin: 0;
		padding: 0;
		width: 280px;
	}

	/* Lotus petals unfurling */
	.portrait-lotus {
		position: absolute;
		top: 175px;
		left: 50%;
		width: 240px;
		height: 240px;
		margin-left: -120px;
		margin-top: -120px;
		pointer-events: none;
		z-index: 1;
		filter: drop-shadow(0 0 6px rgba(240, 199, 94, 0.6));
		opacity: 0.5;
	}

	.lotus-petal {
		transform-origin: 100px 100px;
		animation: petal-unfurl 8s ease-in-out infinite;
	}

	@keyframes petal-unfurl {
		0%, 100% { transform: scale(0.6); opacity: 0.4; }
		50% { transform: scale(1.1); opacity: 0.9; }
	}

	/* Rose window cathedral pattern */
	.portrait-rose-window {
		position: absolute;
		top: 175px;
		left: 50%;
		width: 460px;
		height: 460px;
		margin-left: -230px;
		margin-top: -230px;
		pointer-events: none;
		z-index: 0;
		color: rgba(240, 199, 94, 0.15);
		filter: drop-shadow(0 0 3px rgba(240, 199, 94, 0.4));
		animation: rose-pulse 8s ease-in-out infinite;
	}

	@keyframes rose-pulse {
		0%, 100% { opacity: 0.6; transform: scale(1) rotate(0deg); }
		50% { opacity: 1; transform: scale(1.05) rotate(4deg); }
	}

	/* Rotating ring of ancient runes */
	.portrait-runes-ring {
		position: absolute;
		top: 175px;
		left: 50%;
		width: 0;
		height: 0;
		pointer-events: none;
		z-index: 5;
	}

	.runes-ring-inner {
		position: absolute;
		width: 0;
		height: 0;
		animation: runes-ring-spin 40s linear infinite;
	}

	.rune-letter {
		position: absolute;
		left: 0;
		top: 0;
		font-family: serif;
		font-size: 14px;
		color: rgba(255, 230, 160, 0.65);
		text-shadow: 0 0 4px rgba(240, 199, 94, 0.8);
		transform: rotate(var(--rl-angle)) translateY(-170px);
	}

	@keyframes runes-ring-spin {
		to { transform: rotate(360deg); }
	}

	.portrait-summoning-circle {
		position: absolute;
		inset: -4%;
		z-index: 0;
		pointer-events: none;
		color: rgba(240, 199, 94, 0.55);
	}
	.portrait-summoning-circle .sc-ring {
		position: absolute;
		inset: 0;
		animation: sc-spin 60s linear infinite;
	}
	.portrait-summoning-circle .sc-ring-years {
		inset: -5%;
		animation: sc-spin 90s linear infinite reverse;
		font-family: "Cinzel", "Trajan Pro", serif;
		letter-spacing: 0.12em;
		font-size: 0.7rem;
		text-transform: uppercase;
	}
	.portrait-summoning-circle .sc-rune,
	.portrait-summoning-circle .sc-year {
		position: absolute;
		inset: 0;
		display: grid;
		place-items: start center;
		transform: rotate(var(--sc-angle));
	}
	.portrait-summoning-circle .sc-rune { font-size: 0.85rem; }
	@keyframes sc-spin { to { transform: rotate(360deg); } }

	.portrait-grimoire-pages {
		position: absolute;
		inset: -8% -12%;
		z-index: 0;
		pointer-events: none;
	}
	.portrait-grimoire-pages .grimoire-page {
		position: absolute;
		width: 22%;
		opacity: 0.55;
		filter: drop-shadow(0 6px 14px rgba(0, 0, 0, 0.5));
		animation: grimoire-drift 18s ease-in-out infinite;
	}
	.grimoire-page-1 { --gp-rot: -12deg; top: 6%; left: -6%; animation-delay: 0s; }
	.grimoire-page-2 { --gp-rot: 9deg; top: 58%; right: -8%; animation-delay: 6s; }
	.grimoire-page-3 { --gp-rot: -4deg; top: 32%; left: 94%; animation-delay: 12s; }
	@keyframes grimoire-drift {
		0%, 100% { transform: translate(0, 0) rotate(var(--gp-rot, 0deg)); opacity: 0.45; }
		50% { transform: translate(6px, -10px) rotate(var(--gp-rot, 0deg)); opacity: 0.65; }
	}

	/* Growing vines that creep around frame */
	.portrait-vines {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: 5;
		filter: drop-shadow(0 0 3px rgba(240, 199, 94, 0.6));
	}

	.vine {
		stroke-dasharray: 600;
		stroke-dashoffset: 600;
		animation: vine-grow 12s ease-in-out infinite;
	}

	.vine-2 { animation-delay: 3s; }

	@keyframes vine-grow {
		0%, 10% { stroke-dashoffset: 600; }
		45% { stroke-dashoffset: 0; }
		80% { stroke-dashoffset: 0; }
		100% { stroke-dashoffset: -600; }
	}

	.vine-leaf {
		opacity: 0;
		transform-origin: center;
		animation: vine-leaf-pop 12s ease-in-out infinite;
	}

	.vine-leaf-1 { animation-delay: 4s; }
	.vine-leaf-2 { animation-delay: 7s; }

	@keyframes vine-leaf-pop {
		0%, 30%, 100% { opacity: 0; transform: scale(0.3); }
		40% { opacity: 0.8; transform: scale(1.2); }
		80% { opacity: 0.8; transform: scale(1); }
	}

	/* Spinning 3D gold coin */
	.portrait-coin-wrap {
		position: absolute;
		top: -20px;
		right: -30px;
		width: 42px;
		height: 42px;
		pointer-events: none;
		z-index: 8;
		perspective: 200px;
		filter: drop-shadow(0 3px 8px rgba(240, 199, 94, 0.6)) drop-shadow(0 0 8px rgba(240, 199, 94, 0.8));
	}

	.coin {
		position: absolute;
		inset: 0;
		transform-style: preserve-3d;
		animation: coin-spin 4s linear infinite;
	}

	.coin-face {
		position: absolute;
		inset: 0;
		backface-visibility: hidden;
	}

	.coin-back {
		transform: rotateY(180deg);
	}

	.coin svg {
		width: 100%;
		height: 100%;
	}

	@keyframes coin-spin {
		to { transform: rotateY(360deg); }
	}

	/* Ornate baroque frame border scrollwork */
	.portrait-baroque {
		position: absolute;
		top: -20px;
		left: -20px;
		width: calc(100% + 40px);
		height: calc(100% + 40px);
		pointer-events: none;
		z-index: 5;
		filter: drop-shadow(0 0 4px rgba(240, 199, 94, 0.7));
		animation: baroque-pulse 5s ease-in-out infinite;
	}

	@keyframes baroque-pulse {
		0%, 100% { opacity: 0.8; }
		50% { opacity: 1; }
	}

	/* Levitating runestones */
	.portrait-runestones {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 7;
	}

	.runestone {
		position: absolute;
		left: var(--rsx);
		top: var(--rsy);
		width: 36px;
		height: 36px;
		border-radius: 6px;
		background:
			linear-gradient(135deg, rgba(80, 60, 30, 0.7) 0%, rgba(60, 40, 20, 0.6) 100%),
			radial-gradient(circle at 30% 30%, rgba(240, 199, 94, 0.3), transparent);
		border: 1px solid rgba(240, 199, 94, 0.5);
		box-shadow:
			0 0 10px rgba(240, 199, 94, 0.6),
			inset 0 0 6px rgba(0, 0, 0, 0.5);
		display: flex;
		align-items: center;
		justify-content: center;
		animation: runestone-levitate 6s ease-in-out infinite;
		animation-delay: var(--rsd);
	}

	.runestone span {
		font-family: serif;
		font-size: 20px;
		color: rgba(255, 230, 160, 0.95);
		text-shadow: 0 0 4px rgba(240, 199, 94, 1), 0 0 10px rgba(240, 199, 94, 0.7);
	}

	@keyframes runestone-levitate {
		0%, 100% { transform: translateY(0) rotate(-4deg); }
		50% { transform: translateY(-10px) rotate(4deg); }
	}

	/* Flying owl silhouette */
	.portrait-owl {
		position: absolute;
		top: 15%;
		left: -50px;
		width: 40px;
		height: 30px;
		color: rgba(80, 60, 30, 0.85);
		filter: drop-shadow(0 0 3px rgba(240, 199, 94, 0.6));
		z-index: 7;
		pointer-events: none;
		opacity: 0;
		animation: owl-fly 30s linear infinite;
	}

	.owl-wing-l, .owl-wing-r {
		transform-origin: center;
		animation: owl-wing-flap 0.4s ease-in-out infinite;
	}

	.owl-wing-r { animation-delay: 0.2s; }

	@keyframes owl-wing-flap {
		0%, 100% { transform: scaleY(1); }
		50% { transform: scaleY(0.5); }
	}

	@keyframes owl-fly {
		0%, 85%, 100% { opacity: 0; transform: translate(0, 0) scale(1); }
		5% { opacity: 0.9; }
		50% { transform: translate(200px, -40px) scale(0.85); }
		80% { opacity: 0.5; transform: translate(420px, -20px) scale(0.7); }
	}

	/* Mouse parallax — subtle card tilt follows mouse */
	.about-hero-photo {
		--mx: 0;
		--my: 0;
		transition: transform 300ms ease-out;
	}

	.about-hero-photo.parallax-active .portrait-card {
		transform: perspective(800px) rotateY(calc(var(--mx) * 3deg)) rotateX(calc(var(--my) * -3deg));
	}

	/* Golden Snitch circling the portrait */
	.portrait-snitch-wrap {
		position: absolute;
		top: 175px;
		left: 50%;
		width: 0;
		height: 0;
		pointer-events: none;
		z-index: 8;
	}

	.snitch-orbit {
		position: absolute;
		width: 0;
		height: 0;
		animation: snitch-orbit 11s linear infinite;
	}

	@keyframes snitch-orbit {
		0% { transform: rotate(0deg) translateY(-180px) rotate(0deg); }
		50% { transform: rotate(180deg) translateY(-140px) rotate(-180deg); }
		100% { transform: rotate(360deg) translateY(-180px) rotate(-360deg); }
	}

	.snitch {
		position: absolute;
		left: -20px;
		top: -10px;
		width: 40px;
		height: 20px;
		filter: drop-shadow(0 0 4px rgba(255, 240, 200, 1)) drop-shadow(0 0 12px rgba(240, 199, 94, 0.8));
	}

	.snitch-wing {
		transform-origin: center;
		animation: snitch-wing-flap 0.25s ease-in-out infinite;
	}

	.snitch-wing-right {
		animation-delay: 0.125s;
	}

	@keyframes snitch-wing-flap {
		0%, 100% { transform: scaleY(1); opacity: 0.9; }
		50% { transform: scaleY(0.3); opacity: 0.5; }
	}

	/* Edge filigree ornaments */
	.portrait-filigree {
		position: absolute;
		top: 50%;
		width: 20px;
		height: 120px;
		margin-top: -60px;
		pointer-events: none;
		z-index: 5;
		filter: drop-shadow(0 0 3px rgba(240, 199, 94, 0.6));
		animation: filigree-sway 5s ease-in-out infinite;
	}

	.portrait-filigree-left {
		left: -24px;
		transform: scaleX(-1);
	}

	.portrait-filigree-right {
		right: -24px;
		animation-delay: 2.5s;
	}

	@keyframes filigree-sway {
		0%, 100% { opacity: 0.7; transform: translateX(0) scaleX(var(--fs, 1)); }
		50% { opacity: 1; transform: translateX(var(--fx, 2px)) scaleX(var(--fs, 1)); }
	}

	.portrait-filigree-left { --fs: -1; --fx: -2px; }
	.portrait-filigree-right { --fs: 1; --fx: 2px; }

	/* Magical sigil / pentagram */
	.portrait-sigil {
		position: absolute;
		top: 175px;
		left: 50%;
		width: 320px;
		height: 320px;
		margin-left: -160px;
		margin-top: -160px;
		pointer-events: none;
