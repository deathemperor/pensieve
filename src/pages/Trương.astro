								<circle cx="20" cy="20" r="18" fill="url(#snitchGrad)" stroke="#b48c3c" stroke-width="1" />
								<polygon points="20,8 24,17 33,17 26,23 29,32 20,27 11,32 14,23 7,17 16,17" fill="#b48c3c" />
							</svg>
