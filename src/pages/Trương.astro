	}
	.wrap-card:not(.wrap-hero):hover::after {
		border-color: rgba(240, 199, 94, 0.38);
		box-shadow:
			inset 0 0 22px rgba(240, 199, 94, 0.08),
			0 0 30px rgba(240, 199, 94, 0.1);
	}
	/* Hero card gets a hover gold-glow via box-shadow on the card itself
	   so the ::after filigree stays intact. */
	.wrap-hero {
		transition: box-shadow 320ms;
	}
	.wrap-hero:hover {
		box-shadow:
			inset 0 0 26px rgba(240, 199, 94, 0.08),
			0 0 36px rgba(240, 199, 94, 0.1);
	}
	/* Memory tendril: a single thin stroke rising from the bottom-left
	   on hover, like memory substance being drawn into the vial.
	   Exclude .wrap-hero — it already has its own silvery filigree rim
	   via ::before, so we reserve that pseudo for the hero card alone. */
	.wrap-card:not(.wrap-hero)::before {
		content: "";
		position: absolute;
		bottom: 0.4rem;
		left: 22%;
		width: 1.5px;
		height: 0;
		background: linear-gradient(180deg,
			transparent 0%,
			rgba(240, 199, 94, 0.4) 45%,
			rgba(200, 210, 225, 0.3) 100%);
