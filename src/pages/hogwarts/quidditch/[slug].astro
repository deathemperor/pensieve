---
export const prerender = false;

import Base from "../../../layouts/Base.astro";
import { getEmDashEntry } from "emdash";
import { getCurrentLang } from "../../../utils/lang";
import { loadFromR2 } from "../../../lib/animations/load-from-r2.ts";
import RawViewer from "../../../components/animations/RawViewer.astro";
import LiveRender from "../../../components/animations/LiveRender.astro";
import RenderFilmstrip from "../../../components/animations/RenderFilmstrip.astro";
import LessonCard from "../../../components/animations/LessonCard.astro";
import PracticePad from "../../../components/animations/PracticePad.astro";
import { LESSONS } from "../../../data/animation-lessons.ts";
import { env } from "cloudflare:workers";

import PlaceholderHero from "../../../animations/placeholder/index.astro";
import SnitchTrailHero from "../../../animations/snitch-trail/index.astro";
import MaraudersMapHero from "../../../animations/marauders-map/index.astro";
import CatWalkHero from "../../../animations/cat-walk/index.astro";

interface AnimationData {
  title: string;
  description?: string;
  tags?: string[];
  hero_component?: string;
  primary_session_id?: string;
  language?: string;
}

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/hogwarts/quidditch/");

const currentLang = getCurrentLang(Astro);
const isVi = currentLang === "vi";

const entryResult = await getEmDashEntry("animations" as never, slug, { locale: "en" } as never);
const entry = (entryResult as unknown as { entry?: { id: string; data: AnimationData }; cacheHint?: unknown }).entry;
const cacheHint = (entryResult as unknown as { cacheHint?: unknown }).cacheHint;
if (!entry) return new Response("Not Found", { status: 404 });
if (cacheHint) Astro.cache.set(cacheHint as never);

// Plan B: R2-backed loader queries animation_sessions in D1, fetches the
// latest published transcript.jsonl.gz from R2 MEDIA, and returns the same
// shape the fixture did. Falls back to the on-disk fixture when R2 has no
// data yet — preserves the placeholder during rollout.
const fixture = await loadFromR2(
  slug,
  env as Parameters<typeof loadFromR2>[1],
);

// Hero component registry — explicit map. Astro can't dynamically import
// user-authored components from a runtime-computed path while keeping
// tree-shaking correct.
const HERO_COMPONENTS = {
  placeholder: PlaceholderHero,
  "snitch-trail": SnitchTrailHero,
  "marauders-map": MaraudersMapHero,
  "cat-walk": CatWalkHero,
} as const;

const Hero = (HERO_COMPONENTS as Record<string, typeof PlaceholderHero>)[slug];
---

<Base
  title={`${entry.data.title} — Quidditch`}
  description={entry.data.description ?? "Animation playground artifact"}
  breadcrumbs={[
    { label: "Hogwarts", href: "/" },
    { label: isVi ? "Sân Quidditch" : "Quidditch Pitch", href: "/hogwarts/quidditch/" },
    { label: entry.data.title },
  ]}
>
  <article class="animation-page">
    <header class="anim-head">
      <h1>{entry.data.title}</h1>
      {entry.data.description && <p class="anim-desc">{entry.data.description}</p>}
    </header>

    <section class="hero-stage" aria-label="Hero animation">
      {Hero ? <Hero /> : (
        <div class="hero-missing">
          No hero component registered for slug "{slug}". Add it to
          HERO_COMPONENTS in src/pages/hogwarts/quidditch/[slug].astro.
        </div>
      )}
    </section>

    {LESSONS[slug] && <LessonCard lesson={LESSONS[slug]} />}

    <section class="intro-banner" aria-label="About this recording">
      <div class="intro-inner">
        <p class="intro-kicker">{isVi ? "Bản ghi phiên dựng" : "Build recording"}</p>
        <h2 class="intro-lede">
          {isVi
            ? "Đây là toàn bộ phiên Claude Code dựng animation này."
            : "This is the full Claude Code session that built this animation."}
        </h2>
        <p class="intro-body">
          {isVi
            ? "Mỗi tool call, mỗi prompt, mỗi chỉnh sửa — được ghi lại. Bấm ▶ hoặc Space để xem nó tự tái dựng. Kéo thanh thời gian để nhảy đến bất kỳ khoảnh khắc nào. Khung Live Render sẽ cập nhật theo."
            : "Every tool call, every prompt, every edit — captured. Press ▶ or Space to watch it rebuild itself. Drag the timeline to jump to any moment. The Live Render pane updates as you scrub."}
        </p>
        <p class="intro-hint" aria-hidden="true">
          <kbd>Space</kbd> <span>play/pause</span>
          <kbd>←</kbd><kbd>→</kbd> <span>step</span>
          <kbd>Shift</kbd>+<kbd>click</kbd> <span class="copy-hint">a chapter to share it</span>
        </p>
      </div>
    </section>

    <section class="diary-section" aria-label="Build diary">
      <div class="section-head">
        <h2>{isVi ? "Nhật ký dựng" : "Build diary"}</h2>
        <p class="section-sub">
          {isVi
            ? "Toàn bộ phiên Claude Code. Dùng ← → hoặc click chapter để di chuyển."
            : "Full Claude Code session. Use ← → or click a chapter to scrub."}
        </p>
        <button type="button" class="share-btn" data-share aria-live="polite">
          <span class="share-icon" aria-hidden="true">🔗</span>
          <span class="share-label">{isVi ? "Sao chép liên kết đến điểm này" : "Copy link to this moment"}</span>
        </button>
      </div>
      <RawViewer transcript={fixture.transcript} chapters={fixture.chapters} />
    </section>

    <LiveRender slug={slug} sourceHistory={fixture.sourceHistory} />

    {fixture.renders && fixture.renders.length > 0 && (
      <RenderFilmstrip slug={slug} renders={fixture.renders} mediaBase="/api/animation-render" />
    )}

    <PracticePad slug={slug} sourceHistory={fixture.sourceHistory} />
  </article>
</Base>

<style>
  .animation-page { max-width: 1080px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
  .anim-head { margin-bottom: 2rem; }
  .anim-head h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; letter-spacing: -0.02em; }
  .anim-desc { color: var(--secondary, #8a8f98); max-width: 60ch; margin: 0; line-height: 1.6; }

  .hero-stage {
    border: 1px solid var(--border, rgba(255, 255, 255, 0.06));
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 3rem;
  }
  .hero-missing {
    padding: 3rem;
    text-align: center;
    color: var(--muted, #62666d);
    font-family: var(--mono, ui-monospace);
    font-size: 0.875rem;
  }

  /* Intro banner */
  .intro-banner {
    margin: 0 0 2.5rem;
    padding: 1.5rem 1.75rem;
    border: 1px solid var(--border, rgba(255, 255, 255, 0.06));
    border-radius: 12px;
    background:
      radial-gradient(circle at 0% 0%, rgba(94, 106, 210, 0.08) 0%, transparent 60%),
      var(--elevated, #141516);
  }
  .intro-kicker {
    font-family: var(--mono, ui-monospace);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent, #5e6ad2);
    margin: 0 0 0.5rem;
  }
  .intro-lede {
    font-size: clamp(1rem, 2.4vw, 1.25rem);
    letter-spacing: -0.01em;
    margin: 0 0 0.75rem;
    line-height: 1.35;
    max-width: 60ch;
  }
  .intro-body {
    color: var(--secondary, #8a8f98);
    max-width: 64ch;
    margin: 0 0 1rem;
    line-height: 1.6;
    font-size: 0.9375rem;
  }
  .intro-hint {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    align-items: center;
    margin: 0;
    color: var(--muted, #62666d);
    font-size: 0.75rem;
    font-family: var(--mono, ui-monospace);
  }
  .intro-hint kbd {
    display: inline-block;
    padding: 0.125rem 0.4rem;
    border: 1px solid var(--border, rgba(255, 255, 255, 0.12));
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.03);
    color: var(--text, #f7f8f8);
    font-size: 0.7rem;
    font-family: inherit;
    margin-right: 0.2rem;
  }

  /* Share button */
  .share-btn {
    margin-top: 0.75rem;
    appearance: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    border: 1px solid var(--border, rgba(255, 255, 255, 0.08));
    color: var(--secondary, #8a8f98);
    font-family: inherit;
    font-size: 0.8125rem;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    cursor: pointer;
    transition: border-color 120ms ease, color 120ms ease, background 120ms ease;
  }
  .share-btn:hover {
    border-color: var(--accent, #5e6ad2);
    color: var(--text, #f7f8f8);
    background: rgba(94, 106, 210, 0.08);
  }
  .share-btn.is-copied {
    border-color: #3fb950;
    color: #3fb950;
  }
  .share-btn.is-copied .share-icon::before { content: "✓"; }
  .share-btn.is-copied .share-icon { font-size: 0 0; }
  .share-btn.is-copied .share-icon::before { font-size: 0.9rem; }

  .diary-section { margin-top: 2rem; }
  .section-head { margin-bottom: 1.25rem; }
  .section-head h2 { margin: 0 0 0.25rem; font-size: 1.125rem; }
  .section-sub { color: var(--muted, #62666d); margin: 0; font-size: 0.875rem; }
</style>

<script>
  // Share button — copies current page URL with the active #cursor-N
  // hash to clipboard. Shows ✓ "Copied!" for 1.5s.
  (function attachShareButton() {
    document.addEventListener("DOMContentLoaded", () => {
      const btn = document.querySelector<HTMLButtonElement>("[data-share]");
      if (!btn) return;
      const label = btn.querySelector<HTMLElement>(".share-label");
      const originalText = label?.textContent ?? "";
      btn.addEventListener("click", async () => {
        const url = window.location.origin + window.location.pathname + window.location.hash;
        try {
          await navigator.clipboard.writeText(url);
          btn.classList.add("is-copied");
          if (label) label.textContent = "Copied!";
          window.setTimeout(() => {
            btn.classList.remove("is-copied");
            if (label) label.textContent = originalText;
          }, 1500);
        } catch {
          // clipboard API unavailable — do nothing
        }
      });
    });
  })();
</script>
