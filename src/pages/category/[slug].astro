---
export const prerender = false;

import { getTerm, getEmDashCollection, getEntryTerms } from "emdash";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getReadingTime } from "../../utils/reading-time";
import { themeForCategory } from "../../themes/categoryThemes";
import { link } from "../../utils/link";
import { getCurrentLang } from "../../utils/lang";

const currentLang = getCurrentLang(Astro);
const { slug } = Astro.params;
const term = slug ? await getTerm("category", slug) : null;

if (!term) {
	return Astro.redirect(link("404"));
}

const theme = themeForCategory(term.slug);

const { entries: allPosts } = await getEmDashCollection("posts", {
	where: { category: term.slug },
	orderBy: { published_at: "desc" },
});
const posts = allPosts.filter((p) => p.data.language === currentLang);

// Fetch tags for display on each post card
const filteredPosts = await Promise.all(
	posts.map(async (post) => {
		const tags = await getEntryTerms("posts", post.data.id, "tag");
		return { post, tags };
	})
);
---

<Base
	title={`${term.label} posts`}
	description={`All posts in ${term.label}`}
	theme={theme}
>
	<section class="archive-section">
		<header class="archive-header">
			<span class="archive-label">
				<span class="archive-dot" />
				Category
			</span>
			<h1 class="archive-title">{term.label}</h1>
			<p class="archive-count">
				{filteredPosts.length} {filteredPosts.length === 1 ? "post" : "posts"}
			</p>
		</header>

		{
			filteredPosts.length === 0 ? (
				<p class="no-posts">No posts in this category yet.</p>
			) : (
				<div class="posts-grid">
					{filteredPosts.map(({ post, tags }) => (
						<PostCard
							title={post.data.title}
							excerpt={post.data.excerpt}
							featuredImage={post.data.featured_image}
							href={link(`posts/${post.id}`)}
							date={post.data.publishedAt ?? undefined}
							readingTime={getReadingTime(post.data.content)}
							tags={tags.map((t) => ({ slug: t.slug, label: t.label }))}
							themeSlug={theme ? (theme.slug as any) : null}
							categoryLabel={term.label}
						/>
					))}
				</div>
			)
		}
	</section>
</Base>

<style>
	.archive-section {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-8) var(--spacing-24);
	}

	.archive-header {
		margin-bottom: var(--spacing-10);
		padding-bottom: var(--spacing-6);
		border-bottom: 1px solid var(--color-border);
	}

	.archive-label {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-2);
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		font-weight: 500;
		color: var(--color-muted);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		margin: 0 0 var(--spacing-3);
	}

	.archive-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--color-accent);
	}

	.archive-title {
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 3.5vw, 2.5rem);
		font-weight: var(--font-weight-display, 590);
		letter-spacing: -0.022em;
		line-height: 1.1;
		margin: 0 0 var(--spacing-2);
		color: var(--color-text);
	}

	.archive-count {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		margin: 0;
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: var(--spacing-4);
	}

	.no-posts {
		color: var(--color-muted);
		font-family: var(--font-sans);
	}

	@media (max-width: 700px) {
		.archive-section {
			padding: var(--spacing-10) var(--spacing-5) var(--spacing-16);
		}
	}
</style>
