---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import { getCurrentLang } from "../../utils/lang";
import { setCachePolicy } from "../../lib/cachePolicy";
setCachePolicy(Astro, "static");

const isVi = getCurrentLang(Astro) === "vi";

// Frozen snapshot — Google Takeout YouTube watch-history export 2026-05-03.
// Source: takeout/.../YouTube and YouTube Music/history/watch-history.json (gitignored).

const SNAPSHOT = {
	exported: "2026-05-03",
	rangeStart: "2025-11-16",
	rangeEnd: "2026-05-03",
	spanDays: 169,
	totalWatches: 10169,
	perDay: 60,
	uniqueChannels: 3288,
	uniqueVideos: 8031,
	rewatchedVideos: 179,
	musicSharePct: 0.9,
	kidsSearches: 149,
};

interface ChannelRow {
	rank: number;
	name: string;
	count: number;
	share: number;
}

const TOP_10_CHANNELS: ChannelRow[] = [
	{ rank: 1, name: "Zack D. Films", count: 958, share: 9.4 },
	{ rank: 2, name: "Manchester United", count: 223, share: 2.2 },
	{ rank: 3, name: "Outstanding Screenplays", count: 209, share: 2.1 },
	{ rank: 4, name: "Premier League", count: 133, share: 1.3 },
	{ rank: 5, name: "ESPN FC", count: 130, share: 1.3 },
	{ rank: 6, name: "Theo Rogan Shorts", count: 128, share: 1.3 },
	{ rank: 7, name: "FPT Bóng Đá", count: 126, share: 1.2 },
	{ rank: 8, name: "The New York Times", count: 122, share: 1.2 },
	{ rank: 9, name: "The Overlap", count: 116, share: 1.1 },
	{ rank: 10, name: "Sky Sports Premier League", count: 99, share: 1.0 },
];

interface SubjectRow { icon: string; keyEn: string; keyVi: string; count: number; share: number }
const SUBJECTS: SubjectRow[] = [
	{ icon: "👾", keyEn: "Muggle Curios (short-form animation)", keyVi: "Đồ Chơi Muggle (clip ngắn)", count: 1762, share: 17.3 },
	{ icon: "🏟️", keyEn: "Quidditch (Football)", keyVi: "Quidditch (Bóng Đá)", count: 1686, share: 16.6 },
	{ icon: "🪄", keyEn: "Transfiguration (Code & Tech)", keyVi: "Biến Hình (Code & Công nghệ)", count: 432, share: 4.2 },
	{ icon: "🎬", keyEn: "Charms (Cinema)", keyVi: "Bùa Chú (Điện ảnh)", count: 353, share: 3.5 },
	{ icon: "📜", keyEn: "History of Magic (Long-form essays)", keyVi: "Lịch Sử Phép Thuật (Bài luận dài)", count: 344, share: 3.4 },
	{ icon: "🦉", keyEn: "Occlumency (Stoicism, Peterson)", keyVi: "Bí Tâm (Khắc kỷ, Peterson)", count: 337, share: 3.3 },
	{ icon: "📰", keyEn: "The Quibbler (News)", keyVi: "Quibbler (Tin tức)", count: 310, share: 3.0 },
	{ icon: "🔮", keyEn: "Divination (Business)", keyVi: "Tiên Đoán (Kinh doanh)", count: 296, share: 2.9 },
	{ icon: "🐠", keyEn: "Care of Magical Creatures", keyVi: "Chăm Sóc Sinh Vật", count: 211, share: 2.1 },
];

const t = {
	pageTitle: isVi ? "Tưởng Ký Của Những Cái Nhìn — Người Xem Bên Dưới Dữ Liệu" : "The Pensieve of Views — The Watcher Underneath The Data",
	pageDesc: isVi
		? "Bảy đặc điểm cá tính được dữ liệu YouTube watch history xác nhận: tôi là ai khi tự động phát đang chạy."
		: "Seven personality traits the YouTube watch history confirms: who I am when autoplay is running.",
	dumbledore: isVi
		? '"Anh nghĩ sự thật thường tốt hơn dối trá chứ?" — Albus Dumbledore'
		: '"You think the truth is generally preferable to lies?" — Albus Dumbledore',
	introTitle: isVi ? "Đây không phải báo cáo về những gì tôi xem." : "This isn't a report about what I watch.",
	introBody: isVi
		? `Đây là chân dung người xem bên dưới ${SNAPSHOT.totalWatches.toLocaleString()} lượt xem qua ${SNAPSHOT.spanDays} ngày YouTube. Google đã giới hạn cửa sổ Takeout ở ~6 tháng — đây là một học kỳ ở Hogwarts, không phải bảy năm. Dữ liệu hỗ trợ kết luận; không phải ngược lại.`
		: `It's a portrait of the watcher underneath ${SNAPSHOT.totalWatches.toLocaleString()} YouTube watches across ${SNAPSHOT.spanDays} days. Google now caps the Takeout window at ~6 months — this is one term at Hogwarts, not seven years. The data supports the conclusions; not the other way around.`,

	t1Title: isVi ? "I. Người Xem Hoạt Hình Như Tiếng Ồn Trắng" : "I. The Animation-As-White-Noise Watcher",
	t1Body1: isVi
		? "Vùng hấp dẫn lớn nhất không phải một niềm say mê — mà một kênh chạy nền. 9.4% mọi lượt xem là Zack D. Films, kênh hoạt hình ngắn về sự thật kỳ lạ. 958 lượt qua 169 ngày — gần sáu lượt mỗi ngày, cho một kênh anh không yêu."
		: "The largest gravity well isn't a passion — it's a channel that runs in the background. 9.4% of all watches is Zack D. Films, a short-form animation channel of strange-fact vignettes. 958 plays in 169 days — nearly six a day, for a channel he doesn't love.",
	t1Body2: isVi
		? "Anh mở nó khi đang làm việc khác — như tiếng radio nền, nhưng có hình. Đây là người xem có thói quen tiêu thụ-như-bầu-bạn: cần cái gì đó chạy, không cần cái đó hay."
		: "He opens it while doing something else — like background radio, but with pictures. This is a watcher with a consumption-as-companionship habit: something needs to be running; the something doesn't need to be good.",

	t2Title: isVi ? "II. Người Trung Thành Ngày Có Trận" : "II. The Match-Day Loyalist",
	t2Body1: isVi
		? "17% YouTube là bóng đá: Manchester United chính thức (223), Premier League (133), ESPN FC (130), FPT Bóng Đá (126), The Overlap (116), Sky Sports Premier League (99). Sáu kênh anh quay lại ngay cả khi không có gì mới."
		: "17% of YouTube is football: Manchester United official (223), Premier League (133), ESPN FC (130), FPT Bóng Đá (126), The Overlap (116), Sky Sports Premier League (99). Six channels he returns to even when there's nothing new.",
	t2Body2: isVi
		? "Anh xem highlight khi chờ, xem phân tích sau trận như người khác xem dự báo thời tiết. Đây không phải fan thời vụ. Đây là lòng trung thành kéo dài qua nhiều mùa giải, nhiều HLV, nhiều thay đổi cầu thủ."
		: "He watches highlights while waiting, watches post-match analysis like other people watch the weather. This isn't a casual fan. This is loyalty that has weathered seasons, managers, and squad changes.",

	t3Title: isVi ? "III. Người Quay Lại Hannah Fry" : "III. The Hannah Fry Returner",
	t3Body1: isVi
		? "Trong số mọi video xem lại trong 5,5 tháng, tám là clip khoa học ngắn của Hannah Fry — Apollo, hắt-hơi-trước-mặt-trời, lon nắp kẹt, ống hút giấy, đền Parthenon, Ramanujan, lice. Nhiều hơn bất kỳ giọng nói nào khác."
		: "Of every video rewatched in 5.5 months, eight are Hannah Fry's tiny science explainers — Apollo, sneeze-at-sun, stuck lid, paper straws, the Parthenon, Ramanujan, lice. More than any other voice.",
	t3Body2: isVi
		? "Cụ thể quay lại những khoảnh khắc toán học gặp một thứ nhỏ và đẹp. Đó là một loại sở thích hẹp — không phải khoa học hàn lâm, không phải khoa học phổ thông, mà là khoảnh khắc khi một nhà toán học chỉ một thứ nhỏ và nó tỏa ra."
		: "Specifically returns to moments where mathematics meets a small, beautiful thing. That's a narrow taste — not academic science, not popular science, but the moment when a mathematician points at a small thing and it glows.",

	t4Title: isVi ? "IV. Người Lặp Podcast Lex Fridman" : "IV. The Lex Fridman Looper",
	t4Body1: isVi
		? "Ba podcast Lex Fridman được xem lại bốn lần mỗi cái: John Carmack về lập trình (#309), Peter Steinberger về AI agent (#491), Jeff Kaplan về thiết kế game (#493). Drumeo Chad Smith chơi \"Otherside\" — năm lần xem lại, là video được lặp lại nhiều nhất trong cả tưởng ký."
		: "Three Lex Fridman podcasts each rewatched four times: John Carmack on programming (#309), Peter Steinberger on AI agents (#491), Jeff Kaplan on game design (#493). Drumeo Chad Smith playing \"Otherside\" — five rewatches, the single most-looped video in the whole Pensieve.",
	t4Body2: isVi
		? "Không phải nghe một lần là xong. Nghe đi nghe lại như sách kỹ thuật, mỗi lần một lớp mới. Đây là người xem có thói quen học bằng việc lặp — không phải đọc lướt, mà thuộc lòng."
		: "Not listened-to-once-and-done. Listened on loop like technical books, a new layer each time. This is a watcher with a learn-by-repetition habit — not skimming, but committing-to-memory.",

	t5Title: isVi ? "V. Khẩu Phần YouTube Ba Giờ Mỗi Ngày" : "V. The Three-Hours-Of-YouTube-A-Day Diet",
	t5Body1: isVi
		? "60 lượt mở mỗi ngày trong 169 ngày. Khoảng ba tiếng YouTube mỗi ngày nếu giả định video trung bình ba phút. Không phải binge — đây là pacing đều, gần như thiền định."
		: "60 opens a day for 169 days. About three hours of YouTube daily if you assume average video length of three minutes. Not bingeing — this is steady pacing, almost meditative.",
	t5Body2: isVi
		? "Tin tức khi làm việc, highlight khi chờ, podcast clip khi di chuyển, hoạt hình ngắn khi nghỉ. Bốn kịch bản, một thói quen: cần cái gì đó chạy đều, suốt ngày."
		: "News while working, highlights while waiting, podcast clips during transit, short-form animation while resting. Four scenarios, one habit: something needs to be running, evenly, all day.",

	t6Title: isVi ? "VI. Tài Khoản Chia Sẻ Với Một Đứa Trẻ" : "VI. The Account Shared with a Child",
	t6Body1: isVi
		? "149 lượt tìm kiếm trong cùng cửa sổ là \"Peppa Pig\", \"Baby Shark\", \"Siêu Nhân Cơ Động\", \"PAW Patrol\", \"Dave and Ava\". Bản tổng hợp PAW Patrol hai giờ được xem lại hai lần. Tài khoản chia sẻ với một đứa trẻ."
		: "149 search queries in the same window are for \"Peppa Pig\", \"Baby Shark\", \"Sieu Nhan Co Dong\", \"PAW Patrol\", \"Dave and Ava\". The PAW Patrol two-hour compilation was rewatched twice. The account is shared with a child.",
	t6Body2: isVi
		? "Đây là đặc điểm trung thực phải bao gồm: lịch sử xem không hoàn toàn của tôi. Một phần nhỏ là một đứa nhỏ với iPad. Trung thực hơn việc giả vờ tưởng ký chỉ chứa tôi."
		: "This is the honest trait that must be included: the watch history isn't entirely mine. A small portion is a child with an iPad. More honest than pretending the Pensieve only holds me.",

	t7Title: isVi ? "VII. Phạm Vi Rộng, Lòng Trung Thành Hẹp" : "VII. Wide Scope, Narrow Loyalties",
	t7Body1: isVi
		? "Bảy đặc điểm cộng dồn thành một chân dung: người xem có khẩu phần lớn nhưng nhóm nhỏ. Manchester United và Hannah Fry và Lex Fridman và Outstanding Screenplays và Theo - t3.gg — cùng một sự quay lại, tuần này qua tuần khác. Không phải Ravenclaw đơn thuần (quá bồn chồn để định cư một bộ môn). Không phải Hufflepuff đơn thuần (quá tò mò để gọi là trung thành)."
		: "Seven traits add up to one portrait: a watcher with a large diet but a small set of returns. Manchester United and Hannah Fry and Lex Fridman and Outstanding Screenplays and Theo - t3.gg — same returns, week after week. Not Ravenclaw alone (too restless to settle on a single discipline). Not Hufflepuff alone (too curious to be called loyal).",
	t7Body2: isVi
		? "Mà là đường nối giữa hai bên: một người xem đọc để thuộc về nhiều nơi cùng lúc, với một góc tưởng ký dành cho đứa nhỏ leo vào xin Baby Shark."
		: "But the seam between them: a watcher who reads to belong to many places at once, with one corner of the basin reserved for the kid who climbs in and asks for Baby Shark.",

	refTitle: isVi ? "Phụ Lục — Phân Tích Theo Môn & Top Kênh" : "Reference — Subjects & Top Channels",
	refSubjects: isVi ? "Hogwarts Subjects (theo lượt xem)" : "Hogwarts Subjects (by watch share)",
	refChannels: isVi ? "Top 10 Kênh" : "Top 10 Channels",
	refColSubj: isVi ? "Môn" : "Subject",
	refColCount: isVi ? "Lượt" : "Watches",
	refColShare: isVi ? "Tỷ lệ" : "Share",
	refColCh: isVi ? "Kênh" : "Channel",

	cavTitle: isVi ? "Lưu Ý — Những Gì Không Thể Cho Thấy" : "Caveats — What This Cannot Show",
	caveats: isVi
		? [
			["Khoảng thời gian.", `Takeout chỉ trả về ${SNAPSHOT.spanDays} ngày — Google đã siết cửa sổ.`],
			["Đặc điểm là phỏng đoán.", `Trên ${SNAPSHOT.totalWatches.toLocaleString()} lượt xem. Mẫu lớn hơn (hoặc cửa sổ dài hơn) có thể tinh chỉnh.`],
			["Bỏ qua trong vài giây = xem trọn vẹn.", "Một cú click 5 giây và một video 40 phút đều là một dòng."],
			["Ô nhiễm tự động phát.", "Nhiều mục cuối phiên là tự động phát mà tôi không yêu cầu."],
			["Xem ẩn danh.", "Bất cứ thứ gì xem mà không đăng nhập đều không xuất hiện."],
		]
		: [
			["Time horizon.", `Takeout returned only ${SNAPSHOT.spanDays} days — Google tightened the window.`],
			["Traits are inferred.", `From ${SNAPSHOT.totalWatches.toLocaleString()} watches. A larger sample (or longer window) might refine these.`],
			["Skipped within seconds counts the same as watched in full.", "A 5-second click and a 40-minute video are both one row."],
			["Autoplay pollution.", "Many entries near the end of a session are autoplay I never asked for."],
			["Signed-out viewing.", "Anything watched without being logged in does not appear."],
		],
	footnote: isVi
		? `Tạo từ Google Takeout export ngày ${SNAPSHOT.exported}. Dữ liệu nguồn được giữ riêng tư.`
		: `Generated from Google Takeout export of ${SNAPSHOT.exported}. Source data is kept private.`,
};

const formatDate = (iso: string) => {
	const d = new Date(iso);
	return isVi
		? `${d.getDate()} tháng ${d.getMonth() + 1}, ${d.getFullYear()}`
		: d.toLocaleDateString("en-US", { day: "numeric", month: "long", year: "numeric" });
};
---

<Base
	title={t.pageTitle}
	description={t.pageDesc}
	breadcrumbs={[
		{ label: isVi ? "Phòng Cần Thiết" : "Room of Requirement", href: "/room-of-requirement" },
		{ label: t.pageTitle },
	]}
>
	<article class="pov">
		<header class="pov-hdr">
			<h1 class="pov-title">{t.pageTitle}</h1>
			<p class="pov-sub">{t.pageDesc}</p>
			<blockquote class="pov-quote">{t.dumbledore}</blockquote>
			<p class="pov-intro"><strong>{t.introTitle}</strong> {t.introBody}</p>
			<p class="pov-window">
				{formatDate(SNAPSHOT.rangeStart)} → {formatDate(SNAPSHOT.rangeEnd)} · {SNAPSHOT.spanDays} {isVi ? "ngày" : "days"} · {SNAPSHOT.totalWatches.toLocaleString()} {isVi ? "lượt xem" : "watches"}
			</p>
		</header>

		<section class="pov-trait">
			<h2 class="pov-h2">{t.t1Title}</h2>
			<p class="pov-body">{t.t1Body1}</p>
			<p class="pov-body">{t.t1Body2}</p>
		</section>

		<section class="pov-trait">
			<h2 class="pov-h2">{t.t2Title}</h2>
			<p class="pov-body">{t.t2Body1}</p>
			<p class="pov-body">{t.t2Body2}</p>
		</section>

		<section class="pov-trait">
			<h2 class="pov-h2">{t.t3Title}</h2>
			<p class="pov-body">{t.t3Body1}</p>
			<p class="pov-body">{t.t3Body2}</p>
		</section>

		<section class="pov-trait">
			<h2 class="pov-h2">{t.t4Title}</h2>
			<p class="pov-body">{t.t4Body1}</p>
			<p class="pov-body">{t.t4Body2}</p>
		</section>

		<section class="pov-trait">
			<h2 class="pov-h2">{t.t5Title}</h2>
			<p class="pov-body">{t.t5Body1}</p>
			<p class="pov-body">{t.t5Body2}</p>
		</section>

		<section class="pov-trait">
			<h2 class="pov-h2">{t.t6Title}</h2>
			<p class="pov-body">{t.t6Body1}</p>
			<p class="pov-body">{t.t6Body2}</p>
		</section>

		<section class="pov-trait pov-synth">
			<h2 class="pov-h2">{t.t7Title}</h2>
			<p class="pov-body">{t.t7Body1}</p>
			<p class="pov-body">{t.t7Body2}</p>
		</section>

		<section class="pov-ref">
			<h2 class="pov-h2">{t.refTitle}</h2>
			<h3 class="pov-h3">{t.refSubjects}</h3>
			<div class="pov-table-wrap">
				<table class="pov-table">
					<thead>
						<tr><th>{t.refColSubj}</th><th class="num">{t.refColCount}</th><th class="num">{t.refColShare}</th></tr>
					</thead>
					<tbody>
						{SUBJECTS.map((s) => (
							<tr>
								<td><span class="pov-icon">{s.icon}</span> {isVi ? s.keyVi : s.keyEn}</td>
								<td class="num">{s.count.toLocaleString()}</td>
								<td class="num">{s.share.toFixed(1)}%</td>
							</tr>
						))}
					</tbody>
				</table>
			</div>

			<h3 class="pov-h3">{t.refChannels}</h3>
			<div class="pov-table-wrap">
				<table class="pov-table">
					<thead>
						<tr><th>#</th><th>{t.refColCh}</th><th class="num">{t.refColCount}</th><th class="num">{t.refColShare}</th></tr>
					</thead>
					<tbody>
						{TOP_10_CHANNELS.map((c) => (
							<tr>
								<td class="rank">{c.rank}</td>
								<td>{c.name}</td>
								<td class="num">{c.count.toLocaleString()}</td>
								<td class="num">{c.share.toFixed(1)}%</td>
							</tr>
						))}
					</tbody>
				</table>
			</div>
		</section>

		<section class="pov-trait">
			<h2 class="pov-h2">{t.cavTitle}</h2>
			<ul class="pov-caveats">
				{t.caveats.map(([term, body]) => (
					<li><strong>{term}</strong> {body}</li>
				))}
			</ul>
		</section>

		<footer class="pov-foot">
			<p>{t.footnote}</p>
		</footer>
	</article>
</Base>

<style>
	.pov { max-width: var(--wide-width); margin: 0 auto; padding: var(--spacing-12) var(--spacing-8) var(--spacing-16); }
	.pov-hdr { margin-bottom: var(--spacing-12); }
	.pov-title { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); font-weight: var(--font-weight-display); letter-spacing: -0.02em; color: var(--color-text); margin: 0 0 var(--spacing-3); }
	.pov-sub { font-family: var(--font-sans); font-size: var(--font-size-md); color: var(--color-muted); font-style: italic; margin: 0 0 var(--spacing-5); max-width: 70ch; }
	.pov-quote { font-family: var(--font-sans); font-style: italic; color: var(--color-text-secondary); border-left: 2px solid var(--color-border); padding: var(--spacing-2) 0 var(--spacing-2) var(--spacing-4); margin: 0 0 var(--spacing-5); max-width: 70ch; }
	.pov-intro { font-family: var(--font-sans); color: var(--color-text); line-height: var(--leading-relaxed); margin: 0 0 var(--spacing-3); max-width: 70ch; }
	.pov-window { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--color-muted); margin: 0; }

	.pov-trait { margin-top: var(--spacing-12); }
	.pov-h2 { font-family: var(--font-display); font-size: clamp(1.4rem, 2.4vw, 1.8rem); font-weight: var(--font-weight-display); color: var(--color-text); margin: 0 0 var(--spacing-4); letter-spacing: -0.01em; }
	.pov-h3 { font-family: var(--font-display); font-size: 1.1rem; font-weight: 600; color: var(--color-text); margin: var(--spacing-6) 0 var(--spacing-3); }
	.pov-body { font-family: var(--font-sans); font-size: var(--font-size-md); color: var(--color-text); line-height: var(--leading-relaxed); margin: 0 0 var(--spacing-3); max-width: 70ch; }
	.pov-icon { display: inline-block; margin-right: 0.3em; }

	.pov-synth { padding: var(--spacing-6) var(--spacing-6); background: var(--color-surface-elevated); border: 1px solid var(--color-border); border-radius: var(--radius); }

	.pov-ref { margin-top: var(--spacing-14); }
