// 25 long-tail samples — randomly drawn from rare hosts (1–3 visits)
const WIDER_READING: Array<[string, string]> = [
	["chosun.com", "G-Drive Fire Destroys 125,000 Officials' Data"],
	["killedbygoogle.com", "Google Graveyard — Killed by Google"],
	["addyosmani.com", "AddyOsmani.com — 21 Lessons From 14 Years at Google"],
	["antirez.com", "Don't fall into the anti-AI hype — antirez"],
	["jalammar.github.io", "The Illustrated Transformer — Jay Alammar"],
	["alexschapiro.com", "Alex Schapiro — Security research, ethical hacking, and building stuff"],
	["0x44.xyz", "How I found a bypass in Google's big anti-adblock update"],
	["a16z.com", "Why Software Is Eating the World — Andreessen Horowitz"],
