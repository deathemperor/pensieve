---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import { getCurrentLang } from "../../utils/lang";
import { setCachePolicy } from "../../lib/cachePolicy";
setCachePolicy(Astro, "static");

const isVi = getCurrentLang(Astro) === "vi";

// Frozen snapshot from Google Takeout Chrome history export 2026-05-03.
// Source: takeout/Takeout/Chrome/History.json (gitignored).
// To refresh: re-run takeout/chrome/analyze.py and update constants.

const SNAPSHOT = {
	exported: "2026-05-03",
	rangeStart: "2025-05-04",
	rangeEnd: "2026-05-03",
	spanDays: 365,
	totalHistoryEntries: 83850,
	articlesAfterFilter: 3977,
	rareUniqueHosts: 450,
};

interface SubjectRow {
	icon: string;
	keyEn: string;
	keyVi: string;
	count: number;
	share: number;
	topHosts: Array<[string, number]>;
}

const SUBJECTS: SubjectRow[] = [
	{
		icon: "🪄", keyEn: "Software Craft", keyVi: "Thủ Công Phần Mềm", count: 873, share: 21.9,
		topHosts: [["stackoverflow.com", 91], ["expo.dev", 87], ["apollographql.com", 61], ["simonwillison.net", 42], ["docs.cloud.google.com", 40]],
	},
	{
		icon: "🇻🇳", keyEn: "Vietnamese Voices", keyVi: "Tiếng Nói Việt", count: 618, share: 15.5,
		topHosts: [["vnexpress.net", 167], ["vi.wikipedia.org", 30], ["tuoitre.vn", 28], ["thanhnien.vn", 20]],
	},
	{
		icon: "🔮", keyEn: "AI Frontier", keyVi: "Tiền Tuyến AI", count: 543, share: 13.7,
		topHosts: [["blog.google", 103], ["ai.google.dev", 100], ["ai-sdk.dev", 74], ["forum.cursor.com", 26], ["lmarena.ai", 22]],
	},
	{
		icon: "💬", keyEn: "Tech Discussion", keyVi: "Thảo Luận Công Nghệ", count: 334, share: 8.4,
		topHosts: [["reddit.com", 127], ["news.ycombinator.com", 125], ["businessinsider.com", 17], ["macrumors.com", 12]],
	},
	{
		icon: "📜", keyEn: "Wikipedia & Curiosity", keyVi: "Wikipedia & Tò Mò", count: 298, share: 7.5,
		topHosts: [["en.wikipedia.org", 193], ["archive.is", 45], ["gameofthrones.fandom.com", 32], ["imdb.com", 19]],
	},
	{
		icon: "🐠", keyEn: "Care of Magical Creatures", keyVi: "Chăm Sóc Sinh Vật", count: 134, share: 3.4,
		topHosts: [["thuysinhtim.vn", 22], ["shelly.com", 22], ["weekaqua.world", 18], ["buceplant.com", 13]],
	},
];

const widerCount = SNAPSHOT.articlesAfterFilter - SUBJECTS.reduce((s, x) => s + x.count, 0);

const t = {
	pageTitle: isVi ? "Cú Đường — Người Đọc Bên Dưới Dữ Liệu" : "The Owlery — The Reader Underneath The Data",
	pageDesc: isVi
		? "Sáu đặc điểm cá tính được dữ liệu Chrome history xác nhận: tôi là ai khi tôi tự chọn cái để đọc."
		: "Six personality traits the Chrome history data confirms: who I am when I choose what to read.",
	dumbledore: isVi
		? '"Lời nói, theo ý kiến không hề khiêm tốn của tôi, là nguồn ma thuật vô tận nhất của chúng ta." — Albus Dumbledore'
		: '"Words are, in my not-so-humble opinion, our most inexhaustible source of magic." — Albus Dumbledore',
	introTitle: isVi ? "Đây không phải báo cáo về việc đọc của tôi." : "This isn't a report about my reading.",
	introBody: isVi
		? `Đây là chân dung người đọc bên dưới ${SNAPSHOT.articlesAfterFilter.toLocaleString()} bài viết qua ${SNAPSHOT.spanDays} ngày Chrome history. ${SNAPSHOT.totalHistoryEntries.toLocaleString()} mục lịch sử thô được lọc xuống còn gần 4.000 bài thật sự đọc — tab công việc, dashboard, đăng nhập, mạng xã hội đều bị bỏ. Dữ liệu hỗ trợ kết luận; không phải ngược lại.`
		: `It's a portrait of the reader underneath ${SNAPSHOT.articlesAfterFilter.toLocaleString()} articles across ${SNAPSHOT.spanDays} days of Chrome history. ${SNAPSHOT.totalHistoryEntries.toLocaleString()} raw history entries filtered down to nearly 4,000 actually-read articles — work tabs, dashboards, logins, and social feeds dropped. The data supports the conclusions; not the other way around.`,

	t1Title: isVi ? "I. Kỹ Sư Mở Stack Overflow Lúc 3 Giờ Chiều" : "I. The Stack-Overflow-At-3-PM Engineer",
	t1Body1: isVi
		? "22% năm đọc của anh là tài liệu phần mềm — Stack Overflow, framework docs, changelog Vercel, blog Simon Willison. Cộng thêm 14% paper AI và tài liệu Claude SDK. Cộng thêm 8% thảo luận công nghệ trên Hacker News và Reddit. Tổng: 44% việc đọc là phần kéo dài của nghề."
		: "22% of his year-of-reading is software craft — Stack Overflow, framework docs, Vercel changelogs, Simon Willison's blog. Plus 14% AI papers and Claude SDK pages. Plus 8% tech discussion on Hacker News and Reddit. Total: 44% of reading is an extension of the workday.",
	t1Body2: isVi
		? "Anh không nghỉ ngơi khỏi công việc bằng cách đọc; anh đọc để tiếp tục làm việc. Đây là kỹ sư mà việc đọc là tủ thuốc hằng ngày — không phải giải trí, không phải khám phá, mà là việc giữ tay nghề ở mỗi giờ ngẫu nhiên."
		: "He doesn't take breaks from his work to read; he reads to keep doing his work. This is an engineer for whom reading is the daily medicine cabinet — not entertainment, not exploration, but keeping his hand sharp at random hours.",

	t2Title: isVi ? "II. Người Chơi Cá Thuộc Tên Latin" : "II. The Hobbyist Who Knows the Latin Names",
	t2Body1: isVi
		? "Hồ thủy sinh chỉ chiếm 3% Chrome reading — nhỏ về khối lượng. Nhưng độ chuyên thì khác: anh tìm \"astatheros macracanthus\", \"oscura heterospila\", \"motaguense\" — tên loài cichlid Latin nhập từ trí nhớ, qua nhiều năm, nhiều lần."
		: "Aquariums show up at only 3% of his Chrome reading — small in volume. But the depth is different: he searches \"astatheros macracanthus\", \"oscura heterospila\", \"motaguense\" — Latin cichlid species names typed from memory, over many years, many times.",
	t2Body2: isVi
		? "Hầu hết người chơi cá nói \"cichlid vàng\" hoặc \"cá Trung Mỹ\". Anh không. Đây là loại sở thích mà chiều sâu sống ngoài lịch sử trình duyệt — sống trong phòng cá, trong tủ kính, trong các tên Latin đã thuộc lòng."
		: "Most fishkeepers say \"yellow cichlid\" or \"Central American cichlid.\" He doesn't. This is the kind of hobby where depth lives outside the browser history — lives in the tank room, in the glass cabinet, in the Latin names committed to memory.",

	t3Title: isVi ? "III. Kẻ Lang Thang Wikipedia Lúc Nửa Đêm" : "III. The Midnight Wikipedia Wanderer",
	t3Body1: isVi
		? 'Wikipedia chiếm 8% Chrome reading. Trong một năm anh mở tab cho "Loạn 12 sứ quân" (sứ quân Việt thế kỷ 10), "Apple Computer, Inc. v. Microsoft Corp." (vụ kiện UI 1988), "Honda CRF series" (xe trail), "Heimdall" (thần Bắc Âu), "Saturday Night Live 50th Anniversary", "List of Michelin-starred restaurants in Vietnam".'
		: 'Wikipedia is 8% of his Chrome reading. In one year he opened tabs for "Loạn 12 sứ quân" (10th-century Vietnamese warlords), "Apple Computer, Inc. v. Microsoft Corp." (the 1988 UI lawsuit), "Honda CRF series" (trail bikes), "Heimdall" (the Norse god), "Saturday Night Live 50th Anniversary", "List of Michelin-starred restaurants in Vietnam".',
	t3Body2: isVi
		? "Sáu chủ đề, một đêm — không cái nào cho công việc. Sự lang thang là thật và cụ thể. Khi anh không đọc tài liệu kỹ thuật và không đọc bóng đá, anh đọc thứ này. Đó là khu vực tò mò thuần khiết, nhỏ về khối lượng, đặc biệt về độ rộng."
		: "Six subjects, one night — none for work. The wandering is real and specific. When he isn't reading technical docs and isn't reading football, he reads this. That's the zone of pure curiosity — small in volume, distinctive in breadth.",

	t4Title: isVi ? "IV. Người Đọc Hai Tiếng" : "IV. The Bilingual Reader",
	t4Body1: isVi
		? "16% Chrome reading là tiếng Việt — VnExpress, Tuổi Trẻ, Thanh Niên, vi.wikipedia. Đây là tỷ lệ đáng kể. Quê hương đọc hằng ngày bằng tiếng mẹ đẻ; mọi thứ khác đọc bằng tiếng Anh."
		: "16% of his Chrome reading is Vietnamese — VnExpress, Tuoi Tre, Thanh Nien, vi.wikipedia. That's a meaningful share. The home country reads daily in his native voice; everything else reads in English.",
	t4Body2: isVi
		? "Hai tiếng, một người, không xung đột — chỉ là hai cửa sổ vào cùng một thế giới. Đặc điểm này giải thích vì sao tin Việt và phân tích quốc tế cùng tồn tại trong một ngày đọc — hai tủ sách trong cùng một phòng."
		: "Two languages, one person, no conflict — just two windows into the same world. This trait explains why Vietnamese news and international analysis coexist within a single day of reading — two bookshelves in the same room.",

	t5Title: isVi ? "V. Bề Rộng Sống Ở Các Góc" : "V. The Breadth Lives In The Corners",
	t5Body1: isVi
		? "450 tên miền chỉ vào một hoặc hai lần — đây là đuôi dài thật sự. Trong đó có chosun.com (báo Hàn Quốc), avbrief.com (tin hàng không), manus.im (AI agent platform Trung Quốc), antirez.com (kỹ sư Redis), 0x44.xyz (security researcher), addyosmani.com (engineer Google), jalammar.github.io (giải thích Transformer)."
		: "450 domains visited exactly once or twice — that's the actual long tail. Among them: chosun.com (Korean newspaper), avbrief.com (aviation news), manus.im (Chinese AI agent startup), antirez.com (Redis engineer), 0x44.xyz (security researcher), addyosmani.com (Google engineer), jalammar.github.io (Transformer explainer).",
	t5Body2: isVi
		? "\"Tôi đọc bài từ khắp nơi\" không hẳn đúng theo khối lượng — phần lớn là nghề. Nhưng các góc hẹp này là thật. Mỗi góc một bài, mỗi bài một niềm tò mò. Bề rộng không sống ở khối lượng. Sống ở các góc, và các góc được yêu."
		: "\"I read articles from everywhere\" isn't quite right by volume — the bulk is craft. But these narrow corners are real. One article per corner, one curiosity per article. Breadth doesn't live in volume. It lives in the corners, and the corners are loved.",

	t6Title: isVi ? "VI. Người Thợ, Với Sở Thích Bên Cạnh" : "VI. A Craftsman, With Hobbies On The Side",
	t6Body1: isVi
		? "Sáu đặc điểm — kỹ sư 3 giờ chiều, người chơi cá thuộc Latin, kẻ lang thang Wikipedia, người đọc hai tiếng, các góc bề rộng — tổng hợp thành một chân dung nhất quán."
		: "Six traits — the 3 PM engineer, the Latin-name hobbyist, the midnight Wanderer, the bilingual reader, the corners-of-breadth — add up to one consistent portrait.",
	t6Body2: isVi
		? "Người thợ thủ công đọc để giữ tay nghề, với những lòng trung thành sâu bên cạnh — Manchester United, hồ cá, tin Việt Nam. Không phải học giả khảo sát mọi châu lục. Nhưng cũng không phải kỹ sư hẹp. Đó là cái gì đó cụ thể hơn: một người mang công việc của mình vào mọi thứ anh đọc, và mang sự yêu mến vào những góc còn lại."
		: "A craftsman reading to stay sharp, with deep loyalties on the side — Manchester United, fish-keeping, Vietnamese news. Not a polymath surveying every continent. But also not a narrow engineer. It's something more specific: a person who brings his work into everything he reads, and brings affection into the corners that remain.",

	refTitle: isVi ? "Phụ Lục — Phân Tích Theo Môn" : "Reference — Breakdown by Subject",
	refBody: isVi ? "Bảng số liệu hỗ trợ các đặc điểm ở trên." : "The numbers backing the traits above.",
	refColSubj: isVi ? "Môn" : "Subject",
	refColCount: isVi ? "Bài" : "Articles",
	refColShare: isVi ? "Tỷ lệ" : "Share",
	refColTop: isVi ? "Outlets hàng đầu" : "Top outlets",

	cavTitle: isVi ? "Lưu Ý — Những Gì Không Thể Cho Thấy" : "Caveats — What This Cannot Show",
	caveats: isVi
		? [
			["Khoảng thời gian.", `Takeout chỉ trả về ${SNAPSHOT.spanDays} ngày — bất cứ điều gì trước ${SNAPSHOT.rangeStart} đều vô hình.`],
			["Đặc điểm là phỏng đoán.", "Trên ~4.000 bài viết được lọc. Mẫu lớn hơn có thể tinh chỉnh."],
			["Độ sâu đọc.", "Một tiêu đề có thể là đóng tab 3 giây hoặc đọc sâu 30 phút. Chrome không ghi thời gian dừng."],
			["Thiết bị khác.", "Bài đọc trên điện thoại hoặc tablet (không sync) không xuất hiện."],
			["Ẩn danh.", "Bất cứ thứ gì mở trong chế độ ẩn danh đều vô hình."],
		]
		: [
			["Time horizon.", `Takeout returned only ${SNAPSHOT.spanDays} days — anything before ${SNAPSHOT.rangeStart} is invisible.`],
			["Traits are inferred.", "From ~4,000 filtered articles. A larger sample might refine these."],
			["Reading depth.", "A title could be a 3-second tab close or a 30-minute deep read. Chrome doesn't record dwell."],
			["Other devices.", "Articles read on phone or tablet (without sync) don't appear here."],
			["Incognito.", "Anything opened in private mode is invisible."],
		],
	footnote: isVi
		? `Tạo từ Google Takeout export ngày ${SNAPSHOT.exported}. Dữ liệu nguồn được giữ riêng tư.`
		: `Generated from Google Takeout export of ${SNAPSHOT.exported}. Source data is kept private.`,
};

const formatDate = (iso: string) => {
	const d = new Date(iso);
	return isVi
		? `${d.getDate()} tháng ${d.getMonth() + 1}, ${d.getFullYear()}`
		: d.toLocaleDateString("en-US", { day: "numeric", month: "long", year: "numeric" });
};
---

<Base
	title={t.pageTitle}
	description={t.pageDesc}
	breadcrumbs={[
		{ label: isVi ? "Phòng Cần Thiết" : "Room of Requirement", href: "/room-of-requirement" },
		{ label: t.pageTitle },
	]}
>
	<article class="ow">
		<header class="ow-hdr">
			<h1 class="ow-title">{t.pageTitle}</h1>
			<p class="ow-sub">{t.pageDesc}</p>
			<blockquote class="ow-quote">{t.dumbledore}</blockquote>
			<p class="ow-intro"><strong>{t.introTitle}</strong> {t.introBody}</p>
			<p class="ow-window">
				{formatDate(SNAPSHOT.rangeStart)} → {formatDate(SNAPSHOT.rangeEnd)} · {SNAPSHOT.spanDays} {isVi ? "ngày" : "days"} · {SNAPSHOT.articlesAfterFilter.toLocaleString()} {isVi ? "bài viết" : "articles"}
			</p>
		</header>

		<section class="ow-trait">
			<h2 class="ow-h2">{t.t1Title}</h2>
			<p class="ow-body">{t.t1Body1}</p>
			<p class="ow-body">{t.t1Body2}</p>
		</section>

		<section class="ow-trait">
			<h2 class="ow-h2">{t.t2Title}</h2>
			<p class="ow-body">{t.t2Body1}</p>
			<p class="ow-body">{t.t2Body2}</p>
		</section>

		<section class="ow-trait">
			<h2 class="ow-h2">{t.t3Title}</h2>
			<p class="ow-body">{t.t3Body1}</p>
			<p class="ow-body">{t.t3Body2}</p>
		</section>

		<section class="ow-trait">
			<h2 class="ow-h2">{t.t4Title}</h2>
			<p class="ow-body">{t.t4Body1}</p>
			<p class="ow-body">{t.t4Body2}</p>
		</section>

		<section class="ow-trait">
			<h2 class="ow-h2">{t.t5Title}</h2>
			<p class="ow-body">{t.t5Body1}</p>
			<p class="ow-body">{t.t5Body2}</p>
		</section>

		<section class="ow-trait ow-synth">
			<h2 class="ow-h2">{t.t6Title}</h2>
			<p class="ow-body">{t.t6Body1}</p>
			<p class="ow-body">{t.t6Body2}</p>
		</section>

		<section class="ow-ref">
			<h2 class="ow-h2">{t.refTitle}</h2>
			<p class="ow-em">{t.refBody}</p>
			<div class="ow-table-wrap">
				<table class="ow-table">
					<thead>
						<tr><th>{t.refColSubj}</th><th class="num">{t.refColCount}</th><th class="num">{t.refColShare}</th><th>{t.refColTop}</th></tr>
					</thead>
					<tbody>
						{SUBJECTS.map((s) => (
							<tr>
								<td><span class="ow-icon">{s.icon}</span> {isVi ? s.keyVi : s.keyEn}</td>
								<td class="num">{s.count.toLocaleString()}</td>
								<td class="num">{s.share.toFixed(1)}%</td>
								<td class="ow-tophosts">{s.topHosts.map(([h, n]) => `${h} (${n})`).join(", ")}</td>
							</tr>
						))}
						<tr class="ow-rest">
							<td><span class="ow-icon">❓</span> {isVi ? "Đuôi dài (450 host hiếm)" : "Long tail (450 rare hosts)"}</td>
							<td class="num">{widerCount.toLocaleString()}</td>
							<td class="num">{(widerCount / SNAPSHOT.articlesAfterFilter * 100).toFixed(1)}%</td>
							<td class="ow-tophosts">—</td>
						</tr>
					</tbody>
				</table>
			</div>
		</section>

		<section class="ow-trait">
			<h2 class="ow-h2">{t.cavTitle}</h2>
			<ul class="ow-caveats">
				{t.caveats.map(([term, body]) => (
					<li><strong>{term}</strong> {body}</li>
				))}
			</ul>
		</section>

		<footer class="ow-foot">
			<p>{t.footnote}</p>
		</footer>
	</article>
</Base>

<style>
	.ow { max-width: var(--wide-width); margin: 0 auto; padding: var(--spacing-12) var(--spacing-8) var(--spacing-16); }
	.ow-hdr { margin-bottom: var(--spacing-12); }
	.ow-title { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); font-weight: var(--font-weight-display); letter-spacing: -0.02em; color: var(--color-text); margin: 0 0 var(--spacing-3); }
	.ow-sub { font-family: var(--font-sans); font-size: var(--font-size-md); color: var(--color-muted); font-style: italic; margin: 0 0 var(--spacing-5); max-width: 70ch; }
	.ow-quote { font-family: var(--font-sans); font-style: italic; color: var(--color-text-secondary); border-left: 2px solid var(--color-border); padding: var(--spacing-2) 0 var(--spacing-2) var(--spacing-4); margin: 0 0 var(--spacing-5); max-width: 70ch; }
	.ow-intro { font-family: var(--font-sans); color: var(--color-text); line-height: var(--leading-relaxed); margin: 0 0 var(--spacing-3); max-width: 70ch; }
	.ow-window { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--color-muted); margin: 0; }

	.ow-trait { margin-top: var(--spacing-12); }
	.ow-h2 { font-family: var(--font-display); font-size: clamp(1.4rem, 2.4vw, 1.8rem); font-weight: var(--font-weight-display); color: var(--color-text); margin: 0 0 var(--spacing-4); letter-spacing: -0.01em; }
	.ow-body { font-family: var(--font-sans); font-size: var(--font-size-md); color: var(--color-text); line-height: var(--leading-relaxed); margin: 0 0 var(--spacing-3); max-width: 70ch; }
	.ow-em { font-family: var(--font-sans); font-size: var(--font-size-sm); font-style: italic; color: var(--color-text-secondary); margin: 0 0 var(--spacing-4); max-width: 70ch; }
	.ow-icon { display: inline-block; margin-right: 0.3em; }

	.ow-synth { padding: var(--spacing-6) var(--spacing-6); background: var(--color-surface-elevated); border: 1px solid var(--color-border); border-radius: var(--radius); }

	.ow-ref { margin-top: var(--spacing-14); }
	.ow-table-wrap { overflow-x: auto; margin: var(--spacing-4) 0 var(--spacing-3); border: 1px solid var(--color-border); border-radius: var(--radius); background: var(--color-surface-elevated); }
	.ow-table { width: 100%; border-collapse: collapse; font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.ow-table thead th { text-align: left; padding: var(--spacing-3) var(--spacing-4); font-family: var(--font-mono); font-size: var(--font-size-xs); font-weight: 500; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.04em; border-bottom: 1px solid var(--color-border); background: var(--color-surface); }
	.ow-table tbody td { padding: var(--spacing-2) var(--spacing-4); color: var(--color-text); border-bottom: 1px solid var(--color-border); vertical-align: top; }
	.ow-table tbody tr:last-child td { border-bottom: 0; }
	.ow-table .num { text-align: right; font-variant-numeric: tabular-nums; font-family: var(--font-mono); }
	.ow-table .ow-tophosts { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--color-text-secondary); }
	.ow-table .ow-rest td { color: var(--color-muted); font-style: italic; }

