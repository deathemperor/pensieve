---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import { getCurrentLang } from "../../utils/lang";
import { setCachePolicy } from "../../lib/cachePolicy";
setCachePolicy(Astro, "static");

const isVi = getCurrentLang(Astro) === "vi";

// Frozen snapshot — Google Takeout (Chrome history) + My Activity (Discover) export 2026-05-03.
// Sources gitignored under takeout/. To refresh: re-run analyzers and update.

const SNAPSHOT = {
	exported: "2026-05-03",
	chromeStart: "2025-05-04",
	chromeEnd: "2026-05-03",
	chromeDays: 365,
	chromeArticles: 3977,
	discoverStart: "2025-03-30",
	discoverEnd: "2026-05-03",
	discoverDays: 400,
	discoverTaps: 352,
	combinedTotal: 4329,
};

const t = {
	pageTitle: isVi ? "Cú Đường — Năm Đọc" : "The Owlery — A Year of Reading",
	pageDesc: isVi
		? "Bảy đặc điểm cá tính được rút từ cả việc đọc có chủ ý (Chrome) lẫn việc đọc do thuật toán mang đến (iOS Discover). Cùng một người, hai bề mặt."
		: "Seven personality traits drawn from both deliberate reading (Chrome) and algorithmically-delivered reading (iOS Discover). Same person, two surfaces.",
	dumbledore: isVi
		? '"Lời nói, theo ý kiến không hề khiêm tốn của tôi, là nguồn ma thuật vô tận nhất của chúng ta." — Albus Dumbledore'
		: '"Words are, in my not-so-humble opinion, our most inexhaustible source of magic." — Albus Dumbledore',
	intro: isVi
		? `Hai cửa sổ vào cùng một người đọc. Chrome desktop (cú tôi gửi đi — ${SNAPSHOT.chromeArticles.toLocaleString()} bài tự tìm trong ${SNAPSHOT.chromeDays} ngày, sau khi loại tab công việc) và feed Discover trên iOS (cú đến tay — ${SNAPSHOT.discoverTaps} lượt chạm bài thuật toán chọn trong ${SNAPSHOT.discoverDays} ngày). Đây là những gì các bài viết — không phải tên miền — nói về tôi.`
		: `Two windows into the same reader. Chrome desktop (owls I send out — ${SNAPSHOT.chromeArticles.toLocaleString()} articles I sought across ${SNAPSHOT.chromeDays} days, after work tabs are stripped) and the iOS Discover feed (owls that arrive — ${SNAPSHOT.discoverTaps} taps to articles the algorithm chose across ${SNAPSHOT.discoverDays} days). What follows is what the articles — not the domain names — say about me.`,

	t1Title: isVi ? "I. Người Tra Lỗi Lúc 3 Giờ Chiều" : "I. The 3-PM Lookup Engineer",
	t1Body1: isVi
		? 'Khi code hỏng lúc 3 giờ chiều, anh tìm. Copy thông báo lỗi, dán vào ô tìm kiếm, đọc câu trả lời được upvote nhất. Mỗi ngày, không cách nào khác. "How to flush DNS cache." "Why is my Next.js page returning JSON instead of HTML." "TypeScript union type assertion." "Cocoapods private pods setup." "Eslint rule for arrow function expressions."'
		: 'When code breaks at 3 PM, he looks it up. Copy the error message, paste it in the search box, read the highest-voted answer. Every day, no other way. "How to flush DNS cache." "Why is my Next.js page returning JSON instead of HTML." "TypeScript union type assertion." "Cocoapods private pods setup." "Eslint rule for arrow function expressions."',
	t1Body2: isVi
		? "Đây là người thợ giải bài toán nhỏ liên tục. Đọc không phải để giải trí — đọc để mở khóa bước tiếp. 22% việc đọc Chrome là loại này; cộng thêm 14% paper AI và Claude SDK docs. Tổng cộng khoảng 44% năm đọc là phần kéo dài của ngày làm việc."
		: "This is a craftsman solving small problems on repeat. Reading isn't for pleasure — it's to unblock the next move. 22% of Chrome reading is this kind of lookup; plus 14% AI papers and Claude SDK docs. Combined: roughly 44% of the year-of-reading is an extension of the workday.",

	t2Title: isVi ? "II. Người Hâm Mộ Manchester United 17 Năm" : "II. The 17-Year Manchester United Lifer",
	t2Body1: isVi
		? 'Mainoo. Garnacho. Mbeumo. "Lisandro Martinez on his recovery." "List of managers out of contract." "Eric Cantona asked to front Manchester United documentary." "ANOTHER Bruno Assist | Chelsea v Man Utd Extended Highlights." Trên Discover, 159 lượt chạm X threads — phần lớn là MU. Trên YouTube, 223 lượt xem kênh chính thức của United.'
		: 'Mainoo. Garnacho. Mbeumo. "Lisandro Martinez on his recovery." "List of managers out of contract." "Eric Cantona asked to front Manchester United documentary." "ANOTHER Bruno Assist | Chelsea v Man Utd Extended Highlights." On Discover, 159 X-thread taps — most of them MU. On YouTube, 223 watches of the official United channel.',
	t2Body2: isVi
		? "Qua mọi thay đổi thuật toán, mọi đổi việc, mọi đổi nước, đội bóng vẫn hiện lên vì nó vẫn quan trọng. 105 lần tìm \"mu fixtures\" qua nhiều năm nói cùng một điều. Đây không phải fan thời vụ. Đây là lòng trung thành đời người."
		: "Through every algorithm change, every job change, every country change, the team keeps coming up because it keeps mattering. The 105 lifetime \"mu fixtures\" searches say the same thing. Not a casual fan. A lifelong loyalist.",

	t3Title: isVi ? "III. Người Đọc Bản Ra Mắt Hằng Ngày" : "III. The Daily Releaser",
	t3Body1: isVi
		? '"Gemini 3 Pro: the frontier of vision AI." "More advanced AI capabilities…" "The cost-friendly MacBook upgrade." "I test Gemini for a living — here\'s what surprised me." "Orchestrating AI Code Review at scale." "GitHub announcements." Mỗi thông báo Apple, mỗi cập nhật Claude, mỗi bản ra mắt framework — anh đã đọc trước cà phê sáng.'
		: '"Gemini 3 Pro: the frontier of vision AI." "More advanced AI capabilities…" "The cost-friendly MacBook upgrade." "I test Gemini for a living — here\'s what surprised me." "Orchestrating AI Code Review at scale." "GitHub announcements." Every Apple announcement, every Claude SDK update, every framework release — read before morning coffee.',
	t3Body2: isVi
		? "29% lượt chạm Discover thuộc về loại này; 14% việc đọc Chrome cũng. Biết cái gì ship hôm nay là một phần của tay nghề, không phải tin tức. Đây là người thợ giữ nhịp một lĩnh vực chuyển động nhanh — không phải để mắt vào, mà để cả hai."
		: "29% of Discover taps are this category; 14% of Chrome reading is too. Knowing what shipped today is part of the craft, not news. This is a craftsman keeping pace with a fast-moving field — not keeping an eye on it, keeping both.",

	t4Title: isVi ? "IV. Người Chơi Cá Thuộc Tên Latin" : "IV. The Hobbyist Who Knows the Latin Names",
	t4Body1: isVi
		? '"Astatheros macracanthus." "Oscura heterospila." "Motaguense." Tên loài cichlid Latin nhập từ trí nhớ, qua nhiều năm, nhiều lần. Cộng thêm "Plant Profile — Flame Moss," "Rare Wild Betta Fish," "Nature Aquarium World — Takashi Amano," "Reverse Osmosis Filters & Accessories."'
		: '"Astatheros macracanthus." "Oscura heterospila." "Motaguense." Latin cichlid species names typed from memory, over many years, many times. Plus "Plant Profile — Flame Moss," "Rare Wild Betta Fish," "Nature Aquarium World — Takashi Amano," "Reverse Osmosis Filters & Accessories."',
	t4Body2: isVi
		? "Hầu hết người chơi cá nói \"cichlid vàng\" hoặc \"cá Trung Mỹ\". Anh không. Sở thích này có chiều sâu sống ngoài lịch sử trình duyệt — sống trong phòng cá, trong tủ kính, trong tên Latin đã thuộc lòng. 3% theo khối lượng đọc, một trăm phần trăm theo độ chuyên."
		: "Most fishkeepers say \"yellow cichlid\" or \"Central American cichlid.\" He doesn't. This hobby's depth lives outside browser history — in the tank room, in the glass cabinet, in the Latin names committed to memory. 3% by volume, one-hundred percent by specificity.",

	t5Title: isVi ? "V. Kẻ Lang Thang Wikipedia Lúc Nửa Đêm" : "V. The Midnight Wikipedia Wanderer",
	t5Body1: isVi
		? '"Loạn 12 sứ quân." "Apple Computer, Inc. v. Microsoft Corp." "Honda CRF series." "Heimdall." "Saturday Night Live 50th Anniversary Special." "List of Michelin-starred restaurants in Vietnam." "List of countries by GDP (PPP)." "Quentin Tarantino." "The Bear (TV series)." "Ramanujan."'
		: '"Loạn 12 sứ quân." "Apple Computer, Inc. v. Microsoft Corp." "Honda CRF series." "Heimdall." "Saturday Night Live 50th Anniversary Special." "List of Michelin-starred restaurants in Vietnam." "List of countries by GDP (PPP)." "Quentin Tarantino." "The Bear (TV series)." "Ramanujan."',
	t5Body2: isVi
		? "Sáu chủ đề, một đêm — sứ quân Việt thế kỷ 10 gặp vụ kiện UI 1988 gặp xe trail Honda gặp thần Bắc Âu. Không cái nào cho công việc. Sự lang thang là thật và cụ thể. Khi anh không tra lỗi và không xem highlight, anh đọc cái này. 8% việc đọc — không nhiều, nhưng đậm đặc."
		: "Six subjects, one night — 10th-century Vietnamese warlords meet 1988 software lawsuits meet Honda trail bikes meet Norse gods. None for work. The wandering is real and specific. When he isn't looking up errors and isn't watching highlights, he reads this. 8% of reading — not much, but concentrated.",

	t6Title: isVi ? "VI. Người Đọc Hai Tiếng" : "VI. The Bilingual Reader",
	t6Body1: isVi
		? '"Shark Bình tham gia rửa tiền trong vụ Mr Pips lừa đảo 1.300 tỉ đồng." "Nam sinh Bách khoa Hà Nội gây sốt với Phở anh Hai." "HCMC\'s scoop of nostalgia, served." "Loạn 12 sứ quân — Wikipedia tiếng Việt." "Con ma nhà họ Hứa." "Danh sách Thủ tướng Chính phủ Việt Nam."'
		: '"Shark Bình tham gia rửa tiền trong vụ Mr Pips lừa đảo 1.300 tỉ đồng." "Nam sinh Bách khoa Hà Nội gây sốt với Phở anh Hai." "HCMC\'s scoop of nostalgia, served." "Loạn 12 sứ quân — Wikipedia tiếng Việt." "Con ma nhà họ Hứa." "Danh sách Thủ tướng Chính phủ Việt Nam."',
	t6Body2: isVi
		? "Tin Việt đọc bằng tiếng Việt. Phân tích quê nhà đọc bằng tiếng Anh (e.vnexpress, Tuổi Trẻ phiên bản English). Một quê hương, hai cửa sổ — không cái nào cảm thấy xa lạ. 16% Chrome reading là tiếng Việt; 5% lượt chạm Discover là báo Việt. Hai bề mặt nói cùng một thói quen."
		: "Vietnamese news read in Vietnamese. Home-country analysis read in English (e.vnexpress, Tuoi Tre's English edition). One country, two windows — neither feels foreign. 16% of Chrome reading is Vietnamese; 5% of Discover taps are Vietnamese press. Two surfaces, one habit.",

	t7Title: isVi ? "VII. Bài Đọc Một Lần, Không Quay Lại" : "VII. Read Once, Never Returned To",
	t7Body1: isVi
		? '"How I found a bypass in Google\'s big anti-adblock update." "21 Lessons From 14 Years at Google." "The Illustrated Transformer." "Don\'t fall into the anti-AI hype." "Sort your dependencies!" "Context Engineering for AI Agents: Lessons from Building Manus." "Why Software Is Eating the World." "United MAX Hit by Falling Object at 36,000 Feet."'
		: '"How I found a bypass in Google\'s big anti-adblock update." "21 Lessons From 14 Years at Google." "The Illustrated Transformer." "Don\'t fall into the anti-AI hype." "Sort your dependencies!" "Context Engineering for AI Agents: Lessons from Building Manus." "Why Software Is Eating the World." "United MAX Hit by Falling Object at 36,000 Feet."',
	t7Body2: isVi
		? "Mỗi bài đọc một lần, không bookmark, không quay lại. Không phải vì chúng dễ quên — mà vì chúng đã được đọc. Đây là người không lưu tài liệu để đọc lại; người đọc rồi đi. \"Tôi đọc bài từ khắp nơi\" không hẳn đúng theo khối lượng — nhưng các bài này là thật."
		: "Each read once, never bookmarked, never returned to. Not because they're forgettable — because they're done. This is someone who doesn't save articles to re-read; he reads, and moves on. \"I read articles from everywhere\" isn't quite right by volume — but these are real.",

	t8Title: isVi ? "VIII. Người Thợ Với Sở Thích Bên Cạnh" : "VIII. A Craftsman With Hobbies On The Side",
	t8Body1: isVi
		? "Bảy đặc điểm — kỹ sư 3 giờ chiều, người United đời người, người ra mắt hằng ngày, người chơi cá Latin, kẻ lang thang Wikipedia, người đọc hai tiếng, người đọc một lần — tổng hợp thành một chân dung nhất quán qua hai bề mặt."
		: "Seven traits — 3-PM engineer, lifelong United fan, daily releaser, Latin-name hobbyist, midnight Wanderer, bilingual reader, read-once-and-move-on — add up to one consistent portrait across two surfaces.",
	t8Body2: isVi
		? "Người thợ thủ công đọc để giữ tay nghề, với những lòng trung thành sâu bên cạnh. Không phải học giả khảo sát mọi châu lục. Cũng không phải kỹ sư hẹp. Cái gì đó cụ thể hơn: một người mang công việc vào mọi thứ anh đọc, và mang sự yêu mến vào những góc còn lại."
		: "A craftsman reading to stay sharp, with deep loyalties on the side. Not a polymath surveying every continent. Also not a narrow engineer. Something more specific: a person who brings his work into everything he reads, and brings affection into the corners that remain.",

	cavTitle: isVi ? "Lưu Ý — Những Gì Không Thể Cho Thấy" : "Caveats — What This Cannot Show",
	caveats: isVi
		? [
			["Tên miền không phải nội dung.", "Một số host được tải nền (script bên thứ ba, redirect, image CDN, đăng nhập) mà tôi không nhớ ghé thăm — chính tại sao báo cáo này dùng tiêu đề bài viết, không phải danh sách host."],
			["Khoảng thời gian.", `Chrome: ${SNAPSHOT.chromeDays} ngày. Discover: ${SNAPSHOT.discoverDays} ngày. Trước hai mốc đó: vô hình.`],
			["Đặc điểm là phỏng đoán.", "Trên ~4.300 bài tổng cộng. Mẫu lớn hơn có thể tinh chỉnh."],
			["Độ sâu đọc không biết.", "Một tiêu đề có thể là đóng tab 3 giây hoặc đọc sâu 30 phút."],
			["Thiết bị khác / ẩn danh.", "Bài đọc trên điện thoại không sync, hoặc trong chế độ ẩn danh, không xuất hiện."],
		]
		: [
			["Domains aren't content.", "Some hosts are loaded in the background (3rd-party scripts, redirects, image CDNs, login flows) that I have no memory of visiting — which is exactly why this report quotes article titles, not host lists."],
			["Time horizon.", `Chrome: ${SNAPSHOT.chromeDays} days. Discover: ${SNAPSHOT.discoverDays} days. Before those: invisible.`],
			["Traits are inferred.", "From ~4,300 articles total. A larger sample might refine these."],
			["Reading depth is unknown.", "A title could be a 3-second tab close or a 30-minute deep read."],
			["Other devices / incognito.", "Articles read on phones without sync, or in private mode, don't appear."],
		],
	footnote: isVi
		? `Tạo từ Google Takeout (Chrome) và My Activity (Discover) export ngày ${SNAPSHOT.exported}. Dữ liệu nguồn được giữ riêng tư.`
		: `Generated from Google Takeout (Chrome) and My Activity (Discover) exports of ${SNAPSHOT.exported}. Source data is kept private.`,
};

const formatDate = (iso: string) => {
	const d = new Date(iso);
	return isVi
		? `${d.getDate()} tháng ${d.getMonth() + 1}, ${d.getFullYear()}`
		: d.toLocaleDateString("en-US", { day: "numeric", month: "long", year: "numeric" });
};
---

<Base
	title={t.pageTitle}
	description={t.pageDesc}
	breadcrumbs={[
		{ label: isVi ? "Phòng Cần Thiết" : "Room of Requirement", href: "/room-of-requirement" },
		{ label: t.pageTitle },
	]}
>
	<article class="ow">
		<header class="ow-hdr">
			<h1 class="ow-title">{t.pageTitle}</h1>
			<p class="ow-sub">{t.pageDesc}</p>
			<blockquote class="ow-quote">{t.dumbledore}</blockquote>
			<p class="ow-intro">{t.intro}</p>
			<p class="ow-window">
				{isVi ? "Chrome:" : "Chrome:"} {formatDate(SNAPSHOT.chromeStart)} → {formatDate(SNAPSHOT.chromeEnd)}
				· {isVi ? "Discover:" : "Discover:"} {formatDate(SNAPSHOT.discoverStart)} → {formatDate(SNAPSHOT.discoverEnd)}
				· {SNAPSHOT.combinedTotal.toLocaleString()} {isVi ? "bài tổng cộng" : "articles total"}
			</p>
		</header>

		<section class="ow-trait">
			<h2 class="ow-h2">{t.t1Title}</h2>
			<p class="ow-body">{t.t1Body1}</p>
			<p class="ow-body">{t.t1Body2}</p>
		</section>

		<section class="ow-trait">
			<h2 class="ow-h2">{t.t2Title}</h2>
			<p class="ow-body">{t.t2Body1}</p>
			<p class="ow-body">{t.t2Body2}</p>
		</section>

		<section class="ow-trait">
			<h2 class="ow-h2">{t.t3Title}</h2>
			<p class="ow-body">{t.t3Body1}</p>
			<p class="ow-body">{t.t3Body2}</p>
		</section>

		<section class="ow-trait">
			<h2 class="ow-h2">{t.t4Title}</h2>
			<p class="ow-body">{t.t4Body1}</p>
			<p class="ow-body">{t.t4Body2}</p>
		</section>

		<section class="ow-trait">
			<h2 class="ow-h2">{t.t5Title}</h2>
			<p class="ow-body">{t.t5Body1}</p>
			<p class="ow-body">{t.t5Body2}</p>
		</section>

		<section class="ow-trait">
			<h2 class="ow-h2">{t.t6Title}</h2>
			<p class="ow-body">{t.t6Body1}</p>
			<p class="ow-body">{t.t6Body2}</p>
		</section>

		<section class="ow-trait">
			<h2 class="ow-h2">{t.t7Title}</h2>
			<p class="ow-body">{t.t7Body1}</p>
			<p class="ow-body">{t.t7Body2}</p>
		</section>

		<section class="ow-trait ow-synth">
			<h2 class="ow-h2">{t.t8Title}</h2>
			<p class="ow-body">{t.t8Body1}</p>
			<p class="ow-body">{t.t8Body2}</p>
		</section>

		<section class="ow-trait">
			<h2 class="ow-h2">{t.cavTitle}</h2>
			<ul class="ow-caveats">
				{t.caveats.map(([term, body]) => (
					<li><strong>{term}</strong> {body}</li>
				))}
			</ul>
		</section>

		<footer class="ow-foot">
			<p>{t.footnote}</p>
		</footer>
	</article>
</Base>

<style>
	.ow { max-width: var(--wide-width); margin: 0 auto; padding: var(--spacing-12) var(--spacing-8) var(--spacing-16); }
	.ow-hdr { margin-bottom: var(--spacing-12); }
	.ow-title { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); font-weight: var(--font-weight-display); letter-spacing: -0.02em; color: var(--color-text); margin: 0 0 var(--spacing-3); }
	.ow-sub { font-family: var(--font-sans); font-size: var(--font-size-md); color: var(--color-muted); font-style: italic; margin: 0 0 var(--spacing-5); max-width: 70ch; }
	.ow-quote { font-family: var(--font-sans); font-style: italic; color: var(--color-text-secondary); border-left: 2px solid var(--color-border); padding: var(--spacing-2) 0 var(--spacing-2) var(--spacing-4); margin: 0 0 var(--spacing-5); max-width: 70ch; }
	.ow-intro { font-family: var(--font-sans); color: var(--color-text); line-height: var(--leading-relaxed); margin: 0 0 var(--spacing-3); max-width: 70ch; }
	.ow-window { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--color-muted); margin: 0; }

	.ow-trait { margin-top: var(--spacing-12); }
	.ow-h2 { font-family: var(--font-display); font-size: clamp(1.4rem, 2.4vw, 1.8rem); font-weight: var(--font-weight-display); color: var(--color-text); margin: 0 0 var(--spacing-4); letter-spacing: -0.01em; }
	.ow-body { font-family: var(--font-sans); font-size: var(--font-size-md); color: var(--color-text); line-height: var(--leading-relaxed); margin: 0 0 var(--spacing-3); max-width: 70ch; }

	.ow-synth { padding: var(--spacing-6) var(--spacing-6); background: var(--color-surface-elevated); border: 1px solid var(--color-border); border-radius: var(--radius); }

	.ow-caveats { list-style: none; padding: 0; margin: var(--spacing-4) 0 0; display: flex; flex-direction: column; gap: var(--spacing-3); }
	.ow-caveats li { font-family: var(--font-sans); font-size: var(--font-size-sm); color: var(--color-text); line-height: var(--leading-relaxed); padding-left: var(--spacing-4); border-left: 2px solid var(--color-border); max-width: 75ch; }

	.ow-foot { margin-top: var(--spacing-12); padding-top: var(--spacing-5); border-top: 1px solid var(--color-border); }
	.ow-foot p { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--color-muted); margin: 0; }

	@media (max-width: 700px) {
		.ow { padding: var(--spacing-8) var(--spacing-5) var(--spacing-12); }
	}
</style>
