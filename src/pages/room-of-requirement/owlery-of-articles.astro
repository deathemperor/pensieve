---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import { getCurrentLang } from "../../utils/lang";
import { setCachePolicy } from "../../lib/cachePolicy";
setCachePolicy(Astro, "static");

const isVi = getCurrentLang(Astro) === "vi";

// ────────────────────────────────────────────────────────────────────
// Frozen snapshot — Chrome history Takeout export 2026-05-03.
// Source data + analyzer in takeout/chrome/ (gitignored).
// To refresh: re-run takeout/chrome/analyze.py and update the constants below.
// ────────────────────────────────────────────────────────────────────

const SNAPSHOT = {
	exported: "2026-05-03",
	rangeStart: "2025-05-04",
	rangeEnd: "2026-05-03",
	spanDays: 365,
	totalHistoryEntries: 83850,
	articlesAfterFilter: 3977,
	rareUniqueHosts: 450,
};

interface Subject {
	icon: string;
	keyEn: string;
	keyVi: string;
	blurbEn: string;
	blurbVi: string;
	count: number;
	share: number;
	topHosts: Array<[string, number]>;
	samples: Array<[string, string]>; // [host, title]
}

const SUBJECTS: Subject[] = [
	{
		icon: "🪄",
