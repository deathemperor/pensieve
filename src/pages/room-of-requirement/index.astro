  .floo-ember.glow { animation: emberRise 1.3s ease-out forwards !important; }
  @keyframes emberRise { 0% { opacity: 1; transform: translate(0, 0); } 100% { opacity: 0; transform: translate(var(--dx, 0), -200px); } }
  .floo-smoke {
