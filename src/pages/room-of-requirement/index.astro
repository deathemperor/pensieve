  .dash-panel.pulling { animation: portkeyPull 1.1s cubic-bezier(0.4,0,0.2,1) forwards !important; }
  @keyframes portkeyPull {
    0% { transform: rotate(0deg) scale(1); }
    10% { border-color: #d4a843; box-shadow: 0 0 20px rgba(212,168,67,0.5); }
    20% { transform: rotate(3deg) scale(1.02); box-shadow: 0 0 40px rgba(212,168,67,0.6), inset 0 0 30px rgba(212,168,67,0.2); }
    35% { transform: rotate(-2deg) scale(1.03); box-shadow: 0 0 60px rgba(212,168,67,0.7); }
    50% { transform: rotate(5deg) scale(1); }
    65% { transform: rotate(-4deg) scale(0.9); }
    80% { transform: rotate(15deg) scale(0.6); opacity: 0.5; filter: blur(3px); }
