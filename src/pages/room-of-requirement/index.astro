    8% { opacity: 0.3; filter: blur(0.5px); }
    16% { opacity: 0.95; filter: blur(0); }
    24% { opacity: 0.15; filter: blur(1px); box-shadow: 0 0 30px rgba(255,255,255,0.3); }
    35% { opacity: 0.8; transform: scale(1.01); filter: blur(0); }
    45% { opacity: 0.1; filter: blur(2px); }
    55% { opacity: 0.6; transform: scale(0.99); filter: blur(0); box-shadow: 0 0 60px rgba(200,200,255,0.4); }
    65% { opacity: 0.05; filter: blur(3px); }
    75% { opacity: 0.3; filter: blur(0); }
    85% { opacity: 0.02; filter: blur(4px); }
    100% { opacity: 0; filter: blur(4px); transform: scale(0.96); }
