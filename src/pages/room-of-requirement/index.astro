  .vanish-static.show { animation: staticFlicker 0.3s ease-in-out !important; }
  @keyframes staticFlicker { 0%, 100% { opacity: 0; } 50% { opacity: 0.9; } }
</style>

<script>
  // Size the door SVG trace to match actual panel dimensions
  // pathLength="100" normalizes so stroke-dasharray: 100 = full perimeter
  function sizeDoorTrace() {
    const stage = document.getElementById('stage-door');
    if (!stage) return;
    const panel = stage.querySelector('.dash-panel');
    const rect = panel.getBoundingClientRect();
    const w = rect.width + 2, h = rect.height + 2;
    const svg = stage.querySelector('.door-trace-svg svg');
    const rectEl = stage.querySelector('.trace-path');
    if (svg && rectEl) {
      svg.setAttribute('viewBox', `0 0 ${w} ${h}`);
      rectEl.setAttribute('width', w - 2);
      rectEl.setAttribute('height', h - 2);
    }
  }

  // Restore panels on back navigation
  window.addEventListener('pageshow', () => {
    document.querySelectorAll('.dash-stage').forEach(stage => {
      const panel = stage.querySelector('.dash-panel');
      if (panel) {
        panel.className = panel.className.replace(/\s*(diving|burning|casting|apparating|pulling|vanishing)\b/g, '');
        panel.style.cssText = '';
      }
      stage.classList.remove('tracing', 'door-open');
      stage.querySelectorAll('.pensieve-ripple,.pensieve-vortex,.pensieve-bubble,.pensieve-wisp,.floo-flame,.floo-ember,.floo-smoke,.floo-spark,.patronus-ray,.patronus-core,.apparition-crack,.apparition-lightning,.apparition-shockwave,.portkey-swirl,.portkey-spark,.portkey-trail,.vanish-shimmer,.vanish-static').forEach(e => e.remove());
    });
    sizeDoorTrace();
  });

  // Initial size
  sizeDoorTrace();
  window.addEventListener('resize', sizeDoorTrace);

  function spawn(container, className, styles, lifetime) {
    const el = document.createElement('div');
    el.className = className;
    Object.assign(el.style, styles);
    container.appendChild(el);
    if (lifetime) setTimeout(() => el.remove(), lifetime);
    return el;
  }

  function navigate(href, delay) {
    setTimeout(() => {
      if (document.startViewTransition) {
        document.startViewTransition(() => { window.location.href = href; });
      } else {
        window.location.href = href;
      }
    }, delay);
  }

  // Helper: trigger stage-level atmospheric glow with a color
  function atmoGlow(stage, color, lifetime) {
    stage.style.setProperty('--atmo-color', color);
    stage.classList.add('atmo-on');
    setTimeout(() => {
      stage.classList.remove('atmo-on');
      stage.classList.add('atmo-fade');
      setTimeout(() => stage.classList.remove('atmo-fade'), 300);
    }, lifetime);
  }

  const magic = {
    door(stage, panel, href) {
      sizeDoorTrace(); // ensure trace matches current panel size
      atmoGlow(stage, 'rgba(88,166,255,0.3)', 1600);
      stage.classList.add('tracing');
      setTimeout(() => stage.classList.add('door-open'), 900);
      navigate(href, 1800);
    },

    pensieve(stage, panel, href) {
      atmoGlow(stage, 'rgba(88,166,255,0.35)', 1300);
      panel.classList.add('diving');
      // Vortex swirl — bigger, longer-lasting
      const vortex = spawn(stage, 'pensieve-vortex', { left: '50%', top: '50%' });
      setTimeout(() => vortex.remove(), 1400);
      // 6 ripples for wider coverage
      for (let i = 0; i < 6; i++) {
        setTimeout(() => spawn(stage, 'pensieve-ripple', { left: '50%', top: '50%' }, 1400), i * 180 + 200);
      }
      // Silvery memory wisps drifting out
      for (let i = 0; i < 8; i++) {
        setTimeout(() => {
          const w = spawn(stage, 'pensieve-wisp', {
            left: '50%', top: '50%',
            '--wr': (i * 45 + Math.random() * 20) + 'deg',
          });
          requestAnimationFrame(() => w.classList.add('drift'));
          setTimeout(() => w.remove(), 1200);
        }, 200 + i * 60);
      }
      // Bubbles rising from the basin
      for (let i = 0; i < 12; i++) {
        setTimeout(() => {
          const size = 4 + Math.random() * 10;
          const b = spawn(stage, 'pensieve-bubble', {
            left: (20 + Math.random() * 60) + '%',
            bottom: (10 + Math.random() * 30) + '%',
            width: size + 'px', height: size + 'px',
            '--bdx': (Math.random() - 0.5) * 40 + 'px',
          });
          requestAnimationFrame(() => b.classList.add('rise'));
          setTimeout(() => b.remove(), 1400);
        }, 150 + i * 60);
      }
      navigate(href, 1400);
    },

    floo(stage, panel, href) {
      atmoGlow(stage, 'rgba(63,185,80,0.4)', 1100);
      panel.classList.add('burning');
      // Smoke plume expanding from the bottom
      const smoke = spawn(stage, 'floo-smoke', {});
      requestAnimationFrame(() => smoke.classList.add('bloom'));
      setTimeout(() => smoke.remove(), 1100);
      // Initial ignition sparks — 5 bright flashes
      for (let i = 0; i < 5; i++) {
        setTimeout(() => {
          const sp = spawn(stage, 'floo-spark', {
            left: (25 + Math.random() * 50) + '%',
            bottom: (20 + Math.random() * 30) + '%',
            transform: 'translate(-50%, -50%)',
          });
          requestAnimationFrame(() => sp.classList.add('flash'));
          setTimeout(() => sp.remove(), 400);
        }, 60 + i * 40);
      }
      // Dense flames — 35 of them across the width
      for (let i = 0; i < 35; i++) {
        setTimeout(() => {
          const width = 6 + Math.random() * 10;
          const height = 14 + Math.random() * 36;
          const greens = ['#3fb950', '#2ea043', '#56d364', '#4ac76a'];
          const color = greens[Math.floor(Math.random() * greens.length)];
          const f = spawn(stage, 'floo-flame', {
            left: (5 + Math.random() * 90) + '%',
            bottom: (-10 + Math.random() * 25) + '%',
            width: width + 'px',
            height: height + 'px',
            color: color,
            background: color,
          });
          requestAnimationFrame(() => f.classList.add('lit'));
          setTimeout(() => f.remove(), 1100);
        }, i * 25 + 80);
      }
      // Ember sparks rising
      for (let i = 0; i < 25; i++) {
        setTimeout(() => {
          const e = spawn(stage, 'floo-ember', {
            left: (10 + Math.random() * 80) + '%',
            bottom: (5 + Math.random() * 20) + '%',
            '--dx': (Math.random() - 0.5) * 80 + 'px',
          });
          requestAnimationFrame(() => e.classList.add('glow'));
          setTimeout(() => e.remove(), 1400);
        }, i * 40 + 150);
      }
      navigate(href, 1200);
    },

    patronus(stage, panel, href) {
      atmoGlow(stage, 'rgba(200,220,255,0.5)', 1300);
      panel.classList.add('casting');
      // Central flash core
      setTimeout(() => {
        const core = spawn(stage, 'patronus-core', { left: '50%', top: '50%', transform: 'translate(-50%,-50%)' });
        requestAnimationFrame(() => core.classList.add('active'));
        setTimeout(() => core.remove(), 1100);
      }, 300);
      // 16 rays at 22.5° intervals, bursting outward
      for (let i = 0; i < 16; i++) {
        setTimeout(() => {
          const r = spawn(stage, 'patronus-ray', {
            left: '50%', top: '50%',
            transform: `rotate(${i * 22.5}deg)`,
            transformOrigin: 'left center',
          });
          requestAnimationFrame(() => r.classList.add('burst'));
          setTimeout(() => r.remove(), 900);
        }, 400 + i * 15);
      }
      navigate(href, 1400);
    },

    apparition(stage, panel, href) {
      atmoGlow(stage, 'rgba(255,255,255,0.35)', 1000);
      panel.classList.add('apparating');
      // 4 lightning bolts striking down (was 3)
      for (let i = 0; i < 4; i++) {
        setTimeout(() => {
          const lx = 30 + Math.random() * 40;
          const l = spawn(stage, 'apparition-lightning', {
            left: lx + '%', top: '-10%',
            transform: `rotate(${(Math.random() - 0.5) * 12}deg)`,
          });
          requestAnimationFrame(() => l.classList.add('strike'));
          setTimeout(() => l.remove(), 300);
        }, 250 + i * 70);
      }
      // Big central crack flash
      setTimeout(() => {
        const c = spawn(stage, 'apparition-crack', { left: '50%', top: '50%', transform: 'translate(-50%,-50%)' });
        requestAnimationFrame(() => c.classList.add('pop'));
        setTimeout(() => c.remove(), 400);
      }, 550);
      // Shockwave ring at the squeeze-point
      setTimeout(() => {
        const sw = spawn(stage, 'apparition-shockwave', {});
        requestAnimationFrame(() => sw.classList.add('blast'));
        setTimeout(() => sw.remove(), 600);
      }, 600);
      navigate(href, 1100);
    },

    portkey(stage, panel, href) {
      atmoGlow(stage, 'rgba(212,168,67,0.4)', 1100);
      panel.classList.add('pulling');
      // Golden dust trail — spiraling ring
      const trail = spawn(stage, 'portkey-trail', {});
      requestAnimationFrame(() => trail.classList.add('spin'));
      setTimeout(() => trail.remove(), 1000);
      // 3 concentric swirls at different scales
      for (let i = 0; i < 3; i++) {
        setTimeout(() => {
          const size = 100 + i * 50;
          const sw = spawn(stage, 'portkey-swirl', {
            left: '50%', top: '50%',
            width: size + 'px', height: size + 'px',
          });
          requestAnimationFrame(() => sw.classList.add('active'));
          setTimeout(() => sw.remove(), 1200);
        }, 150 + i * 100);
      }
      // Golden sparks flying outward — 20 of them
      for (let i = 0; i < 20; i++) {
        setTimeout(() => {
          const angle = (i / 20) * Math.PI * 2 + Math.random() * 0.3;
          const dist = 100 + Math.random() * 100;
          const s = spawn(stage, 'portkey-spark', {
            left: '50%', top: '50%',
            '--dx': Math.cos(angle) * dist + 'px',
            '--dy': Math.sin(angle) * dist + 'px',
          });
          requestAnimationFrame(() => s.classList.add('fly'));
          setTimeout(() => s.remove(), 1000);
        }, 300 + i * 15);
      }
      navigate(href, 1200);
    },

    vanish(stage, panel, href) {
      atmoGlow(stage, 'rgba(200,200,255,0.3)', 1300);
      panel.classList.add('vanishing');
      // 5 shimmer sweeps during the phase-in/out
      for (let i = 0; i < 5; i++) {
        setTimeout(() => {
          const sh = spawn(stage, 'vanish-shimmer', {});
          requestAnimationFrame(() => sh.classList.add('sweep'));
          setTimeout(() => sh.remove(), 600);
        }, i * 220 + 80);
      }
      // Static noise flickers at each "solid" moment
      for (let i = 0; i < 6; i++) {
        setTimeout(() => {
          const st = spawn(stage, 'vanish-static', {});
          requestAnimationFrame(() => st.classList.add('show'));
          setTimeout(() => st.remove(), 300);
        }, 120 + i * 180);
      }
      navigate(href, 1400);
    },
  };

  document.querySelectorAll('[data-magic]').forEach(panel => {
    const type = panel.dataset.magic;
    const href = panel.getAttribute('href');
    if (!href || !magic[type]) return;
    const stage = panel.closest('.dash-stage');
    if (!stage) return;

    panel.addEventListener('click', (e) => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      e.preventDefault();
      magic[type](stage, panel, href);
    });
  });
</script>
