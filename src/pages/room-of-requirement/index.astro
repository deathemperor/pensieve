  .floo-spark.flash { animation: sparkFlash 0.4s ease-out forwards !important; }
  @keyframes sparkFlash {
    0% { opacity: 1; transform: translate(-50%, -50%) scale(0.3); }
    30% { opacity: 1; transform: translate(-50%, -50%) scale(2); }
    100% { opacity: 0; transform: translate(-50%, -50%) scale(0.5); }
  }

  /* ═══ Patronus particles ═══ */
  .patronus-core {
    position: absolute !important; width: 60px !important; height: 60px !important;
    border-radius: 50% !important; pointer-events: none !important; z-index: 3 !important;
    opacity: 0 !important;
    background: radial-gradient(circle, #fff, rgba(200,220,255,0.8) 30%, transparent 70%) !important;
    box-shadow: 0 0 80px rgba(200,220,255,0.8), 0 0 160px rgba(200,220,255,0.5) !important;
  }
  .patronus-core.active { animation: coreFlash 1.1s ease-out forwards !important; }
  @keyframes coreFlash {
    0% { opacity: 0; transform: translate(-50%,-50%) scale(0.3); }
