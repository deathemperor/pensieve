---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import { link } from "../../utils/link";
import { getCurrentLang } from "../../utils/lang";
import { arsenal } from "../../data/arsenal";
const isVi = getCurrentLang(Astro) === "vi";

const arsenalWands = arsenal.filter((i) => i.tier === "wand").length;
const arsenalTotal = arsenal.length;

const techStack = [
	{
		name: "Astro",
		role: isVi ? "Framework SSR" : "SSR framework",
		description: isVi ? "Trang server-rendered, không JS phía client mặc định" : "Server-rendered pages, zero client JS by default",
		url: "https://astro.build",
		color: "#FF5D01",
	},
	{
		name: "EmDash CMS",
		role: isVi ? "Quản lý nội dung" : "Content management",
		description: isVi ? "CMS gốc Astro với giao diện quản trị, bình luận, hệ thống plugin" : "Astro-native CMS with admin UI, comments, plugin system",
		url: "https://emdashcms.com",
		color: "#58a6ff",
	},
	{
		name: "Cloudflare Workers",
		role: isVi ? "Hosting & tính toán" : "Hosting & compute",
		description: isVi ? "Edge runtime — D1 (SQL), R2 (lưu trữ), KV (session), Cron Triggers" : "Edge runtime — D1 (SQL), R2 (storage), KV (sessions), Cron Triggers",
		url: "https://workers.cloudflare.com",
		color: "#F6821F",
	},
	{
		name: "Resend",
		role: isVi ? "Gửi email" : "Email delivery",
		description: isVi ? "Email giao dịch — bình luận, xác nhận đặt lịch, nhắc 24h" : "Transactional email — comments, booking confirmations, 24h reminders",
		url: "https://resend.com",
		color: "#3fb950",
	},
	{
		name: "Google Calendar",
		role: isVi ? "Đồng bộ lịch" : "Calendar sync",
		description: isVi ? "OAuth + Calendar API — kiểm tra rảnh, tạo sự kiện cho /book" : "OAuth + Calendar API — free/busy checks, event insert for /book",
		url: "https://developers.google.com/calendar",
		color: "#4285F4",
	},
	{
		name: "Claude Code",
		role: isVi ? "Lập trình viên AI" : "AI pair programmer",
		description: isVi ? "Tác tử CLI của Anthropic — xây dựng mọi dòng code của trang này" : "Anthropic's CLI agent — built every line of this site",
		url: "https://claude.com/claude-code",
		color: "#DA7756",
	},
	{
		name: "GitHub Actions",
		role: "CI/CD",
		description: isVi ? "Triển khai tự động khi push lên main" : "Automated deployment on push to main",
		url: "https://github.com/features/actions",
		color: "#2088FF",
	},
];

const agents = [
	{
		name: "session-logger",
		purpose: isVi ? "Ghi nhật ký xây dựng có cấu trúc sau mỗi phiên làm việc" : "Appends structured entries to the build diary after each work session",
	},
	{
		name: "moderate-comments",
		purpose: isVi ? "Duyệt, phê duyệt, đánh dấu spam, xóa bình luận qua API quản trị EmDash" : "Lists, approves, spams, trashes, or deletes comments via the EmDash admin API",
	},
	{
		name: "Explore",
		purpose: isVi ? "Khám phá codebase nhanh — tìm file, tìm kiếm code, trả lời câu hỏi kiến trúc" : "Fast codebase exploration — finds files, searches code, answers architecture questions",
	},
	{
		name: "Plan",
		purpose: isVi ? "Thiết kế chiến lược triển khai, xác định file quan trọng, cân nhắc đánh đổi" : "Designs implementation strategies, identifies critical files, weighs trade-offs",
	},
	{
		name: "geminio",
		purpose: isVi ? "Cảnh sát i18n — đảm bảo mọi text đều có song ngữ EN/VI" : "i18n police — ensures all text has bilingual EN/VI versions",
	},
	{
		name: "argus-filch",
		purpose: isVi ? "Tìm lỗi và sửa — tuần tra codebase tìm link hỏng, import thiếu, lỗi runtime" : "Bug finder — patrols codebase for broken links, missing imports, runtime errors",
	},
];

const plugins = [
	{
		name: "plugin-resend",
		purpose: isVi ? "Gửi email qua Resend API + thông báo bình luận" : "Email delivery via Resend API + comment notification emails",
	},
	{
		name: "plugin-forms",
		purpose: isVi ? "Xử lý biểu mẫu (tích hợp EmDash)" : "Form handling (EmDash built-in)",
	},
	{
		name: "plugin-webhook-notifier",
		purpose: isVi ? "Thông báo webhook khi nội dung/media thay đổi" : "Webhook notifications on content/media changes",
	},
	{
		name: "plugin-pensieve-engage",
		purpose: isVi ? "Đăng ký email, gửi bản tin, theo dõi click, phân tích đọc" : "Email subscriptions, newsletter dispatch, click tracking, reading analytics",
	},
];

// Task Observatory data from D1
import { env } from "cloudflare:workers";
const db = env.DB;
let taskSystems: { slug: string; name: string; tool: string; color: string; routes: string; open: number; done: number }[] = [];

const hpSystemDefs = [
  { slug: "remembrall", name: "Remembrall", tool: "Todoist", color: "#e5534b", routes: isVi ? "Suy nghĩ nhanh, nhắc nhở" : "Quick thoughts, reminders" },
  { slug: "marauders-map", name: "Marauder's Map", tool: "GitHub Issues", color: "#d4a843", routes: isVi ? "Lỗi code, yêu cầu tính năng" : "Code bugs, feature requests" },
  { slug: "owls", name: "O.W.L.s", tool: "Linear", color: "#7c3aed", routes: isVi ? "Dự án lớn, lộ trình" : "Epics, roadmap" },
  { slug: "room-of-requirement", name: "Room of Requirement", tool: "Notion", color: "#3fb950", routes: isVi ? "Ghi chú nghiên cứu, quyết định thiết kế" : "Research notes, design decisions" },
  { slug: "pensieve-strands", name: "Pensieve Strands", tool: "Session Tracker", color: "#58a6ff", routes: isVi ? "Nhật ký phiên tự động" : "Automatic session trail" },
  { slug: "marauders-parchment", name: "Marauder's Parchment", tool: "TASKS.md", color: "#d2a679", routes: isVi ? "Việc cần làm ngay trong repo" : "Immediate in-repo actions" },
];

if (db) {
  try {
    const counts = await db.prepare(
      "SELECT hp_system, status, COUNT(*) as count FROM tasks GROUP BY hp_system, status"
    ).all();
    const countMap = new Map<string, { open: number; done: number }>();
    for (const row of (counts.results ?? []) as any[]) {
      const existing = countMap.get(row.hp_system) ?? { open: 0, done: 0 };
      if (row.status === 'open' || row.status === 'in_progress') existing.open += row.count;
      else if (row.status === 'done') existing.done += row.count;
      countMap.set(row.hp_system, existing);
    }
    taskSystems = hpSystemDefs.map(sys => ({
      ...sys,
      open: countMap.get(sys.slug)?.open ?? 0,
      done: countMap.get(sys.slug)?.done ?? 0,
    }));
  } catch {
    taskSystems = hpSystemDefs.map(sys => ({ ...sys, open: 0, done: 0 }));
  }
} else {
  taskSystems = hpSystemDefs.map(sys => ({ ...sys, open: 0, done: 0 }));
}

// Design docs from D1
let designDocs: { id: string; title: string; doc_type: string; project: string; summary: string; prompt: string; file_path: string; notion_url: string; line_count: number; created_at: string }[] = [];

if (db) {
  try {
    const docs = await db.prepare(
      "SELECT * FROM design_docs ORDER BY project, doc_type DESC"
    ).all();
    designDocs = (docs.results ?? []) as any[];
  } catch {
    designDocs = [];
  }
}

const docsByProject = new Map<string, typeof designDocs>();
for (const doc of designDocs) {
  const existing = docsByProject.get(doc.project) ?? [];
  existing.push(doc);
  docsByProject.set(doc.project, existing);
}

const totalSpecs = designDocs.filter(d => d.doc_type === 'spec').length;
const totalPlans = designDocs.filter(d => d.doc_type === 'plan').length;
const totalLines = designDocs.reduce((sum, d) => sum + (d.line_count ?? 0), 0);

// Task totals
let totalTasks = 0;
let openTasks = 0;
let doneTasks = 0;
if (db) {
  try {
    const r = await db.prepare("SELECT status, COUNT(*) as count FROM tasks GROUP BY status").all();
    for (const row of (r.results ?? []) as any[]) {
      totalTasks += row.count;
      if (row.status === 'open' || row.status === 'in_progress') openTasks += row.count;
      else if (row.status === 'done') doneTasks += row.count;
    }
  } catch {}
}

// Wishlist (Diagon Alley) — count by priority for the hub card.
import { getEmDashCollection } from "emdash";
import { setCachePolicy } from "../../lib/cachePolicy";
setCachePolicy(Astro, "ror-hub");
let wishWant = 0;
let wishSomeday = 0;
let wishAcquired = 0;
try {
  const { entries: wishesRaw } = await getEmDashCollection("wishlist");
  for (const e of wishesRaw) {
    if (e.data.status !== "published") continue;
    const p = (e.data.priority ?? "want") as string;
    if (p === "acquired") wishAcquired++;
    else if (p === "someday") wishSomeday++;
    else wishWant++;
  }
} catch { /* collection unavailable — counts stay zero */ }
const wishTotal = wishWant + wishSomeday + wishAcquired;
---

<Base title="Room of Requirement" description={isVi ? "Trang web này được xây dựng như thế nào, từng phiên Claude Code" : "How this site is built, one Claude Code session at a time"} breadcrumbs={[{ label: "Room of Requirement" }]}>
  <!-- Hero -->
  <section class="room-hero">
    <div class="room-hero-inner">
      <div class="room-rule" />
      <span class="room-label">{isVi ? "Xây Dựng" : "The Build"}</span>
      <h1 class="room-title">Room of Requirement</h1>
      <p class="room-subtitle">
        {isVi ? "Trang web này được xây dựng hoàn toàn bởi" : "This site is built entirely by"}
        {" "}
        <a href="https://claude.com/claude-code" class="cc-link">Claude Code</a>,
        {isVi
          ? " tác tử AI lập trình của Anthropic. Mọi trang, plugin, triển khai và cấu hình đều được lập trình cặp trong terminal."
          : " Anthropic's AI coding agent. Every page, plugin, deployment, and configuration was pair-programmed in the terminal."}
      </p>
      <div class="hero-links">
        <a href="/room-of-requirement/priori-incantatem" class="diary-link">
          {isVi ? "Nhật ký xây dựng" : "Build diary"} &rarr;
        </a>
        <a href="/room-of-requirement/daily-prophet" class="diary-link">
          {isVi ? "Nhật Báo Tiên Tri" : "The Daily Prophet"} &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Dashboard Grid -->
  <section class="room-dashboard">
    <div class="dash-grid">

      <!-- 7: Vanishing Cabinet → What CC Does -->
      <div class="dash-stage dash-stage-full" id="stage-vanish">
        <div class="dash-panel">
          <div class="dash-panel-inner">
            <div class="dash-row">
              <div class="dash-role-group">
                <span class="dash-dot" style="background: var(--color-accent);" />
                <span class="dash-role-label" style="color: var(--color-accent);">Claude Code</span>
                <span class="dash-role-count">7 {isVi ? "vai trò" : "roles"}</span>
              </div>
              <div class="dash-role-group">
                <span class="dash-dot" style="background: #3fb950;" />
                <span class="dash-role-label" style="color: #3fb950;">{isVi ? "Con Người" : "Human"}</span>
                <span class="dash-role-count">5 {isVi ? "vai trò" : "roles"}</span>
              </div>
            </div>
            <span class="dash-muted-line">{isVi ? "Mã nguồn · Hạ tầng · CI/CD · Plugin · DNS · Kiến trúc · Git" : "Source code · Infrastructure · CI/CD · Plugins · DNS · Architecture · Git"}</span>
          </div>
        </div>
      </div>

      <!-- 5: Apparition → Architecture -->
      <div class="dash-stage dash-stage-full" id="stage-apparition">
        <div class="dash-panel">
          <div class="dash-panel-inner">
            <span class="dash-panel-title">{isVi ? "Kiến Trúc" : "Architecture"}</span>
            <div class="dash-tech-grid">
              {techStack.map((t) => (
                <a href={t.url} target="_blank" rel="noopener" class="dash-tech-item" style={`--tech-color: ${t.color};`}>
                  <span class="dash-tech-name">{t.name}</span>
                  <span class="dash-tech-role">{t.role}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- 6: Portkey → Source -->
      <div class="dash-stage" id="stage-portkey">
        <a href="https://github.com/deathemperor/pensieve" target="_blank" rel="noopener" class="dash-panel dash-nav-panel" data-magic="portkey">
          <div class="dash-panel-inner">
            <span class="dash-panel-title">{isVi ? "Mã Nguồn" : "Source"}</span>
            <div class="dash-row" style="gap: 6px;">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" style="color: var(--color-text);"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
              <span class="dash-mono">deathemperor/pensieve</span>
            </div>
          </div>
        </a>
      </div>

      <!-- 1: Wand Trace Door → Task Observatory -->
      <div class="dash-stage dash-stage-door" id="stage-door">
        <div class="door-glow"></div>
        <div class="door-trace-svg">
          <svg preserveAspectRatio="none">
            <defs>
              <linearGradient id="doorGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#58a6ff"/>
                <stop offset="35%" stop-color="#7c3aed"/>
                <stop offset="70%" stop-color="#d4a843"/>
                <stop offset="100%" stop-color="#58a6ff"/>
              </linearGradient>
            </defs>
            <rect class="trace-path" x="1" y="1" rx="12" ry="12" pathLength="100" vector-effect="non-scaling-stroke"/>
          </svg>
        </div>
        <a href="/room-of-requirement/task-observatory" class="dash-panel dash-nav-panel" data-magic="door">
          <div class="dash-panel-inner">
            <span class="dash-panel-title">{isVi ? "Đài Quan Sát" : "Task Observatory"}</span>
            <div class="dash-hp-dots">
              {taskSystems.map(sys => (
                <span class="dash-hp-dot">
                  <span class="dash-dot" style={`background: ${sys.color};`} />
                  <span style={`font-size: 10px; color: ${sys.color};`}>{sys.name}</span>
                </span>
              ))}
            </div>
            <span class="dash-panel-stat">
              {totalTasks} {isVi ? "nhiệm vụ" : "tasks"} · {openTasks} {isVi ? "mở" : "open"} / {doneTasks} {isVi ? "xong" : "done"} &rarr;
            </span>
          </div>
        </a>
        <div class="door-room">
          <div style="text-align: center;">
            <div class="door-room-title">{isVi ? "Đài Quan Sát" : "Task Observatory"}</div>
            <div class="door-room-hint">{isVi ? "đang vào..." : "entering..."}</div>
          </div>
        </div>
      </div>

      <!-- 2: Pensieve Dive → Restricted Section -->
      <div class="dash-stage" id="stage-pensieve">
        <a href="/room-of-requirement/restricted-section" class="dash-panel dash-nav-panel" data-magic="pensieve">
          <div class="dash-panel-inner">
            <span class="dash-panel-title">{isVi ? "Khu Cấm" : "The Restricted Section"}</span>
            <div class="dash-row" style="gap: 8px;">
              <span class="dash-badge dash-badge-spec">{totalSpecs} {isVi ? "thiết kế" : "specs"}</span>
              <span class="dash-badge dash-badge-plan">{totalPlans} {isVi ? "kế hoạch" : "plans"}</span>
            </div>
            <span class="dash-panel-stat">{docsByProject.size} {isVi ? "dự án" : "projects"} · {totalLines.toLocaleString()} {isVi ? "dòng" : "lines"} &rarr;</span>
          </div>
        </a>
      </div>

      <!-- 4: Patronus Burst → House-Elves -->
      <div class="dash-stage" id="stage-patronus">
        <a href="/room-of-requirement/house-elves" class="dash-panel dash-nav-panel" data-magic="patronus">
          <div class="dash-panel-inner">
            <span class="dash-panel-title">{isVi ? "Gia Tinh" : "House-Elves"}</span>
            <span class="dash-name-list">{agents.map(a => a.name).join(" · ")}</span>
            <span class="dash-panel-stat">{agents.length} {isVi ? "tác tử" : "agents"} &rarr;</span>
          </div>
        </a>
      </div>

      <!-- 3: Floo Network → Plugins -->
      <div class="dash-stage" id="stage-floo">
        <a href="/room-of-requirement/plugins" class="dash-panel dash-nav-panel" data-magic="floo">
          <div class="dash-panel-inner">
            <span class="dash-panel-title">Plugins</span>
            <span class="dash-name-list">{plugins.map(p => p.name.replace('plugin-', '')).join(" · ")}</span>
            <span class="dash-panel-stat">{plugins.length} plugins &rarr;</span>
          </div>
        </a>
      </div>

      <!-- Superpowers Artifacts -->
      <div class="dash-stage" id="stage-superpowers">
        <a href="https://github.com/deathemperor/pensieve/tree/main/.superpowers/brainstorm" target="_blank" rel="noopener" class="dash-panel dash-nav-panel" data-magic="portkey">
          <div class="dash-panel-inner">
            <span class="dash-panel-title">{isVi ? "Siêu Năng Lực" : "Superpowers"}</span>
            <span class="dash-name-list">{isVi ? "Bản xem trước brainstorm · Mockup tương tác · Lịch sử thiết kế" : "Brainstorm previews · Interactive mockups · Design history"}</span>
            <span class="dash-panel-stat">{isVi ? "Xem trên GitHub" : "View on GitHub"} &rarr;</span>
          </div>
        </a>
      </div>

      <!-- Diagon Alley → Wishlist -->
      <div class="dash-stage" id="stage-diagon">
        <a href="/room-of-requirement/diagon-alley" class="dash-panel dash-nav-panel" data-magic="diagon">
          <div class="dash-panel-inner">
            <span class="dash-panel-title">{isVi ? "Hẻm Xéo" : "Diagon Alley"}</span>
            <div class="dash-row" style="gap: 8px;">
              <span class="dash-badge dash-badge-want">{wishWant} {isVi ? "muốn" : "want"}</span>
              <span class="dash-badge dash-badge-someday">{wishSomeday} {isVi ? "khi nào đó" : "someday"}</span>
              {wishAcquired > 0 && (
                <span class="dash-badge dash-badge-acquired">{wishAcquired} {isVi ? "đã có" : "acquired"}</span>
              )}
            </div>
            <span class="dash-panel-stat">{wishTotal} {isVi ? "món đồ chờ chủ" : "items on the shelf"} &rarr;</span>
          </div>
        </a>
      </div>

      <!-- Mad-Eye's Trunk → Personal Arsenal -->
      <div class="dash-stage" id="stage-trunk">
        <a href="/room-of-requirement/the-trunk" class="dash-panel dash-nav-panel" data-magic="portkey">
          <div class="dash-panel-inner">
            <span class="dash-panel-title">{isVi ? "Rương Mắt Điên" : "Mad-Eye's Trunk"}</span>
            <span class="dash-name-list">{isVi ? "Đũa phép · Bùa chú · macOS · iPhone · CLI" : "Wands · Spells · macOS · iPhone · CLI"}</span>
            <span class="dash-panel-stat">{arsenalWands} {isVi ? "đũa phép" : "wands"} · {arsenalTotal} {isVi ? "vật phẩm" : "items"} &rarr;</span>
          </div>
        </a>
      </div>

    </div>
  </section>
</Base>

<style>
  /* Hero */
  .room-hero { position: relative; border-bottom: 1px solid var(--color-border); }
  .room-hero-inner { max-width: var(--wide-width); margin: 0 auto; padding: var(--spacing-24) var(--spacing-8) var(--spacing-20); }
  .room-rule { width: 24px; height: 1px; background: var(--color-accent); margin-bottom: var(--spacing-5); }
  .room-label { display: block; font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: 500; text-transform: uppercase; letter-spacing: var(--tracking-wider); color: var(--color-muted); margin-bottom: var(--spacing-4); }
  .room-title { font-family: var(--font-display); font-size: clamp(1.875rem, 3.5vw, 3rem); font-weight: var(--font-weight-display); line-height: 1.1; letter-spacing: -0.022em; color: var(--color-text); margin: 0 0 var(--spacing-5); }
  .room-subtitle { font-family: var(--font-sans); font-size: var(--font-size-base); line-height: var(--leading-relaxed); color: var(--color-text-secondary); max-width: 55ch; margin: 0 0 var(--spacing-6); }
  .cc-link { color: var(--color-accent); text-decoration: none; font-weight: 500; }
  .cc-link:hover { text-decoration: underline; }
  .hero-links { display: flex; gap: var(--spacing-6); }
  .diary-link { display: inline-block; font-family: var(--font-mono); font-size: var(--font-size-sm); color: var(--color-accent); text-decoration: none; transition: opacity var(--transition-fast); }
  .diary-link:hover { opacity: 0.8; }

  /* Dashboard grid — 900px inner matches the column width (~450px) the particle
     sizes were calibrated for in the brainstorm preview. */
  .room-dashboard { max-width: var(--wide-width); margin: 0 auto; padding: var(--spacing-8); }
  .dash-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-4); position: relative; max-width: 900px; margin: 0 auto; }

  /* Stage wrapper — holds particles, doesn't animate */
  .dash-stage { position: relative; border-radius: var(--radius-lg); opacity: 0; animation: materialize 0.4s ease-out forwards; }
  .dash-stage:nth-child(1) { animation-delay: 0ms; }
