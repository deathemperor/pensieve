    75% { opacity: 0.5; transform: scale(0.96) translateY(-12px); filter: blur(3px); box-shadow: 0 0 80px rgba(63,185,80,0.5); }
    100% { opacity: 0; transform: scale(0.85) translateY(-50px); filter: blur(8px); }
  }

  .dash-panel.casting { animation: patronusBurst 1.4s ease-out forwards !important; }
  @keyframes patronusBurst {
    0% {}
    12% { border-color: rgba(200,220,255,0.8); box-shadow: 0 0 30px rgba(200,220,255,0.4), inset 0 0 20px rgba(200,220,255,0.15); }
    28% { box-shadow: 0 0 80px rgba(200,220,255,0.6), inset 0 0 60px rgba(200,220,255,0.2); transform: scale(1.03); background: rgba(200,220,255,0.04); }
    45% { box-shadow: 0 0 140px rgba(200,220,255,0.8), 0 0 200px rgba(200,220,255,0.5); background: rgba(200,220,255,0.1); transform: scale(1.05); }
    65% { opacity: 0.7; transform: scale(1.08); filter: blur(1px); }
    85% { opacity: 0.2; filter: blur(5px); transform: scale(1.15); }
    100% { opacity: 0; filter: blur(10px); transform: scale(1.3); }
  }

  .dash-panel.apparating { animation: apparate 1s cubic-bezier(0.4,0,0.2,1) forwards !important; }
  @keyframes apparate {
    0% { transform: scale(1, 1); opacity: 1; }
    15% { transform: scale(1.03, 0.97); box-shadow: 0 0 30px rgba(212,168,67,0.4); }
    35% { transform: scale(0.3, 1.9); opacity: 0.7; filter: blur(3px); box-shadow: 0 0 60px rgba(255,255,255,0.5); }
    55% { transform: scale(0.08, 2.8); opacity: 0.4; filter: blur(5px); }
    75% { transform: scale(0.03, 3.5); opacity: 0.2; filter: blur(7px); }
    100% { transform: scale(0, 4); opacity: 0; filter: blur(10px); }
