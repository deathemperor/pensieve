---
export const prerender = false;

import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import { link } from "../../utils/link";
import { getCurrentLang } from "../../utils/lang";

const lang = getCurrentLang(Astro);
const isVi = lang === "vi";

const { entries: diaryRaw, cacheHint } = await getEmDashCollection("diary");
Astro.cache.set(cacheHint);

interface DiaryEntry {
	date: string;
	createdAt: string;
	title: string;
	type: "build" | "plan" | "fix" | "deploy";
	prompt: string;
	summary: string;
	model: string;
	claudeCode: string;
	inputTokens: number;
	outputTokens: number;
	cacheRead: number;
	cost: number;
}

const entries: DiaryEntry[] = diaryRaw
	.filter((e) => e.data.status === "published")
	.sort((a, b) => {
		const da = String(a.data.publishedAt ?? a.data.createdAt ?? "");
		const db = String(b.data.publishedAt ?? b.data.createdAt ?? "");
		return db.localeCompare(da);
	})
	.map((e) => ({
		date: e.data.date ?? "",
		createdAt: String(e.data.createdAt ?? ""),
		title: e.data.title,
		type: (e.data.entry_type ?? "build") as DiaryEntry["type"],
		prompt: e.data.prompt ?? "",
		summary: e.data.summary ?? "",
		model: e.data.model ?? "unknown",
		claudeCode: e.data.claude_code ?? "unknown",
		inputTokens: e.data.input_tokens ?? 0,
		outputTokens: e.data.output_tokens ?? 0,
		cacheRead: e.data.cache_read ?? 0,
		cost: e.data.cost ?? 0,
	}));

// Group by date
const grouped = new Map<string, DiaryEntry[]>();
for (const entry of entries) {
	const existing = grouped.get(entry.date);
	if (existing) {
		existing.push(entry);
	} else {
		grouped.set(entry.date, [entry]);
	}
}

const totalTokens = entries.reduce((sum, e) => sum + e.inputTokens + e.outputTokens, 0);
const totalCost = entries.reduce((sum, e) => sum + e.cost, 0);

const typeLabels: Record<string, Record<string, string>> = {
	en: { build: "Spell Cast", plan: "Prophecy", fix: "Reparo", deploy: "Apparition" },
	vi: { build: "Phép Thuật", plan: "Lời Tiên Tri", fix: "Reparo", deploy: "Hiện Hình" },
};

const typeColors: Record<string, string> = {
	build: "#5e6ad2",
	plan: "#d4a843",
	fix: "#e5534b",
	deploy: "#3fb950",
};

function formatDate(dateStr: string) {
	const d = new Date(dateStr + "T00:00:00");
	return d.toLocaleDateString(isVi ? "vi-VN" : "en-US", {
		weekday: "long",
		year: "numeric",
		month: "long",
		day: "numeric",
	});
}

function formatModel(model: string) {
	if (model === "unknown") return null;
	return model
		.replace("claude-", "")
		.replace(/-(\d+)-(\d+)/, " $1.$2")
		.replace(/-/g, " ")
		.replace(/\b\w/g, (c) => c.toUpperCase());
}
---

<Base title={isVi ? "Priori Incantatem — Nhật Ký Xây Dựng" : "Priori Incantatem — Build Diary"} description={isVi ? "Dòng thời gian mỗi phép thuật Claude Code thực hiện để xây dựng trang web này" : "A timeline of every spell cast by Claude Code to build this site"} breadcrumbs={[{ label: "Room of Requirement", href: "/room-of-requirement" }, { label: "Priori Incantatem" }]}>
	<section class="pi-hero">
		<div class="pi-hero-inner">
			<div class="pi-rule" />
			<span class="pi-label">{isVi ? "Nhật Ký Xây Dựng" : "Build Diary"}</span>
			<h1 class="pi-title">Priori Incantatem</h1>
			<p class="pi-subtitle">
				{isVi ? (
					<>Mỗi câu thần chú mà <a href="https://claude.com/claude-code" class="cc-link">Claude Code</a> đã niệm để tạo nên trang web này. Phép ngược dòng hé lộ lịch sử cây đũa phép.</>
				) : (
					<>Every incantation cast by <a href="https://claude.com/claude-code" class="cc-link">Claude Code</a> to conjure this site into existence. A reverse spell revealing the wand's history.</>
				)}
			</p>
			<div class="pi-stats">
				<span class="pi-stat">
					<span class="pi-stat-value">{entries.length}</span>
					<span class="pi-stat-label">{isVi ? "phép thuật" : "spells cast"}</span>
				</span>
				<span class="pi-stat-dot" />
				<span class="pi-stat">
					<span class="pi-stat-value">{grouped.size}</span>
					<span class="pi-stat-label">{isVi ? "ngày" : "days"}</span>
				</span>
				{totalTokens > 0 && (
					<>
						<span class="pi-stat-dot" />
						<span class="pi-stat">
							<span class="pi-stat-value">{totalTokens >= 1_000_000 ? `${(totalTokens / 1_000_000).toFixed(1)}M` : `${(totalTokens / 1000).toFixed(0)}K`}</span>
							<span class="pi-stat-label">tokens</span>
						</span>
					</>
				)}
				{totalCost > 0 && (
					<>
						<span class="pi-stat-dot" />
						<span class="pi-stat">
							<span class="pi-stat-value">${`$${(totalCost / 100).toFixed(2)}`}</span>
							<span class="pi-stat-label">{isVi ? "chi phí" : "cost"}</span>
						</span>
					</>
				)}
			</div>
		</div>
	</section>

	<section class="timeline-section">
		<div class="timeline-inner">
			<div class="timeline-line" />
			{[...grouped.entries()].map(([date, dayEntries], i) => (
				<details class="day-group" open={i === 0}>
					<summary class="day-header">
						<span class="day-dot" />
						<time class="day-date">{formatDate(date)}</time>
						<span class="day-count">{dayEntries.length}</span>
						<span class="day-chevron" />
					</summary>
					<div class="day-entries">
						{dayEntries.map((entry) => (
							<article class="entry" style={`--type-color: ${typeColors[entry.type] ?? typeColors.build};`}>
								<div class="entry-type">
									<span class="entry-type-dot" />
									{typeLabels[lang]?.[entry.type] ?? entry.type}
									<time class="entry-date">{entry.createdAt ? new Date(entry.createdAt).toLocaleString(isVi ? "vi-VN" : "en-US", { month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" }) : entry.date}</time>
								</div>
								<h3 class="entry-title">{entry.title}</h3>
								{entry.prompt && (
									<blockquote class="entry-prompt">
										{entry.prompt.split("\n").map((line, i) => (
											<>{i > 0 && <br />}{line}</>
										))}
									</blockquote>
								)}
								<p class="entry-summary">{entry.summary}</p>
								<div class="entry-meta">
									{formatModel(entry.model) && (
										<span class="entry-badge model-badge">{formatModel(entry.model)}</span>
									)}
									{entry.claudeCode !== "unknown" && (
										<span class="entry-badge cc-badge">CC {entry.claudeCode}</span>
									)}
									{(entry.inputTokens + entry.outputTokens) > 0 && (
										<span class="entry-badge token-badge">
											{((entry.inputTokens + entry.outputTokens) / 1000).toFixed(1)}K tokens
										</span>
									)}
									{entry.cost > 0 && (
										<span class="entry-badge cost-badge">${`$${(entry.cost / 100).toFixed(2)}`}</span>
									)}
								</div>
							</article>
						))}
					</div>
				</details>
			))}
		</div>
	</section>
</Base>

<style>
	/* Hero */
	.pi-hero {
		border-bottom: 1px solid var(--color-border);
	}

	.pi-hero-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-8) var(--spacing-16);
	}

	.pi-back {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		text-decoration: none;
		margin-bottom: var(--spacing-8);
		transition: color var(--transition-fast);
	}

	.pi-back:hover {
		color: var(--color-accent);
	}

	.pi-rule {
		width: 24px;
		height: 1px;
		background: var(--color-accent);
		margin-bottom: var(--spacing-5);
	}

	.pi-label {
		display: block;
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-muted);
		margin-bottom: var(--spacing-4);
	}

	.pi-title {
		font-family: var(--font-display);
		font-size: clamp(1.875rem, 3.5vw, 3rem);
		font-weight: var(--font-weight-display);
		line-height: 1.1;
		letter-spacing: -0.022em;
		color: var(--color-text);
		margin: 0 0 var(--spacing-5);
		font-style: italic;
	}

	.pi-subtitle {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		max-width: 55ch;
		margin: 0 0 var(--spacing-6);
	}

	.cc-link {
		color: var(--color-accent);
		text-decoration: none;
		font-weight: 500;
	}

	.cc-link:hover {
		text-decoration: underline;
	}

	.pi-stats {
		display: flex;
		align-items: center;
		gap: var(--spacing-4);
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.pi-stat {
		display: flex;
		align-items: baseline;
		gap: var(--spacing-2);
	}

	.pi-stat-value {
		font-weight: 600;
		color: var(--color-text);
		font-size: var(--font-size-lg);
	}

	.pi-stat-dot {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: currentColor;
		opacity: 0.5;
	}

	/* Timeline */
	.timeline-section {
		padding-bottom: var(--spacing-24);
	}

	.timeline-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-12) var(--spacing-8);
		position: relative;
	}

	.timeline-line {
		position: absolute;
		left: calc(var(--spacing-8) + 7px);
		top: var(--spacing-12);
		bottom: var(--spacing-12);
		width: 1px;
		background: var(--color-border);
	}

	/* Day group */
	.day-group {
		position: relative;
		margin-bottom: var(--spacing-10);
	}

	.day-group:last-child {
		margin-bottom: 0;
	}

	.day-header {
		display: flex;
		align-items: center;
		gap: var(--spacing-4);
		margin-bottom: var(--spacing-5);
		position: relative;
		cursor: pointer;
		list-style: none;
		user-select: none;
	}

	.day-header::-webkit-details-marker {
		display: none;
	}

	.day-header::marker {
		display: none;
		content: "";
	}

	.day-count {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--color-muted);
		background: color-mix(in srgb, var(--color-muted) 10%, transparent);
		border: 1px solid color-mix(in srgb, var(--color-muted) 15%, transparent);
		padding: 0 var(--spacing-2);
		border-radius: 3px;
		line-height: 1.6;
	}

	.day-chevron {
		width: 16px;
		height: 16px;
		margin-left: auto;
		position: relative;
		flex-shrink: 0;
	}

	.day-chevron::before {
		content: "";
		position: absolute;
		top: 50%;
		left: 50%;
		width: 6px;
		height: 6px;
		border-right: 1.5px solid var(--color-muted);
		border-bottom: 1.5px solid var(--color-muted);
		transform: translate(-50%, -65%) rotate(45deg);
		transition: transform var(--transition-fast);
	}

	.day-group[open] > .day-chevron::before,
	.day-group[open] > .day-header .day-chevron::before {
		transform: translate(-50%, -35%) rotate(-135deg);
	}

	.day-group:not([open]) > .day-header {
		margin-bottom: 0;
	}

	.day-dot {
		width: 15px;
		height: 15px;
		border-radius: 50%;
		background: var(--color-bg);
		border: 2px solid var(--color-accent);
		flex-shrink: 0;
		z-index: 1;
	}

	.day-date {
		font-family: var(--font-display);
		font-size: var(--font-size-base);
		font-weight: var(--font-weight-display);
		color: var(--color-text);
		letter-spacing: -0.011em;
	}

	/* Entries */
	.day-entries {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
		padding-left: calc(15px + var(--spacing-4));
	}

	.entry {
		--type-color: var(--color-accent);
		padding: var(--spacing-5);
		background: var(--color-surface-elevated);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		border-left: 2px solid var(--type-color);
		transition: border-color var(--transition-fast);
	}

	.entry:hover {
		border-color: color-mix(in srgb, var(--type-color) 50%, var(--color-border));
		border-left-color: var(--type-color);
	}

	.entry-type {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-2);
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--type-color);
		font-weight: 500;
		margin-bottom: var(--spacing-2);
	}

	.entry-type-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--type-color);
	}

	.entry-date {
		margin-left: auto;
		color: var(--color-muted);
		font-weight: 400;
	}

	.entry-prompt {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		font-style: italic;
		margin: 0 0 var(--spacing-2);
		padding-left: var(--spacing-4);
		border-left: 2px solid var(--color-border);
		line-height: var(--leading-relaxed);
	}

	.entry-title {
		font-family: var(--font-display);
		font-size: var(--font-size-base);
		font-weight: var(--font-weight-display);
		color: var(--color-text);
		margin: 0 0 var(--spacing-2);
		letter-spacing: -0.011em;
	}

	.entry-summary {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		line-height: var(--leading-relaxed);
		margin: 0 0 var(--spacing-3);
	}

	.entry-meta {
		display: flex;
		gap: var(--spacing-2);
		flex-wrap: wrap;
	}

	.entry-badge {
		display: inline-block;
		padding: 1px var(--spacing-2);
		font-family: var(--font-mono);
		font-size: 11px;
		border-radius: 3px;
		line-height: 1.6;
	}

	.model-badge {
		background: color-mix(in srgb, var(--color-accent) 12%, transparent);
		color: var(--color-accent);
		border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
	}

	.cc-badge {
		background: color-mix(in srgb, var(--color-muted) 10%, transparent);
		color: var(--color-muted);
		border: 1px solid color-mix(in srgb, var(--color-muted) 15%, transparent);
	}

	.token-badge {
		background: color-mix(in srgb, #3fb950 10%, transparent);
		color: #3fb950;
		border: 1px solid color-mix(in srgb, #3fb950 18%, transparent);
	}

	.cost-badge {
		background: color-mix(in srgb, #d4a843 10%, transparent);
		color: #d4a843;
		border: 1px solid color-mix(in srgb, #d4a843 18%, transparent);
	}

	/* Responsive */
	@media (max-width: 900px) {
		.pi-hero-inner {
			padding: var(--spacing-12) var(--spacing-6) var(--spacing-12);
		}

		.timeline-inner {
			padding: var(--spacing-10) var(--spacing-6);
		}

		.timeline-line {
			left: calc(var(--spacing-6) + 7px);
		}
	}

	@media (max-width: 600px) {
		.pi-hero-inner {
			padding: var(--spacing-10) var(--spacing-5);
		}

		.timeline-inner {
			padding: var(--spacing-8) var(--spacing-5);
		}

		.timeline-line {
			left: calc(var(--spacing-5) + 7px);
		}

		.day-entries {
			padding-left: calc(15px + var(--spacing-3));
		}
	}
</style>
