---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import { getCurrentLang } from "../../utils/lang";
import { setCachePolicy } from "../../lib/cachePolicy";
setCachePolicy(Astro, "static");

const isVi = getCurrentLang(Astro) === "vi";

// Frozen snapshot from Google My Activity export 2026-05-03.
// Source: takeout/myactivity/.../Discover/MyActivity.json (gitignored).
// To refresh: re-run takeout/discover/analyze.py and update constants.

const SNAPSHOT = {
	exported: "2026-05-03",
	rangeStart: "2025-03-30",
	rangeEnd: "2026-05-03",
	spanDays: 400,
	articles: 352,
	sessions: 403,
	uniqueHosts: 73,
};

interface Source {
	icon: string;
	keyEn: string;
	keyVi: string;
	blurbEn: string;
	blurbVi: string;
	count: number;
	share: number;
	samples: Array<[string, string]>;
}

const SOURCES: Source[] = [
	{
		icon: "🐦",
		keyEn: "X / Twitter Threads",
		keyVi: "X / Twitter Threads",
		blurbEn: "what people are saying in real-time — football fans, AI researchers, tech voices",
		blurbVi: "những gì mọi người đang nói trong thời gian thực — fan bóng đá, nhà nghiên cứu AI, tiếng nói công nghệ",
		count: 159,
		share: 45.2,
		samples: [
			["x.com", "Manchester United want to sign… (transfer thread)"],
			["x.com", "Claude Opus 4.7 just implemented… (AI announcement)"],
			["x.com", "Kobbie Mainoo is determined to… (United midfielder)"],
			["x.com", "People often separate React components… (programming hot-take)"],
			["x.com", "T1 coaching staff gets a 2.4… (League of Legends)"],
			["x.com", "👔 List of managers out of contract… (football)"],
			["x.com", "Google Maps Platform powers more… (tech)"],
			["x.com", "Lisandro Martinez on his recovery… (United defender)"],
		],
	},
	{
		icon: "🪄",
		keyEn: "Tech Press",
		keyVi: "Báo Công Nghệ",
		blurbEn: "the trade press — Verge, TechCrunch, Ars, 9to5, Tom's Guide, blog.google",
		blurbVi: "báo chuyên ngành — Verge, TechCrunch, Ars, 9to5, blog Google",
		count: 103,
		share: 29.3,
		samples: [
			["theverge.com", "The Verge — tech & culture coverage"],
			["techcrunch.com", "Fintech founder charged with…"],
			["blog.google", "More advanced AI capabilities…"],
			["9to5mac.com", "The cost-friendly MacBook upgrade…"],
			["github.blog", "GitHub announcements"],
			["arstechnica.com", "Ars Technica deep dives"],
			["simonwillison.net", "Simon Willison's blog — LLM commentary"],
			["tomsguide.com", "I test Gemini for a living…"],
		],
	},
	{
		icon: "🌍",
		keyEn: "World Press",
		keyVi: "Báo Thế Giới",
		blurbEn: "the broadsheets — NYT, Atlantic, Economist, Guardian, FT, Bloomberg",
		blurbVi: "báo lớn — NYT, Atlantic, Economist, Guardian, FT, Bloomberg",
		count: 40,
		share: 11.4,
		samples: [
			["theatlantic.com", "'We're Definitely Going to…'"],
			["nytimes.com", "New York Times — front-page coverage"],
			["economist.com", "The Economist — global affairs"],
			["theguardian.com", "Eric Cantona asked to front Manchester United…"],
			["ft.com", "Financial Times — markets coverage"],
			["bloomberg.com", "Bloomberg — finance & tech"],
			["wsj.com", "Wall Street Journal"],
			["reuters.com", "Reuters — wire-service news"],
		],
	},
	{
		icon: "🇻🇳",
		keyEn: "Vietnamese News",
		keyVi: "Tin Việt Nam",
		blurbEn: "VnExpress International, Tuổi Trẻ — Vietnam in English",
		blurbVi: "VnExpress International, Tuổi Trẻ — Việt Nam bằng tiếng Anh",
		count: 16,
		share: 4.5,
		samples: [
			["e.vnexpress.net", "HCMC's scoop of nostalgia, served…"],
			["e.vnexpress.net", "VnExpress International front page"],
			["news.tuoitre.vn", "Tuổi Trẻ Online English"],
		],
	},
	{
		icon: "🎮",
		keyEn: "Gaming & Pop Culture",
		keyVi: "Game & Văn Hóa Đại Chúng",
		blurbEn: "games, TV, the wider entertainment world",
		blurbVi: "game, phim, thế giới giải trí",
		count: 10,
		share: 2.8,
		samples: [
			["polygon.com", "Polygon — gaming culture"],
			["ign.com", "IGN — game reviews"],
			["news.blizzard.com", "Blizzard official news"],
			["movieweb.com", "Movie news & reviews"],
			["pcgamer.com", "PC Gamer"],
		],
	},
	{
		icon: "🏟️",
		keyEn: "Football Press",
		keyVi: "Báo Bóng Đá",
		blurbEn: "the football specialist outlets — ManUtd, TalkSport",
		blurbVi: "báo chuyên bóng đá — ManUtd, TalkSport",
		count: 2,
		share: 0.6,
		samples: [
			["manutd.com", "Manchester United official"],
			["talksport.com", "TalkSport football radio"],
		],
	},
];

const t = {
	pageTitle: isVi ? "Cú Bưu — Discover Mang Đến Gì" : "Owl Post — What Discover Delivers",
	pageDesc: isVi
		? "Một năm thuật toán Google Discover thả lên màn hình tôi và những bài tôi đã chạm — báo cáo trung thực về việc thuật toán có 'số' của tôi đến đâu."
		: "A year of articles Google's Discover algorithm dropped on my screen and which ones I tapped — an honest report on how well the algorithm has my number.",
	hagrid: isVi
		? '"Có người nói hắn đã chết. Lời nhảm, theo ý tôi." — Hagrid'
		: '"There\'s some that say he died. Codswallop, in my opinion." — Hagrid',
	intro: isVi
		? "Cú Đường là cho cú tôi gửi đi — bài viết tôi tự tìm trên Chrome. Đây là ngược lại: cú thuật toán Google Discover thả trước cửa, và cái tôi đã mở. Bề mặt khác, cùng một người đọc. My Activity trả về"
		: "The Owlery is for owls I send out — articles I sought on Chrome. This is the inverse: owls Google's Discover algorithm dropped on my doorstep, and what I opened. Different surface, same reader. My Activity returned",
	intro2: isVi ? "lần chạm bài viết từ Discover trên iOS Google app trong" : "Discover article taps from the iOS Google app across",
	intro3: isVi ? "ngày, cộng với" : "days, plus",
	intro4: isVi
		? 'phiên "N cards in your feed" — những lúc feed mở nhưng không chạm gì. Bài viết là tín hiệu thật.'
		: '"N cards in your feed" sessions — moments the feed opened but nothing was tapped. The articles are the truer signal.',

	s1: isVi ? "I. Cú Đến Từ Đâu" : "I. Where the Owls Come From",
	s1Sub: isVi
		? '"Cú bay đến từ mọi hướng; câu hỏi là người ta chọn mở cái nào."'
		: '"Owls fly here from every direction; the question is which ones one chooses to open."',
	colSrc: isVi ? "Nguồn" : "Source",
	colCovers: isVi ? "Cái gì sống ở đây" : "What lives here",
	colArticles: isVi ? "Bài" : "Articles",
	colShare: isVi ? "Tỷ lệ" : "Share",
	longTail: isVi ? "Đuôi dài — báo nhỏ" : "Long-tail outlets",
	longTailBlurb: isVi ? "tên miền chỉ-một-lần" : "one-off domains",
	hostsNote: isVi
		? `${SNAPSHOT.uniqueHosts} tên miền duy nhất. Thuật toán quăng lưới rộng hơn việc đọc có chủ ý, nhưng phần lớn lưới rơi xuống cùng vài cây quen.`
		: `${SNAPSHOT.uniqueHosts} unique hosts. The algorithm casts a wider net than deliberate reading does — but most of the casting lands on the same few favorite trees.`,

	s2: isVi ? "II. Bên Trong Mỗi Nguồn — Mẫu Đại Diện" : "II. Inside Each Source — A Sampling",
	s2Sub: isVi ? "Tiêu đề đại diện mỗi nguồn." : "Representative titles per source.",

	s3: isVi ? "III. Nón Phân Loại" : "III. The Sorting Hat — What This Reveals",
	s3p1: isVi
		? "Thuật toán có \"số\" của tôi. **45% lượt chạm vào X threads** — và X threads nó phục vụ được dệt CHẶT: chuyển nhượng Manchester United, thông báo AI, hot-take lập trình, thread công nghệ thi thoảng. Feed không phơi tôi ra với một thế giới rộng hơn; nó *tập trung* thế giới hiện tại của tôi."
		: "The algorithm has my number. **45% of taps go to X threads** — and the X threads it serves are *tightly* themed: Manchester United transfers, AI announcements, programming hot-takes, the occasional Vietnam-watching tech thread. The feed is not exposing me to a wider world; it is *concentrating* my existing world.",
	s3p2: isVi
		? "Sau X, lớp tiếp theo là **29% báo công nghệ** — Verge, TechCrunch, Ars, 9to5, Tom's Guide. Đây là người thợ giữ nhịp, giống Chrome. Rồi **5% tin Việt Nam** (chủ yếu e.vnexpress, VnExpress tiếng Anh) và **11% báo thế giới** (NYT, Atlantic, Economist, Guardian — báo lớn) — đây là những thứ THẬT SỰ vươn ra ngoài nghề."
		: "After X, the next layer is **29% tech press** — Verge, TechCrunch, Ars, 9to5, Tom's Guide. This is craftsman keeping pace, same as Chrome. Then **5% Vietnamese news** (mostly e.vnexpress, the English-language VnExpress) and **11% world press** (NYT, Atlantic, Economist, Guardian — the broadsheets) — these are the ones that *do* reach beyond the trade.",
	s3p3: isVi
		? "Sự thật trung thực: Discover **không phải** cánh cửa bí mật đến việc đọc rộng hơn. Đó là một tấm gương khác đôi chút của cùng một người. Fan bóng đá, người theo dõi AI, công dân Việt Nam, đôi khi đọc báo lớn. Bề rộng là thật nhưng nhỏ."
		: "The honest truth: Discover is *not* the secret door to wider reading. It's a slightly different mirror of the same person. Football fan, AI watcher, Vietnam citizen, occasional broadsheet reader. The breadth is real but small.",

	s4: isVi ? "IV. Những Gì Không Thể Cho Thấy" : "IV. What This Cannot Show",
	caveats: isVi
		? [
			["Lịch sử Discover ngắn.", `My Activity trả về ${SNAPSHOT.spanDays} ngày; lượt chạm trước ${SNAPSHOT.rangeStart} không có ở đây. Google giữ Discover taps khoảng 12–14 tháng theo mặc định.`],
			["\"N cards in your feed\" không có chạm là vô hình với khẩu vị.", `Thuật toán hiển thị hàng trăm cards mỗi ngày; chúng ta chỉ thấy ${SNAPSHOT.articles} chạm, không phải hàng nghìn lượt cuộn qua.`],
			["Một số mục là \"Content From Discover\" không có tiêu đề.", "Google ẩn những cái đó vì lý do nội dung/bản quyền. Tính trong tổng nhưng loại khỏi danh sách bài."],
			["Độ sâu đọc không biết.", "Chạm một X tweet không giống đọc một bài Atlantic 30 phút; cả hai đều tính một dòng."],
			["Chỉ iOS Google app.", "Đây là feed Discover trong iOS Google app, tách biệt với lịch sử Chrome (đã phân tích trong Cú Đường). Bài đọc qua Safari, webview của app mạng xã hội, hoặc trên desktop không xuất hiện."],
		]
		: [
			["Discover history is short.", `My Activity returned ${SNAPSHOT.spanDays} days; taps before ${SNAPSHOT.rangeStart} aren't here. Google retains Discover taps for ~12–14 months by default.`],
			["\"N cards in your feed\" without a tap is invisible to taste.", `The algorithm shows hundreds of cards every day; we only see the ${SNAPSHOT.articles} taps, not the thousands of scrolls past.`],
			["Some entries say \"Content From Discover\" with no title.", "Google redacts those for content/copyright reasons. Counted in totals but excluded from the article list."],
			["Read depth is unknown.", "Tapping an X tweet is not the same as reading a 30-minute Atlantic essay; both count as one row."],
			["iOS Google app only.", "This is the Discover feed inside the iOS Google app, separate from Chrome history (already analyzed in The Owlery). Articles read via Safari, social-app webviews, or on desktop don't appear."],
		],
	footnote: isVi
		? `Tạo từ Google My Activity export ngày ${SNAPSHOT.exported}. Dữ liệu nguồn được giữ riêng tư.`
		: `Generated from Google My Activity export of ${SNAPSHOT.exported}. Source data is kept private.`,
};

const formatDate = (iso: string) => {
	const d = new Date(iso);
	return isVi
		? `${d.getDate()} tháng ${d.getMonth() + 1}, ${d.getFullYear()}`
		: d.toLocaleDateString("en-US", { day: "numeric", month: "long", year: "numeric" });
};

const longTailCount = SNAPSHOT.articles - SOURCES.reduce((s, x) => s + x.count, 0);
---

<Base
	title={t.pageTitle}
	description={t.pageDesc}
	breadcrumbs={[
		{ label: isVi ? "Phòng Cần Thiết" : "Room of Requirement", href: "/room-of-requirement" },
		{ label: t.pageTitle },
	]}
>
	<article class="op">
		<header class="op-hdr">
			<h1 class="op-title">{t.pageTitle}</h1>
			<p class="op-sub">{t.pageDesc}</p>
			<blockquote class="op-quote">{t.hagrid}</blockquote>
			<p class="op-intro">
				{t.intro} <strong>{SNAPSHOT.articles}</strong> {t.intro2}
				<strong>{formatDate(SNAPSHOT.rangeStart)} → {formatDate(SNAPSHOT.rangeEnd)}</strong> ({SNAPSHOT.spanDays} {isVi ? "ngày" : "days"})
				{t.intro3} <strong>{SNAPSHOT.sessions}</strong> {t.intro4}
			</p>
		</header>

		<section class="op-sec">
			<h2 class="op-h2">{t.s1}</h2>
			<p class="op-em">{t.s1Sub}</p>
			<div class="op-table-wrap">
				<table class="op-table">
					<thead>
						<tr><th>{t.colSrc}</th><th>{t.colCovers}</th><th class="num">{t.colArticles}</th><th class="num">{t.colShare}</th></tr>
					</thead>
					<tbody>
						{SOURCES.map((s) => (
							<tr>
								<td class="src"><span class="op-icon">{s.icon}</span> <strong>{isVi ? s.keyVi : s.keyEn}</strong></td>
								<td class="op-blurb">{isVi ? s.blurbVi : s.blurbEn}</td>
								<td class="num">{s.count}</td>
								<td class="num">{s.share.toFixed(1)}%</td>
							</tr>
						))}
						<tr class="op-rest">
							<td class="src"><span class="op-icon">❓</span> {t.longTail}</td>
							<td class="op-blurb">{t.longTailBlurb}</td>
							<td class="num">{longTailCount}</td>
							<td class="num">{(longTailCount / SNAPSHOT.articles * 100).toFixed(1)}%</td>
						</tr>
					</tbody>
				</table>
			</div>
			<p class="op-meta">{t.hostsNote}</p>
		</section>

		<section class="op-sec">
			<h2 class="op-h2">{t.s2}</h2>
			<p class="op-em">{t.s2Sub}</p>
			{SOURCES.map((s) => (
				<div class="op-source">
					<h3 class="op-h3"><span class="op-icon">{s.icon}</span> {isVi ? s.keyVi : s.keyEn}</h3>
					<p class="op-blurb">{isVi ? s.blurbVi : s.blurbEn}</p>
					<ul class="op-samples">
						{s.samples.map(([h, title]) => (
							<li><span class="op-host">[{h}]</span> {title}</li>
						))}
					</ul>
				</div>
			))}
		</section>

		<section class="op-sec op-hat">
			<h2 class="op-h2">{t.s3}</h2>
			<p class="op-body" set:html={t.s3p1} />
			<p class="op-body" set:html={t.s3p2} />
			<p class="op-body op-coda" set:html={t.s3p3} />
		</section>

		<section class="op-sec">
			<h2 class="op-h2">{t.s4}</h2>
			<ul class="op-caveats">
				{t.caveats.map(([term, body]) => (
					<li><strong>{term}</strong> {body}</li>
				))}
			</ul>
		</section>

		<footer class="op-foot">
			<p>{t.footnote}</p>
		</footer>
	</article>
</Base>

<style>
	.op { max-width: var(--wide-width); margin: 0 auto; padding: var(--spacing-12) var(--spacing-8) var(--spacing-16); }
	.op-hdr { margin-bottom: var(--spacing-12); }
	.op-title { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); font-weight: var(--font-weight-display); letter-spacing: -0.02em; color: var(--color-text); margin: 0 0 var(--spacing-3); }
	.op-sub { font-family: var(--font-sans); font-size: var(--font-size-md); color: var(--color-muted); font-style: italic; margin: 0 0 var(--spacing-5); max-width: 60ch; }
	.op-quote { font-family: var(--font-sans); font-style: italic; color: var(--color-text-secondary); border-left: 2px solid var(--color-border); padding: var(--spacing-2) 0 var(--spacing-2) var(--spacing-4); margin: 0 0 var(--spacing-5); max-width: 70ch; }
	.op-intro { font-family: var(--font-sans); color: var(--color-text); line-height: var(--leading-relaxed); margin: 0; max-width: 70ch; }

	.op-sec { margin-top: var(--spacing-14); }
	.op-h2 { font-family: var(--font-display); font-size: clamp(1.4rem, 2.4vw, 1.8rem); font-weight: var(--font-weight-display); color: var(--color-text); margin: 0 0 var(--spacing-2); letter-spacing: -0.01em; }
	.op-h3 { font-family: var(--font-display); font-size: 1.1rem; font-weight: 600; color: var(--color-text); margin: 0 0 var(--spacing-2); }
	.op-em { font-family: var(--font-sans); font-size: var(--font-size-sm); font-style: italic; color: var(--color-text-secondary); margin: 0 0 var(--spacing-4); }
	.op-body { font-family: var(--font-sans); font-size: var(--font-size-md); color: var(--color-text); line-height: var(--leading-relaxed); margin: 0 0 var(--spacing-4); max-width: 70ch; }
	.op-blurb { font-family: var(--font-sans); font-size: var(--font-size-sm); color: var(--color-text-secondary); margin: 0 0 var(--spacing-3); }
	.op-meta { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--color-muted); margin: var(--spacing-3) 0 0; line-height: var(--leading-relaxed); max-width: 70ch; }
	.op-host { color: var(--color-text-secondary); font-family: var(--font-mono); font-size: var(--font-size-xs); }
	.op-icon { display: inline-block; margin-right: 0.3em; }

	.op-table-wrap { overflow-x: auto; margin: var(--spacing-4) 0 var(--spacing-3); border: 1px solid var(--color-border); border-radius: var(--radius); background: var(--color-surface-elevated); }
	.op-table { width: 100%; border-collapse: collapse; font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.op-table thead th { text-align: left; padding: var(--spacing-3) var(--spacing-4); font-family: var(--font-mono); font-size: var(--font-size-xs); font-weight: 500; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.04em; border-bottom: 1px solid var(--color-border); background: var(--color-surface); }
	.op-table tbody td { padding: var(--spacing-2) var(--spacing-4); color: var(--color-text); border-bottom: 1px solid var(--color-border); vertical-align: top; }
	.op-table tbody tr:last-child td { border-bottom: 0; }
	.op-table .num { text-align: right; font-variant-numeric: tabular-nums; font-family: var(--font-mono); }
	.op-table .src { white-space: nowrap; }
	.op-table .op-rest td { color: var(--color-muted); font-style: italic; }

	.op-source { margin-bottom: var(--spacing-7); padding-bottom: var(--spacing-5); border-bottom: 1px dashed var(--color-border); }
	.op-source:last-child { border-bottom: 0; }
	.op-samples { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--spacing-2); }
	.op-samples li { font-family: var(--font-sans); font-size: var(--font-size-sm); color: var(--color-text); line-height: var(--leading-relaxed); padding-left: var(--spacing-3); }

	.op-hat .op-coda { margin-top: var(--spacing-4); padding-top: var(--spacing-4); border-top: 1px solid var(--color-border); font-style: italic; color: var(--color-text-secondary); }

	.op-caveats { list-style: none; padding: 0; margin: var(--spacing-4) 0 0; display: flex; flex-direction: column; gap: var(--spacing-3); }
	.op-caveats li { font-family: var(--font-sans); font-size: var(--font-size-sm); color: var(--color-text); line-height: var(--leading-relaxed); padding-left: var(--spacing-4); border-left: 2px solid var(--color-border); max-width: 75ch; }

	.op-foot { margin-top: var(--spacing-12); padding-top: var(--spacing-5); border-top: 1px solid var(--color-border); }
	.op-foot p { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--color-muted); margin: 0; }

	@media (max-width: 700px) {
		.op { padding: var(--spacing-8) var(--spacing-5) var(--spacing-12); }
	}
</style>
