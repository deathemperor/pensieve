---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import { getCurrentLang } from "../../utils/lang";
const isVi = getCurrentLang(Astro) === "vi";

// The Restricted Section — design docs from D1
import { env } from "cloudflare:workers";
const db = env.DB;
let designDocs: { id: string; title: string; doc_type: string; project: string; summary: string; prompt: string; file_path: string; notion_url: string; line_count: number; created_at: string }[] = [];

if (db) {
  try {
    const docs = await db.prepare(
      "SELECT * FROM design_docs ORDER BY project, doc_type DESC"
    ).all();
    designDocs = (docs.results ?? []) as any[];
  } catch {
    designDocs = [];
  }
}

// Group docs by project
const docsByProject = new Map<string, typeof designDocs>();
for (const doc of designDocs) {
  const existing = docsByProject.get(doc.project) ?? [];
  existing.push(doc);
  docsByProject.set(doc.project, existing);
}

const projectDisplayNames: Record<string, string> = {
  "hp-task-management": "HP Task Management",
  "hogwarts-library": "Hogwarts Library",
};

// Stats
const totalSpecs = designDocs.filter(d => d.doc_type === 'spec').length;
const totalPlans = designDocs.filter(d => d.doc_type === 'plan').length;
const totalLines = designDocs.reduce((sum, d) => sum + (d.line_count ?? 0), 0);

const title = isVi ? "Khu Cấm" : "The Restricted Section";
const description = isVi ? "Bản thiết kế và kế hoạch triển khai" : "Design specs and implementation plans";
---

<Base
  title={title}
  description={description}
  breadcrumbs={[
    { label: "Room of Requirement", href: "/room-of-requirement" },
    { label: isVi ? "Khu Cấm" : "The Restricted Section" },
  ]}
>
  <section class="rs-page-hero">
    <div class="rs-page-inner">
      <div class="room-rule" />
      <h1 class="rs-page-title">{isVi ? "Khu Cấm" : "The Restricted Section"}</h1>
      <p class="rs-page-desc">
        {isVi
          ? "Bản thiết kế và kế hoạch triển khai — mọi quyết định kiến trúc được ghi lại từ các phiên brainstorm."
          : "Design specs and implementation plans — every architecture decision captured from brainstorming sessions."}
      </p>
    </div>
    <svg class="rs-skeleton-cat" viewBox="0 0 220 110" aria-hidden="true">
      <defs>
        <radialGradient id="rs-eye-glow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#9be7ff" stop-opacity="1"/>
          <stop offset="60%" stop-color="#5ab8ff" stop-opacity="0.55"/>
          <stop offset="100%" stop-color="#1a4a7a" stop-opacity="0"/>
        </radialGradient>
        <filter id="rs-bone-glow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="0.6" result="b"/>
          <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
      </defs>
      <g class="rs-cat-bones" filter="url(#rs-bone-glow)" stroke="#e8eef5" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <!-- spine: nape to hips -->
        <path class="rs-bone rs-spine" d="M58 56 Q90 48 130 52 Q160 55 178 58"/>
        <!-- ribs: 7 curved arcs hanging from spine -->
        <path class="rs-bone rs-rib" d="M72 53 Q73 66 78 74"/>
        <path class="rs-bone rs-rib" d="M82 51 Q83 66 88 75"/>
        <path class="rs-bone rs-rib" d="M92 51 Q93 67 98 76"/>
        <path class="rs-bone rs-rib" d="M102 51 Q103 67 108 76"/>
        <path class="rs-bone rs-rib" d="M112 51 Q113 67 118 76"/>
        <path class="rs-bone rs-rib" d="M122 52 Q123 67 128 76"/>
        <path class="rs-bone rs-rib" d="M132 53 Q133 67 138 76"/>
        <!-- pelvis -->
        <path class="rs-bone rs-pelvis" d="M168 57 Q174 64 178 72 M178 58 Q182 64 186 72"/>
        <!-- front legs -->
        <path class="rs-bone rs-leg rs-leg-fr" d="M68 76 L66 92 L70 100"/>
        <path class="rs-bone rs-leg rs-leg-fl" d="M76 76 L78 92 L74 100"/>
        <!-- back legs -->
        <path class="rs-bone rs-leg rs-leg-br" d="M170 75 L173 92 L168 100"/>
        <path class="rs-bone rs-leg rs-leg-bl" d="M180 76 L182 92 L186 100"/>
        <!-- paw joints -->
        <circle class="rs-joint" cx="68" cy="100" r="1.6"/>
        <circle class="rs-joint" cx="76" cy="100" r="1.6"/>
        <circle class="rs-joint" cx="170" cy="100" r="1.6"/>
        <circle class="rs-joint" cx="184" cy="100" r="1.6"/>
        <!-- tail: arcing whip with vertebrae -->
        <path class="rs-bone rs-tail" d="M186 58 Q200 50 208 36 Q212 24 204 16"/>
        <circle class="rs-vert" cx="190" cy="55" r="1.1"/>
        <circle class="rs-vert" cx="196" cy="50" r="1.1"/>
        <circle class="rs-vert" cx="202" cy="44" r="1.1"/>
        <circle class="rs-vert" cx="207" cy="36" r="1.1"/>
        <circle class="rs-vert" cx="208" cy="26" r="1.1"/>
        <circle class="rs-vert" cx="205" cy="18" r="1.1"/>
        <!-- skull -->
        <g class="rs-skull">
          <!-- cranium -->
          <path d="M30 50 Q22 42 28 32 Q34 22 50 22 Q62 22 64 32 Q64 42 60 48 Z"/>
          <!-- ears -->
          <path d="M30 30 L28 18 L36 26"/>
          <path d="M58 28 L62 17 L54 24"/>
          <!-- jaw -->
          <path d="M32 48 Q40 58 56 56 Q60 53 60 48"/>
          <!-- nose triangle -->
          <path d="M32 44 L30 48 L34 48 Z" fill="#e8eef5"/>
          <!-- teeth -->
          <path d="M36 52 L36 55 M40 53 L40 56 M44 53 L44 56 M48 53 L48 56 M52 53 L52 56" stroke-width="0.9"/>
          <!-- eye sockets -->
          <ellipse class="rs-eye-socket" cx="40" cy="36" rx="4" ry="5"/>
          <ellipse class="rs-eye-socket" cx="54" cy="36" rx="4" ry="5"/>
          <!-- glowing pupils -->
          <circle class="rs-eye" cx="40" cy="36" r="2.2" fill="url(#rs-eye-glow)" stroke="none"/>
          <circle class="rs-eye" cx="54" cy="36" r="2.2" fill="url(#rs-eye-glow)" stroke="none"/>
          <!-- whisker dots (sockets) -->
          <circle cx="34" cy="46" r="0.5" fill="#e8eef5"/>
          <circle cx="34" cy="49" r="0.5" fill="#e8eef5"/>
          <circle cx="34" cy="52" r="0.5" fill="#e8eef5"/>
        </g>
      </g>
    </svg>
  </section>

  <section class="rs-page-section">
    <div class="rs-page-inner">
      {designDocs.length > 0 ? (
        <>
          <div class="rs-stats">
            <span class="rs-stat">{designDocs.length} {isVi ? 'tài liệu' : 'docs'}</span>
            <span class="rs-stat-sep">&middot;</span>
            <span class="rs-stat">{docsByProject.size} {isVi ? 'dự án' : 'projects'}</span>
            <span class="rs-stat-sep">&middot;</span>
            <span class="rs-stat"><span class="rs-dot rs-dot-spec" />{totalSpecs} {isVi ? 'thiết kế' : 'specs'}</span>
            <span class="rs-stat-sep">&middot;</span>
            <span class="rs-stat"><span class="rs-dot rs-dot-plan" />{totalPlans} {isVi ? 'kế hoạch' : 'plans'}</span>
            <span class="rs-stat-sep">&middot;</span>
            <span class="rs-stat">{totalLines.toLocaleString()} {isVi ? 'dòng' : 'lines'}</span>
          </div>
          <div class="rs-list">
            {[...docsByProject.entries()].map(([project, docs]) => (
              <div class="rs-group">
                <div class="rs-group-header">
                  <span class="rs-group-name">{projectDisplayNames[project] ?? project}</span>
                  <span class="rs-group-count">{docs.length}</span>
                </div>
                {docs.map(doc => (
                  <details class="rs-row">
                    <summary class={`rs-row-summary rs-row-${doc.doc_type}`}>
                      <span class={`rs-badge rs-badge-${doc.doc_type}`}>
                        {doc.doc_type === 'spec' ? (isVi ? 'Thiết kế' : 'Spec') : (isVi ? 'Kế hoạch' : 'Plan')}
                      </span>
                      <span class="rs-row-title">{doc.title}</span>
                      <span class="rs-row-meta">
                        <span class="rs-row-date">{new Date(doc.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
                        <span class="rs-row-lines">{doc.line_count?.toLocaleString()}</span>
                      </span>
                      <span class="rs-row-links">
                        {doc.notion_url && (
                          <a href={doc.notion_url} target="_blank" rel="noopener" class="rs-link" title="Notion" onclick="event.stopPropagation()">
                            <svg width="12" height="12" viewBox="0 0 100 100" fill="currentColor"><path d="M6.6 12.2c4-3.5 5.3-3 16-2.1l43.6 3c1.8.2 .4 1.8-.7 2.1L54 22.9c-2.5 1.5-3.4 1.2-10.3.6L12.8 19c-2.3-.5-2.8-1.5-.7-2.8zm4.2 13.7v46c0 2.5 1.2 3.5 4.2 3.3l48-2.8c3-.2 3.5-2 3.5-4.3v-45c0-2.3-.9-3.5-2.8-3.3l-50 2.8c-2.1.2-2.8 1.5-2.8 3.3zm47.5 2.3c.4 1.6 0 3.2-1.6 3.4l-2.3.4v34c-2 1.1-3.9 1.6-5.3 1.6-2.5 0-3.2-.7-5-3L28.8 40.1V63l4.8 1.1s0 3.2-4.2 3.2l-11.6.7c-.4-.7 0-2.5 1.2-2.8l3.2-.9V33.5l-4.4-.3c-.4-1.6.5-4.2 3.7-4.4l12.5-.7 16.7 25.4V32.7l-4.1-.5c-.4-2.1 1.1-3.5 3-3.7z"/></svg>
                          </a>
                        )}
                        <a href={`https://github.com/deathemperor/pensieve/blob/main/${doc.file_path}`} target="_blank" rel="noopener" class="rs-link" title="GitHub" onclick="event.stopPropagation()">
                          <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                        </a>
                      </span>
                    </summary>
                    <div class="rs-detail">
                      {doc.summary && <p class="rs-detail-summary">{doc.summary}</p>}
                      {doc.prompt && (
                        <div class="rs-detail-prompt">
                          <span class="rs-detail-prompt-label">Prompt</span>
                          <span class="rs-detail-prompt-text">{doc.prompt}</span>
                        </div>
                      )}
                    </div>
                  </details>
                ))}
              </div>
            ))}
          </div>
        </>
      ) : (
        <p class="rs-empty">
          {isVi ? "Chưa có tài liệu nào." : "No documents yet."}
        </p>
      )}
    </div>
  </section>
</Base>

<style>
  .rs-page-hero {
    border-bottom: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }

  /* Skeleton Cat — Mrs. Norris in bone form, prowling the Restricted Section */
  .rs-skeleton-cat {
    position: absolute;
    bottom: 6px;
    left: -240px;
    width: 220px;
    height: 110px;
    pointer-events: none;
    opacity: 0;
    animation: rs-cat-prowl 28s linear infinite;
    transform-origin: 50% 100%;
    z-index: 1;
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.45));
  }

  @keyframes rs-cat-prowl {
    0%   { left: -240px; opacity: 0; transform: scaleX(1); }
    4%   { opacity: 0.85; }
    20%  { left: 28%; transform: scaleX(1) translateY(0); }
    21%  { transform: scaleX(1) translateY(-1px); } /* paw step */
    35%  { left: 52%; transform: scaleX(1) translateY(0); }
    50%  { left: 70%; transform: scaleX(1); opacity: 0.9; }
    55%  { left: 70%; opacity: 0; }
    56%  { left: 70%; transform: scaleX(-1); } /* turn around (vanish + flip) */
    60%  { left: 70%; opacity: 0.9; }
    80%  { left: 18%; transform: scaleX(-1); }
    96%  { left: -240px; transform: scaleX(-1); opacity: 0.4; }
    100% { left: -240px; opacity: 0; transform: scaleX(1); }
  }

  /* Bones flicker as if barely held together */
  .rs-cat-bones {
    animation: rs-bone-flicker 5.5s ease-in-out infinite;
  }
  @keyframes rs-bone-flicker {
    0%, 100% { opacity: 1; }
    47% { opacity: 1; }
    49% { opacity: 0.55; } /* brief skip */
    50% { opacity: 1; }
    72% { opacity: 0.8; }
    74% { opacity: 1; }
  }

  /* Spine: subtle breathing arc */
  .rs-spine {
    transform-origin: 50% 56px;
    animation: rs-spine-breathe 3.4s ease-in-out infinite;
  }
  @keyframes rs-spine-breathe {
    0%, 100% { transform: translateY(0) scaleY(1); }
    50% { transform: translateY(-1px) scaleY(1.03); }
  }

  /* Ribs: stagger expand/contract — breathing rib cage */
  .rs-rib {
    transform-origin: top center;
    animation: rs-rib-breathe 3.4s ease-in-out infinite;
  }
  .rs-rib:nth-of-type(2) { animation-delay: 0.05s; }
  .rs-rib:nth-of-type(3) { animation-delay: 0.10s; }
  .rs-rib:nth-of-type(4) { animation-delay: 0.15s; }
  .rs-rib:nth-of-type(5) { animation-delay: 0.10s; }
  .rs-rib:nth-of-type(6) { animation-delay: 0.05s; }
  @keyframes rs-rib-breathe {
    0%, 100% { transform: scaleX(1); }
    50% { transform: scaleX(1.08); }
  }

  /* Legs: simulate a gait — alternating front/back pairs */
  .rs-leg-fr, .rs-leg-bl {
    transform-origin: top center;
    animation: rs-leg-step 0.8s ease-in-out infinite;
  }
  .rs-leg-fl, .rs-leg-br {
    transform-origin: top center;
    animation: rs-leg-step 0.8s ease-in-out infinite reverse;
  }
  @keyframes rs-leg-step {
    0%, 100% { transform: rotate(-6deg); }
    50% { transform: rotate(8deg); }
  }

  /* Tail: bony whip, sways like a metronome */
  .rs-tail {
    transform-origin: 186px 58px;
    animation: rs-tail-sway 2.2s ease-in-out infinite;
  }
  .rs-vert {
    transform-origin: 186px 58px;
    animation: rs-tail-sway 2.2s ease-in-out infinite;
  }
  @keyframes rs-tail-sway {
    0%, 100% { transform: rotate(-12deg); }
    50% { transform: rotate(14deg); }
  }

  /* Skull: head bob in time with steps */
  .rs-skull {
    transform-origin: 46px 38px;
    animation: rs-head-bob 0.8s ease-in-out infinite;
  }
  @keyframes rs-head-bob {
    0%, 100% { transform: translateY(0) rotate(-1deg); }
    50% { transform: translateY(-1.5px) rotate(1deg); }
  }

  /* Eye sockets: hollow black */
  .rs-eye-socket {
    fill: #05080d;
    stroke: #e8eef5;
    stroke-width: 0.9;
  }

  /* Glowing pupils with blink */
  .rs-eye {
    transform-origin: center;
    animation: rs-eye-blink 4.7s steps(1, end) infinite, rs-eye-pulse 1.8s ease-in-out infinite;
    filter: drop-shadow(0 0 3px #6ec8ff) drop-shadow(0 0 6px #4aa8ff);
  }
  @keyframes rs-eye-blink {
    0%, 92%, 100% { transform: scaleY(1); }
    93%, 95% { transform: scaleY(0.05); }
    94% { transform: scaleY(0.05); }
  }
  @keyframes rs-eye-pulse {
    0%, 100% { opacity: 0.9; }
    50% { opacity: 1; }
  }

  /* Joints: subtle pulse so paws look alive */
  .rs-joint {
    fill: #e8eef5;
    animation: rs-joint-pulse 1.6s ease-in-out infinite;
  }
  @keyframes rs-joint-pulse {
    0%, 100% { opacity: 0.7; r: 1.6; }
    50% { opacity: 1; r: 2; }
  }

  @media (prefers-reduced-motion: reduce) {
    .rs-skeleton-cat,
    .rs-cat-bones,
    .rs-spine, .rs-rib,
    .rs-leg-fr, .rs-leg-fl, .rs-leg-br, .rs-leg-bl,
    .rs-tail, .rs-vert, .rs-skull, .rs-eye, .rs-joint {
      animation: none;
    }
    .rs-skeleton-cat { left: 80px; opacity: 0.7; }
  }

  .rs-page-inner {
    max-width: var(--wide-width);
    margin: 0 auto;
    padding: var(--spacing-16) var(--spacing-8);
  }

  .room-rule {
    width: 24px;
    height: 1px;
    background: var(--color-accent);
    margin-bottom: var(--spacing-5);
  }

  .rs-page-title {
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 3.5vw, 3rem);
    font-weight: var(--font-weight-display);
    line-height: 1.1;
    letter-spacing: -0.022em;
    color: var(--color-text);
    margin: 0 0 var(--spacing-5);
  }

  .rs-page-desc {
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    max-width: 55ch;
    margin: 0;
  }

  .rs-page-section {
    border-bottom: 1px solid var(--color-border);
  }

  .rs-empty {
    font-family: var(--font-sans);
    font-size: var(--font-size-sm);
    color: var(--color-muted);
    font-style: italic;
    margin: 0;
  }

  /* Restricted Section — compact list */
  .rs-stats {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--color-muted);
    margin-bottom: var(--spacing-6);
    flex-wrap: wrap;
  }

  .rs-stat {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .rs-stat-sep {
    color: var(--color-border);
  }

  .rs-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .rs-dot-spec { background: #7c3aed; }
  .rs-dot-plan { background: #d4a843; }

  .rs-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-5);
  }

  .rs-group-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    margin-bottom: var(--spacing-2);
  }

  .rs-group-name {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    font-weight: 500;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .rs-group-count {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-muted);
    background: var(--color-surface-elevated);
    padding: 1px 6px;
    border-radius: 8px;
  }

  .rs-row {
    border-left: 2px solid transparent;
    transition: border-color var(--transition-fast);
  }

  .rs-row[open] {
    border-left-color: var(--color-border);
  }

  .rs-row-summary {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    padding: var(--spacing-2) var(--spacing-3);
    border-radius: var(--radius);
    cursor: pointer;
    list-style: none;
    transition: background var(--transition-fast);
  }

  .rs-row-summary::-webkit-details-marker { display: none; }
  .rs-row-summary::marker { content: ""; }

  .rs-row-summary:hover {
    background: var(--color-surface-elevated);
  }

  .rs-row-spec { border-left: 2px solid color-mix(in srgb, #7c3aed 40%, transparent); }
  .rs-row-plan { border-left: 2px solid color-mix(in srgb, #d4a843 40%, transparent); }

  .rs-badge {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 1px 6px;
    border-radius: 3px;
    flex-shrink: 0;
    width: 40px;
    text-align: center;
  }

  .rs-badge-spec {
    color: #7c3aed;
    background: color-mix(in srgb, #7c3aed 12%, transparent);
  }

  .rs-badge-plan {
    color: #d4a843;
    background: color-mix(in srgb, #d4a843 12%, transparent);
  }

  .rs-row-title {
    font-family: var(--font-sans);
    font-size: var(--font-size-sm);
    color: var(--color-text);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .rs-row-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    flex-shrink: 0;
  }

  .rs-row-date,
  .rs-row-lines {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-muted);
  }

  .rs-row-lines::after {
    content: " ln";
  }

  .rs-row-links {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    flex-shrink: 0;
  }

  .rs-link {
    color: var(--color-muted);
    transition: color var(--transition-fast);
    display: flex;
    align-items: center;
    padding: 2px;
  }

  .rs-link:hover {
    color: var(--color-accent);
  }

  /* Expanded detail */
  .rs-detail {
    padding: var(--spacing-3) var(--spacing-3) var(--spacing-3) calc(40px + var(--spacing-3) + var(--spacing-3));
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .rs-detail-summary {
    font-family: var(--font-sans);
