---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import { getCurrentLang } from "../../utils/lang";
const isVi = getCurrentLang(Astro) === "vi";

// The Restricted Section — design docs from D1
import { env } from "cloudflare:workers";
const db = env.DB;
let designDocs: { id: string; title: string; doc_type: string; project: string; summary: string; prompt: string; file_path: string; notion_url: string; line_count: number; created_at: string }[] = [];

if (db) {
  try {
    const docs = await db.prepare(
      "SELECT * FROM design_docs ORDER BY project, doc_type DESC"
    ).all();
    designDocs = (docs.results ?? []) as any[];
  } catch {
    designDocs = [];
  }
}

// Group docs by project
const docsByProject = new Map<string, typeof designDocs>();
for (const doc of designDocs) {
  const existing = docsByProject.get(doc.project) ?? [];
  existing.push(doc);
  docsByProject.set(doc.project, existing);
}

const projectDisplayNames: Record<string, string> = {
  "hp-task-management": "HP Task Management",
  "hogwarts-library": "Hogwarts Library",
};

// Stats
const totalSpecs = designDocs.filter(d => d.doc_type === 'spec').length;
const totalPlans = designDocs.filter(d => d.doc_type === 'plan').length;
const totalLines = designDocs.reduce((sum, d) => sum + (d.line_count ?? 0), 0);

const title = isVi ? "Khu Cấm" : "The Restricted Section";
const description = isVi ? "Bản thiết kế và kế hoạch triển khai" : "Design specs and implementation plans";
---

<Base
  title={title}
  description={description}
  breadcrumbs={[
    { label: "Room of Requirement", href: "/room-of-requirement" },
    { label: isVi ? "Khu Cấm" : "The Restricted Section" },
  ]}
>
  <section class="rs-page-hero">
    <div class="rs-page-inner">
      <div class="room-rule" />
      <h1 class="rs-page-title rs-title-shake">{isVi ? "Khu Cấm" : "The Restricted Section"}</h1>
      <p class="rs-page-desc">
        {isVi
          ? "Bản thiết kế và kế hoạch triển khai — mọi quyết định kiến trúc được ghi lại từ các phiên brainstorm."
          : "Design specs and implementation plans — every architecture decision captured from brainstorming sessions."}
      </p>
    </div>
    <!-- Hero-wide atmospheric glow — pulses brightest at peak -->
    <div class="rs-stage-glow" aria-hidden="true"></div>
    <!-- Concentric hiss soundwaves — fire from mouth at peak -->
    <div class="rs-hiss-waves" aria-hidden="true">
      <span class="rs-hiss-wave" style="--i:0"></span>
      <span class="rs-hiss-wave" style="--i:1"></span>
      <span class="rs-hiss-wave" style="--i:2"></span>
      <span class="rs-hiss-wave" style="--i:3"></span>
    </div>
    <!-- Spectral aura traveling with the cat: ground shadow + ectoplasm haze -->
    <div class="rs-cat-aura" aria-hidden="true">
      <div class="rs-cat-shadow"></div>
      <div class="rs-cat-haze"></div>
    </div>
    <!-- Ghost double — translucent cat-shape that lags behind for echo effect -->
    <svg class="rs-cat-ghost" viewBox="0 0 220 110" aria-hidden="true">
      <use href="#rs-cat-silhouette"/>
    </svg>
    <!-- Familiar pack: 2 smaller skeleton kittens trailing the alpha cat -->
    <svg class="rs-cat-mini rs-cat-mini-1" viewBox="0 0 220 110" aria-hidden="true">
      <use href="#rs-cat-silhouette-detailed"/>
    </svg>
    <svg class="rs-cat-mini rs-cat-mini-2" viewBox="0 0 220 110" aria-hidden="true">
      <use href="#rs-cat-silhouette-detailed"/>
    </svg>
    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
      <symbol id="rs-cat-silhouette-detailed" viewBox="0 0 220 110">
        <g stroke="#cce8ff" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <path d="M58 56 Q90 48 130 52 Q160 55 178 58"/>
          <path d="M82 51 Q83 66 88 75 M102 51 Q103 67 108 76 M122 52 Q123 67 128 76"/>
          <path d="M168 57 Q174 64 178 72 M178 58 Q182 64 186 72"/>
          <path d="M68 76 L66 92 L70 100 M76 76 L78 92 L74 100"/>
          <path d="M170 75 L173 92 L168 100 M180 76 L182 92 L186 100"/>
          <path d="M186 58 Q200 50 208 36 Q212 24 204 16"/>
          <path d="M30 50 Q22 42 28 32 Q34 22 50 22 Q62 22 64 32 Q64 42 60 48 Z"/>
          <path d="M30 30 L28 18 L36 26 M58 28 L62 17 L54 24"/>
          <ellipse cx="40" cy="36" rx="3" ry="4" fill="#05080d"/>
          <ellipse cx="54" cy="36" rx="3" ry="4" fill="#05080d"/>
          <circle cx="40" cy="36" r="1.6" fill="#9be7ff"/>
          <circle cx="54" cy="36" r="1.6" fill="#9be7ff"/>
        </g>
      </symbol>
    </svg>
    <!-- Hidden symbol for ghost double to reuse cat outline -->
    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
      <symbol id="rs-cat-silhouette" viewBox="0 0 220 110">
        <g stroke="#9be7ff" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" opacity="0.6">
          <path d="M58 56 Q90 48 130 52 Q160 55 178 58"/>
          <path d="M168 57 Q174 64 178 72 M178 58 Q182 64 186 72"/>
          <path d="M68 76 L66 92 L70 100 M76 76 L78 92 L74 100"/>
          <path d="M170 75 L173 92 L168 100 M180 76 L182 92 L186 100"/>
          <path d="M186 58 Q200 50 208 36 Q212 24 204 16"/>
          <path d="M30 50 Q22 42 28 32 Q34 22 50 22 Q62 22 64 32 Q64 42 60 48 Z"/>
        </g>
      </symbol>
    </svg>
    <!-- Trailing ectoplasm wisps spawned in CSS along the prowl path -->
    <div class="rs-cat-trail" aria-hidden="true">
      <span class="rs-wisp" style="--i:0"></span>
      <span class="rs-wisp" style="--i:1"></span>
      <span class="rs-wisp" style="--i:2"></span>
      <span class="rs-wisp" style="--i:3"></span>
      <span class="rs-wisp" style="--i:4"></span>
      <span class="rs-wisp" style="--i:5"></span>
      <span class="rs-wisp" style="--i:6"></span>
      <span class="rs-wisp" style="--i:7"></span>
    </div>
    <!-- Detached bone shards floating up like fireflies -->
    <div class="rs-bone-shards" aria-hidden="true">
      <span class="rs-shard rs-shard-rib" style="--i:0"></span>
      <span class="rs-shard rs-shard-vert" style="--i:1"></span>
      <span class="rs-shard rs-shard-rib" style="--i:2"></span>
      <span class="rs-shard rs-shard-vert" style="--i:3"></span>
      <span class="rs-shard rs-shard-rib" style="--i:4"></span>
      <span class="rs-shard rs-shard-vert" style="--i:5"></span>
    </div>
    <!-- Summoning circle — appears under cat at peak (40-48% of prowl) -->
    <div class="rs-summon-circle" aria-hidden="true">
      <div class="rs-summon-ring rs-summon-ring-1"></div>
      <div class="rs-summon-ring rs-summon-ring-2"></div>
      <div class="rs-summon-ring rs-summon-ring-3"></div>
    </div>
    <!-- Patronus-style 12 rays bursting from cat's chest at peak -->
    <div class="rs-ray-burst" aria-hidden="true">
      <span class="rs-ray" style="--a:0deg"></span>
      <span class="rs-ray" style="--a:30deg"></span>
      <span class="rs-ray" style="--a:60deg"></span>
      <span class="rs-ray" style="--a:90deg"></span>
      <span class="rs-ray" style="--a:120deg"></span>
      <span class="rs-ray" style="--a:150deg"></span>
      <span class="rs-ray" style="--a:180deg"></span>
      <span class="rs-ray" style="--a:210deg"></span>
      <span class="rs-ray" style="--a:240deg"></span>
      <span class="rs-ray" style="--a:270deg"></span>
      <span class="rs-ray" style="--a:300deg"></span>
      <span class="rs-ray" style="--a:330deg"></span>
    </div>
    <!-- Paw-print trail left behind on the floor -->
    <div class="rs-paw-trail" aria-hidden="true">
      <span class="rs-paw" style="--i:0"></span>
      <span class="rs-paw" style="--i:1"></span>
      <span class="rs-paw" style="--i:2"></span>
      <span class="rs-paw" style="--i:3"></span>
      <span class="rs-paw" style="--i:4"></span>
      <span class="rs-paw" style="--i:5"></span>
      <span class="rs-paw" style="--i:6"></span>
      <span class="rs-paw" style="--i:7"></span>
    </div>
    <svg class="rs-skeleton-cat" viewBox="0 0 220 110" aria-hidden="true">
      <defs>
        <radialGradient id="rs-eye-glow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#ffffff" stop-opacity="1"/>
          <stop offset="35%" stop-color="#9be7ff" stop-opacity="0.95"/>
          <stop offset="75%" stop-color="#5ab8ff" stop-opacity="0.4"/>
          <stop offset="100%" stop-color="#1a4a7a" stop-opacity="0"/>
        </radialGradient>
        <radialGradient id="rs-eye-burst" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#ffffff" stop-opacity="0.9"/>
          <stop offset="40%" stop-color="#9be7ff" stop-opacity="0.5"/>
          <stop offset="100%" stop-color="#5ab8ff" stop-opacity="0"/>
        </radialGradient>
        <linearGradient id="rs-bone-fill" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#ffffff" stop-opacity="1"/>
          <stop offset="100%" stop-color="#b8d4ec" stop-opacity="0.9"/>
        </linearGradient>
        <filter id="rs-bone-glow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="0.8" result="b1"/>
          <feGaussianBlur stdDeviation="2.5" in="SourceGraphic" result="b2"/>
          <feFlood flood-color="#7ec8ff" flood-opacity="0.9" result="rim"/>
          <feComposite in="rim" in2="b2" operator="in" result="halo"/>
          <feMerge>
            <feMergeNode in="halo"/>
            <feMergeNode in="b1"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
        <filter id="rs-cat-flicker" x="-20%" y="-20%" width="140%" height="140%">
          <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" seed="3" result="noise">
            <animate attributeName="seed" values="3;7;1;5;3" dur="2.4s" repeatCount="indefinite"/>
          </feTurbulence>
          <feDisplacementMap in="SourceGraphic" in2="noise" scale="0.6"/>
        </filter>
      </defs>
      <!-- Aura halo behind the eyes — pulses at peak moments -->
      <g class="rs-eye-burst-group">
        <circle class="rs-eye-burst" cx="40" cy="36" r="14" fill="url(#rs-eye-burst)"/>
        <circle class="rs-eye-burst" cx="54" cy="36" r="14" fill="url(#rs-eye-burst)"/>
      </g>
      <!-- Lightning crackles along spine at apparation — jagged white bolts -->
      <g class="rs-lightning" stroke="#ffffff" stroke-width="0.8" fill="none" stroke-linecap="round" filter="url(#rs-bone-glow)">
        <path class="rs-bolt rs-bolt-1" d="M62 50 L66 48 L64 54 L70 52 L68 58 L74 56"/>
        <path class="rs-bolt rs-bolt-2" d="M120 48 L124 46 L122 52 L128 50 L126 56"/>
        <path class="rs-bolt rs-bolt-3" d="M168 56 L172 54 L170 60 L176 58 L174 62"/>
      </g>
      <g class="rs-cat-bones" filter="url(#rs-bone-glow)" stroke="url(#rs-bone-fill)" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <!-- spine: nape to hips -->
        <path class="rs-bone rs-spine" d="M58 56 Q90 48 130 52 Q160 55 178 58"/>
        <!-- ribs: 7 curved arcs hanging from spine -->
        <path class="rs-bone rs-rib" d="M72 53 Q73 66 78 74"/>
        <path class="rs-bone rs-rib" d="M82 51 Q83 66 88 75"/>
        <path class="rs-bone rs-rib" d="M92 51 Q93 67 98 76"/>
        <path class="rs-bone rs-rib" d="M102 51 Q103 67 108 76"/>
        <path class="rs-bone rs-rib" d="M112 51 Q113 67 118 76"/>
        <path class="rs-bone rs-rib" d="M122 52 Q123 67 128 76"/>
        <path class="rs-bone rs-rib" d="M132 53 Q133 67 138 76"/>
        <!-- pelvis -->
        <path class="rs-bone rs-pelvis" d="M168 57 Q174 64 178 72 M178 58 Q182 64 186 72"/>
        <!-- front legs -->
        <path class="rs-bone rs-leg rs-leg-fr" d="M68 76 L66 92 L70 100"/>
        <path class="rs-bone rs-leg rs-leg-fl" d="M76 76 L78 92 L74 100"/>
        <!-- back legs -->
        <path class="rs-bone rs-leg rs-leg-br" d="M170 75 L173 92 L168 100"/>
        <path class="rs-bone rs-leg rs-leg-bl" d="M180 76 L182 92 L186 100"/>
        <!-- paw joints -->
        <circle class="rs-joint" cx="68" cy="100" r="1.6"/>
        <circle class="rs-joint" cx="76" cy="100" r="1.6"/>
        <circle class="rs-joint" cx="170" cy="100" r="1.6"/>
        <circle class="rs-joint" cx="184" cy="100" r="1.6"/>
        <!-- tail: arcing whip with vertebrae -->
        <path class="rs-bone rs-tail" d="M186 58 Q200 50 208 36 Q212 24 204 16"/>
        <circle class="rs-vert" cx="190" cy="55" r="1.1"/>
        <circle class="rs-vert" cx="196" cy="50" r="1.1"/>
        <circle class="rs-vert" cx="202" cy="44" r="1.1"/>
        <circle class="rs-vert" cx="207" cy="36" r="1.1"/>
        <circle class="rs-vert" cx="208" cy="26" r="1.1"/>
        <circle class="rs-vert" cx="205" cy="18" r="1.1"/>
        <!-- skull -->
        <g class="rs-skull">
          <!-- cranium -->
          <path d="M30 50 Q22 42 28 32 Q34 22 50 22 Q62 22 64 32 Q64 42 60 48 Z"/>
          <!-- ears -->
          <path d="M30 30 L28 18 L36 26"/>
          <path d="M58 28 L62 17 L54 24"/>
          <!-- jaw -->
          <path d="M32 48 Q40 58 56 56 Q60 53 60 48"/>
          <!-- nose triangle -->
          <path d="M32 44 L30 48 L34 48 Z" fill="#e8eef5"/>
          <!-- teeth -->
          <path d="M36 52 L36 55 M40 53 L40 56 M44 53 L44 56 M48 53 L48 56 M52 53 L52 56" stroke-width="0.9"/>
          <!-- eye sockets -->
          <ellipse class="rs-eye-socket" cx="40" cy="36" rx="4" ry="5"/>
          <ellipse class="rs-eye-socket" cx="54" cy="36" rx="4" ry="5"/>
          <!-- glowing pupils -->
          <circle class="rs-eye" cx="40" cy="36" r="2.2" fill="url(#rs-eye-glow)" stroke="none"/>
          <circle class="rs-eye" cx="54" cy="36" r="2.2" fill="url(#rs-eye-glow)" stroke="none"/>
          <!-- whisker dots (sockets) -->
          <circle cx="34" cy="46" r="0.5" fill="#e8eef5"/>
          <circle cx="34" cy="49" r="0.5" fill="#e8eef5"/>
          <circle cx="34" cy="52" r="0.5" fill="#e8eef5"/>
        </g>
      </g>
    </svg>
  </section>

  <section class="rs-page-section">
    <div class="rs-page-inner">
      {designDocs.length > 0 ? (
        <>
          <div class="rs-stats">
            <span class="rs-stat">{designDocs.length} {isVi ? 'tài liệu' : 'docs'}</span>
            <span class="rs-stat-sep">&middot;</span>
            <span class="rs-stat">{docsByProject.size} {isVi ? 'dự án' : 'projects'}</span>
            <span class="rs-stat-sep">&middot;</span>
            <span class="rs-stat"><span class="rs-dot rs-dot-spec" />{totalSpecs} {isVi ? 'thiết kế' : 'specs'}</span>
            <span class="rs-stat-sep">&middot;</span>
            <span class="rs-stat"><span class="rs-dot rs-dot-plan" />{totalPlans} {isVi ? 'kế hoạch' : 'plans'}</span>
            <span class="rs-stat-sep">&middot;</span>
            <span class="rs-stat">{totalLines.toLocaleString()} {isVi ? 'dòng' : 'lines'}</span>
          </div>
          <div class="rs-list">
            {[...docsByProject.entries()].map(([project, docs]) => (
              <div class="rs-group">
                <div class="rs-group-header">
                  <span class="rs-group-name">{projectDisplayNames[project] ?? project}</span>
                  <span class="rs-group-count">{docs.length}</span>
                </div>
                {docs.map(doc => (
                  <details class="rs-row">
                    <summary class={`rs-row-summary rs-row-${doc.doc_type}`}>
                      <span class={`rs-badge rs-badge-${doc.doc_type}`}>
                        {doc.doc_type === 'spec' ? (isVi ? 'Thiết kế' : 'Spec') : (isVi ? 'Kế hoạch' : 'Plan')}
                      </span>
                      <span class="rs-row-title">{doc.title}</span>
                      <span class="rs-row-meta">
                        <span class="rs-row-date">{new Date(doc.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
                        <span class="rs-row-lines">{doc.line_count?.toLocaleString()}</span>
                      </span>
                      <span class="rs-row-links">
                        {doc.notion_url && (
                          <a href={doc.notion_url} target="_blank" rel="noopener" class="rs-link" title="Notion" onclick="event.stopPropagation()">
                            <svg width="12" height="12" viewBox="0 0 100 100" fill="currentColor"><path d="M6.6 12.2c4-3.5 5.3-3 16-2.1l43.6 3c1.8.2 .4 1.8-.7 2.1L54 22.9c-2.5 1.5-3.4 1.2-10.3.6L12.8 19c-2.3-.5-2.8-1.5-.7-2.8zm4.2 13.7v46c0 2.5 1.2 3.5 4.2 3.3l48-2.8c3-.2 3.5-2 3.5-4.3v-45c0-2.3-.9-3.5-2.8-3.3l-50 2.8c-2.1.2-2.8 1.5-2.8 3.3zm47.5 2.3c.4 1.6 0 3.2-1.6 3.4l-2.3.4v34c-2 1.1-3.9 1.6-5.3 1.6-2.5 0-3.2-.7-5-3L28.8 40.1V63l4.8 1.1s0 3.2-4.2 3.2l-11.6.7c-.4-.7 0-2.5 1.2-2.8l3.2-.9V33.5l-4.4-.3c-.4-1.6.5-4.2 3.7-4.4l12.5-.7 16.7 25.4V32.7l-4.1-.5c-.4-2.1 1.1-3.5 3-3.7z"/></svg>
                          </a>
                        )}
                        <a href={`https://github.com/deathemperor/pensieve/blob/main/${doc.file_path}`} target="_blank" rel="noopener" class="rs-link" title="GitHub" onclick="event.stopPropagation()">
                          <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                        </a>
                      </span>
                    </summary>
                    <div class="rs-detail">
                      {doc.summary && <p class="rs-detail-summary">{doc.summary}</p>}
                      {doc.prompt && (
                        <div class="rs-detail-prompt">
                          <span class="rs-detail-prompt-label">Prompt</span>
                          <span class="rs-detail-prompt-text">{doc.prompt}</span>
                        </div>
                      )}
                    </div>
                  </details>
                ))}
              </div>
            ))}
          </div>
        </>
      ) : (
        <p class="rs-empty">
          {isVi ? "Chưa có tài liệu nào." : "No documents yet."}
        </p>
      )}
    </div>
  </section>
</Base>

<style>
  .rs-page-hero {
    border-bottom: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
    --rs-prowl-dur: 16s;
    --rs-cat-w: 320px;
    --rs-cat-h: 160px;
    isolation: isolate;
  }

  /* Title shake — sympathetic motion at peak (40-44% of prowl) */
  .rs-title-shake {
    display: inline-block;
    animation: rs-title-shake var(--rs-prowl-dur, 16s) linear infinite;
    transform-origin: center;
  }
  @keyframes rs-title-shake {
    0%, 36%, 50%, 100% { transform: translate(0, 0); text-shadow: none; }
    38% { transform: translate(-1px, 0); }
    39% { transform: translate(2px, -1px); text-shadow: 2px 0 0 rgba(255,100,200,0.5), -2px 0 0 rgba(126,200,255,0.5); }
    40% { transform: translate(-2px, 1px); text-shadow: 3px 0 0 rgba(255,100,200,0.7), -3px 0 0 rgba(126,200,255,0.7); }
    41% { transform: translate(3px, -1px); text-shadow: 2px 0 0 rgba(255,230,100,0.7), -2px 0 0 rgba(155,231,255,0.7); }
    42% { transform: translate(-2px, 1px); text-shadow: 3px 0 0 rgba(255,230,100,0.8), -3px 0 0 rgba(126,200,255,0.7); }
    43% { transform: translate(1px, 0); text-shadow: 1px 0 0 rgba(255,200,60,0.4), -1px 0 0 rgba(155,231,255,0.4); }
    44% { transform: translate(0, 0); text-shadow: none; }
  }

  /* ═══ Skeleton Cat — Mrs. Norris in bone form, prowling the Restricted Section ═══ */
  /* Architecture: 4 synchronized layers all share the rs-cat-prowl timing
     - aura (ground shadow + ectoplasm haze) travels with cat
     - trail (ectoplasm wisps) emit from cat's body, drift up
     - shards (rib/vertebra particles) detach and float up with eye-burst peaks
     - cat (svg bones) is the focal point with its own micro-animations  */

  .rs-skeleton-cat {
    position: absolute;
    bottom: 4px;
    left: -320px;
    width: var(--rs-cat-w, 320px);
    height: var(--rs-cat-h, 160px);
    pointer-events: none;
    opacity: 0;
    animation: rs-cat-prowl var(--rs-prowl-dur, 16s) cubic-bezier(0.4, 0, 0.2, 1) infinite;
    transform-origin: 50% 100%;
    z-index: 2;
    filter: drop-shadow(0 6px 10px rgba(0, 8, 20, 0.7))
            drop-shadow(0 0 18px rgba(126, 200, 255, 0.35));
    will-change: left, opacity, transform, filter;
  }

  @keyframes rs-cat-prowl {
    /* Phase 1: APPARATE IN from left edge with ice-blue aura */
    0%   { left: -280px; opacity: 0; transform: scaleX(1) scaleY(0.92); filter: drop-shadow(0 6px 10px rgba(0,8,20,0.7)) drop-shadow(0 0 18px rgba(126,200,255,0)) blur(6px); }
    3%   { left: -180px; opacity: 0.15; filter: drop-shadow(0 6px 10px rgba(0,8,20,0.7)) drop-shadow(0 0 28px rgba(126,200,255,0.6)) blur(3px); }
    6%   { left: -100px; opacity: 0.95; transform: scaleX(1) scaleY(1); filter: drop-shadow(0 6px 10px rgba(0,8,20,0.7)) drop-shadow(0 0 18px rgba(126,200,255,0.4)) blur(0); }
    /* Phase 2: PROWL rightward — color shifts from ice to violet */
    18%  { left: 22%; transform: scaleX(1) scaleY(1) translateY(0); filter: drop-shadow(0 6px 10px rgba(0,8,20,0.7)) drop-shadow(0 0 18px rgba(168,140,255,0.45)); }
    24%  { transform: scaleX(1) scaleY(0.99) translateY(-1.5px); }
    30%  { left: 38%; transform: scaleX(1) scaleY(1) translateY(0); filter: drop-shadow(0 6px 10px rgba(0,8,20,0.7)) drop-shadow(0 0 22px rgba(168,140,255,0.55)); }
    /* Phase 3: PEAK PAUSE — freeze mid-stage, ARCH back, hiss, full burst */
    36%  { left: 48%; transform: scaleX(1) scaleY(1) translateY(0); }
    38%  { left: 50%; transform: scaleX(1) scaleY(1.05) translateY(-3px) skewX(-2deg); } /* recoil */
    40%  { left: 50%; opacity: 1; transform: scaleX(1) scaleY(1.18) translateY(-8px) skewX(-4deg) rotate(-3deg); filter: drop-shadow(0 8px 14px rgba(0,8,20,0.85)) drop-shadow(0 0 50px rgba(255, 100, 200, 0.95)) drop-shadow(0 0 90px rgba(255, 60, 160, 0.5)); } /* ARCH + violet-pink burst */
    42%  { left: 50%; transform: scaleX(1) scaleY(1.22) translateY(-10px) skewX(-5deg) rotate(-4deg); filter: drop-shadow(0 8px 14px rgba(0,8,20,0.85)) drop-shadow(0 0 60px rgba(255, 230, 100, 1)) drop-shadow(0 0 110px rgba(255, 200, 60, 0.6)); } /* PEAK gold flash */
    44%  { left: 50%; transform: scaleX(1) scaleY(1.18) translateY(-8px) skewX(-3deg) rotate(-2deg); filter: drop-shadow(0 8px 14px rgba(0,8,20,0.85)) drop-shadow(0 0 50px rgba(155, 231, 255, 0.9)) drop-shadow(0 0 80px rgba(90, 184, 255, 0.4)); } /* settle to ice blue */
    47%  { left: 51%; transform: scaleX(1) scaleY(1.05) translateY(-3px) skewX(0); }
    50%  { left: 54%; opacity: 0.95; transform: scaleX(1) scaleY(1) translateY(0); filter: drop-shadow(0 6px 10px rgba(0,8,20,0.7)) drop-shadow(0 0 22px rgba(126,200,255,0.5)); }
    /* Phase 4: continue prowl to right side */
    55%  { left: 72%; transform: scaleX(1) scaleY(1); opacity: 0.92; }
    /* Phase 5: VANISHING-CABINET flip */
    58%  { left: 75%; opacity: 0.6; filter: blur(2px) drop-shadow(0 0 30px rgba(255,255,255,0.6)); }
    60%  { left: 75%; opacity: 0; transform: scaleX(0.05) scaleY(1.4); filter: blur(6px) drop-shadow(0 0 50px rgba(255,255,255,0.8)); }
    62%  { left: 75%; opacity: 0; transform: scaleX(-0.05) scaleY(1.4); }
    64%  { left: 75%; opacity: 0.6; transform: scaleX(-1) scaleY(1); filter: blur(2px) drop-shadow(0 0 30px rgba(255,255,255,0.6)); }
    66%  { left: 73%; opacity: 0.95; transform: scaleX(-1) scaleY(1); filter: drop-shadow(0 6px 10px rgba(0,8,20,0.7)) drop-shadow(0 0 18px rgba(126,200,255,0.4)); }
    /* Phase 6: prowl leftward back home — emerald cast */
    78%  { left: 32%; transform: scaleX(-1) scaleY(1); opacity: 0.95; filter: drop-shadow(0 6px 10px rgba(0,8,20,0.7)) drop-shadow(0 0 22px rgba(63,185,80,0.5)); }
    88%  { left: 8%; transform: scaleX(-1) scaleY(1); opacity: 0.9; filter: drop-shadow(0 6px 10px rgba(0,8,20,0.7)) drop-shadow(0 0 18px rgba(126,200,255,0.4)); }
    /* Phase 7: APPARATE OUT at left edge */
    93%  { left: -100px; opacity: 0.5; transform: scaleX(-1) scaleY(0.96); filter: blur(3px) drop-shadow(0 0 24px rgba(126,200,255,0.5)); }
    97%  { left: -200px; opacity: 0.1; filter: blur(6px); }
    100% { left: -280px; opacity: 0; transform: scaleX(1) scaleY(0.9); filter: blur(8px); }
  }

  /* Hero-wide atmospheric stage glow — pulses brightest at peak */
  .rs-stage-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(ellipse at 50% 100%, rgba(126, 200, 255, 0.10), rgba(168, 140, 255, 0.06) 30%, transparent 60%);
    opacity: 0;
    animation: rs-stage-glow-pulse var(--rs-prowl-dur, 16s) linear infinite;
    mix-blend-mode: screen;
  }
  @keyframes rs-stage-glow-pulse {
    0%, 5%, 95%, 100%        { opacity: 0; background: radial-gradient(ellipse at 50% 100%, rgba(126,200,255,0.10), transparent 60%); }
    8%                       { opacity: 0.6; background: radial-gradient(ellipse at 10% 100%, rgba(126,200,255,0.18), transparent 60%); }
    20%                      { opacity: 0.5; background: radial-gradient(ellipse at 25% 100%, rgba(168,140,255,0.16), transparent 60%); }
    36%                      { opacity: 0.7; background: radial-gradient(ellipse at 50% 100%, rgba(255,100,200,0.20), transparent 60%); }
    40%                      { opacity: 1;   background: radial-gradient(ellipse at 50% 100%, rgba(255,230,100,0.30), rgba(255,100,200,0.18) 35%, transparent 65%); } /* PEAK gold-pink flood */
    44%                      { opacity: 0.9; background: radial-gradient(ellipse at 50% 100%, rgba(155,231,255,0.25), transparent 60%); }
    55%                      { opacity: 0.5; background: radial-gradient(ellipse at 75% 100%, rgba(126,200,255,0.16), transparent 60%); }
    65%                      { opacity: 0.7; background: radial-gradient(ellipse at 75% 100%, rgba(255,255,255,0.20), transparent 60%); } /* flip flash */
    80%                      { opacity: 0.5; background: radial-gradient(ellipse at 25% 100%, rgba(63,185,80,0.18), transparent 60%); }
  }

  /* Hiss soundwaves — concentric arcs from cat's mouth at peak */
  .rs-hiss-waves {
    position: absolute;
    bottom: 60px;
    left: -280px;
    width: 280px;
    height: 0;
    pointer-events: none;
    z-index: 2;
    animation: rs-cat-prowl var(--rs-prowl-dur, 16s) cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
  .rs-hiss-wave {
    position: absolute;
    left: 18%;
    top: 0;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 2px solid rgba(255, 230, 100, 0.7);
    box-shadow: 0 0 12px rgba(255, 200, 60, 0.6), inset 0 0 8px rgba(255, 230, 100, 0.4);
    transform: translate(-50%, -50%) scale(0);
    opacity: 0;
    animation: rs-hiss-pulse var(--rs-prowl-dur, 16s) linear infinite;
    animation-delay: calc(var(--i) * 0.08s);
  }
  @keyframes rs-hiss-pulse {
    0%, 38%, 50%, 100% { opacity: 0; transform: translate(-50%, -50%) scale(0); }
    40% { opacity: 1; transform: translate(-50%, -50%) scale(0.5); border-width: 3px; }
    44% { opacity: 0.7; transform: translate(-50%, -50%) scale(2.5); border-width: 1.5px; }
    48% { opacity: 0; transform: translate(-50%, -50%) scale(4); border-width: 0.5px; }
  }

  /* Familiar pack: 2 smaller kittens trailing alpha at offset phases */
  .rs-cat-mini {
    position: absolute;
    bottom: 4px;
    pointer-events: none;
    opacity: 0;
    z-index: 2;
    transform-origin: 50% 100%;
    filter: drop-shadow(0 4px 6px rgba(0, 8, 20, 0.6))
            drop-shadow(0 0 12px rgba(126, 200, 255, 0.3));
    will-change: left, opacity, transform, filter;
  }
  .rs-cat-mini-1 {
    width: calc(var(--rs-cat-w, 320px) * 0.55);
    height: calc(var(--rs-cat-h, 160px) * 0.55);
    animation: rs-cat-prowl var(--rs-prowl-dur, 16s) cubic-bezier(0.4, 0, 0.2, 1) infinite;
    animation-delay: -1.6s; /* 10% phase offset on a 16s timeline */
    bottom: -4px;
  }
  .rs-cat-mini-2 {
    width: calc(var(--rs-cat-w, 320px) * 0.42);
    height: calc(var(--rs-cat-h, 160px) * 0.42);
    animation: rs-cat-prowl var(--rs-prowl-dur, 16s) cubic-bezier(0.4, 0, 0.2, 1) infinite;
    animation-delay: -2.8s;
    bottom: -8px;
  }

  /* Ghost double — translucent cat-shape lagging behind */
  .rs-cat-ghost {
    position: absolute;
    bottom: 4px;
    left: -280px;
    width: 280px;
    height: 140px;
    pointer-events: none;
    opacity: 0;
    z-index: 1;
    animation: rs-cat-prowl var(--rs-prowl-dur, 16s) cubic-bezier(0.4, 0, 0.2, 1) infinite;
    animation-delay: -0.4s; /* trails behind by 0.4s */
    mix-blend-mode: screen;
    filter: blur(2.5px) drop-shadow(0 0 12px rgba(155, 231, 255, 0.6));
    transform-origin: 50% 100%;
  }
  /* Ghost is fainter than the cat — override the cat's full opacity */
  .rs-cat-ghost { animation-name: rs-cat-prowl-ghost; }
  @keyframes rs-cat-prowl-ghost {
    0%, 6%   { left: -280px; opacity: 0; transform: scaleX(1); }
    9%       { left: -100px; opacity: 0.45; transform: scaleX(1); }
    21%      { left: 22%; opacity: 0.4; transform: scaleX(1); }
    33%      { left: 38%; opacity: 0.4; transform: scaleX(1); }
    40%      { left: 50%; opacity: 0.6; transform: scaleX(1) scaleY(1.18) translateY(-8px); }
    44%      { left: 50%; opacity: 0.5; transform: scaleX(1) scaleY(1.18) translateY(-8px); }
    50%      { left: 54%; opacity: 0.4; transform: scaleX(1); }
    58%      { left: 75%; opacity: 0.3; }
    60%, 64% { left: 75%; opacity: 0; }
    69%      { left: 73%; opacity: 0.45; transform: scaleX(-1); }
    81%      { left: 32%; opacity: 0.4; transform: scaleX(-1); }
    91%      { left: 8%; opacity: 0.35; transform: scaleX(-1); }
    96%      { left: -100px; opacity: 0.2; }
    100%     { left: -280px; opacity: 0; transform: scaleX(1); }
  }

  /* Ground shadow + ectoplasm haze — moves with cat */
  .rs-cat-aura {
    position: absolute;
    bottom: -10px;
    left: -280px;
    width: 280px;
    height: 80px;
    pointer-events: none;
    z-index: 1;
    opacity: 0;
    animation: rs-cat-prowl var(--rs-prowl-dur, 16s) cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
  .rs-cat-shadow {
    position: absolute;
    bottom: 0;
    left: 25%;
    width: 50%;
    height: 16px;
    border-radius: 50%;
    background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.55), rgba(0, 0, 0, 0.2) 60%, transparent 75%);
    filter: blur(4px);
    animation: rs-shadow-pulse 0.8s ease-in-out infinite;
  }
  @keyframes rs-shadow-pulse {
    0%, 100% { transform: scaleX(1) scaleY(1); opacity: 0.85; }
    50%      { transform: scaleX(1.08) scaleY(0.85); opacity: 1; }
  }
  .rs-cat-haze {
    position: absolute;
    bottom: 8px;
    left: 15%;
    width: 70%;
    height: 70px;
    border-radius: 50%;
    background: radial-gradient(ellipse at 50% 70%, rgba(126, 200, 255, 0.18), rgba(90, 184, 255, 0.06) 40%, transparent 70%);
    filter: blur(8px);
    animation: rs-haze-breathe 3.4s ease-in-out infinite;
    mix-blend-mode: screen;
  }
  @keyframes rs-haze-breathe {
    0%, 100% { transform: scale(1); opacity: 0.7; }
    50%      { transform: scale(1.15); opacity: 1; }
  }

  /* Trailing ectoplasm wisps — emit behind the cat, drift up */
  .rs-cat-trail {
    position: absolute;
    bottom: 20px;
    left: -280px;
    width: 280px;
    height: 90px;
    pointer-events: none;
    z-index: 2;
    animation: rs-cat-prowl var(--rs-prowl-dur, 16s) cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
  .rs-wisp {
    position: absolute;
    bottom: 4px;
    left: 38%;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 50%, rgba(200, 230, 255, 0.6), rgba(126, 200, 255, 0.2) 50%, transparent 75%);
    filter: blur(3px);
    mix-blend-mode: screen;
    opacity: 0;
    animation: rs-wisp-rise 2.8s ease-out infinite;
    animation-delay: calc(var(--i) * 0.34s);
  }
  @keyframes rs-wisp-rise {
    0%   { opacity: 0; transform: translate(0, 0) scale(0.4); }
    25%  { opacity: 0.85; transform: translate(-10px, -16px) scale(1); }
    100% { opacity: 0; transform: translate(-32px, -56px) scale(1.6); }
  }

  /* Detached bone shards — float up from the cat */
  .rs-bone-shards {
    position: absolute;
    bottom: 30px;
    left: -280px;
    width: 280px;
    height: 100px;
    pointer-events: none;
    z-index: 3;
    animation: rs-cat-prowl var(--rs-prowl-dur, 16s) cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
  .rs-shard {
    position: absolute;
    bottom: 0;
    left: calc(30% + var(--i) * 6%);
    background: linear-gradient(180deg, #ffffff, #b8d4ec);
    box-shadow: 0 0 4px rgba(155, 231, 255, 0.8), 0 0 10px rgba(90, 184, 255, 0.4);
    opacity: 0;
    animation: rs-shard-float 4.2s ease-out infinite;
    animation-delay: calc(var(--i) * 0.6s);
  }
  .rs-shard-rib {
    width: 8px;
    height: 2px;
    border-radius: 1px;
    transform-origin: center;
  }
  .rs-shard-vert {
    width: 3px;
    height: 3px;
    border-radius: 50%;
  }
  @keyframes rs-shard-float {
    0%   { opacity: 0; transform: translate(0, 0) rotate(0deg); }
    15%  { opacity: 1; transform: translate(-4px, -10px) rotate(45deg); }
    60%  { opacity: 0.7; transform: translate(-18px, -50px) rotate(220deg); }
    100% { opacity: 0; transform: translate(-30px, -90px) rotate(420deg); }
  }

  /* Eye-burst aura — pulses at PEAK (40-44% of prowl) */
  .rs-eye-burst-group { opacity: 0; }
  .rs-eye-burst {
    transform-origin: center;
    transform-box: fill-box;
    animation: rs-eye-burst-pulse var(--rs-prowl-dur, 16s) cubic-bezier(0.4, 0, 0.2, 1) infinite;
    mix-blend-mode: screen;
  }
  .rs-skeleton-cat .rs-eye-burst-group { animation: rs-eye-burst-fade var(--rs-prowl-dur, 16s) linear infinite; }
  @keyframes rs-eye-burst-fade {
    0%, 36%, 50%, 100% { opacity: 0; }
    40%, 44% { opacity: 1; }
  }
  @keyframes rs-eye-burst-pulse {
    0%, 36%, 50%, 100% { transform: scale(0.4); }
    40% { transform: scale(2.2); }
    44% { transform: scale(2.8); }
  }

  /* Bones flicker as if barely held together */
  .rs-cat-bones {
    animation: rs-bone-flicker 5.5s ease-in-out infinite;
  }
  @keyframes rs-bone-flicker {
    0%, 100% { opacity: 1; }
    47% { opacity: 1; }
    49% { opacity: 0.55; } /* brief skip */
    50% { opacity: 1; }
    72% { opacity: 0.8; }
    74% { opacity: 1; }
  }

  /* Spine: subtle breathing arc */
  .rs-spine {
    transform-origin: 50% 56px;
    animation: rs-spine-breathe 3.4s ease-in-out infinite;
  }
  @keyframes rs-spine-breathe {
    0%, 100% { transform: translateY(0) scaleY(1); }
    50% { transform: translateY(-1px) scaleY(1.03); }
  }

  /* Ribs: stagger expand/contract — breathing rib cage */
  .rs-rib {
    transform-origin: top center;
    animation: rs-rib-breathe 3.4s ease-in-out infinite;
  }
  .rs-rib:nth-of-type(2) { animation-delay: 0.05s; }
  .rs-rib:nth-of-type(3) { animation-delay: 0.10s; }
  .rs-rib:nth-of-type(4) { animation-delay: 0.15s; }
  .rs-rib:nth-of-type(5) { animation-delay: 0.10s; }
  .rs-rib:nth-of-type(6) { animation-delay: 0.05s; }
  @keyframes rs-rib-breathe {
    0%, 100% { transform: scaleX(1); }
    50% { transform: scaleX(1.08); }
  }

  /* Legs: simulate a gait — alternating front/back pairs */
  .rs-leg-fr, .rs-leg-bl {
    transform-origin: top center;
    animation: rs-leg-step 0.8s ease-in-out infinite;
  }
  .rs-leg-fl, .rs-leg-br {
    transform-origin: top center;
    animation: rs-leg-step 0.8s ease-in-out infinite reverse;
  }
  @keyframes rs-leg-step {
    0%, 100% { transform: rotate(-6deg); }
    50% { transform: rotate(8deg); }
  }

  /* Tail: bony whip, sways like a metronome */
  .rs-tail {
    transform-origin: 186px 58px;
    animation: rs-tail-sway 2.2s ease-in-out infinite;
  }
  .rs-vert {
    transform-origin: 186px 58px;
    animation: rs-tail-sway 2.2s ease-in-out infinite;
  }
  @keyframes rs-tail-sway {
    0%, 100% { transform: rotate(-12deg); }
    50% { transform: rotate(14deg); }
  }

  /* Skull: head bob in time with steps */
  .rs-skull {
    transform-origin: 46px 38px;
    animation: rs-head-bob 0.8s ease-in-out infinite;
  }
  @keyframes rs-head-bob {
    0%, 100% { transform: translateY(0) rotate(-1deg); }
    50% { transform: translateY(-1.5px) rotate(1deg); }
  }

  /* Eye sockets: hollow black */
  .rs-eye-socket {
    fill: #05080d;
    stroke: #e8eef5;
    stroke-width: 0.9;
  }

  /* Glowing pupils with blink + radial pulse */
  .rs-eye {
    transform-origin: center;
    transform-box: fill-box;
    animation: rs-eye-blink 4.7s steps(1, end) infinite, rs-eye-pulse 1.8s ease-in-out infinite;
    filter: drop-shadow(0 0 4px #9be7ff) drop-shadow(0 0 10px #5ab8ff) drop-shadow(0 0 18px rgba(90, 184, 255, 0.6));
  }
  @keyframes rs-eye-blink {
    0%, 92%, 100% { transform: scaleY(1); }
    93%, 95% { transform: scaleY(0.05); }
    94% { transform: scaleY(0.05); }
  }
  @keyframes rs-eye-pulse {
    0%, 100% { opacity: 0.9; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.15); }
  }

  /* The bones get a subtle turbulence flicker — only at PEAK, not always */
  .rs-skeleton-cat:hover .rs-cat-bones,
  .rs-skeleton-cat .rs-cat-bones {
    /* base look already has the rs-bone-glow filter; turbulence is too jittery to leave on always */
  }

  /* Bones draw themselves in via stroke-dasharray during apparation phase */
  .rs-bone {
    stroke-dasharray: 200;
    stroke-dashoffset: 0;
    animation: rs-bone-draw 24s ease-in-out infinite;
  }
  @keyframes rs-bone-draw {
    /* Apparation in (0-6%): bones draw from nothing */
    0%, 1% { stroke-dashoffset: 200; }
    6% { stroke-dashoffset: 0; }
    /* Stable through prowl */
    58% { stroke-dashoffset: 0; }
    /* Vanish out at flip (60-62%): bones erase */
    60% { stroke-dashoffset: 200; }
    62% { stroke-dashoffset: 200; }
    /* Re-draw after flip */
    66% { stroke-dashoffset: 0; }
    93% { stroke-dashoffset: 0; }
    /* Final apparation out (97-100%) */
    97% { stroke-dashoffset: 200; }
    100% { stroke-dashoffset: 200; }
  }
  /* Stagger the rib draw-ins for visual richness */
  .rs-rib:nth-of-type(2) { animation-delay: 0.05s; }
  .rs-rib:nth-of-type(3) { animation-delay: 0.10s; }
  .rs-rib:nth-of-type(4) { animation-delay: 0.15s; }
  .rs-rib:nth-of-type(5) { animation-delay: 0.20s; }

  /* Lightning bolts along spine — flicker on and off at apparation moments */
  .rs-lightning { opacity: 0; animation: rs-lightning-flicker var(--rs-prowl-dur, 16s) linear infinite; }
  @keyframes rs-lightning-flicker {
    0%, 1.5%, 6%, 60%, 62%, 100% { opacity: 0; }
    2%, 3%, 4%, 5% { opacity: 1; }
    60.5%, 61% { opacity: 1; }
    /* mid-prowl crackle at peak too */
    40%, 42%, 44% { opacity: 1; }
    41%, 43% { opacity: 0.4; }
    45%, 50% { opacity: 0; }
    /* leftward apparation flicker */
    93%, 94%, 95% { opacity: 1; }
    93.5%, 94.5% { opacity: 0.3; }
  }
  .rs-bolt { stroke-dasharray: 50; }
  .rs-bolt-1 { animation: rs-bolt-strike 0.18s steps(2) infinite; }
  .rs-bolt-2 { animation: rs-bolt-strike 0.24s steps(2) infinite reverse; }
  .rs-bolt-3 { animation: rs-bolt-strike 0.20s steps(2) infinite; }
  @keyframes rs-bolt-strike {
    0% { stroke-dashoffset: 50; }
    100% { stroke-dashoffset: 0; }
  }

  /* Patronus 12-ray burst — fires at PEAK (40-46%) from cat's chest */
  .rs-ray-burst {
    position: absolute;
    bottom: 60px;
    left: -280px;
    width: 280px;
    height: 0;
    pointer-events: none;
    z-index: 2;
    animation: rs-cat-prowl var(--rs-prowl-dur, 16s) cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
  .rs-ray-burst::before {
    /* anchor at cat's chest center, 50% of the prowl box */
    content: "";
    position: absolute;
    left: 50%;
    top: 0;
    width: 0;
    height: 0;
  }
  .rs-ray {
    position: absolute;
    left: 50%;
    top: 0;
    width: 2px;
    height: 0;
    background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(155, 231, 255, 0.6), transparent);
    transform-origin: top center;
    transform: rotate(var(--a)) translateY(0);
    opacity: 0;
    filter: drop-shadow(0 0 4px rgba(155, 231, 255, 0.95));
    animation: rs-ray-fire var(--rs-prowl-dur, 16s) linear infinite;
  }
  @keyframes rs-ray-fire {
    0%, 38%, 50%, 100% { height: 0; opacity: 0; }
    40% { height: 0; opacity: 1; }
    44% { height: 90px; opacity: 1; }
    48% { height: 130px; opacity: 0; }
  }

