---
export const prerender = false;

import { env } from "cloudflare:workers";
import Base from "../../../layouts/Base.astro";
import TierSection from "../../../components/portraits/TierSection.astro";
import CorridorTable from "../../../components/portraits/CorridorTable.astro";
import GuestBanner from "../../../components/portraits/GuestBanner.astro";
import RemindersPill from "../../../components/portraits/RemindersPill.astro";
import PipelinePill from "../../../components/portraits/PipelinePill.astro";
import { requireAdmin } from "../../../lib/portraits/auth";
import { listContacts } from "../../../lib/portraits/db";
import type { Contact, TierCode } from "../../../lib/portraits/types";
import { getCurrentLang } from "../../../utils/lang";

const lang = getCurrentLang(Astro);
const isVi = lang === "vi";
const auth = await requireAdmin(Astro);
const db = (env as any).DB;

const url = new URL(Astro.request.url);
const q = auth.admin ? (url.searchParams.get("q") ?? "").trim() : "";
const tiersParam = auth.admin ? (url.searchParams.get("tiers") ?? "").trim() : "";
const selectedTiers = tiersParam
  ? (tiersParam.split(",").map((t) => t.trim().toUpperCase()).filter((t): t is TierCode => ["S","A","B","C","D"].includes(t as TierCode)))
  : undefined;

const contacts: Contact[] = await listContacts(db, {
  includePlaceholders: !auth.admin,
  onlyPlaceholders: !auth.admin,
  search: q || undefined,
  tiers: selectedTiers,
});

const buckets: Record<TierCode, Contact[]> = { S: [], A: [], B: [], C: [], D: [] };
for (const c of contacts) buckets[c.prestige_tier].push(c);
const total = contacts.length;

// Cache: guest cached 1h at the edge; admin never cached anywhere.
// Astro.cache.set only honors maxAge/swr/tags; set the full Cache-Control header directly for "private, no-store".
Astro.cache.set({ maxAge: auth.admin ? 0 : 3600 });
Astro.response.headers.set(
  "Cache-Control",
  auth.admin ? "private, no-store" : "public, max-age=3600, s-maxage=3600",
);
---

<Base
  title={isVi ? "Phòng Tranh — Room of Requirement" : "Portraits — Room of Requirement"}
  description={isVi ? "Bộ sưu tập riêng các nhân vật quan trọng." : "A private rolodex of notable figures."}
>
  <main class="portraits-page">
    <header class="portraits-hero">
      <h1>{isVi ? "Phòng Tranh" : "Portraits"}</h1>
      <p class="hero-sub">
        {isVi
          ? <>Phòng tranh những người định hình công việc. {total} {total === 1 ? "chân dung" : "chân dung"}.</>
          : <>A gallery of the people who shape the work. {total} {total === 1 ? "portrait" : "portraits"}.</>}
      </p>
      {auth.admin && (
        <div class="admin-actions">
          <a class="btn" href="/room-of-requirement/portraits/dashboard">📊 {isVi ? "Tổng quan" : "Dashboard"}</a>
          <a class="btn btn-primary" href="/room-of-requirement/portraits/add">＋ New portrait</a>
          <a class="btn" href="/room-of-requirement/portraits/capture">📷 Capture card</a>
          <a class="btn" href="/room-of-requirement/portraits/import">📁 Import</a>
          <a class="btn" href="/room-of-requirement/portraits/sync">🔗 Sync</a>
          <a class="btn" href="/room-of-requirement/portraits/graph">🕸 Graph</a>
          <a class="btn" href="/room-of-requirement/portraits/events">🎟 Events</a>
        </div>
      )}
      {auth.admin && (
        <div class="header-pills">
          <RemindersPill db={db} />
          <PipelinePill db={db} />
        </div>
      )}
      {auth.admin && (
        <form class="gallery-filter" method="get" data-current-q={q}>
          <input
            type="search"
            name="q"
            value={q}
            placeholder={isVi ? "Tìm theo tên, công ty, thẻ…" : "Search name, company, tag…"}
            autocomplete="off"
          />
          <div class="tier-chips">
            {(["S","A","B","C","D"] as const).map((tier) => {
              const active = (selectedTiers ?? []).includes(tier);
              const next = active
                ? (selectedTiers ?? []).filter((t) => t !== tier)
                : [...(selectedTiers ?? []), tier];
              const params = new URLSearchParams();
              if (q) params.set("q", q);
              if (next.length > 0) params.set("tiers", next.join(","));
              const href = `?${params.toString()}`;
              return (
                <a class={`tier-chip chip-${tier} ${active ? "active" : ""}`} href={href}>
                  {tier}
                </a>
              );
            })}
            {(q || (selectedTiers && selectedTiers.length > 0)) && (
              <a class="tier-chip clear" href="?">{isVi ? "xoá" : "clear"}</a>
            )}
          </div>
          <button type="submit" class="filter-apply">{isVi ? "Tìm" : "Search"}</button>
        </form>
      )}
    </header>

    {!auth.admin && <GuestBanner />}

    {buckets.S.length > 0 && <TierSection tier="S" contacts={buckets.S} isAdminView={auth.admin} />}
    {buckets.A.length > 0 && <TierSection tier="A" contacts={buckets.A} isAdminView={auth.admin} />}
    {buckets.B.length > 0 && <TierSection tier="B" contacts={buckets.B} isAdminView={auth.admin} />}
    {buckets.C.length > 0 && <TierSection tier="C" contacts={buckets.C} isAdminView={auth.admin} />}
    {buckets.D.length > 0 && <CorridorTable contacts={buckets.D} />}

    {total === 0 && (
      <div class="empty">
        <p>
          {isVi ? "Chưa có chân dung nào." : "No portraits yet."}
          {" "}
          {auth.admin
            ? (isVi ? "Thêm liên lạc đầu tiên để khai trương phòng tranh." : "Add your first contact to start the gallery.")
            : ""}
        </p>
      </div>
    )}
  </main>

  {auth.admin && (
    <aside id="slideover" class="slideover" aria-hidden="true" aria-labelledby="slideover-title">
      <div class="slideover-head">
        <h2 id="slideover-title" class="slideover-title">—</h2>
        <div class="slideover-actions">
          <a id="slideover-fullpage" class="slideover-link" href="#">{isVi ? "Mở rộng" : "Full page"} ↗</a>
          <button id="slideover-close" class="slideover-close" aria-label="Close">✕</button>
        </div>
      </div>
      <div id="slideover-body" class="slideover-body">
        <p class="slideover-placeholder muted">{isVi ? "Đang tải…" : "Loading…"}</p>
      </div>
    </aside>
  )}
</Base>

<script>
  // Slide-over: intercept admin gallery clicks, fetch JSON, render a preview.
  // Desktop only (≥ 900px). On narrow viewports, the click falls through to
  // the full-page route — the slide-over is hidden by CSS.
  const slideover = document.getElementById("slideover") as HTMLElement | null;
  const titleEl = document.getElementById("slideover-title") as HTMLElement | null;
  const bodyEl = document.getElementById("slideover-body") as HTMLElement | null;
  const fullLink = document.getElementById("slideover-fullpage") as HTMLAnchorElement | null;
  const closeBtn = document.getElementById("slideover-close") as HTMLButtonElement | null;

  function isWideViewport(): boolean { return window.matchMedia("(min-width: 900px)").matches; }
  function closeSlide() {
    if (!slideover) return;
    slideover.setAttribute("aria-hidden", "true");
    slideover.classList.remove("open");
  }
  function escape(s: string | null | undefined): string {
    if (s == null) return "";
    return String(s).replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]!));
  }

  async function openSlide(contactId: string) {
    if (!slideover || !bodyEl || !titleEl || !fullLink) return;
    slideover.setAttribute("aria-hidden", "false");
    slideover.classList.add("open");
    titleEl.textContent = "…";
    bodyEl.replaceChildren();
    const loading = document.createElement("p");
    loading.className = "slideover-placeholder muted";
    loading.textContent = "Loading…";
    bodyEl.appendChild(loading);
    fullLink.href = `/room-of-requirement/portraits/${contactId}`;

    const res = await fetch(`/api/portraits/${contactId}`);
    if (!res.ok) {
      bodyEl.replaceChildren();
      const err = document.createElement("p");
      err.className = "slideover-placeholder muted";
      err.textContent = `Failed to load: ${res.statusText}`;
      bodyEl.appendChild(err);
      return;
    }
    const data = await res.json() as { contact: { id: string; full_name: string; display_name: string | null; title: string | null; company: string | null; prestige_tier: string; tier_score: number; bio: string | null; channels: Array<{ kind: string; value: string; is_primary: number }>; tags: string | null } };
    const c = data.contact;

    titleEl.textContent = c.display_name ?? c.full_name;

    // Build body safely with DOM APIs (no innerHTML).
    bodyEl.replaceChildren();

    if (c.title || c.company) {
      const role = document.createElement("p");
      role.className = "slideover-role";
      role.textContent = [c.title, c.company].filter(Boolean).join(" · ");
      bodyEl.appendChild(role);
    }

    const badges = document.createElement("div");
    badges.className = "slideover-badges";
    const tb = document.createElement("span");
    tb.className = "slideover-tier-badge";
    tb.textContent = `Tier ${c.prestige_tier}`;
    badges.appendChild(tb);
    const sc = document.createElement("span");
    sc.className = "muted";
    sc.textContent = `score ${c.tier_score}`;
    badges.appendChild(sc);
    bodyEl.appendChild(badges);

    if (c.bio) {
      const bio = document.createElement("p");
      bio.className = "slideover-bio";
      bio.textContent = c.bio;
      bodyEl.appendChild(bio);
    }

    if (Array.isArray(c.channels) && c.channels.length > 0) {
      const h = document.createElement("h3");
      h.className = "slideover-h3";
      h.textContent = "Channels";
      bodyEl.appendChild(h);
      const ul = document.createElement("ul");
      ul.className = "slideover-channels";
      for (const ch of c.channels) {
        const li = document.createElement("li");
        const kind = document.createElement("span");
        kind.className = "slideover-kind";
        kind.textContent = ch.kind;
        li.appendChild(kind);
        if (ch.kind === "email") {
          const a = document.createElement("a");
          a.href = `mailto:${ch.value}`;
          a.textContent = ch.value;
          li.appendChild(a);
        } else if (ch.kind === "phone") {
          const a = document.createElement("a");
          a.href = `tel:${ch.value.replace(/[^+\d]/g, "")}`;
          a.textContent = ch.value;
          li.appendChild(a);
        } else {
          const sp = document.createElement("span");
          sp.textContent = ch.value;
          li.appendChild(sp);
        }
        ul.appendChild(li);
      }
      bodyEl.appendChild(ul);
    }

    const tags: string[] = c.tags ? (() => { try { return JSON.parse(c.tags) as string[]; } catch { return []; } })() : [];
    if (tags.length > 0) {
      const tagBox = document.createElement("div");
      tagBox.className = "slideover-tags";
      for (const t of tags) {
        const tag = document.createElement("span");
        tag.className = "slideover-tag";
        tag.textContent = t;
        tagBox.appendChild(tag);
      }
      bodyEl.appendChild(tagBox);
    }
  }

  // Intercept gallery card clicks (only on wide viewports).
  document.querySelectorAll<HTMLAnchorElement>(".portrait-card, .corridor-table a").forEach((link) => {
    link.addEventListener("click", (e) => {
      if (!isWideViewport()) return;
      const href = link.getAttribute("href") ?? "";
      const m = href.match(/\/portraits\/([^\/?#]+)/);
      if (!m) return;
      e.preventDefault();
      openSlide(m[1]);
    });
  });

  closeBtn?.addEventListener("click", closeSlide);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeSlide();
  });
</script>

<style>
  .portraits-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.25rem 5rem;
  }
  .portraits-hero {
    padding: 2rem 0 1.5rem;
    border-bottom: 1px solid #1a1a1a;
  }
  .portraits-hero h1 {
    font-family: "Inter Tight", sans-serif;
    font-weight: 500;
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: -0.02em;
    margin: 0;
    color: #e8e6e0;
  }
  .hero-sub {
    color: #8a877e;
    margin: 0.5rem 0 0;
    font-size: 1rem;
  }
  .admin-actions { margin-top: 1rem; }
  .btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    border: 1px solid #3a3a3a;
    border-radius: 3px;
    color: #e8e6e0;
    text-decoration: none;
    font-size: 0.9rem;
    transition: border-color 120ms ease, background 120ms ease;
  }
  .btn:hover { border-color: #6a665e; background: #161616; }
  .btn-primary { border-color: #d4a89a; color: #d4a89a; }
  .btn-primary:hover { background: rgba(212, 168, 154, 0.08); }

  .empty {
    padding: 4rem 0;
    text-align: center;
    color: #6a665e;
  }

  .header-pills { margin-top: 0.75rem; display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; }

  .gallery-filter {
    display: flex; flex-wrap: wrap; gap: 0.5rem 0.75rem; align-items: center;
    margin-top: 1rem;
    padding: 0.75rem; background: #0f0f0f; border: 1px solid #1f1f1f; border-radius: 3px;
  }
  .gallery-filter input[type="search"] {
    flex: 1 1 16rem; min-width: 12rem;
    background: #111; border: 1px solid #2a2a2a; color: #e8e6e0;
    padding: 0.4rem 0.6rem; border-radius: 3px; font: inherit;
  }
  .gallery-filter input[type="search"]:focus { border-color: #d4a89a; outline: none; }
  .tier-chips { display: flex; gap: 0.3rem; flex-wrap: wrap; }
  .tier-chip {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 1.8rem; height: 1.8rem;
    padding: 0 0.55rem;
    border: 1px solid #2a2a2a; border-radius: 3px;
    color: #8a877e; text-decoration: none; font-size: 0.8125rem; letter-spacing: 0.04em;
    transition: border-color 120ms ease, background 120ms ease;
  }
  .tier-chip:hover { border-color: #6a665e; background: #161616; }
  .tier-chip.active { border-color: #d4a89a; color: #d4a89a; background: rgba(212, 168, 154, 0.08); }
  .tier-chip.chip-S.active { border-color: #f8e08c; color: #f8e08c; background: rgba(248, 224, 140, 0.08); }
  .tier-chip.chip-A.active { border-color: #e6e8ea; color: #e6e8ea; background: rgba(230, 232, 234, 0.06); }
  .tier-chip.chip-B.active { border-color: #cd8a4e; color: #cd8a4e; background: rgba(205, 138, 78, 0.08); }
  .tier-chip.clear { color: #6a665e; border-color: transparent; padding: 0 0.8rem; }
  .tier-chip.clear:hover { color: #e57373; }
  .filter-apply {
    background: transparent; border: 1px solid #d4a89a; color: #d4a89a;
    padding: 0.35rem 0.8rem; border-radius: 3px; cursor: pointer; font: inherit;
  }
  .filter-apply:hover { background: rgba(212, 168, 154, 0.08); }

  /* Slide-over (desktop ≥ 900px only) */
  .slideover {
    position: fixed;
    top: 0; right: 0;
    width: min(480px, 45vw);
    height: 100vh;
    background: #0a0a0a;
    border-left: 1px solid #1f1f1f;
    box-shadow: -8px 0 24px rgba(0,0,0,0.6);
    padding: 1.25rem 1.5rem;
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 220ms ease;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .slideover.open { transform: translateX(0); }
  .slideover[aria-hidden="true"] { pointer-events: none; }
  @media (max-width: 899px) { .slideover { display: none; } }

  .slideover-head { display: flex; justify-content: space-between; align-items: baseline; gap: 0.5rem; border-bottom: 1px solid #1a1a1a; padding-bottom: 0.75rem; }
  .slideover-title { font-family: "Inter Tight", sans-serif; font-weight: 500; font-size: 1.35rem; margin: 0; color: #e8e6e0; }
  .slideover-actions { display: flex; gap: 0.5rem; align-items: center; }
  .slideover-link { color: #8a877e; text-decoration: none; font-size: 0.8125rem; }
  .slideover-link:hover { color: #d4a89a; }
  .slideover-close {
    background: transparent; border: 1px solid #2a2a2a; color: #8a877e;
    width: 1.8rem; height: 1.8rem; border-radius: 3px; cursor: pointer;
    display: grid; place-items: center; font-size: 0.95rem;
  }
  .slideover-close:hover { border-color: #e57373; color: #e57373; }

  .slideover-body { display: flex; flex-direction: column; gap: 0.75rem; }
  .slideover-placeholder { text-align: center; padding: 2rem 0; font-style: italic; }
  .slideover-role { color: #9a968c; margin: 0; }
  .slideover-badges { display: flex; gap: 0.5rem; align-items: center; }
  .slideover-tier-badge { font-size: 0.6875rem; letter-spacing: 0.08em; text-transform: uppercase; color: #d4a89a; border: 1px solid #d4a89a; padding: 0.1rem 0.4rem; border-radius: 2px; }
  .slideover-bio { color: #bdb8ac; line-height: 1.55; margin: 0.5rem 0 0; }
  .slideover-h3 { font-family: "Inter Tight", sans-serif; font-weight: 500; font-size: 0.75rem; letter-spacing: 0.18em; text-transform: uppercase; color: #9a968c; margin: 0.75rem 0 0.35rem; }
  .slideover-channels { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.35rem; font-size: 0.9rem; }
  .slideover-channels li { display: flex; gap: 0.75rem; align-items: baseline; }
  .slideover-kind { color: #6a665e; font-size: 0.7rem; letter-spacing: 0.06em; text-transform: uppercase; width: 4rem; }
  .slideover-channels a { color: #e8e6e0; text-decoration: none; border-bottom: 1px dashed #3a3a3a; }
  .slideover-channels a:hover { color: #d4a89a; border-bottom-color: #d4a89a; }
  .slideover-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: 0.5rem; }
  .slideover-tag { font-size: 0.7rem; padding: 0.1rem 0.4rem; border: 1px solid #2a2a2a; border-radius: 2px; color: #9a968c; }
</style>
