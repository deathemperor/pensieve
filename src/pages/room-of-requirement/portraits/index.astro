---
export const prerender = false;

import { env } from "cloudflare:workers";
import Base from "../../../layouts/Base.astro";
import TierSection from "../../../components/portraits/TierSection.astro";
import CorridorTable from "../../../components/portraits/CorridorTable.astro";
import GuestBanner from "../../../components/portraits/GuestBanner.astro";
import RemindersPill from "../../../components/portraits/RemindersPill.astro";
import PipelinePill from "../../../components/portraits/PipelinePill.astro";
import { requireAdmin } from "../../../lib/portraits/auth";
import { listContacts } from "../../../lib/portraits/db";
import type { Contact, TierCode } from "../../../lib/portraits/types";
import { getCurrentLang } from "../../../utils/lang";

const lang = getCurrentLang(Astro);
const isVi = lang === "vi";
const auth = await requireAdmin(Astro);
const db = (env as any).DB;

const url = new URL(Astro.request.url);
const q = auth.admin ? (url.searchParams.get("q") ?? "").trim() : "";
const tiersParam = auth.admin ? (url.searchParams.get("tiers") ?? "").trim() : "";
const selectedTiers = tiersParam
  ? (tiersParam.split(",").map((t) => t.trim().toUpperCase()).filter((t): t is TierCode => ["S","A","B","C","D"].includes(t as TierCode)))
  : undefined;

const contacts: Contact[] = await listContacts(db, {
  includePlaceholders: !auth.admin,
  onlyPlaceholders: !auth.admin,
  search: q || undefined,
  tiers: selectedTiers,
});

const buckets: Record<TierCode, Contact[]> = { S: [], A: [], B: [], C: [], D: [] };
for (const c of contacts) buckets[c.prestige_tier].push(c);
const total = contacts.length;

// Cache: guest cached 1h at the edge; admin never cached anywhere.
// Astro.cache.set only honors maxAge/swr/tags; set the full Cache-Control header directly for "private, no-store".
Astro.cache.set({ maxAge: auth.admin ? 0 : 3600 });
Astro.response.headers.set(
  "Cache-Control",
  auth.admin ? "private, no-store" : "public, max-age=3600, s-maxage=3600",
);
---

<Base
  title={isVi ? "Phòng Tranh — Room of Requirement" : "Portraits — Room of Requirement"}
  description={isVi ? "Bộ sưu tập riêng các nhân vật quan trọng." : "A private rolodex of notable figures."}
>
  <main class="portraits-page">
    <header class="portraits-hero">
      <h1>{isVi ? "Phòng Tranh" : "Portraits"}</h1>
      <p class="hero-sub">
        {isVi
          ? <>Phòng tranh những người định hình công việc. {total} {total === 1 ? "chân dung" : "chân dung"}.</>
          : <>A gallery of the people who shape the work. {total} {total === 1 ? "portrait" : "portraits"}.</>}
      </p>
      {auth.admin && (
        <div class="admin-actions">
          <a class="btn btn-primary" href="/room-of-requirement/portraits/add">＋ New portrait</a>
          <a class="btn" href="/room-of-requirement/portraits/capture">📷 Capture card</a>
          <a class="btn" href="/room-of-requirement/portraits/import">📁 Import</a>
          <a class="btn" href="/room-of-requirement/portraits/sync">🔗 Sync</a>
          <a class="btn" href="/room-of-requirement/portraits/graph">🕸 Graph</a>
          <a class="btn" href="/room-of-requirement/portraits/events">🎟 Events</a>
        </div>
      )}
      {auth.admin && (
        <div class="header-pills">
          <RemindersPill db={db} />
          <PipelinePill db={db} />
        </div>
      )}
      {auth.admin && (
        <form class="gallery-filter" method="get" data-current-q={q}>
          <input
            type="search"
            name="q"
            value={q}
            placeholder={isVi ? "Tìm theo tên, công ty, thẻ…" : "Search name, company, tag…"}
            autocomplete="off"
          />
          <div class="tier-chips">
            {(["S","A","B","C","D"] as const).map((tier) => {
              const active = (selectedTiers ?? []).includes(tier);
              const next = active
                ? (selectedTiers ?? []).filter((t) => t !== tier)
                : [...(selectedTiers ?? []), tier];
              const params = new URLSearchParams();
              if (q) params.set("q", q);
              if (next.length > 0) params.set("tiers", next.join(","));
              const href = `?${params.toString()}`;
              return (
                <a class={`tier-chip chip-${tier} ${active ? "active" : ""}`} href={href}>
                  {tier}
                </a>
              );
            })}
            {(q || (selectedTiers && selectedTiers.length > 0)) && (
              <a class="tier-chip clear" href="?">{isVi ? "xoá" : "clear"}</a>
            )}
          </div>
          <button type="submit" class="filter-apply">{isVi ? "Tìm" : "Search"}</button>
        </form>
      )}
    </header>

    {!auth.admin && <GuestBanner />}

    {buckets.S.length > 0 && <TierSection tier="S" contacts={buckets.S} isAdminView={auth.admin} />}
    {buckets.A.length > 0 && <TierSection tier="A" contacts={buckets.A} isAdminView={auth.admin} />}
    {buckets.B.length > 0 && <TierSection tier="B" contacts={buckets.B} isAdminView={auth.admin} />}
    {buckets.C.length > 0 && <TierSection tier="C" contacts={buckets.C} isAdminView={auth.admin} />}
    {buckets.D.length > 0 && <CorridorTable contacts={buckets.D} />}

    {total === 0 && (
      <div class="empty">
        <p>
          {isVi ? "Chưa có chân dung nào." : "No portraits yet."}
          {" "}
          {auth.admin
            ? (isVi ? "Thêm liên lạc đầu tiên để khai trương phòng tranh." : "Add your first contact to start the gallery.")
            : ""}
        </p>
      </div>
    )}
  </main>
</Base>

<style>
  .portraits-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.25rem 5rem;
  }
  .portraits-hero {
    padding: 2rem 0 1.5rem;
    border-bottom: 1px solid #1a1a1a;
  }
  .portraits-hero h1 {
    font-family: "Inter Tight", sans-serif;
    font-weight: 500;
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: -0.02em;
    margin: 0;
    color: #e8e6e0;
  }
  .hero-sub {
    color: #8a877e;
    margin: 0.5rem 0 0;
    font-size: 1rem;
  }
  .admin-actions { margin-top: 1rem; }
  .btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    border: 1px solid #3a3a3a;
    border-radius: 3px;
    color: #e8e6e0;
    text-decoration: none;
    font-size: 0.9rem;
    transition: border-color 120ms ease, background 120ms ease;
  }
  .btn:hover { border-color: #6a665e; background: #161616; }
  .btn-primary { border-color: #d4a89a; color: #d4a89a; }
  .btn-primary:hover { background: rgba(212, 168, 154, 0.08); }

  .empty {
    padding: 4rem 0;
    text-align: center;
    color: #6a665e;
  }

  .header-pills { margin-top: 0.75rem; display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; }

  .gallery-filter {
    display: flex; flex-wrap: wrap; gap: 0.5rem 0.75rem; align-items: center;
    margin-top: 1rem;
    padding: 0.75rem; background: #0f0f0f; border: 1px solid #1f1f1f; border-radius: 3px;
  }
  .gallery-filter input[type="search"] {
    flex: 1 1 16rem; min-width: 12rem;
    background: #111; border: 1px solid #2a2a2a; color: #e8e6e0;
    padding: 0.4rem 0.6rem; border-radius: 3px; font: inherit;
  }
  .gallery-filter input[type="search"]:focus { border-color: #d4a89a; outline: none; }
  .tier-chips { display: flex; gap: 0.3rem; flex-wrap: wrap; }
  .tier-chip {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 1.8rem; height: 1.8rem;
    padding: 0 0.55rem;
    border: 1px solid #2a2a2a; border-radius: 3px;
    color: #8a877e; text-decoration: none; font-size: 0.8125rem; letter-spacing: 0.04em;
    transition: border-color 120ms ease, background 120ms ease;
  }
  .tier-chip:hover { border-color: #6a665e; background: #161616; }
  .tier-chip.active { border-color: #d4a89a; color: #d4a89a; background: rgba(212, 168, 154, 0.08); }
  .tier-chip.chip-S.active { border-color: #f8e08c; color: #f8e08c; background: rgba(248, 224, 140, 0.08); }
  .tier-chip.chip-A.active { border-color: #e6e8ea; color: #e6e8ea; background: rgba(230, 232, 234, 0.06); }
  .tier-chip.chip-B.active { border-color: #cd8a4e; color: #cd8a4e; background: rgba(205, 138, 78, 0.08); }
  .tier-chip.clear { color: #6a665e; border-color: transparent; padding: 0 0.8rem; }
  .tier-chip.clear:hover { color: #e57373; }
  .filter-apply {
    background: transparent; border: 1px solid #d4a89a; color: #d4a89a;
    padding: 0.35rem 0.8rem; border-radius: 3px; cursor: pointer; font: inherit;
  }
  .filter-apply:hover { background: rgba(212, 168, 154, 0.08); }
</style>
