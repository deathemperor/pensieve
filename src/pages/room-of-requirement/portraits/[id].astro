---
export const prerender = false;

import { env } from "cloudflare:workers";
import Base from "../../../layouts/Base.astro";
import { requireAdmin } from "../../../lib/portraits/auth";
import { getContact } from "../../../lib/portraits/db";
import type { ContactWithChannels } from "../../../lib/portraits/types";
import Timeline from "../../../components/portraits/Timeline.astro";
import NotesTab from "../../../components/portraits/NotesTab.astro";
import Relationships from "../../../components/portraits/Relationships.astro";
import IntroPaths from "../../../components/portraits/IntroPaths.astro";
import Mentions from "../../../components/portraits/Mentions.astro";
import Deals from "../../../components/portraits/Deals.astro";
import Collaborators from "../../../components/portraits/Collaborators.astro";
import { tierName } from "../../../lib/portraits/tier-labels";
import { renderMarkdown } from "../../../lib/portraits/markdown";
import { getCurrentLang } from "../../../utils/lang";

const lang = getCurrentLang(Astro);
const isVi = lang === "vi";
const auth = await requireAdmin(Astro);
const db = (env as any).DB;
const id = Astro.params.id;

if (typeof id !== "string" || !id) {
  return new Response("Bad request", { status: 400 });
}

const contact: ContactWithChannels | null = await getContact(db, id);

// Guests can only read placeholder rows. 404 on anything else to avoid existence-leak.
if (!contact || (!auth.admin && contact.is_placeholder !== 1)) {
  return new Response("Not found", { status: 404 });
}

const tags = contact.tags ? (JSON.parse(contact.tags) as string[]) : [];
const tierLabel = tierName(contact.prestige_tier, lang);

const photoCardId = (contact.photo_key ?? "").match(/portraits\/cards\/(c_[a-f0-9]+)/)?.[1] ?? null;
// External avatar (web-research headshot) takes precedence over the card-derived photo.
// Resolved here using the parsed externalIds below.
let photoUrl: string | null = photoCardId ? `/api/portraits/cards/${photoCardId}/image` : null;

// Web research dossier stored in external_ids JSON.
interface DossierQuote { text: string; source?: string; date?: string; attributed_to?: string }
interface DossierMilestone { label: string; year?: string; detail?: string }
interface DossierPost { title: string; date?: string; url?: string }
interface DossierRecognition { label: string; year?: string }
type ExternalIds = {
  linkedin?: string; company_linkedin?: string; website?: string; site?: string;
  medium?: string; company?: string; press?: string[]; avatar?: string;
  quotes?: DossierQuote[]; milestones?: DossierMilestone[];
  posts?: DossierPost[]; recognitions?: DossierRecognition[];
};
let externalIds: ExternalIds = {};
try { externalIds = contact.external_ids ? (JSON.parse(contact.external_ids) as ExternalIds) : {}; } catch { /* malformed JSON; render nothing */ }
const namedLinks: Array<{ label: string; url: string }> = [];
if (externalIds.linkedin) namedLinks.push({ label: "LinkedIn", url: externalIds.linkedin });
if (externalIds.company_linkedin) namedLinks.push({ label: "Company LinkedIn", url: externalIds.company_linkedin });
if (externalIds.website) namedLinks.push({ label: isVi ? "Trang web" : "Website", url: externalIds.website });
if (externalIds.site) namedLinks.push({ label: isVi ? "Trang chính" : "Main site", url: externalIds.site });
if (externalIds.company) namedLinks.push({ label: isVi ? "Công ty" : "Company", url: externalIds.company });
if (externalIds.medium) namedLinks.push({ label: "Medium", url: externalIds.medium });
const pressUrls: string[] = Array.isArray(externalIds.press) ? externalIds.press.filter((u): u is string => typeof u === "string") : [];
const pressHostnames = pressUrls.map((u) => { try { return new URL(u).hostname.replace(/^www\./, ""); } catch { return u; } });
if (externalIds.avatar && /^https?:\/\//.test(externalIds.avatar)) photoUrl = externalIds.avatar;
const bioHtml = contact.bio ? renderMarkdown(contact.bio) : "";
const quotes = Array.isArray(externalIds.quotes) ? externalIds.quotes : [];
const milestones = Array.isArray(externalIds.milestones) ? externalIds.milestones : [];
const posts = Array.isArray(externalIds.posts) ? externalIds.posts : [];
const recognitions = Array.isArray(externalIds.recognitions) ? externalIds.recognitions : [];
const quoteHostname = (u?: string) => { if (!u) return ""; try { return new URL(u).hostname.replace(/^www\./, ""); } catch { return u; } };

// Phase 2: list any cards attached to this contact (admin view only).
interface CardSummary { id: string; captured_at: string; ocr_status: string }
let cards: CardSummary[] = [];
if (auth.admin) {
  const rs = await db
    .prepare("SELECT id, captured_at, ocr_status FROM contact_cards WHERE contact_id=? ORDER BY captured_at DESC")
    .bind(contact.id)
    .all() as { results: CardSummary[] };
  cards = (rs.results ?? []) as CardSummary[];
}

// Astro.cache.set only honors maxAge/swr/tags; set the full Cache-Control directly for "private, no-store".
Astro.cache.set({ maxAge: auth.admin ? 0 : 3600 });
Astro.response.headers.set(
  "Cache-Control",
  auth.admin ? "private, no-store" : "public, max-age=3600, s-maxage=3600",
);
---

<Base title={`${contact.display_name ?? contact.full_name} — Portrait`} description={contact.bio ?? ""}>
  <main class="detail-page">
    <header class="detail-hero">
      <a class="back-link" href="/room-of-requirement/portraits">← {isVi ? "Phòng Tranh" : "Portraits"}</a>
      <div class="detail-identity">
        <div class="detail-photo" data-tier={contact.prestige_tier}>
          {photoUrl ? (
            <img src={photoUrl} alt={contact.display_name ?? contact.full_name} />
          ) : (
            <span class="initials">
              {contact.full_name.split(" ").map((p) => p[0] ?? "").join("").slice(0, 2).toUpperCase()}
            </span>
          )}
        </div>
        <div class="detail-meta">
          <h1>{contact.display_name ?? contact.full_name}</h1>
          {contact.title || contact.company ? (
            <p class="role">{contact.title}{contact.title && contact.company ? " · " : ""}{contact.company}</p>
          ) : null}
          <div class="badges">
            <span class="tier-badge">{tierLabel}</span>
            <span class="score">{isVi ? "điểm" : "score"} {contact.tier_score}</span>
            {contact.is_placeholder === 1 && <span class="demo-ribbon">★ {isVi ? "trưng bày" : "demo"}</span>}
          </div>
          {auth.admin && contact.is_placeholder !== 1 && (
            <a class="edit-link" href={`/room-of-requirement/portraits/${contact.id}/edit`}>
              ✎ {isVi ? "Sửa" : "Edit"}
            </a>
          )}
        </div>
      </div>
    </header>

    {bioHtml && <section class="section"><div class="bio" set:html={bioHtml} /></section>}

    {(namedLinks.length > 0 || pressUrls.length > 0) && (
      <section class="section">
        <h2 class="section-title">{isVi ? "Liên kết & Báo chí" : "Links & Press"}</h2>
        {namedLinks.length > 0 && (
          <ul class="ext-link-list">
            {namedLinks.map((l) => (
              <li><a href={l.url} target="_blank" rel="noopener noreferrer">{l.label}</a></li>
            ))}
          </ul>
        )}
        {pressUrls.length > 0 && (
          <ul class="press-list">
            {pressUrls.map((u, i) => (
              <li><a href={u} target="_blank" rel="noopener noreferrer">{pressHostnames[i]}</a></li>
            ))}
          </ul>
        )}
      </section>
    )}

    {quotes.length > 0 && (
      <section class="section">
        <h2 class="section-title">{isVi ? "Phát biểu" : "Quotes"}</h2>
        <ul class="quote-list">
          {quotes.map((q) => (
            <li class="quote">
              <blockquote>{q.text}</blockquote>
              <cite>
                {q.attributed_to ?? (contact.display_name ?? contact.full_name)}
                {q.date ? ` · ${q.date}` : ""}
                {q.source ? (
                  <> · <a href={q.source} target="_blank" rel="noopener noreferrer">{quoteHostname(q.source)}</a></>
                ) : null}
              </cite>
            </li>
          ))}
        </ul>
      </section>
    )}

    {milestones.length > 0 && (
      <section class="section">
        <h2 class="section-title">{isVi ? "Cột mốc" : "Milestones"}</h2>
        <ul class="milestone-list">
          {milestones.map((m) => (
            <li>
              {m.year ? <span class="milestone-year">{m.year}</span> : null}
              <span class="milestone-label">{m.label}</span>
              {m.detail ? <span class="milestone-detail"> — {m.detail}</span> : null}
            </li>
          ))}
        </ul>
      </section>
    )}

    {recognitions.length > 0 && (
      <section class="section">
        <h2 class="section-title">{isVi ? "Vinh danh" : "Recognitions"}</h2>
        <ul class="recognition-list">
          {recognitions.map((r) => (
            <li>★ {r.label}{r.year ? ` (${r.year})` : ""}</li>
          ))}
        </ul>
      </section>
    )}

    {posts.length > 0 && (
      <section class="section">
        <h2 class="section-title">{isVi ? "Bài viết / Bài đăng" : "Posts"}</h2>
        <ul class="post-list">
          {posts.map((p) => (
            <li>
              {p.url ? (
                <a href={p.url} target="_blank" rel="noopener noreferrer">{p.title}</a>
              ) : (
                <span>{p.title}</span>
              )}
              {p.date ? <span class="post-date"> — {p.date}</span> : null}
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="section">
      <h2 class="section-title">{isVi ? "Kênh liên lạc" : "Channels"}</h2>
      {contact.channels.length === 0 ? (
        <p class="muted">{isVi ? "Chưa có kênh nào được ghi." : "No channels recorded."}</p>
      ) : (
        <ul class="channel-list">
          {contact.channels.map((ch) => (
            <li class="channel">
              <span class="channel-kind">{ch.kind}</span>
              <span class="channel-value">
                {ch.kind === "email" ? (
                  <>
                    <a href={`mailto:${ch.value}`}>{ch.value}</a>
                    {auth.admin && !contact.is_placeholder && (
                      <button
                        class="compose-btn"
                        data-email={ch.value}
                        data-contact={contact.id}
                        title="Compose with Resend"
                      >✉️</button>
                    )}
                  </>
                ) : ch.kind === "phone" ? (
                  <a href={`tel:${ch.value.replace(/[^+\d]/g, "")}`}>{ch.value}</a>
                ) : ch.kind === "url" || ch.kind === "linkedin" || ch.kind === "twitter" || ch.kind === "x" || ch.kind === "facebook" ? (
                  <a href={ch.value} target="_blank" rel="noopener noreferrer">{ch.value}</a>
                ) : (
                  ch.value
                )}
              </span>
              {ch.label && <span class="channel-label">{ch.label}</span>}
              {ch.is_primary === 1 && <span class="primary-dot" title="primary">●</span>}
            </li>
          ))}
        </ul>
      )}
    </section>

    {tags.length > 0 && (
      <section class="section">
        <h2 class="section-title">{isVi ? "Thẻ" : "Tags"}</h2>
        <div class="tags">
          {tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      </section>
    )}

    {auth.admin && <Timeline db={db} contactId={contact.id} />}
    {auth.admin && <NotesTab db={db} contactId={contact.id} />}
    {auth.admin && <Relationships db={db} contactId={contact.id} />}

    {auth.admin && contact.is_placeholder !== 1 && <IntroPaths db={db} contactId={contact.id} />}

    {auth.admin && contact.is_placeholder !== 1 && <Mentions db={db} contactId={contact.id} />}

    {auth.admin && contact.is_placeholder !== 1 && <Deals db={db} contactId={contact.id} />}

    {auth.admin && contact.is_placeholder !== 1 && <Collaborators db={db} contactId={contact.id} />}

    {auth.admin && cards.length > 0 && (
      <section class="section">
        <h2 class="section-title">Cards</h2>
        <div class="cards-grid">
          {cards.map((c) => (
            <a class="card-tile" href={`/api/portraits/cards/${c.id}/image`}>
              <img src={`/api/portraits/cards/${c.id}/image`} alt="business card" loading="lazy" />
              <span class={`card-status card-status-${c.ocr_status}`}>{c.ocr_status}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="section meta">
      <dl>
        <dt>{isVi ? "Nguồn" : "Source"}</dt><dd>{contact.source}</dd>
        {contact.location && <><dt>{isVi ? "Địa điểm" : "Location"}</dt><dd>{contact.location}</dd></>}
        <dt>{isVi ? "Thêm vào" : "Added"}</dt><dd>{new Date(contact.created_at).toLocaleDateString()}</dd>
        <dt>{isVi ? "Cập nhật" : "Updated"}</dt><dd>{new Date(contact.updated_at).toLocaleDateString()}</dd>
      </dl>
    </section>
  </main>

  <dialog id="compose-dialog" class="compose-dialog">
    <form id="compose-form" method="dialog">
      <header class="compose-head">
        <h3>{isVi ? "Soạn email" : "Compose email"}</h3>
        <span id="compose-to" class="compose-to muted"></span>
      </header>
      <label class="compose-field">
        <span>{isVi ? "Chủ đề" : "Subject"}</span>
        <input type="text" name="subject" required maxlength="200" />
      </label>
      <label class="compose-field">
        <span>{isVi ? "Nội dung" : "Body"}</span>
        <textarea name="body" rows="8" required maxlength="10000"></textarea>
      </label>
      <p id="compose-error" class="error" hidden></p>
      <div class="compose-actions">
        <button type="button" id="compose-cancel" class="btn-ghost">{isVi ? "Huỷ" : "Cancel"}</button>
        <button type="submit" id="compose-send" class="btn-primary">{isVi ? "Gửi" : "Send"}</button>
      </div>
    </form>
  </dialog>
</Base>

<script>
  const dialog = document.getElementById("compose-dialog") as HTMLDialogElement | null;
  const form = document.getElementById("compose-form") as HTMLFormElement | null;
  const toEl = document.getElementById("compose-to") as HTMLSpanElement | null;
  const errEl = document.getElementById("compose-error") as HTMLParagraphElement | null;
  const cancelBtn = document.getElementById("compose-cancel") as HTMLButtonElement | null;
  const sendBtn = document.getElementById("compose-send") as HTMLButtonElement | null;
  let currentContact: { id: string; email: string } | null = null;

  function reset() {
    currentContact = null;
    if (form) form.reset();
    if (errEl) errEl.hidden = true;
    if (sendBtn) { sendBtn.disabled = false; sendBtn.textContent = "Send"; }
  }

  cancelBtn?.addEventListener("click", () => {
    dialog?.close();
    reset();
  });

  dialog?.addEventListener("click", (e) => {
    // Click on backdrop closes
    if (e.target === dialog) { dialog.close(); reset(); }
  });

  document.querySelectorAll<HTMLButtonElement>("button.compose-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const email = btn.dataset.email;
      const cid = btn.dataset.contact;
      if (!email || !cid || !dialog || !toEl) return;
      currentContact = { id: cid, email };
      toEl.textContent = `→ ${email}`;
      dialog.showModal();
      (form?.querySelector("input[name=subject]") as HTMLInputElement | null)?.focus();
    });
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!currentContact || !sendBtn || !errEl) return;
    const fd = new FormData(form);
    const subject = String(fd.get("subject") ?? "").trim();
    const body = String(fd.get("body") ?? "").trim();
    if (!subject || !body) return;

    errEl.hidden = true;
    sendBtn.disabled = true;
    sendBtn.textContent = "Sending…";

    const res = await fetch("/api/portraits/outreach/send", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ contact_id: currentContact.id, to: currentContact.email, subject, body }),
    });
    const data = (await res.json().catch(() => ({}))) as { resend_id?: string; error?: string; hint?: string; retry_after?: number };

    if (res.ok) {
      dialog?.close();
      reset();
      window.location.reload();
      return;
    }

    const hint = data.hint ? ` — ${data.hint}` : "";
    const retry = data.retry_after ? ` (retry in ${data.retry_after}s)` : "";
    errEl.textContent = `Send failed: ${data.error ?? res.statusText}${hint}${retry}`;
    errEl.hidden = false;
    sendBtn.disabled = false;
    sendBtn.textContent = "Send";
  });
</script>

<style>
  .detail-page { max-width: 800px; margin: 0 auto; padding: 2rem 1.25rem 5rem; }
  .back-link { color: #8a877e; text-decoration: none; font-size: 0.875rem; }
  .back-link:hover { color: #d4a89a; }

  .detail-identity {
    display: flex; gap: 1.5rem; align-items: flex-start;
    margin-top: 1rem;
  }
  .detail-photo {
    width: 120px; height: 120px; border-radius: 4px;
    background: #1a1a1a; display: grid; place-items: center;
    border: 1px solid #2a2a2a; flex-shrink: 0;
    overflow: hidden;
  }
  .detail-photo img {
    width: 100%; height: 100%; object-fit: cover;
  }
  .detail-photo[data-tier="S"] { border-color: #e7c76b; box-shadow: 0 0 12px rgba(231,199,107,0.2); }
  .detail-photo[data-tier="A"] { border-color: #c8cbd0; }
  .detail-photo[data-tier="B"] { border-color: #cd8a4e; }
  .initials {
    font-family: "Inter Tight", sans-serif; font-weight: 600;
    font-size: 1.75rem; color: #666;
  }
  .detail-meta h1 {
    font-family: "Inter Tight", sans-serif; font-weight: 500;
    font-size: clamp(1.5rem, 4vw, 2.25rem); margin: 0;
    color: #e8e6e0;
  }
  .role { color: #9a968c; margin: 0.25rem 0 0.5rem; }
  .badges { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }
  .tier-badge {
    font-size: 0.6875rem; letter-spacing: 0.08em; text-transform: uppercase;
    color: #8a877e; border: 1px solid #3a3a3a; padding: 0.1rem 0.4rem; border-radius: 2px;
  }
  .score { font-size: 0.75rem; color: #6a665e; }
  .demo-ribbon { font-size: 0.75rem; color: #d4a89a; }

  .section { padding: 1.5rem 0; border-top: 1px solid #1a1a1a; margin-top: 1.5rem; }
  .section-title {
    font-family: "Inter Tight", sans-serif; font-weight: 500;
    font-size: 0.8125rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: #9a968c; margin: 0 0 0.75rem;
  }
  .bio { color: #bdb8ac; line-height: 1.65; margin: 0; }
  .bio p { margin: 0 0 0.8rem 0; }
  .bio p:last-child { margin-bottom: 0; }
  .bio a { color: #d8c89c; border-bottom: 1px dotted #5a4a2a; }
  .bio a:hover { color: #f0d97e; border-bottom-style: solid; }
  .bio ul, .bio ol { margin: 0.5rem 0 0.8rem 1.25rem; padding: 0; }
  .bio li { margin: 0.2rem 0; }
  .bio blockquote {
    margin: 0.6rem 0; padding: 0.5rem 0.9rem;
    border-left: 2px solid #5a4a2a; color: #c8c0b0;
    font-style: italic;
  }
  .bio strong { color: #d8d0bc; }
  .bio code {
    background: #1a1a1a; padding: 0.05rem 0.3rem;
    border-radius: 3px; font-size: 0.92em;
  }
  .bio h2, .bio h3, .bio h4 {
    margin: 1rem 0 0.4rem; color: #d8c89c;
    font-family: "Inter Tight", sans-serif; font-weight: 600;
  }
  .bio h3 { font-size: 1rem; }
  .bio h4 { font-size: 0.9rem; }
  .ext-link-list, .press-list {
    list-style: none; padding: 0; margin: 0 0 0.75rem 0;
    display: flex; flex-wrap: wrap; gap: 0.5rem;
  }
  .ext-link-list li a, .press-list li a {
    display: inline-block;
    padding: 0.25rem 0.65rem;
    border: 1px solid #2a2a2a;
    border-radius: 4px;
    color: #bdb8ac;
    text-decoration: none;
    font-size: 0.85rem;
  }
  .ext-link-list li a:hover, .press-list li a:hover {
    border-color: #c8a45e;
    color: #d8c89c;
  }
  .press-list li a { font-family: "Inter Tight", sans-serif; opacity: 0.85; }

  .quote-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1rem; }
  .quote blockquote {
    margin: 0; padding: 0.75rem 1rem;
    border-left: 2px solid #c8a45e;
    color: #e1d8c4;
    font-style: italic;
    line-height: 1.55;
  }
  .quote cite {
    display: block; margin-top: 0.35rem; padding-left: 1rem;
    color: #8a847a; font-style: normal; font-size: 0.85rem;
  }
  .quote cite a { color: #bdb8ac; }

  .milestone-list, .recognition-list, .post-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.4rem;
    color: #bdb8ac; line-height: 1.5;
  }
  .milestone-year {
    display: inline-block; min-width: 6rem;
    color: #c8a45e; font-family: "Inter Tight", sans-serif; font-weight: 600;
  }
  .milestone-detail { color: #8a847a; }
  .post-date { color: #8a847a; font-size: 0.85rem; }
  .muted { color: #6a665e; }

  .channel-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .channel { display: flex; gap: 0.75rem; align-items: baseline; font-size: 0.9375rem; }
  .channel-kind {
    width: 5rem; text-transform: uppercase; font-size: 0.6875rem;
    letter-spacing: 0.08em; color: #6a665e;
  }
  .channel-value a { color: #e8e6e0; text-decoration: none; border-bottom: 1px dashed #3a3a3a; }
  .channel-value a:hover { border-bottom-color: #d4a89a; color: #d4a89a; }
  .channel-label { font-size: 0.75rem; color: #6a665e; }
  .primary-dot { color: #d4a89a; font-size: 0.6rem; }

  .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .tag {
    font-size: 0.75rem; padding: 0.15rem 0.5rem;
    border: 1px solid #2a2a2a; border-radius: 2px; color: #9a968c;
  }

  .meta dl {
    display: grid; grid-template-columns: 6rem 1fr; gap: 0.35rem 1rem;
    font-size: 0.875rem;
  }
  .meta dt { color: #6a665e; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.06em; }
  .meta dd { color: #bdb8ac; margin: 0; }

  .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 0.75rem; }
  .card-tile { position: relative; display: block; border: 1px solid #2a2a2a; border-radius: 4px; overflow: hidden; }
  .card-tile img { width: 100%; height: 90px; object-fit: cover; }
