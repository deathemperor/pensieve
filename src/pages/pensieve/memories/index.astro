---
// /pensieve/memories — list view, editorial direction.
// Year-grouped rows, hairline filter rail, accent dot per category.
// Drops the "Spell Duration / Penned By / Enchantments" theme vocab
// in favor of plain editorial chrome — keeps the soul, sheds the
// friction.
export const prerender = false;

import { getEmDashCollection, getEntryTerms } from "emdash";
import Base from "../../../layouts/Base.astro";
import { getReadingTime } from "../../../utils/reading-time";
import { link } from "../../../utils/link";
import { getCurrentLang } from "../../../utils/lang";
import { categoryThemeMap, type ThemeSlug } from "../../../themes/categoryThemes";
import { themes } from "../../../themes";
import { setCachePolicy } from "../../../lib/cachePolicy";
setCachePolicy(Astro, "blog-index");

const currentLang = getCurrentLang(Astro);
const isVi = currentLang === "vi";

const { entries: allPosts, cacheHint } = await getEmDashCollection("posts");
Astro.cache.set(cacheHint);

const posts = allPosts.filter((p) => p.data.language === currentLang);
const sortedPosts = posts.toSorted(
	(a, b) => (b.data.publishedAt?.getTime() ?? 0) - (a.data.publishedAt?.getTime() ?? 0),
);

interface Enriched {
	post: (typeof sortedPosts)[number];
	cat: { slug: string; label: string } | null;
	accent: string;
}
const enriched: Enriched[] = await Promise.all(
	sortedPosts.map(async (post) => {
		const cats = await getEntryTerms("posts", post.data.id, "category");
		const c = cats[0] ?? null;
		const themeSlug: ThemeSlug | null = c ? (categoryThemeMap[c.slug] ?? null) : null;
		const accent = themeSlug ? themes[themeSlug].palette.accent : "#9b8cff";
		return { post, cat: c ? { slug: c.slug, label: c.label } : null, accent };
	}),
);

// Category counts for the filter rail.
const counts = new Map<string, { label: string; accent: string; count: number }>();
for (const e of enriched) {
	if (!e.cat) continue;
	const ex = counts.get(e.cat.slug);
	if (ex) ex.count++;
	else counts.set(e.cat.slug, { label: e.cat.label, accent: e.accent, count: 1 });
}
const filterCats = Array.from(counts.entries())
	.map(([slug, v]) => ({ slug, ...v }))
	.sort((a, b) => b.count - a.count);

// Group by year.
const byYear = new Map<number, Enriched[]>();
for (const e of enriched) {
	const y = e.post.data.publishedAt?.getFullYear() ?? 0;
	const arr = byYear.get(y) ?? [];
	arr.push(e);
	byYear.set(y, arr);
}
const years = Array.from(byYear.entries()).sort((a, b) => b[0] - a[0]);

const fmtDate = (d: Date | null | undefined) =>
	d ? d.toLocaleDateString(isVi ? "vi-VN" : "en-US", { month: "short", day: "numeric" }) : "";

let runningNum = 1;
---

<Base
	title={isVi ? "Tất Cả Ký Ức" : "All Memories"}
	description={isVi ? "Duyệt tất cả bài viết" : "Browse all memories"}
	breadcrumbs={[
		{ label: "Pensieve", href: "/pensieve/" },
		{ label: isVi ? "Ký Ức" : "Memories" },
	]}
>
	<div class="memories-page">
		<div class="rule">
			<span>Vol. {new Date().getFullYear() - 2005}</span>
			<span class="hairline" />
			<span>{posts.length} {isVi ? "bài · đang viết tiếp" : "essays · ongoing"}</span>
		</div>

		<h1 class="page-title">
			{isVi ? <Fragment>Tất Cả <em>Ký Ức</em></Fragment> : <Fragment>All <em>Memories</em></Fragment>}
		</h1>
		<p class="page-lede">
			{isVi
				? "Những bài viết dài tôi cứu về từ Facebook trước khi chúng trôi đi — và bài viết mới từ đó đến nay. Ký ức, gia đình, cá, những điều đáng giữ."
				: "Long-form pieces I rescued from Facebook before they scrolled away — and new writing since. Memory, family, fish, the things worth keeping."}
		</p>

		{filterCats.length > 0 && (
			<div class="filter-rail">
				<span class="filter-label">{isVi ? "Lọc" : "Filter"}</span>
				<span class="filter-pill is-active">{isVi ? "Tất cả" : "All"} · {posts.length}</span>
				{filterCats.map((c) => (
					<a href={link(`category/${c.slug}`)} class="filter-pill" style={`--accent: ${c.accent};`}>
						<span class="filter-dot" /> {c.label} · {c.count}
					</a>
				))}
			</div>
		)}

		{sortedPosts.length === 0 ? (
			<p class="empty">{isVi ? "Chưa có bài viết nào." : "No memories yet."}</p>
		) : (
			years.map(([year, items]) => (
				<section class="year-group">
					<div class="year-rule">
						<h2 class="year-label">{year || "—"}</h2>
						<span class="hairline" />
						<span class="year-count">{items.length}</span>
					</div>
					<div class="rows">
						{items.map((e) => {
							const num = String(runningNum++).padStart(3, "0");
							const mins = getReadingTime(e.post.data.content);
							return (
								<a href={link(`memories/${e.post.id}`)} class="row" style={`--accent: ${e.accent};`}>
									<span class="row-num">{num}</span>
									<div class="row-body">
										<div class="row-head">
											<h3 class="row-title">{e.post.data.title}</h3>
											{e.cat && (
												<span class="row-cat">
													<span class="row-dot" /> {e.cat.label}
												</span>
											)}
										</div>
										{e.post.data.excerpt && (
											<p class="row-excerpt">{e.post.data.excerpt}</p>
										)}
										<div class="row-meta">
											{e.post.data.publishedAt && (
												<>
													<time>{fmtDate(e.post.data.publishedAt)}</time>
													<span>·</span>
												</>
											)}
											<span>{mins} {isVi ? "phút" : "min"}</span>
										</div>
									</div>
									<span class="row-arrow">→</span>
								</a>
							);
						})}
					</div>
				</section>
			))
		)}
	</div>
</Base>

<style>
	.memories-page {
		max-width: 920px;
		margin: 0 auto;
		padding: clamp(2.5rem, 6vh, 4rem) 1.5rem 4rem;
	}

	.rule {
		display: flex; align-items: center; gap: 1rem;
		padding-bottom: 1rem; margin-bottom: 1.75rem;
		border-bottom: 1px solid var(--color-border);
		font-family: var(--font-mono); font-size: .7rem;
		color: var(--color-muted); letter-spacing: .08em; text-transform: uppercase;
	}
	.hairline { flex: 1; height: 1px; background: var(--color-border); }

	.page-title {
		font-family: var(--font-display);
		font-size: clamp(2.25rem, 7vw, 4.5rem);
		font-weight: var(--font-weight-display);
		letter-spacing: -.032em; line-height: 1;
		margin: 0 0 1rem; text-wrap: balance;
	}
	.page-title em {
		color: var(--color-muted); font-style: italic; font-weight: 400;
	}
	.page-lede {
		font-size: 1.0625rem; color: var(--color-text-secondary);
		margin: 0 0 2.5rem; line-height: 1.55; max-width: 60ch;
	}

	/* Filter rail */
	.filter-rail {
		display: flex; flex-wrap: wrap; align-items: center; gap: .5rem;
		padding-bottom: .85rem; border-bottom: 1px solid var(--color-border);
		margin-bottom: 1.5rem;
	}
	.filter-label {
		font-family: var(--font-mono); font-size: .65rem;
		letter-spacing: .14em; text-transform: uppercase;
		color: var(--color-muted); margin-right: .25rem;
	}
	.filter-pill {
		--accent: var(--color-accent);
		display: inline-flex; align-items: center; gap: .4rem;
		padding: .35rem .7rem; border-radius: 999px;
		border: 1px solid var(--color-border);
		font-size: .8125rem; color: var(--color-text-secondary);
		text-decoration: none;
		transition: border-color 120ms ease, color 120ms ease;
	}
	.filter-pill:hover { border-color: var(--accent); color: var(--color-text); }
	.filter-pill.is-active {
		border-color: var(--color-text); color: var(--color-text); font-weight: 500;
	}
	.filter-dot {
		width: 6px; height: 6px; border-radius: 50%; background: var(--accent);
	}

	/* Year groups */
	.year-group { margin-bottom: 2.5rem; }
	.year-rule {
		display: flex; align-items: baseline; gap: .85rem; margin-bottom: .5rem;
	}
	.year-label {
		font-family: var(--font-mono); font-size: .75rem; font-weight: 500;
		letter-spacing: .18em; text-transform: uppercase;
		color: var(--color-muted); margin: 0;
	}
	.year-count {
		font-family: var(--font-mono); font-size: .65rem;
		color: var(--color-muted); letter-spacing: .04em;
	}

	/* Rows */
	.rows { display: flex; flex-direction: column; }
	.row {
		--accent: var(--color-accent);
		display: grid; grid-template-columns: 44px 1fr auto; gap: 1.1rem;
		padding: 1rem 0; border-top: 1px solid var(--color-border);
		text-decoration: none; color: inherit; align-items: start;
		transition: background 120ms ease;
	}
	.row:hover { background: rgba(255,255,255,.015); }
	.row-num {
		font-family: var(--font-mono); font-size: .75rem;
		color: var(--accent); padding-top: .25rem; letter-spacing: .04em;
	}
	.row-head {
		display: flex; align-items: baseline; gap: .65rem;
		flex-wrap: wrap; margin-bottom: .25rem;
	}
	.row-title {
		font-family: var(--font-display);
		font-size: 1.125rem; font-weight: var(--font-weight-display);
		letter-spacing: -.018em; line-height: 1.3; margin: 0;
		transition: color 120ms ease;
	}
	.row:hover .row-title { color: var(--accent); }
	.row-cat {
		display: inline-flex; align-items: center; gap: .35rem;
		font-family: var(--font-mono); font-size: .65rem;
		color: var(--accent); letter-spacing: .08em; text-transform: uppercase;
	}
	.row-dot {
		width: 5px; height: 5px; border-radius: 50%; background: var(--accent);
	}
	.row-excerpt {
		font-size: .9rem; line-height: 1.55;
		color: var(--color-text-secondary); margin: 0 0 .35rem; max-width: 62ch;
		display: -webkit-box; -webkit-line-clamp: 2;
		-webkit-box-orient: vertical; overflow: hidden;
	}
	.row-meta {
		display: flex; align-items: center; gap: .5rem;
		font-family: var(--font-mono); font-size: .7rem;
		color: var(--color-muted); letter-spacing: .03em;
	}
	.row-arrow {
		color: var(--color-muted); padding-top: .35rem;
		transition: color 120ms ease, transform 120ms ease;
	}
	.row:hover .row-arrow {
		color: var(--color-text); transform: translateX(2px);
	}

	.empty {
		color: var(--color-muted); font-size: 1.0625rem;
		padding: 2rem 0; text-align: center;
	}

	/* Mobile */
	@media (max-width: 720px) {
		.memories-page { padding: 2.5rem 1.1rem 3rem; }
		.row {
			grid-template-columns: 36px 1fr;
			gap: .75rem; padding: 1rem 0;
		}
		.row-num { padding-top: 4px; grid-row: 1 / span 3; }
		.row-arrow { display: none; }
		.row-head { gap: .5rem; }
		.row-title { font-size: 1rem; }
	}
</style>
