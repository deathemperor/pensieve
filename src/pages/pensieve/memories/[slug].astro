---
// /pensieve/memories/[slug] — reading view, editorial direction.
//
// Body switches to Source Serif 4 — gives essays a different posture
// from the rest of the site ("you're reading now, not browsing").
// First-letter drop cap. Two-column layout: content + sidebar (TOC +
// Lumos + widgets). Bylines + duration + lang collapse to one inline
// strip. The "Penned by Quill" banner becomes a hairline strip with
// a 2px green left bar — same info, ~1/4 the visual cost.
//
// Behavior preserved 1:1: SEO meta, OG image, language sibling
// lookup, reading progress, share popover, Lumos cookie/POST flow,
// comments, "More memories", widget area.
export const prerender = false;

import {
	getEmDashEntry,
	getEmDashCollection,
	getEntryTerms,
	getSeoMeta,
} from "emdash";
import {
	Image,
	PortableText,
	Comments,
	CommentForm,
	WidgetArea,
} from "emdash/ui";
import Base from "../../../layouts/Base.astro";
import PostCard from "../../../components/PostCard.astro";
import { getReadingTime } from "../../../utils/reading-time";
import { themeForFirstCategory } from "../../../themes/categoryThemes";
import { link } from "../../../utils/link";
import { otherLang, langLabel, type Lang } from "../../../utils/lang";
import { setCachePolicy } from "../../../lib/cachePolicy";
setCachePolicy(Astro, "doc");

const { slug } = Astro.params;
if (!slug) return Astro.redirect(link("404"));

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);
if (!post) return Astro.redirect(link("404"));
Astro.cache.set(cacheHint);

function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http") ? image.src : `${Astro.url.origin}${image.src}`;
	}
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	return storageKey ? `${Astro.url.origin}/_emdash/api/media/file/${storageKey}` : undefined;
}
const featuredImageUrl = getImageUrl(post.data.featured_image);
const ogImage = featuredImageUrl ?? `${Astro.url.origin}/og/${slug}.png`;
const seo = getSeoMeta(post, {
	siteTitle: "Pensieve",
	siteUrl: Astro.url.origin,
	path: link(`memories/${slug}`),
	defaultOgImage: ogImage,
});

const tags = await getEntryTerms("posts", post.data.id, "tag");
const categories = await getEntryTerms("posts", post.data.id, "category");
const theme = themeForFirstCategory(categories.map((c) => c.slug));
const primaryCat = categories[0] ?? null;

const postLang = (post.data.language as Lang | undefined) ?? "en";
const isVi = postLang === "vi";
const originalLang = (post.data.original_language as Lang | "mixed" | undefined) ?? postLang;
const isTranslation = originalLang !== "mixed" && originalLang !== postLang;
const siblingLang = otherLang(postLang);

let siblingSlug: string | null = null;
const groupId = post.data.translation_group as string | undefined;
const hasGroupLink = !!groupId && groupId !== post.data.id;
if (post.data.source_id || hasGroupLink) {
	const { entries: allPosts } = await getEmDashCollection("posts");
	const sibling = allPosts.find(
		(p) =>
			p.data.language === siblingLang &&
			((post.data.source_id && p.data.source_id === post.data.source_id) ||
				(hasGroupLink && p.data.translation_group === groupId)),
	);
	if (sibling) siblingSlug = sibling.id;
}

const bylines = post.data.bylines ?? [];
const readingTime = getReadingTime(post.data.content);

// "More memories" — same lang as current reader, exclude self.
const { entries: recentPosts } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 12,
});
const otherPosts = recentPosts
	.filter((p) => p.id !== post.id && p.data.language === postLang)
	.slice(0, 3);
const otherPostsWithTags = await Promise.all(
	otherPosts.map(async (p) => {
		const postTags = await getEntryTerms("posts", p.data.id, "tag");
		return { post: p, tags: postTags, bylines: p.data.bylines ?? [] };
	}),
);

const publishDate =
	post.data.publishedAt?.toLocaleDateString(isVi ? "vi-VN" : "en-US", {
		year: "numeric", month: "long", day: "numeric",
	}) ?? null;
---

<Base
	title={seo.title}
	description={seo.description}
	image={seo.ogImage || `/og/${slug}.svg`}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	content={{ collection: "posts", id: post.data.id, slug }}
	theme={theme}
	breadcrumbs={[
		{ label: "Pensieve", href: "/pensieve/" },
		{ label: isVi ? "Ký Ức" : "Memories", href: "/pensieve/memories" },
		{ label: post.data.title },
	]}
>
	<article class="article">
		<div class="reading-progress"></div>

		{post.data.featured_image && (
			<div class="article-hero" {...post.edit.featured_image}>
				<Image image={post.data.featured_image} />
			</div>
		)}

		<div class="article-grid">
			<div class="article-main">
				<header class="article-header">
					<div class="eyebrow-rule">
						{primaryCat && (
							<span class="eyebrow-cat">
								<span class="eyebrow-dot" /> {primaryCat.label}
							</span>
						)}
						<span class="hairline" />
						{publishDate && <time class="eyebrow-date">{publishDate}</time>}
					</div>

					<h1 class="article-title" {...post.edit.title}>{post.data.title}</h1>

					{post.data.excerpt && (
						<p class="article-excerpt">{post.data.excerpt}</p>
					)}

					<div class="meta-strip">
						{bylines.length > 0 && (
							<span class="meta-byline">
								{bylines[0].byline.avatarMediaId && (
									<img
										src={link(`_emdash/api/media/file/${bylines[0].byline.avatarMediaId}`)}
										alt={bylines[0].byline.displayName}
										class="meta-avatar"
									/>
								)}
								<span class="meta-name">
									{bylines.map((c, i) => (
										<>{i > 0 && ", "}{c.byline.displayName}</>
									))}
								</span>
							</span>
						)}
						<span class="meta-sep">·</span>
						<span class="meta-mins">{readingTime} {isVi ? "phút" : "min"}</span>
						{siblingSlug && (
							<a href={link(`memories/${siblingSlug}`)} class="meta-lang" data-switch-lang={siblingLang}>
								↗ {siblingLang === "vi" ? "Đọc bản tiếng Việt" : "Read in English"}
							</a>
						)}
					</div>

					<div class={`authorship ${isTranslation ? "is-translation" : "is-quill"}`}>
						<span class="authorship-tag">
							{isTranslation
								? (isVi ? "Bản dịch" : "Translation")
								: (isVi ? "Ngòi bút" : "Quill")}
						</span>
						<span class="hairline-v" />
						<span class="authorship-text">
							{isTranslation
								? (isVi
										? `Dịch từ ${langLabel(originalLang as Lang, "vi")} bởi Claude. Mọi suy nghĩ gốc đều của tác giả.`
										: `Translated from ${langLabel(originalLang as Lang, "en")} by Claude. Original thoughts are entirely the author's.`)
								: (isVi
										? "Viết hoàn toàn bằng tay người. Không AI trong văn bản — chỉ ở phần kỹ thuật bên dưới."
										: "Written entirely by hand. No AI in the prose — only in the site beneath it.")}
						</span>
					</div>
				</header>

				<div class="article-content">
					<PortableText value={post.data.content} />
				</div>

				{tags.length > 0 && (
					<div class="article-tags">
						{tags.map((t) => (
							<a href={link(`tag/${t.slug}`)} class="article-tag">{t.label}</a>
						))}
					</div>
				)}

				<div class="share-section">
					<button type="button" class="share-btn" data-share-btn
						data-share-title={post.data.title}
						data-label-share={isVi ? "Chia sẻ" : "Share"}
						data-label-copied={isVi ? "Đã chép liên kết" : "Link copied"}
						aria-haspopup="menu" aria-expanded="false">
						<svg class="share-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"
							stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<circle cx="18" cy="5" r="3" />
							<circle cx="6" cy="12" r="3" />
							<circle cx="18" cy="19" r="3" />
							<line x1="8.59" y1="13.51" x2="15.42" y2="17.49" />
							<line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
						</svg>
						<span class="share-label">{isVi ? "Chia sẻ" : "Share"}</span>
					</button>
					<div class="share-popover" data-share-popover hidden role="menu">
						<button type="button" class="share-option" data-share-copy>
							{isVi ? "Chép liên kết" : "Copy link"}
						</button>
						<a class="share-option" data-share-x target="_blank" rel="noopener noreferrer">X / Twitter</a>
						<a class="share-option" data-share-fb target="_blank" rel="noopener noreferrer">Facebook</a>
						<a class="share-option" data-share-li target="_blank" rel="noopener noreferrer">LinkedIn</a>
					</div>
				</div>

				<div class="article-comments">
					<Comments collection="posts" contentId={post.data.id} threaded />
					<CommentForm collection="posts" contentId={post.data.id} />
					<p class="comments-note">
						{isVi
							? "Cú bưu điện được kiểm duyệt và có thể mất một lúc để tới nơi."
							: "Owl post is moderated and may take a moment to arrive."}
					</p>
				</div>
			</div>

			<aside class="article-sidebar">
				<div class="sidebar-sticky">
					<nav class="toc" aria-label="Table of contents">
						<h4 class="sidebar-label">{isVi ? "Mục lục" : "On this page"}</h4>
						<div class="toc-content" id="toc-content"></div>
					</nav>

					<div class="lumos-tile">
						<button class="lumos-btn" data-post-slug={slug} aria-label="Cast Lumos">
							<span class="lumos-wand">★</span>
							<span class="lumos-count" data-lumos-count>—</span>
						</button>
						<p class="lumos-hint">
							{isVi ? "Thắp sáng ký ức này" : "Illuminate this memory"}
						</p>
					</div>

					<div class="sidebar-widgets">
						<WidgetArea name="sidebar" />
					</div>
				</div>
			</aside>
		</div>
	</article>

	{otherPostsWithTags.length > 0 && (
		<section class="more-posts">
			<div class="more-inner">
				<div class="more-rule">
					<h2 class="more-title">{isVi ? "Thêm ký ức" : "More memories"}</h2>
					<span class="hairline" />
					<a href={link("memories")} class="more-link">
						{isVi ? "Xem tất cả →" : "View all →"}
					</a>
				</div>
				<div class="more-grid">
					{otherPostsWithTags.map(({ post: p, tags: postTags, bylines: postBylines }) => (
						<PostCard
							title={p.data.title}
							excerpt={p.data.excerpt}
							featuredImage={p.data.featured_image}
							href={link(`memories/${p.id}`)}
							date={p.data.publishedAt ?? undefined}
							readingTime={getReadingTime(p.data.content)}
							tags={postTags.map((t) => ({ slug: t.slug, label: t.label }))}
							bylines={postBylines}
						/>
					))}
				</div>
			</div>
		</section>
	)}

	<script>
		function buildToc() {
			const content = document.querySelector(".article-content");
			const tocContainer = document.getElementById("toc-content");
			if (!content || !tocContainer) return;
			const headings = content.querySelectorAll("h2, h3");
			if (headings.length === 0) {
				const toc = document.querySelector(".toc") as HTMLElement | null;
				if (toc) toc.style.display = "none";
				return;
			}
			const list = document.createElement("ul");
			list.className = "toc-list";
			headings.forEach((heading, index) => {
				if (!heading.id) heading.id = `heading-${index}`;
				const li = document.createElement("li");
				li.className = heading.tagName === "H3" ? "toc-item toc-item--nested" : "toc-item";
				const a = document.createElement("a");
				a.href = `#${heading.id}`;
				a.className = "toc-link";
				a.textContent = heading.textContent;
				li.appendChild(a);
				list.appendChild(li);
			});
			tocContainer.appendChild(list);
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						const id = entry.target.id;
						const link = tocContainer.querySelector(`a[href="#${id}"]`);
						if (link && entry.isIntersecting) {
							tocContainer.querySelectorAll(".toc-link").forEach((l) => l.classList.remove("active"));
							link.classList.add("active");
						}
					});
				},
				{ rootMargin: "-80px 0px -80% 0px" },
			);
			headings.forEach((h) => observer.observe(h));
		}
		buildToc();
	</script>
</Base>

<script>
	function initReadingProgress() {
		const bar = document.querySelector('.reading-progress') as HTMLElement | null;
		const content = document.querySelector('.article-content') as HTMLElement | null;
		if (!bar || !content) return;
		let ticking = false;
		function updateProgress() {
			const rect = content!.getBoundingClientRect();
			const contentTop = rect.top + window.scrollY;
			const contentHeight = content!.offsetHeight;
			const viewportHeight = window.innerHeight;
			const scrollY = window.scrollY;
			const scrollable = contentHeight - viewportHeight;
			if (scrollable <= 0) { bar!.style.width = '100%'; return; }
			const progress = Math.min(Math.max((scrollY - contentTop) / scrollable, 0), 1);
			bar!.style.width = `${progress * 100}%`;
			ticking = false;
		}
		window.addEventListener('scroll', () => {
			if (!ticking) { requestAnimationFrame(updateProgress); ticking = true; }
		}, { passive: true });
		updateProgress();
	}
	initReadingProgress();

	// Lumos
	(function () {
		const btn = document.querySelector('.lumos-btn') as HTMLButtonElement | null;
		if (!btn) return;
		const slug = btn.dataset.postSlug;
		const countEl = btn.querySelector('[data-lumos-count]') as HTMLElement;
		const COOKIE = `lumos_${slug}`;
		const API = '/_emdash/api/plugins/pensieve-engage';
		if (document.cookie.includes(COOKIE + '=1')) btn.classList.add('lumos-cast');
		fetch(`${API}/lumos/count?post=${encodeURIComponent(slug!)}`)
			.then(r => r.json())
			.then(res => { const d = res.data ?? res; if (countEl) countEl.textContent = String(d.count || 0); })
			.catch(() => {});
		btn.addEventListener('click', (e: MouseEvent) => {
			if (btn.classList.contains('lumos-cast')) return;
			(window as any).SpellSounds?.lumos?.();
			spawnSparkles(e.clientX, e.clientY);
			fetch(`${API}/lumos/cast`, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ postSlug: slug }),
			})
				.then(r => r.json())
				.then(res => {
					const d = res.data ?? res;
					if (d.success || d.alreadyCast) {
						btn.classList.add('lumos-cast');
						if (countEl) countEl.textContent = String(d.count);
						document.cookie = `${COOKIE}=1;path=/;max-age=${60*60*24*365};samesite=lax`;
					}
				})
				.catch(() => {});
		});
		function spawnSparkles(cx: number, cy: number) {
			for (let i = 0; i < 8; i++) {
				const dot = document.createElement('span');
				dot.className = 'lumos-sparkle';
				const angle = (Math.PI * 2 * i) / 8;
				const dist = 24 + Math.random() * 18;
				dot.style.setProperty('--sx', `${Math.cos(angle) * dist}px`);
				dot.style.setProperty('--sy', `${Math.sin(angle) * dist}px`);
				dot.style.left = `${cx}px`;
				dot.style.top = `${cy}px`;
				document.body.appendChild(dot);
				dot.addEventListener('animationend', () => dot.remove());
			}
		}
	})();

	// Share
	(() => {
		const btn = document.querySelector<HTMLButtonElement>('[data-share-btn]');
		if (!btn) return;
		const popover = document.querySelector<HTMLElement>('[data-share-popover]');
		const copyBtn = document.querySelector<HTMLButtonElement>('[data-share-copy]');
		const xLink = document.querySelector<HTMLAnchorElement>('[data-share-x]');
		const fbLink = document.querySelector<HTMLAnchorElement>('[data-share-fb]');
		const liLink = document.querySelector<HTMLAnchorElement>('[data-share-li]');
		const labelEl = btn.querySelector<HTMLElement>('.share-label');
		const title = btn.dataset.shareTitle || document.title;
		const url = location.href;
		const labelShare = btn.dataset.labelShare || 'Share';
		const labelCopied = btn.dataset.labelCopied || 'Link copied';
		if (xLink) xLink.href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`;
		if (fbLink) fbLink.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;
		if (liLink) liLink.href = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;
		function closePopover() { if (popover) popover.hidden = true; btn?.setAttribute('aria-expanded', 'false'); }
		function openPopover() { if (popover) popover.hidden = false; btn?.setAttribute('aria-expanded', 'true'); }
		btn.addEventListener('click', async (e) => {
			e.preventDefault();
			const nav = navigator as Navigator & { share?: (data: ShareData) => Promise<void> };
			if (nav.share) {
				try { await nav.share({ title, url }); return; } catch {}
			}
			if (popover?.hidden) openPopover(); else closePopover();
		});
		copyBtn?.addEventListener('click', async () => {
			try {
				await navigator.clipboard.writeText(url);
				if (labelEl) {
					labelEl.textContent = labelCopied;
					setTimeout(() => { labelEl.textContent = labelShare; }, 1500);
				}
				closePopover();
			} catch {}
		});
		document.addEventListener('click', (e) => {
			if (!popover || popover.hidden) return;
			const t = e.target as Node;
			if (!popover.contains(t) && !btn.contains(t)) closePopover();
		});
		document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePopover(); });
	})();
</script>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,wght@0,400;0,500;1,400&display=swap');

	.reading-progress {
		position: fixed; top: 0; left: 0; z-index: 200;
		width: 0; height: 2px; background: var(--color-accent);
		transition: width 0.15s ease-out; pointer-events: none;
	}

	.article {
		max-width: var(--wide-width);
		margin: 0 auto;
	}

	.article-hero {
		margin: var(--spacing-12) var(--spacing-6) var(--spacing-10);
		border-radius: var(--radius-lg);
		overflow: hidden;
	}
	.article-hero img {
		width: 100%; height: auto; max-height: 460px; object-fit: cover;
	}

	.article-grid {
		display: grid;
		grid-template-columns: minmax(0, 720px) 220px;
		gap: var(--spacing-10);
		justify-content: center;
		padding: 0 var(--spacing-6);
		margin: var(--spacing-12) 0;
	}
	.article-main { min-width: 0; }
	.article-header { margin-bottom: var(--spacing-10); }

	/* Eyebrow */
	.eyebrow-rule {
		display: flex; align-items: center; gap: var(--spacing-3);
		padding-bottom: var(--spacing-3);
		margin-bottom: var(--spacing-5);
		border-bottom: 1px solid var(--color-border);
	}
	.eyebrow-cat {
		display: inline-flex; align-items: center; gap: 6px;
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-accent);
		letter-spacing: .14em; text-transform: uppercase; font-weight: 500;
	}
	.eyebrow-dot {
		width: 6px; height: 6px; border-radius: 50%;
		background: var(--color-accent);
	}
	.hairline { flex: 1; height: 1px; background: var(--color-border); }
	.eyebrow-date {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted); letter-spacing: .04em;
	}

	/* Title */
	.article-title {
		font-family: var(--font-display);
		font-size: clamp(1.875rem, 5vw, 3rem);
		font-weight: var(--font-weight-display);
		letter-spacing: -.026em; line-height: 1.05;
		margin: 0 0 var(--spacing-4); text-wrap: balance;
	}
	.article-excerpt {
		font-size: var(--font-size-xl);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0 0 var(--spacing-6); max-width: 52ch;
	}

	/* Inline meta strip */
	.meta-strip {
		display: flex; align-items: center; gap: var(--spacing-3);
		flex-wrap: wrap;
		padding-bottom: var(--spacing-4);
		margin-bottom: var(--spacing-5);
		border-bottom: 1px solid var(--color-border);
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted); letter-spacing: .04em;
	}
	.meta-byline { display: inline-flex; align-items: center; gap: 8px; }
	.meta-avatar {
		width: 22px; height: 22px; border-radius: 50%; object-fit: cover;
	}
	.meta-name {
		color: var(--color-text); font-weight: 500;
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
	}
	.meta-lang {
		margin-left: auto;
		padding: 4px 10px;
		border: 1px solid var(--color-border);
		border-radius: 6px;
		color: var(--color-text-secondary);
		text-decoration: none;
		transition: color 120ms ease, border-color 120ms ease;
	}
	.meta-lang:hover {
