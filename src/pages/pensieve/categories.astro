---
export const prerender = false;

import { getEmDashCollection, getEntryTerms } from "emdash";
import Base from "../../layouts/Base.astro";
import { link } from "../../utils/link";
import { categoryThemeMap, type ThemeSlug } from "../../themes/categoryThemes";
import { themes } from "../../themes";
import { getCurrentLang } from "../../utils/lang";

const currentLang = getCurrentLang(Astro);
const { entries: posts, cacheHint } = await getEmDashCollection("posts");
Astro.cache.set(cacheHint);

// Count posts per category, for the current reader language
const counts = new Map<string, number>();
for (const post of posts) {
	if (post.data.language !== currentLang) continue;
	const cats = await getEntryTerms("posts", post.data.id, "category");
	for (const c of cats) {
		counts.set(c.slug, (counts.get(c.slug) ?? 0) + 1);
	}
}

// One tile per unique theme (misc shares lab-notebook with science)
const seen = new Set<ThemeSlug>();
const tiles = Object.entries(categoryThemeMap)
	.filter(([, themeSlug]) => {
		if (seen.has(themeSlug)) return false;
		seen.add(themeSlug);
		return true;
	})
	.map(([slug, themeSlug]) => {
		const theme = themes[themeSlug];
		const label = slug
			.replace(/-/g, " ")
			.replace(/\b\w/g, (c) => c.toUpperCase());
		return {
			slug,
			label,
			theme,
			count: counts.get(slug) ?? 0,
		};
	});

const totalPosts = Array.from(counts.values()).reduce((a, b) => a + b, 0);
---

<Base
	title="Categories"
	description="Browse Pensieve by topic."
>
	<div class="categories-page">
		<header class="page-header">
			<p class="page-eyebrow">{totalPosts} posts · {tiles.length} categories</p>
			<h1 class="page-title">Browse by category</h1>
			<p class="page-subtitle">
				{
					currentLang === "vi"
						? "Mỗi chủ đề có một màu riêng. Chọn một để bắt đầu."
						: "Each topic has its own accent color. Pick one to dive in."
				}
			</p>
		</header>

		<ol class="tile-list">
			{
				tiles.map((t) => (
					<li>
						<a
							href={link(`category/${t.slug}`)}
							class="tile"
							style={`--accent: ${t.theme.palette.accent};`}
							data-empty={t.count === 0}
						>
							<div class="tile-mark" />
							<div class="tile-body">
								<h2 class="tile-name">{t.label}</h2>
								<p class="tile-tagline">{t.theme.tagline}</p>
							</div>
							<div class="tile-meta">
								<span class="tile-count">
									{t.count === 0 ? "—" : `${t.count} post${t.count === 1 ? "" : "s"}`}
								</span>
								<span class="tile-arrow">→</span>
							</div>
						</a>
					</li>
				))
			}
		</ol>
	</div>
</Base>

<style>
	.categories-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-8) var(--spacing-24);
	}

	.page-header {
		margin-bottom: var(--spacing-16);
	}

	.page-eyebrow {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		margin: 0 0 var(--spacing-3);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
	}

	.page-title {
		font-family: var(--font-display);
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: var(--font-weight-display, 590);
		letter-spacing: -0.022em;
		line-height: 1.1;
		margin: 0 0 var(--spacing-4);
		color: var(--color-text);
	}

	.page-subtitle {
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
		max-width: 52ch;
		margin: 0;
	}

	.tile-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
		gap: var(--spacing-4);
	}

	.tile {
		--accent: var(--color-accent);
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: var(--spacing-5);
		padding: var(--spacing-6) var(--spacing-6);
		background: var(--color-surface-elevated);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		text-decoration: none;
		color: inherit;
		transition:
			border-color var(--transition-fast),
			transform var(--transition-fast);
	}

	.tile:hover {
		border-color: color-mix(in srgb, var(--accent) 50%, var(--color-border));
		transform: translateY(-1px);
	}

	.tile[data-empty="true"] {
		opacity: 0.5;
	}

	.tile-mark {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--accent);
	}

	.tile-body {
		min-width: 0;
	}

	.tile-name {
		font-family: var(--font-display);
		font-size: var(--font-size-lg);
		font-weight: var(--font-weight-display, 590);
		letter-spacing: -0.015em;
		line-height: 1.2;
		margin: 0 0 var(--spacing-1);
		color: var(--color-text);
	}

	.tile-tagline {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin: 0;
	}

	.tile-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-3);
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	.tile-arrow {
		color: var(--color-text-secondary);
		transition: color var(--transition-fast), transform var(--transition-fast);
	}

	.tile:hover .tile-arrow {
		color: var(--accent);
		transform: translateX(3px);
	}

	@media (max-width: 700px) {
		.categories-page {
			padding: var(--spacing-10) var(--spacing-5) var(--spacing-16);
		}

		.tile-list {
			grid-template-columns: 1fr;
		}
	}
</style>
