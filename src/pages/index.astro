---
export const prerender = false;
// huuloc.com landing page — standalone, no Base layout
import SiteCat from "../components/SiteCat.astro";
import { getCurrentLang } from "../utils/lang";
const currentLang = getCurrentLang(Astro);
const isVi = currentLang === "vi";
const copy = {
  description: isVi
    ? "Kỹ sư senior, viết song ngữ, Việt Nam. Dự án và bài viết dài lưu ở đây."
    : "Senior engineer, bilingual writer, Vietnam. Projects and long-form writing live here.",
  role: isVi
    ? "Kỹ sư phần mềm senior. Viết song ngữ. Sống ở Việt Nam."
    : "Senior software engineer. Bilingual writer. Based in Vietnam.",
  bio: isVi
    ? "Ở VNG từ 2006, xây hệ thống session và nền tảng phát hành game."
    : "At VNG from 2006, building session systems and game publishing platforms.",
  bioPapaya: isVi
    ? "Giờ ở "
    : "Now at ",
  bioPapayaRest: isVi
    ? ", đưa các tác tử AI vào phần thủ công của việc làm phần mềm. Viết dài bằng tiếng Việt và tiếng Anh — chủ yếu về ký ức, gia đình, cá, và những điều đáng giữ lại."
    : ", putting AI agents to work on the craft side of software. Writes long-form in Vietnamese and English — mostly about memory, family, fish, and the things worth keeping.",
  sectionGrounds: isVi ? "Khuôn Viên" : "The Grounds",
  sectionHogwarts: "Hogwarts",
  sectionNydus: "Nydus",
  sectionBeyond: isVi ? "Ngoài Cổng Trường" : "Beyond the Gates",
  weasleyClockMeta: isVi ? "Lịch gia đình · dương + âm" : "Family calendar · solar + lunar",
  weasleyClockDesc: isVi
    ? "Đồng hồ Weasley trong nhà Nydus. Giỗ, sinh nhật, lễ Tết — hiển thị cả dương lịch và âm lịch."
    : "The Weasley Clock in our home, Nydus. Anniversaries, birthdays, cultural observances — shown in both Gregorian and Vietnamese lunar calendars.",
  pensieveMeta: isVi ? "VI · EN · 130 bài" : "VI · EN · 130 posts",
  pensieveDesc: isVi
    ? "Những câu chuyện dài cứu về từ Facebook, sắp xếp theo chủ đề và có cả hai phiên bản tiếng Việt và tiếng Anh."
    : "Long-form narratives rescued from Facebook, sorted into themed categories with every post available in both Vietnamese and English.",
  rorMeta: isVi ? "Nhật ký xây dựng" : "Build diary",
  rorDesc: isVi
    ? "Trang này được xây như thế nào — kiến trúc, tech stack, và Priori Incantatem: dòng thời gian mọi phiên Claude Code."
    : "How this site is built — architecture, tech stack, and Priori Incantatem: a timeline of every Claude Code session.",
  truongMeta: isVi ? "Giới thiệu" : "About",
  truongDesc: isVi
    ? "Câu chuyện khởi đầu, liên kết hồ sơ, và hoạt động GitHub trực tiếp."
    : "Origin story, profile links, and live GitHub activity.",
  libraryMeta: isVi ? "Slide giáo dục" : "Education slides",
  libraryDesc: isVi
    ? "Bài giảng trình chiếu — lớp AI dựa trên phim ảnh, chạy bằng Reveal.js. Ai cần PowerPoint?"
    : "Slide decks for teaching — movie-based AI lessons, powered by Reveal.js. Who needs PowerPoint?",
  greatHallMeta: isVi ? "Sắp có" : "Coming soon",
  greatHallDesc: isVi
    ? "Khoá học, bài giảng từ trường học và đại học — kho lưu trữ học thuật."
    : "Courses, lectures, and lessons from schools and universities — the academic archive.",
  quidditchMeta: isVi ? "Sân chơi animation" : "Animation playground",
  quidditchDesc: isVi
    ? "Các animation web, mỗi cái đi kèm nhật ký xây Claude Code đầy đủ — lướt qua từng prompt và chỉnh sửa."
    : "Web animations, each paired with a full Claude Code build diary — scrub through every prompt and edit.",
  gamesMeta: isVi ? "Sân chơi" : "Games",
  gamesDesc: isVi
    ? "Tuyển tập game nhỏ tìm được trên GitHub — để chơi, để học cách chúng được dựng nên."
    : "A curated collection of small games found on GitHub — to play, and to study how they were put together.",
  soonBadge: isVi ? "sắp" : "soon",
};
---

<html lang={isVi ? "vi" : "en"}>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Trương Hữu Lộc</title>
<meta name="description" content={copy.description} />
<meta property="og:title" content="Trương Hữu Lộc" />
<meta property="og:description" content={copy.description} />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://huuloc.com/" />
<meta name="ai-content-declaration" content="site-code:ai-generated; content:human-written" />
<meta name="generator" content="Astro + Claude Code" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <details class="lang-toggle">
    <summary>{isVi ? "VI" : "EN"} <span class="arrow">▾</span></summary>
    <div class="lang-menu">
      <a href="#" class="lang-item" data-switch-lang="vi" data-active={isVi}>Tiếng Việt</a>
      <a href="#" class="lang-item" data-switch-lang="en" data-active={!isVi}>English</a>
    </div>
  </details>
  <main class="page">
    <section class="hero">
      <div class="eyebrow">
        <svg width="14" height="14" viewBox="0 0 32 32" aria-hidden="true">
          <path d="M16 28 C16 22 15 18 16 13" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" />
          <path d="M16 15 C13 13 9 10 8 5 C13 6 16 11 16 15" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M16 11 C19 9 23 6 24 2 C19 3 16 7 16 11" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        huuloc.com
      </div>

      <h1 class="name">Trương Hữu Lộc</h1>
      <p class="role">{copy.role}</p>
      <p class="bio">
        {copy.bio}
        {copy.bioPapaya}<a href="https://papaya.asia" rel="noopener">Papaya</a>{copy.bioPapayaRest}
      </p>
    </section>

    <section class="section">
      <span class="section-label">{copy.sectionGrounds}</span>
      <ul class="project-list">
        <li>
          <a href="/pensieve/" class="project">
            <div>
              <div class="project-head">
                <h2 class="project-name"><svg class="project-icon" width="16" height="16" viewBox="0 0 32 32" aria-hidden="true"><ellipse cx="16" cy="10.5" rx="11" ry="2.75" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" /><path d="M5 10.5 L5 14 C5 20.5 9.5 25 16 25 C22.5 25 27 20.5 27 14 L27 10.5" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" /><ellipse cx="16" cy="10.5" rx="4.5" ry="1.1" fill="currentColor" /></svg>Pensieve</h2>
                <span class="project-meta">{copy.pensieveMeta}</span>
              </div>
              <p class="project-desc">{copy.pensieveDesc}</p>
            </div>
            <span class="project-arrow">&rarr;</span>
          </a>
        </li>
        <li>
          <a href="/hol/" class="project">
            <div>
              <div class="project-head">
                <h2 class="project-name"><svg class="project-icon" width="16" height="16" viewBox="0 0 32 32" aria-hidden="true"><rect x="4" y="7" width="24" height="17" rx="2" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" /><path d="M9 12 L23 12 M9 16 L23 16 M9 20 L18 20" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>HOL Archive</h2>
                <span class="project-meta">VI · 25k posts · 2005–</span>
              </div>
              <p class="project-desc">
                Kỷ niệm của một diễn đàn vBulletin cũ, được dựng lại từ
                Internet Archive. Read-only — để nhớ lại những năm tháng đó.
              </p>
            </div>
            <span class="project-arrow">&rarr;</span>
          </a>
        </li>
        <li>
          <a href="/room-of-requirement" class="project">
            <div>
              <div class="project-head">
                <h2 class="project-name"><svg class="project-icon" width="16" height="16" viewBox="0 0 32 32" aria-hidden="true"><path d="M9 28 V10 Q16 2 23 10 V28" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" /><circle cx="20" cy="18" r="1.5" fill="currentColor" /></svg>Room of Requirement</h2>
                <span class="project-meta">{copy.rorMeta}</span>
              </div>
              <p class="project-desc">{copy.rorDesc}</p>
            </div>
            <span class="project-arrow">&rarr;</span>
          </a>
        </li>
        <li>
          <a href="/Trương" class="project">
            <div>
              <div class="project-head">
                <h2 class="project-name"><svg class="project-icon" width="16" height="16" viewBox="0 0 32 32" aria-hidden="true"><path d="M16 28 C16 22 15 18 16 13" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" /><path d="M16 15 C13 13 9 10 8 5 C13 6 16 11 16 15" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" /><path d="M16 11 C19 9 23 6 24 2 C19 3 16 7 16 11" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" /></svg>Trương</h2>
                <span class="project-meta">{copy.truongMeta}</span>
              </div>
              <p class="project-desc">{copy.truongDesc}</p>
            </div>
            <span class="project-arrow">&rarr;</span>
          </a>
        </li>
      </ul>
    </section>

    <section class="section">
      <span class="section-label">{copy.sectionHogwarts}</span>
      <ul class="project-list">
        <li>
          <a href="/hogwarts/library/" class="project">
            <div>
              <div class="project-head">
                <h2 class="project-name"><svg class="project-icon" width="16" height="16" viewBox="0 0 32 32" aria-hidden="true"><path d="M6 4 h20 v24 H6 Z" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" /><line x1="10" y1="9" x2="22" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" /><line x1="10" y1="14" x2="22" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" /><line x1="10" y1="19" x2="18" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" /></svg>The Library</h2>
                <span class="project-meta">{copy.libraryMeta}</span>
              </div>
              <p class="project-desc">{copy.libraryDesc}</p>
            </div>
            <span class="project-arrow">&rarr;</span>
          </a>
        </li>
        <li>
          <span class="project project-coming">
            <div>
              <div class="project-head">
                <h2 class="project-name"><svg class="project-icon" width="16" height="16" viewBox="0 0 32 32" aria-hidden="true"><path d="M8 28 V12 L16 4 L24 12 V28" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" /><line x1="16" y1="4" x2="16" y2="1" stroke="currentColor" stroke-width="2" stroke-linecap="round" /><rect x="13" y="18" width="6" height="6" rx="0.5" fill="none" stroke="currentColor" stroke-width="1.5" /></svg>Great Hall</h2>
                <span class="project-meta">{copy.greatHallMeta}</span>
              </div>
              <p class="project-desc">{copy.greatHallDesc}</p>
            </div>
            <span class="project-arrow coming-badge">{copy.soonBadge}</span>
          </span>
        </li>
        <li>
          <a href="/hogwarts/games/" class="project">
            <div>
              <div class="project-head">
                <h2 class="project-name"><svg class="project-icon" width="16" height="16" viewBox="0 0 32 32" aria-hidden="true"><rect x="4" y="11" width="24" height="13" rx="4" fill="none" stroke="currentColor" stroke-width="2.25" /><line x1="10" y1="17.5" x2="14" y2="17.5" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" /><line x1="12" y1="15.5" x2="12" y2="19.5" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" /><circle cx="21" cy="16" r="1.25" fill="currentColor" /><circle cx="24" cy="19" r="1.25" fill="currentColor" /></svg>The Games Room</h2>
                <span class="project-meta">{copy.gamesMeta}</span>
              </div>
              <p class="project-desc">{copy.gamesDesc}</p>
            </div>
            <span class="project-arrow">&rarr;</span>
          </a>
        </li>
        <li>
          <a class="project project-quidditch" href="/hogwarts/quidditch/">
            <div>
              <div class="project-head">
                <h2 class="project-name">
                  <svg class="project-icon snitch-icon" width="18" height="18" viewBox="0 0 32 32" aria-hidden="true">
                    <g class="snitch-wing snitch-wing-left">
                      <ellipse cx="11" cy="16" rx="6" ry="2" fill="currentColor" opacity="0.5" />
                    </g>
                    <g class="snitch-wing snitch-wing-right">
                      <ellipse cx="21" cy="16" rx="6" ry="2" fill="currentColor" opacity="0.5" />
                    </g>
                    <circle class="snitch-orb" cx="16" cy="16" r="4.5" fill="#d4a02a" stroke="#ffd88a" stroke-width="0.5" />
                    <circle class="snitch-spark" cx="14.5" cy="14.5" r="1.2" fill="#ffffff" opacity="0.9" />
                  </svg>Quidditch Pitch
                </h2>
                <span class="project-meta">{copy.quidditchMeta}</span>
              </div>
              <p class="project-desc">{copy.quidditchDesc}</p>
            </div>
            <span class="project-arrow">&rarr;</span>
          </a>
        </li>
      </ul>
    </section>

    <section class="section">
      <span class="section-label">{copy.sectionNydus}</span>
      <ul class="project-list">
        <li>
          <a href="/nydus/weasley-clock" class="project">
            <div>
              <div class="project-head">
                <h2 class="project-name"><svg class="project-icon" width="16" height="16" viewBox="0 0 32 32" aria-hidden="true"><circle cx="16" cy="16" r="12" fill="none" stroke="currentColor" stroke-width="2.25"/><path d="M16 8 L16 16 L22 19" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/></svg>The Weasley Clock</h2>
                <span class="project-meta">{copy.weasleyClockMeta}</span>
              </div>
              <p class="project-desc">{copy.weasleyClockDesc}</p>
            </div>
            <span class="project-arrow">&rarr;</span>
          </a>
        </li>
      </ul>
    </section>

    <section class="section">
      <span class="section-label">{copy.sectionBeyond}</span>
      <div class="links-row">
        <a href="https://github.com/deathemperor" rel="noopener" class="link-item">GitHub</a>
        <a href="https://www.linkedin.com/in/deathemperor/" rel="noopener" class="link-item">LinkedIn</a>
        <a href="https://fb.me/deathemperor" rel="noopener" class="link-item">Facebook</a>
      </div>
    </section>

    <footer class="foot">
      <span>&copy; Trương Hữu Lộc</span>
    </footer>
  </main>
  <SiteCat />
  <script>
    // Set pref_lang cookie + reload on click. Matches Base.astro's global handler
    // so the same switcher UX works on this standalone page.
    document.querySelectorAll<HTMLAnchorElement>('[data-switch-lang]').forEach((a) => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const v = a.dataset.switchLang || 'en';
        const secure = location.protocol === 'https:' ? '; Secure' : '';
        document.cookie = `pref_lang=${v}; path=/; max-age=${3600 * 24 * 365}; SameSite=Lax${secure}`;
        location.reload();
      });
    });
  </script>
</body>
</html>

<style is:global>
  :root {
    --bg: #08090a;
    --elevated: #141516;
    --text: #f7f8f8;
    --secondary: #8a8f98;
    --muted: #62666d;
    --border: rgba(255, 255, 255, 0.06);
    --accent: #5e6ad2;
    --sans: "Inter", -apple-system, BlinkMacSystemFont, "SF Pro Display", sans-serif;
    --mono: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-size: 16px;
    line-height: 1.55;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
</style>

<style>
  /* Language toggle — top-right, minimal, mirrors the Base.astro nav-lang styling */
  .lang-toggle {
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 10;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
  }
  .lang-toggle > summary {
    list-style: none;
    cursor: pointer;
    padding: 0.35rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--elevated);
    transition: border-color 120ms ease, color 120ms ease;
  }
  .lang-toggle > summary:hover { color: var(--text); border-color: rgba(255,255,255,0.18); }
  .lang-toggle > summary::-webkit-details-marker { display: none; }
  .lang-toggle .arrow { font-size: 0.7em; opacity: 0.6; }
  .lang-menu {
    position: absolute;
    right: 0;
    margin-top: 0.25rem;
    background: var(--elevated);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.25rem;
    min-width: 8rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .lang-item {
    display: block;
    padding: 0.4rem 0.6rem;
    border-radius: 4px;
    text-decoration: none;
    color: var(--secondary);
    font-size: 0.8125rem;
    transition: background 120ms ease, color 120ms ease;
  }
  .lang-item:hover { background: rgba(255,255,255,0.04); color: var(--text); }
  .lang-item[data-active="true"] { color: var(--text); font-weight: 500; }

  .page {
    max-width: 640px;
    margin: 0 auto;
    padding: clamp(3rem, 10vh, 6rem) 1.5rem 4rem;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .hero { margin-bottom: 4rem; }

  .eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin-bottom: 2rem;
  }

  .eyebrow svg { flex-shrink: 0; }

  .name {
    font-family: var(--sans);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 590;
    letter-spacing: -0.024em;
    line-height: 1.08;
    margin: 0 0 0.75rem;
  }

  .role {
    font-size: 1.0625rem;
    color: var(--secondary);
    margin: 0 0 1.5rem;
    max-width: 52ch;
  }

  .bio {
    font-size: 1rem;
    color: var(--secondary);
    margin: 0;
    max-width: 56ch;
    line-height: 1.65;
  }

  .bio a {
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    transition: border-color 120ms ease;
  }

  .bio a:hover { border-color: var(--secondary); }

  .section { margin-bottom: 3rem; }

  .section-label {
    display: block;
    font-family: var(--mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 1rem;
  }

  .project-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .project {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 1rem;
    padding: 1.25rem 1.25rem 1.125rem;
    background: var(--elevated);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: border-color 120ms ease, transform 120ms ease;
  }

  .project:hover {
    border-color: rgba(255, 255, 255, 0.18);
    transform: translateY(-1px);
  }

  /* Animated snitch micro-icon on the Quidditch tile */
  .snitch-icon {
    overflow: visible;
    transform-origin: center;
  }
  .snitch-orb {
    filter: drop-shadow(0 0 3px rgba(212, 160, 42, 0.55));
    animation: snitch-pulse 2.4s ease-in-out infinite;
  }
  .snitch-spark {
    animation: snitch-spark 2.4s ease-in-out infinite;
  }
  .snitch-wing {
    transform-origin: 16px 16px;
    animation: snitch-flap 0.24s ease-in-out infinite alternate;
  }
  .snitch-wing-left { transform: scaleX(-1); }

  @keyframes snitch-pulse {
    0%, 100% { filter: drop-shadow(0 0 2px rgba(212, 160, 42, 0.45)); }
    50%      { filter: drop-shadow(0 0 6px rgba(255, 216, 138, 0.9)); }
  }
  @keyframes snitch-spark {
    0%, 100% { opacity: 0.6; }
    50%      { opacity: 1; }
  }
  @keyframes snitch-flap {
    from { transform: scaleY(0.55); }
    to   { transform: scaleY(1);    }
  }

  .project-quidditch:hover .snitch-orb {
    animation-duration: 1.2s;
  }
  .project-quidditch:hover .snitch-wing {
    animation-duration: 0.12s;
  }

  @media (prefers-reduced-motion: reduce) {
    .snitch-orb, .snitch-spark, .snitch-wing {
      animation: none;
    }
  }

  .project-head {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    margin-bottom: 0.375rem;
  }

  .project-name {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-size: 1.0625rem;
    font-weight: 590;
    letter-spacing: -0.015em;
    margin: 0;
  }

  .project-icon {
    flex-shrink: 0;
