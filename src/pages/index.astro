---
// huuloc.com landing — Direction C ("Daily Prophet" editorial index).
// Replaces the previous 4-up project grid + role/bio split. Brings the
// Pensieve writing forward, masthead-style hero, numbered rows per
// section. Footer simplified to Subscribe + Colophon (Elsewhere lives
// on /Trương).
//
// IA: Featured Pensieve → Writing → Hogwarts → Nydus → Beyond.
// VI/EN strict toggle stays top-right via pref_lang cookie.
// Per-category accent comes in only as a thin vertical rule on cards
// (honors SOUL.md: ONE dark canvas, accents are ribbons).
export const prerender = false;

import { getEmDashCollection, getEntryTerms } from "emdash";
import { getCurrentLang } from "../utils/lang";
import { link } from "../utils/link";
import SiteCat from "../components/SiteCat.astro";
import { setCachePolicy } from "../lib/cachePolicy";
setCachePolicy(Astro, "static");

const currentLang = getCurrentLang(Astro);
const isVi = currentLang === "vi";

// ── Featured Pensieve essays ────────────────────────────────────────
let latest: Array<{ id: string; title: string; cat: string | null; date: Date | null }> = [];
let totalEssays = 0;
try {
	const { entries, cacheHint } = await getEmDashCollection("posts");
	Astro.cache.set(cacheHint);
	const filtered = entries.filter((p) => p.data.language === currentLang);
	totalEssays = filtered.length;
	const sorted = filtered.toSorted(
		(a, b) => (b.data.publishedAt?.getTime() ?? 0) - (a.data.publishedAt?.getTime() ?? 0),
	);
	for (const p of sorted.slice(0, 4)) {
		const cats = await getEntryTerms("posts", p.data.id, "category");
		latest.push({
			id: p.id,
			title: p.data.title,
			cat: cats[0]?.label ?? null,
			date: p.data.publishedAt ?? null,
		});
	}
} catch {
	// No posts yet — featured block hides itself gracefully.
}

const fmtDate = (d: Date | null) =>
	d ? d.toLocaleDateString(isVi ? "vi-VN" : "en-US", { month: "short", year: "numeric" }) : "";

// ── Copy ─────────────────────────────────────────────────────────────
const copy = {
	description: isVi
		? "Kỹ sư senior, viết song ngữ, Việt Nam. Pensieve là nơi giữ lại các bài viết dài."
		: "Senior engineer, bilingual writer, Vietnam. The Pensieve keeps long-form writing.",
	tagline: isVi
		? "Kỹ sư phần mềm senior. Viết song ngữ. Sống ở Việt Nam. Người giữ một Pensieve."
		: "Senior software engineer. Bilingual writer. Based in Vietnam. Keeper of a Pensieve.",
	bio: isVi
		? "Ở VNG từ 2006, xây hệ thống session và nền tảng phát hành game. Giờ ở "
		: "At VNG since 2006, building session systems and game publishing platforms. Now at ",
	bioRest: isVi
		? ", đưa các tác tử AI vào việc làm phần mềm. Viết dài bằng tiếng Việt và tiếng Anh — về ký ức, gia đình, cá."
		: ", building AI agents for the long tail of software work. Long-form in Vietnamese and English — about memory, family, fish.",
	featuredLabel: isVi ? "Nổi bật" : "Featured",
	latestLabel: isVi ? "Mới nhất" : "Latest",
	pensieveTitle: isVi ? "Pensieve" : "The Pensieve",
	pensieveDesc: isVi
		? "Những bài viết dài tôi cứu về từ Facebook trước khi chúng trôi đi. Ký ức, gia đình, cá, những điều đáng giữ."
		: "Essays I rescued from Facebook before they scrolled away. Memory, family, fish, the things worth keeping.",
	readAll: isVi ? `Đọc tất cả ${totalEssays}` : `Read all ${totalEssays}`,
	pensieveMeta: isVi
		? `VI · EN · ${totalEssays} bài · đang viết tiếp`
		: `VI · EN · ${totalEssays} essays · ongoing`,
	secWriting: isVi ? "Viết" : "Writing",
	secHogwarts: "Hogwarts",
	secNydus: "Nydus",
	secBeyond: isVi ? "Ngoài Cổng Trường" : "Beyond the Gates",
	tagWriting: isVi ? "đọc" : "to read",
	tagHogwarts: isVi ? "học & chơi" : "to learn & play",
	tagNydus: isVi ? "nhà" : "home",
	tagBeyond: isVi ? "nơi khác" : "elsewhere",
	holName: "HOL Archive",
	holMeta: "VI · 25k posts · 2005–",
	holDesc: isVi
		? "Diễn đàn vBulletin cũ, dựng lại từ Internet Archive. Read-only — để nhớ những năm đó."
		: "An old vBulletin forum, rebuilt from the Internet Archive. Read-only — for remembering those years.",
	libraryName: "The Library",
	libraryMeta: isVi ? "Slide Reveal.js" : "Reveal.js slides",
	libraryDesc: isVi
		? "Slide cho lớp AI-và-điện-ảnh tôi dạy. Reveal.js, trình chiếu trực tiếp."
		: "Slide decks for the AI-and-cinema class I teach. Reveal.js, presented live.",
	gamesName: "The Games Room",
	gamesMeta: isVi ? "Game tuyển từ GitHub" : "Curated GitHub finds",
	gamesDesc: isVi
		? "Các game nhỏ tôi tìm thấy trên GitHub — để chơi, và để học cách dựng nên."
		: "Small games I found on GitHub — to play, and to study how they were put together.",
	quidditchName: "Quidditch Pitch",
	quidditchMeta: isVi ? "Sân chơi animation" : "Animation playground",
	quidditchDesc: isVi
		? "Animation web, mỗi cái đi kèm nhật ký Claude Code đầy đủ — lướt qua từng prompt."
		: "Web animations, each paired with a full Claude Code build diary — scrub through every prompt.",
	greatHallName: "Great Hall",
	greatHallMeta: isVi ? "Sắp có" : "Coming soon",
	greatHallDesc: isVi
		? "Khoá học, bài giảng — kho lưu trữ học thuật."
		: "Courses, lectures, lessons — the academic archive.",
	soonBadge: isVi ? "sắp" : "soon",
	weasleyName: "The Weasley Clock",
	weasleyMeta: isVi ? "Lịch gia đình · dương + âm" : "Family calendar · solar + lunar",
	weasleyDesc: isVi
		? "Đồng hồ Weasley trong nhà Nydus. Giỗ, sinh nhật, lễ Tết — dương lịch và âm lịch."
		: "The Weasley Clock in our home, Nydus. Anniversaries, birthdays, observances — Gregorian and lunar.",
	rorName: "Room of Requirement",
	rorMeta: isVi ? "Nhật ký xây dựng" : "Build diary",
	rorDesc: isVi
		? "Cách trang này được dựng nên. Kiến trúc, stack, và Priori Incantatem — mọi phiên Claude Code, từ đầu đến cuối."
		: "How this site is built. Architecture, stack, and Priori Incantatem — every Claude Code session, end to end.",
	truongName: "Trương",
	truongMeta: isVi ? "Giới thiệu" : "About",
	truongDesc: isVi
		? "Câu chuyện khởi đầu, hồ sơ, và hoạt động GitHub trực tiếp."
		: "Origin story, profile links, and live GitHub activity.",
	colophonClaude: isVi
		? "Mỗi dòng mã trên trang này do Claude Code viết."
		: "Every line of code on this site was written by Claude Code.",
	colophonStack: isVi
		? "Astro · Cloudflare Workers · D1 · R2 · KV"
		: "Astro · Cloudflare Workers · D1 · R2 · KV",
	subscribe: isVi ? "Đăng ký" : "Subscribe",
	colophon: isVi ? "Đường biên" : "Colophon",
};

// Section structure — pure data so the template stays clean
type Item = {
	href: string | null;
	name: string;
	meta: string;
	desc: string;
	accent: string;
	iconKey: string;
	coming?: boolean;
};
const sections: Array<{ label: string; sub: string; items: Item[] }> = [
	{
		label: copy.secWriting,
		sub: copy.tagWriting,
		items: [
			{ href: "/hol/", name: copy.holName, meta: copy.holMeta, desc: copy.holDesc, accent: "#7a9fb8", iconKey: "archive" },
		],
	},
	{
		label: copy.secHogwarts,
		sub: copy.tagHogwarts,
		items: [
			{ href: "/hogwarts/library/", name: copy.libraryName, meta: copy.libraryMeta, desc: copy.libraryDesc, accent: "#7fb069", iconKey: "library" },
			{ href: "/hogwarts/games/", name: copy.gamesName, meta: copy.gamesMeta, desc: copy.gamesDesc, accent: "#ff8a5b", iconKey: "games" },
			{ href: "/hogwarts/quidditch/", name: copy.quidditchName, meta: copy.quidditchMeta, desc: copy.quidditchDesc, accent: "#d4a02a", iconKey: "snitch" },
			{ href: null, name: copy.greatHallName, meta: copy.greatHallMeta, desc: copy.greatHallDesc, accent: "#62666d", iconKey: "great", coming: true },
		],
	},
	{
		label: copy.secNydus,
		sub: copy.tagNydus,
		items: [
			{ href: "/nydus/weasley-clock", name: copy.weasleyName, meta: copy.weasleyMeta, desc: copy.weasleyDesc, accent: "#e0a87a", iconKey: "clock" },
		],
	},
	{
		label: copy.secBeyond,
		sub: copy.tagBeyond,
		items: [
			{ href: "/room-of-requirement", name: copy.rorName, meta: copy.rorMeta, desc: copy.rorDesc, accent: "#d4a02a", iconKey: "room" },
			{ href: "/Trương", name: copy.truongName, meta: copy.truongMeta, desc: copy.truongDesc, accent: "#c08aff", iconKey: "quill" },
		],
	},
];

// Running 01..NN counter for the row numbers (resets per page, runs across sections)
let runningNum = 1;

// Inline icon helper — keyed by name, returns an SVG string.
function icon(key: string): string {
	const stroke = "var(--accent)";
	switch (key) {
		case "archive":
			return `<svg width="15" height="15" viewBox="0 0 32 32" aria-hidden="true"><rect x="4" y="7" width="24" height="17" rx="2" fill="none" stroke="${stroke}" stroke-width="2.25" stroke-linejoin="round"/><path d="M9 12 L23 12 M9 16 L23 16 M9 20 L18 20" stroke="${stroke}" stroke-width="2" stroke-linecap="round"/></svg>`;
		case "library":
			return `<svg width="15" height="15" viewBox="0 0 32 32" aria-hidden="true"><path d="M6 4 h20 v24 H6 Z" fill="none" stroke="${stroke}" stroke-width="2.25" stroke-linejoin="round"/><line x1="10" y1="9" x2="22" y2="9" stroke="${stroke}" stroke-width="1.5" stroke-linecap="round"/><line x1="10" y1="14" x2="22" y2="14" stroke="${stroke}" stroke-width="1.5" stroke-linecap="round"/><line x1="10" y1="19" x2="18" y2="19" stroke="${stroke}" stroke-width="1.5" stroke-linecap="round"/></svg>`;
		case "games":
			return `<svg width="15" height="15" viewBox="0 0 32 32" aria-hidden="true"><rect x="4" y="11" width="24" height="13" rx="4" fill="none" stroke="${stroke}" stroke-width="2.25"/><line x1="10" y1="17.5" x2="14" y2="17.5" stroke="${stroke}" stroke-width="2.25" stroke-linecap="round"/><line x1="12" y1="15.5" x2="12" y2="19.5" stroke="${stroke}" stroke-width="2.25" stroke-linecap="round"/><circle cx="21" cy="16" r="1.25" fill="${stroke}"/><circle cx="24" cy="19" r="1.25" fill="${stroke}"/></svg>`;
		case "snitch":
			return `<svg width="16" height="16" viewBox="0 0 32 32" aria-hidden="true"><g class="snitch-wing snitch-wing-left"><ellipse cx="11" cy="16" rx="6" ry="2" fill="#d4a02a" opacity=".5"/></g><g class="snitch-wing"><ellipse cx="21" cy="16" rx="6" ry="2" fill="#d4a02a" opacity=".5"/></g><circle class="snitch-orb" cx="16" cy="16" r="4.5" fill="#d4a02a" stroke="#ffd88a" stroke-width=".5"/><circle cx="14.5" cy="14.5" r="1.2" fill="#fff" opacity=".9"/></svg>`;
		case "great":
			return `<svg width="15" height="15" viewBox="0 0 32 32" aria-hidden="true"><path d="M8 28 V12 L16 4 L24 12 V28" fill="none" stroke="${stroke}" stroke-width="2.25" stroke-linejoin="round"/><line x1="16" y1="4" x2="16" y2="1" stroke="${stroke}" stroke-width="2" stroke-linecap="round"/><rect x="13" y="18" width="6" height="6" rx=".5" fill="none" stroke="${stroke}" stroke-width="1.5"/></svg>`;
		case "clock":
			return `<svg width="15" height="15" viewBox="0 0 32 32" aria-hidden="true"><circle cx="16" cy="16" r="12" fill="none" stroke="${stroke}" stroke-width="2.25"/><path d="M16 8 L16 16 L22 19" fill="none" stroke="${stroke}" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
		case "room":
			return `<svg width="15" height="15" viewBox="0 0 32 32" aria-hidden="true"><path d="M9 28 V10 Q16 2 23 10 V28" fill="none" stroke="${stroke}" stroke-width="2.25" stroke-linejoin="round"/><circle cx="20" cy="18" r="1.5" fill="${stroke}"/></svg>`;
		case "quill":
		default:
			return `<svg width="15" height="15" viewBox="0 0 32 32" aria-hidden="true"><path d="M16 28 C16 22 15 18 16 13" fill="none" stroke="${stroke}" stroke-width="2.25" stroke-linecap="round"/><path d="M16 15 C13 13 9 10 8 5 C13 6 16 11 16 15" fill="none" stroke="${stroke}" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 11 C19 9 23 6 24 2 C19 3 16 7 16 11" fill="none" stroke="${stroke}" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
	}
}
---

<html lang={isVi ? "vi" : "en"}>
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Trương Hữu Lộc</title>
	<meta name="description" content={copy.description} />
	<meta property="og:title" content="Trương Hữu Lộc" />
	<meta property="og:description" content={copy.description} />
	<meta property="og:type" content="website" />
	<meta property="og:url" content="https://huuloc.com/" />
	<meta name="ai-content-declaration" content="site-code:ai-generated; content:human-written" />
	<meta name="generator" content="Astro + Claude Code" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;590;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
	<details class="lang-toggle">
		<summary>{isVi ? "VI" : "EN"} <span class="arrow">▾</span></summary>
		<div class="lang-menu">
			<a href="#" class="lang-item" data-switch-lang="vi" data-active={isVi}>Tiếng Việt</a>
			<a href="#" class="lang-item" data-switch-lang="en" data-active={!isVi}>English</a>
		</div>
	</details>

	<main class="page">
		{/* ── Masthead hero ───────────────────────────────────────── */}
		<header class="masthead">
			<div class="rule">
				<span>Vol. {new Date().getFullYear() - 2005} · No. {String(new Date().getMonth() + 1).padStart(2, "0")}</span>
				<span class="rule-mid">
					<svg width="12" height="12" viewBox="0 0 32 32" aria-hidden="true">
						<path d="M16 28 C16 22 15 18 16 13" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" />
						<path d="M16 15 C13 13 9 10 8 5 C13 6 16 11 16 15" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" />
						<path d="M16 11 C19 9 23 6 24 2 C19 3 16 7 16 11" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
					huuloc.com
				</span>
				<span>{new Date().toLocaleDateString(isVi ? "vi-VN" : "en-US", { month: "long", year: "numeric" })}</span>
			</div>
			<h1 class="name">Trương <em>Hữu</em> Lộc</h1>
			<div class="lede">
				<p class="tagline">{copy.tagline}</p>
				<p class="bio">
					{copy.bio}<a href="https://papaya.asia" rel="noopener">Papaya</a>{copy.bioRest}
				</p>
			</div>
		</header>

		{/* ── Featured Pensieve ───────────────────────────────────── */}
		<section class="featured" style="--accent: #9b8cff;">
			<div class="section-rule">
				<span class="section-tag">{copy.featuredLabel}</span>
				<span class="hairline" />
			</div>
			<div class="featured-card">
				<div>
					<h2 class="featured-title">
						<svg width="22" height="22" viewBox="0 0 32 32" aria-hidden="true">
							<ellipse cx="16" cy="10.5" rx="11" ry="2.75" fill="none" stroke="var(--accent)" stroke-width="2.25" stroke-linejoin="round" />
							<path d="M5 10.5 L5 14 C5 20.5 9.5 25 16 25 C22.5 25 27 20.5 27 14 L27 10.5" fill="none" stroke="var(--accent)" stroke-width="2.25" stroke-linejoin="round" />
							<ellipse cx="16" cy="10.5" rx="4.5" ry="1.1" fill="var(--accent)" />
						</svg>
						{copy.pensieveTitle}
					</h2>
					<div class="featured-meta">{copy.pensieveMeta}</div>
					<p class="featured-desc">{copy.pensieveDesc}</p>
					<a href="/pensieve/" class="featured-cta">{copy.readAll} →</a>
				</div>
				{latest.length > 0 && (
					<div class="latest">
						<div class="latest-head">{copy.latestLabel}</div>
						{latest.map((e, i) => (
							<a href={link(`pensieve/memories/${e.id}`)} class="latest-row">
								<span class="latest-num">{String(i + 1).padStart(3, "0")}</span>
								<span class="latest-title">{e.title}</span>
								<span class="latest-date">{fmtDate(e.date)}</span>
							</a>
						))}
					</div>
				)}
			</div>
		</section>

		{/* ── Other sections ──────────────────────────────────────── */}
		{sections.map((sec) => (
			<section class="section">
				<div class="section-rule">
					<h2 class="section-label">{sec.label}</h2>
					<span class="section-sub">{sec.sub}</span>
					<span class="hairline" />
				</div>
				<div class="rows">
					{sec.items.map((it) => {
						const num = String(runningNum++).padStart(2, "0");
						const Tag = it.href ? "a" : "span";
						return (
							<Tag
								href={it.href ?? undefined}
								class:list={["row", { coming: it.coming, "row-quidditch": it.iconKey === "snitch" }]}
								style={`--accent: ${it.accent};`}
							>
								<span class="row-num">{num}</span>
								<div class="row-body">
									<div class="row-head">
										<h3 class="row-name">
											<span class="row-icon" set:html={icon(it.iconKey)} />
											{it.name}
										</h3>
										<span class="row-meta">· {it.meta}</span>
									</div>
									<p class="row-desc">{it.desc}</p>
								</div>
								<span class="row-arrow">{it.coming ? copy.soonBadge : "→"}</span>
							</Tag>
						);
					})}
				</div>
			</section>
		))}

		{/* ── Footer — Subscribe + Colophon (Elsewhere lives on /Trương) ─ */}
		<footer class="foot">
			<div class="foot-col">
				<div class="foot-head">{copy.subscribe}</div>
				<div class="foot-links">
					<a href="/pensieve/rss-en.xml">RSS · EN</a>
					<a href="/pensieve/rss-vi.xml">RSS · VI</a>
					<a href="/pensieve/rss.xml">RSS · All</a>
				</div>
			</div>
			<div class="foot-col foot-colophon">
				<div class="foot-head">{copy.colophon}</div>
				<p class="foot-prose">{copy.colophonClaude}</p>
				<p class="foot-prose foot-stack">{copy.colophonStack}</p>
			</div>
			<div class="foot-end">
				© Trương Hữu Lộc · {new Date().getFullYear()}
			</div>
		</footer>
	</main>

	<SiteCat />
	<script>
		document.querySelectorAll<HTMLAnchorElement>("[data-switch-lang]").forEach((a) => {
			a.addEventListener("click", (e) => {
				e.preventDefault();
				const v = a.dataset.switchLang || "en";
				const secure = location.protocol === "https:" ? "; Secure" : "";
				document.cookie = `pref_lang=${v}; path=/; max-age=${3600 * 24 * 365}; SameSite=Lax${secure}`;
				location.reload();
			});
		});
	</script>
</body>
</html>

<style is:global>
	:root {
		--bg: #08090a;
		--elevated: #141516;
		--text: #f7f8f8;
		--secondary: #8a8f98;
		--muted: #62666d;
		--border: rgba(255,255,255,0.06);
		--accent: #5e6ad2;
		--sans: "Inter Tight", "Inter", -apple-system, BlinkMacSystemFont, "SF Pro Display", sans-serif;
		--mono: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
	}
	* { box-sizing: border-box; }
	html, body { margin: 0; padding: 0; }
	body {
		background: var(--bg);
		color: var(--text);
		font-family: var(--sans);
		font-size: 16px;
		line-height: 1.55;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}
</style>

<style>
	.lang-toggle { position: fixed; top: 1rem; right: 1rem; z-index: 10; font-family: var(--mono); font-size: .75rem; color: var(--muted); }
	.lang-toggle > summary { list-style: none; cursor: pointer; padding: .55rem .7rem; border: 1px solid var(--border); border-radius: 999px; background: var(--elevated); }
	.lang-toggle > summary::-webkit-details-marker { display: none; }
	.lang-menu { position: absolute; right: 0; margin-top: .25rem; background: var(--elevated); border: 1px solid var(--border); border-radius: 8px; padding: .25rem; min-width: 8rem; display: flex; flex-direction: column; }
	.lang-item { padding: .55rem .7rem; border-radius: 4px; text-decoration: none; color: var(--secondary); font-size: .85rem; }
	.lang-item:hover { background: rgba(255,255,255,.04); color: var(--text); }
	.lang-item[data-active="true"] { color: var(--text); font-weight: 500; }

	.page { max-width: 920px; margin: 0 auto; padding: clamp(3rem, 8vh, 5rem) 1.5rem 4rem; }

	/* Masthead */
	.masthead { margin-bottom: 4rem; }
	.rule {
		display: flex; justify-content: space-between; align-items: center; gap: 1rem;
