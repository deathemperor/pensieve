---
import { getEmDashCollection, getEntryTerms } from "emdash";
import Base from "../layouts/Base.astro";
import { getReadingTime } from "../utils/reading-time";
import { link } from "../utils/link";
import { categoryThemeMap, type ThemeSlug } from "../themes/categoryThemes";
import { themes, allThemes } from "../themes";

const { entries: posts, cacheHint } = await getEmDashCollection("posts");
Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

interface EnrichedPost {
	post: (typeof sortedPosts)[number];
	categorySlug: string | null;
	categoryLabel: string | null;
	themeSlug: ThemeSlug | null;
}

async function enrich(post: (typeof sortedPosts)[number]): Promise<EnrichedPost> {
	const cats = await getEntryTerms("posts", post.data.id, "category");
	const categorySlug = cats[0]?.slug ?? null;
	const themeSlug: ThemeSlug | null = categorySlug
		? (categoryThemeMap[categorySlug] ?? null)
		: null;
	return {
		post,
		categorySlug,
		categoryLabel: cats[0]?.label ?? null,
		themeSlug,
	};
}

const enriched = await Promise.all(sortedPosts.map(enrich));
const featured = enriched[0] ?? null;
const featuredTheme = featured?.themeSlug ? themes[featured.themeSlug] : null;

// Group all posts by category slug. Only include categories that have posts,
// and order by "latest post first" so the most-recently-active category floats up.
const groupsMap = new Map<
	string,
	{ slug: string; label: string; themeSlug: ThemeSlug; posts: EnrichedPost[]; latestTs: number }
>();

for (const e of enriched) {
	if (!e.categorySlug || !e.themeSlug) continue;
	const existing = groupsMap.get(e.categorySlug);
	const ts = e.post.data.publishedAt?.getTime() ?? 0;
	if (existing) {
		existing.posts.push(e);
		if (ts > existing.latestTs) existing.latestTs = ts;
	} else {
		groupsMap.set(e.categorySlug, {
			slug: e.categorySlug,
			label: e.categoryLabel ?? e.categorySlug,
			themeSlug: e.themeSlug,
			posts: [e],
			latestTs: ts,
		});
	}
}

const groups = Array.from(groupsMap.values()).sort(
	(a, b) => b.latestTs - a.latestTs,
);

// Category pills: include every category in the map (even empty ones),
// so the reader sees the full catalog. The themed strips below only render
// for categories that have content.
const pills = Object.entries(categoryThemeMap).map(([slug, themeSlug]) => {
	const t = themes[themeSlug];
	const count = groupsMap.get(slug)?.posts.length ?? 0;
	const label = slug
		.replace(/-/g, " ")
		.replace(/\b\w/g, (c) => c.toUpperCase());
	return { slug, label, theme: t, count };
});

function formatDate(date: Date | null | undefined) {
	if (!date) return null;
	return date.toLocaleDateString("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
}
---

<Base
	title="pensieve"
	description="long-form thoughts, one theme per topic"
	loadAllThemeFonts
>
	{
		!featured ? (
			<section class="empty-state">
				<h2>No posts yet</h2>
				<p>Create your first post in the admin panel.</p>
				<a href={link("_emdash/admin/content/posts/new")} class="btn">
					Create a post
				</a>
			</section>
		) : (
			<>
				{/* ========== THEMED HERO ========== */}
				<section
					class="hero"
					style={
						featuredTheme
							? `
								--hero-bg: ${featuredTheme.backgroundCSS ?? featuredTheme.palette.bg};
								--hero-text: ${featuredTheme.palette.text};
								--hero-secondary: ${featuredTheme.palette.textSecondary};
								--hero-muted: ${featuredTheme.palette.muted};
								--hero-accent: ${featuredTheme.palette.accent};
								--hero-font: ${featuredTheme.fonts.sans};
								--hero-display: ${featuredTheme.fonts.display ?? featuredTheme.fonts.sans};
							`
							: undefined
					}
				>
					<a href={link(`posts/${featured.post.id}`)} class="hero-link">
						<div class="hero-inner">
							<div class="hero-rule" />
							{featured.categoryLabel && (
								<span class="hero-category">{featured.categoryLabel}</span>
							)}
							<h1 class="hero-title">{featured.post.data.title}</h1>
							{featured.post.data.excerpt && (
								<p class="hero-excerpt">{featured.post.data.excerpt}</p>
							)}
							<div class="hero-meta">
								{featured.post.data.publishedAt && (
									<>
										<time>{formatDate(featured.post.data.publishedAt)}</time>
										<span class="hero-meta-dot" />
									</>
								)}
								<span>{getReadingTime(featured.post.data.content)} min read</span>
							</div>
						</div>
					</a>
				</section>

				{/* ========== CATEGORY PILLS ========== */}
				<section class="pills-section">
					<div class="pills-inner">
						{pills.map((p) => (
							<a
								href={link(`category/${p.slug}`)}
								class="pill"
								data-empty={p.count === 0}
								style={`
									--pill-accent: ${p.theme.palette.accent};
									--pill-font: ${p.theme.fonts.display ?? p.theme.fonts.sans};
								`}
							>
								<span class="pill-label">{p.label}</span>
								{p.count > 0 && <span class="pill-count">{p.count}</span>}
							</a>
						))}
					</div>
				</section>

				{/* ========== GROUPED SECTIONS ========== */}
				<div class="groups">
					{groups.map((g) => {
						const theme = themes[g.themeSlug];
						return (
							<section
								class="group"
								style={`
									--grp-accent: ${theme.palette.accent};
									--grp-bg: ${theme.palette.bgSubtle};
									--grp-text: ${theme.palette.text};
									--grp-display: ${theme.fonts.display ?? theme.fonts.sans};
									--grp-sans: ${theme.fonts.sans};
								`}
							>
								<header class="group-header">
									<div class="group-bar" />
									<div class="group-heading">
										<span class="group-category">{g.label}</span>
										<span class="group-tagline">{theme.tagline}</span>
									</div>
									<a href={link(`category/${g.slug}`)} class="group-link">
										View all ({g.posts.length}) →
									</a>
								</header>
								<ol class="group-posts">
									{g.posts.slice(0, 3).map((e) => (
										<li class="group-post">
											<a
												href={link(`posts/${e.post.id}`)}
												class="group-post-link"
											>
												<h3 class="group-post-title">
													{e.post.data.title}
												</h3>
												{e.post.data.excerpt && (
													<p class="group-post-excerpt">
														{e.post.data.excerpt}
													</p>
												)}
												<div class="group-post-meta">
													{e.post.data.publishedAt && (
														<time>
															{formatDate(e.post.data.publishedAt)}
														</time>
													)}
													<span class="group-post-dot" />
													<span>
														{getReadingTime(e.post.data.content)} min
													</span>
												</div>
											</a>
										</li>
									))}
								</ol>
							</section>
						);
					})}
				</div>
			</>
		)
	}
</Base>

<style>
	/* ============ HERO ============ */
	.hero {
		--hero-bg: var(--color-bg-subtle);
		--hero-text: var(--color-text);
		--hero-secondary: var(--color-text-secondary);
		--hero-muted: var(--color-muted);
		--hero-accent: var(--color-accent);
		--hero-font: var(--font-sans);
		--hero-display: var(--font-sans);
		background: var(--hero-bg);
		color: var(--hero-text);
		font-family: var(--hero-font);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.hero-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.hero-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-24) var(--spacing-8) var(--spacing-20);
	}

	.hero-rule {
		width: var(--spacing-16);
		height: 4px;
		background: var(--hero-accent);
		margin-bottom: var(--spacing-8);
	}

	.hero-category {
		display: inline-block;
		font-family: var(--hero-display);
		font-size: var(--font-size-sm);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--hero-accent);
		margin-bottom: var(--spacing-6);
	}

	.hero-title {
		font-family: var(--hero-display);
		font-size: clamp(1.75rem, 4.5vw, 3.75rem);
		font-weight: 700;
		line-height: 1.1;
		letter-spacing: -0.015em;
		margin: 0 0 var(--spacing-8);
		color: var(--hero-text);
		max-width: 18ch;
		transition: color var(--transition-fast);
		overflow-wrap: break-word;
		word-wrap: break-word;
		hyphens: auto;
	}

	.hero-link:hover .hero-title {
		color: var(--hero-accent);
	}

	.hero-excerpt {
		font-family: var(--hero-font);
		font-size: clamp(var(--font-size-lg), 2vw, var(--font-size-2xl));
		line-height: 1.55;
		color: var(--hero-secondary);
		margin: 0 0 var(--spacing-8);
		max-width: 62ch;
	}

	.hero-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-3);
		font-size: var(--font-size-sm);
		color: var(--hero-muted);
	}

	.hero-meta-dot {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--hero-muted);
	}

	/* ============ PILLS ============ */
	.pills-section {
		background: var(--color-bg);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.pills-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-6) var(--spacing-8);
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
	}

	.pill {
		--pill-accent: var(--color-accent);
		--pill-font: var(--font-sans);
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-2);
		padding: var(--spacing-2) var(--spacing-4);
		font-family: var(--pill-font);
		font-size: var(--font-size-sm);
		font-weight: 600;
		color: var(--pill-accent);
		background: color-mix(in srgb, var(--pill-accent) 12%, transparent);
		border: 1px solid color-mix(in srgb, var(--pill-accent) 28%, transparent);
		border-radius: 999px;
		text-decoration: none;
		letter-spacing: 0.02em;
		transition:
			background var(--transition-fast),
			border-color var(--transition-fast),
			transform var(--transition-fast);
	}

	.pill:hover {
		background: color-mix(in srgb, var(--pill-accent) 22%, transparent);
		border-color: var(--pill-accent);
		transform: translateY(-1px);
	}

	.pill[data-empty="true"] {
		opacity: 0.45;
	}

	.pill-count {
		font-size: var(--font-size-xs);
		font-weight: 500;
		padding: 0 var(--spacing-2);
		background: color-mix(in srgb, var(--pill-accent) 20%, transparent);
		border-radius: 999px;
	}

	/* ============ GROUPS ============ */
	.groups {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-8) var(--spacing-24);
		display: flex;
		flex-direction: column;
		gap: var(--spacing-16);
	}

	.group {
		--grp-accent: var(--color-accent);
		--grp-bg: var(--color-bg-subtle);
		--grp-text: var(--color-text);
		--grp-display: var(--font-sans);
		--grp-sans: var(--font-sans);
		background: var(--grp-bg);
		color: var(--grp-text);
		font-family: var(--grp-sans);
		border-radius: var(--radius-lg);
		padding: var(--spacing-10) var(--spacing-10) var(--spacing-8);
		position: relative;
	}

	.group-header {
		display: grid;
		grid-template-columns: auto 1fr auto;
		gap: var(--spacing-4);
		align-items: baseline;
		margin-bottom: var(--spacing-8);
		padding-bottom: var(--spacing-6);
		border-bottom: 1px solid color-mix(in srgb, var(--grp-accent) 25%, transparent);
	}

	.group-bar {
		width: 4px;
		height: var(--spacing-10);
		background: var(--grp-accent);
		align-self: center;
	}

	.group-heading {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-1);
		min-width: 0;
	}

	.group-category {
		font-family: var(--grp-display);
		font-size: var(--font-size-2xl);
		font-weight: 700;
		color: var(--grp-accent);
		letter-spacing: -0.01em;
	}

	.group-tagline {
		font-family: var(--grp-sans);
		font-size: var(--font-size-sm);
		color: color-mix(in srgb, var(--grp-text) 60%, transparent);
		font-style: italic;
	}

	.group-link {
		font-size: var(--font-size-sm);
		color: var(--grp-accent);
		text-decoration: none;
		font-weight: 500;
		white-space: nowrap;
		transition: opacity var(--transition-fast);
	}

	.group-link:hover {
		opacity: 0.7;
	}

	.group-posts {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--spacing-6);
	}

	.group-post {
		padding-bottom: var(--spacing-6);
		border-bottom: 1px solid color-mix(in srgb, var(--grp-accent) 15%, transparent);
	}

	.group-post:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.group-post-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.group-post-title {
		font-family: var(--grp-display);
		font-size: var(--font-size-xl);
		font-weight: 600;
		line-height: 1.3;
		margin: 0 0 var(--spacing-2);
		color: var(--grp-text);
		transition: color var(--transition-fast);
	}

	.group-post-link:hover .group-post-title {
		color: var(--grp-accent);
	}

	.group-post-excerpt {
		font-family: var(--grp-sans);
		font-size: var(--font-size-base);
		line-height: 1.6;
		color: color-mix(in srgb, var(--grp-text) 75%, transparent);
		margin: 0 0 var(--spacing-2);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.group-post-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-2);
		font-size: var(--font-size-xs);
		color: color-mix(in srgb, var(--grp-text) 55%, transparent);
		font-family: var(--font-mono);
	}

	.group-post-dot {
		width: 2px;
		height: 2px;
		border-radius: 50%;
		background: currentColor;
	}

	/* ============ EMPTY STATE ============ */
	.empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-3);
		text-align: center;
		padding: var(--spacing-20) var(--spacing-6);
		max-width: 400px;
		margin: 0 auto;
	}

	.empty-state h2 {
		font-size: var(--font-size-2xl);
		font-weight: 600;
	}

	.empty-state p {
		color: var(--color-muted);
	}

	.btn {
		display: inline-block;
		margin-top: var(--spacing-4);
		padding: var(--spacing-3) var(--spacing-6);
		background: var(--color-accent);
		color: var(--color-on-accent);
		text-decoration: none;
		border-radius: var(--radius);
		font-size: var(--font-size-sm);
		font-weight: 500;
	}

	/* ============ RESPONSIVE ============ */
	@media (max-width: 900px) {
		.hero-inner {
			padding: var(--spacing-16) var(--spacing-6) var(--spacing-12);
		}

		.group {
			padding: var(--spacing-8) var(--spacing-6) var(--spacing-6);
		}

		.group-header {
			grid-template-columns: auto 1fr;
		}

		.group-link {
			grid-column: 1 / -1;
			padding-top: var(--spacing-2);
		}

		.groups {
			padding: var(--spacing-12) var(--spacing-4) var(--spacing-16);
			gap: var(--spacing-8);
		}

		.pills-inner {
			padding: var(--spacing-4) var(--spacing-5);
		}
	}

	@media (max-width: 600px) {
		.hero-inner {
			padding: var(--spacing-10) var(--spacing-5) var(--spacing-10);
		}

		.hero-title {
			font-size: clamp(1.5rem, 7vw, 2.25rem);
			max-width: 100%;
		}

		.hero-excerpt {
			font-size: var(--font-size-base);
		}
	}
</style>
