---
// src/components/hol/ThreadRow.astro
import type { Thread } from "../../lib/hol/types";
interface Props { thread: Thread; }
const { thread } = Astro.props;
const href = `/hol/t/${thread.id}-${thread.title_slug}/`;
// SQLite returns 0/1 for boolean; JSX renders 0 as text. Coerce to real bool.
const isSticky = thread.is_sticky === true || thread.is_sticky === 1;
const isLocked = thread.is_locked === true || thread.is_locked === 1;
const posts = thread.post_count ?? thread.reply_count ?? 0;
const last = thread.last_post_at
  ? new Date(thread.last_post_at * 1000).toISOString().slice(0, 10)
  : null;
---
<a class="hol-thread-row" href={href}>
  <div class="hol-thread-main">
    <h3 class="hol-thread-title">
      {isSticky && <span class="hol-badge hol-badge-sticky" title="sticky">Ghim</span>}
      {isLocked && <span class="hol-badge hol-badge-locked" title="locked">Khóa</span>}
      <span class="hol-thread-text">{thread.title}</span>
    </h3>
  </div>
  <div class="hol-thread-stats" aria-label="thread stats">
    <span class="hol-thread-posts">
      <span class="num">{posts.toLocaleString()}</span>
      <span class="unit">{posts === 1 ? "post" : "posts"}</span>
    </span>
    {last && <time class="hol-thread-date" datetime={last}>{last}</time>}
  </div>
</a>
