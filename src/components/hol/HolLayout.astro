---
// src/components/hol/HolLayout.astro
//
// /hol/* pages render inside pensieve's main Base layout so the site
// header / favicon / nav / footer all come from Base. HOL-specific
// classes live in /hol-archive.css which we inject via Base's head slot.
import Base from "../../layouts/Base.astro";

interface Props {
  title: string;
  crumbs?: { label: string; href?: string }[];
}
const { title, crumbs = [] } = Astro.props;

const breadcrumbs = [
  { label: "HOL Archive", href: "/hol/" },
  ...crumbs,
];
---
<Base
  title={title}
  description="HOL — holvn.org forum archive reconstructed from Internet Archive snapshots."
  robots="noindex, nofollow"
  breadcrumbs={breadcrumbs}
>
  <link slot="head" rel="stylesheet" href="/hol-archive.css" />
  <div class="hol-local-nav">
    <form class="hol-header-search" method="get" action="/hol/search/" role="search">
      <input type="search" name="q" placeholder="Tìm kiếm trong HOL…" aria-label="Tìm kiếm" />
      <button type="submit" aria-label="Search">
        <svg width="14" height="14" viewBox="0 0 16 16" aria-hidden="true">
          <circle cx="7" cy="7" r="4.5" fill="none" stroke="currentColor" stroke-width="1.75" />
          <path d="M10.5 10.5 L14 14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
        </svg>
      </button>
    </form>
    <a href="/hol/about/" class="hol-local-nav-link">Giới thiệu</a>
  </div>
  <main class="hol-main">
    <slot />
  </main>
</Base>
