---
// src/components/hol/HolLayout.astro
//
// Shared shell for every /hol/* page. Adds robots meta, breadcrumb hint,
// and a tight container. Intentionally minimal — wraps whatever the
// pensieve root layout would render. (Pensieve does NOT have a forced
// site-wide layout; individual pages set their own.)
interface Props {
  title: string;
  crumbs?: { label: string; href?: string }[];
}
const { title, crumbs = [] } = Astro.props;
---
<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — HOL Archive</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="stylesheet" href="/hol-archive.css" />
  </head>
  <body>
    <header class="hol-header">
      <a href="/hol/"><strong>HOL Archive</strong></a>
      <nav aria-label="Breadcrumb" class="hol-crumbs">
        {crumbs.map((c, i) => (
          <>
            {i > 0 && <span aria-hidden="true"> › </span>}
            {c.href ? <a href={c.href}>{c.label}</a> : <span>{c.label}</span>}
          </>
        ))}
      </nav>
    </header>
    <main class="hol-main">
      <slot />
    </main>
    <footer class="hol-footer">
      <a href="/hol/about/">About this archive</a>
      <span> · </span>
      <a href="/hol/search/">Search</a>
    </footer>
  </body>
</html>
