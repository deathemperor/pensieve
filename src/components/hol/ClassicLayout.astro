---
// src/components/hol/ClassicLayout.astro
//
// vBulletin 3 Darkleaf view. Wraps pensieve's Base (huuloc.com site
// header + favicon — non-negotiable per user directive: "same header as
// mainsite, always") and inside the main slot reconstructs the 764px
// Darkleaf canvas: blue banner, nav button row, tborder/tcat/alt1/alt2
// table markup, postbit, classic pager.
//
// Crumbs are rendered inside the vB3 navbar (their own chrome), NOT in
// Base's breadcrumbs — otherwise users see two breadcrumb trails.
// Base.breadcrumbs still gets the crumbs so the <title> + schema.org
// metadata stay right; we just hide Base's visual trail via CSS below.
import Base from "../../layouts/Base.astro";

interface Props {
  title: string;
  crumbs?: { label: string; href?: string }[];
  modernHref?: string;  // "Modern view" toggle target (optional)
}
const { title, crumbs = [], modernHref } = Astro.props;

const rootCrumb = { label: "HOL", href: "/hol/classic/" };
const fullCrumbs = [rootCrumb, ...crumbs];
---
<Base
  title={title}
  description="HOL — holvn.org forum archive in its original vBulletin 3 Darkleaf theme."
  robots="noindex, nofollow"
  breadcrumbs={[{ label: "HOL Archive", href: "/hol/" }, { label: "Classic view" }, ...crumbs]}
>
  <link rel="stylesheet" href="/hol-archive.css" />
  <link rel="stylesheet" href="/hol-classic.css" />

  <div class="hol-classic">
    <div class="hol-classic-canvas">
      <div class="hol-classic-page">
        <!-- top strip: quick links + vB-style search form (matches the
             original holvn.org header which always sat a Search input
             directly in the nav). Points at /hol/search/ — the modern
             search page; vB3 theme here is pure presentation. -->
        <div class="hol-classic-topstrip">
          <form class="hol-classic-search" method="get" action="/hol/search/" role="search">
            <input type="search" name="q" placeholder="Tìm kiếm…" aria-label="Search HOL" />
            <button type="submit">Search</button>
          </form>
          <span class="hol-classic-toplinks">
            <a href="/hol/classic/">Home</a>&nbsp;|&nbsp;
            <a href="/hol/classic/">Forum</a>&nbsp;|&nbsp;
            <a href="/hol/classic/members/">Members</a>&nbsp;|&nbsp;
            <a href="/hol/about/">About</a>
          </span>
        </div>

        <!-- banner: authentic holvn logo.gif (363×46) + rightbanner.gif
             (403×46) on bannerbg.gif tile, exactly as captured from
             Wayback 2007. -->
        <div class="hol-classic-banner">
          <a href="/hol/classic/" class="hol-classic-logo-img">
            <img
              src="/hol-assets/darkleaf/misc/logo.gif"
              alt="Home Online Community"
              width="363"
              height="46"
            />
          </a>
          <img
            class="hol-classic-rightbanner"
            src="/hol-assets/darkleaf/misc/rightbanner.gif"
            width="403"
            height="46"
            alt=""
            aria-hidden="true"
          />
        </div>

        <!-- slogan strip: topbg.gif repeat-x with authentic slogan.gif -->
        <div class="hol-classic-sloganrow">
          <img
            src="/hol-assets/darkleaf/misc/slogan.gif"
            width="217"
            height="33"
            alt="holvn.org — archived forum"
          />
        </div>

        <!-- nav buttons: real 34px-tall Darkleaf gifs over navbg.gif
             tile. Original skin had Arcade/Jukebox/Register/Shop too —
             omitted here since this is read-only. Only Members + Search
             are real clickable gifs; About + Modern view are text. -->
        <div class="hol-classic-navrow">
          <a href="/hol/classic/members/" title="Members List">
            <img src="/hol-assets/darkleaf/buttons/nav_members.gif" alt="Members" height="34" />
          </a>
          <a href="/hol/search/" title="Search">
            <img src="/hol-assets/darkleaf/buttons/nav_search.gif" alt="Search" height="34" />
          </a>
          <a href="/hol/about/" class="nav-text" title="Giới thiệu">About</a>
          {modernHref && <a href={modernHref} class="nav-text" title="Switch to modern view">Modern view →</a>}
          {!modernHref && <a href="/hol/" class="nav-text" title="Switch to modern view">Modern view →</a>}
        </div>

        <div class="hol-classic-sep"></div>

        <!-- content -->
        <div class="hol-classic-content">
          <!-- breadcrumb (vB3 navbar table) -->
          <table class="tborder" cellpadding="6" cellspacing="1">
            <tr>
              <td class="alt1">
                <span class="navbar">
                  {fullCrumbs.map((c, i) => (
                    <>
                      {i > 0 && <> &gt; </>}
                      {c.href && i < fullCrumbs.length - 1
                        ? <a href={c.href}>{c.label}</a>
                        : <span class={i === fullCrumbs.length - 1 ? "navbar-strong" : ""}>{c.label}</span>}
                    </>
                  ))}
                </span>
              </td>
            </tr>
          </table>

          <slot />

          <p class="hol-classic-note">
            Đây là bản sao chỉ-đọc tái tạo từ Internet Archive (Wayback Machine).
            Không còn đăng ký, đăng nhập, hay đăng bài mới.
          </p>
        </div>

        <div class="hol-classic-sep"></div>
      </div>
    </div>
  </div>
</Base>
