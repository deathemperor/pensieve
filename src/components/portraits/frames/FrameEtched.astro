---
interface Props {
  size?: number
}

const { size = 140 } = Astro.props;
---

<svg
  class="frame frame-etched"
  width={size}
  height={size}
  viewBox="0 0 100 100"
  preserveAspectRatio="none"
  aria-hidden="true"
>
  <rect
    x="1"
    y="1"
    width="98"
    height="98"
    rx="1"
    fill="none"
    stroke="#555"
    stroke-width="0.6"
    stroke-dasharray="1.5 1"
    opacity="0.8"
  />
</svg>

<style>
  .frame-etched {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
</style>
