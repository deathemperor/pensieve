---
import type { MediaValue, ContentBylineCredit } from "emdash";
import { Image } from "emdash/ui";
import { link } from "../utils/link";
import { themes, type ThemeSlug } from "../themes";

interface Props {
	title: string;
	excerpt?: string;
	featuredImage?: MediaValue | string;
	href: string;
	date?: Date;
	readingTime?: number;
	tags?: Array<{ slug: string; label: string }>;
	bylines?: ContentBylineCredit[];
	themeSlug?: ThemeSlug | null;
	categoryLabel?: string | null;
}

const {
	title,
	excerpt,
	featuredImage,
	href,
	date,
	readingTime,
	tags,
	bylines,
	themeSlug,
	categoryLabel,
} = Astro.props;

const theme = themeSlug ? themes[themeSlug] : null;
const accent = theme?.palette.accent;

const formattedDate = date
	? date.toLocaleDateString("en-US", {
			year: "numeric",
			month: "short",
			day: "numeric",
		})
	: null;

const cardStyle = accent ? `--card-accent: ${accent};` : undefined;
---

<article class="post-card" style={cardStyle} data-theme={themeSlug ?? undefined}>
	<a href={href} class="card-link">
		{featuredImage && (
			<div class="card-image">
				<Image image={featuredImage} />
			</div>
		)}
		<div class="card-body">
			{categoryLabel && (
				<span class="card-category">
					<span class="card-category-dot" />
					{categoryLabel}
				</span>
			)}
			<h2 class="card-title">{title}</h2>
			{excerpt && <p class="card-excerpt">{excerpt}</p>}
			<div class="card-meta">
				{formattedDate && <time>{formattedDate}</time>}
				{formattedDate && readingTime && <span class="card-meta-dot" />}
				{readingTime && <span>{readingTime} min</span>}
			</div>
		</div>
	</a>
</article>

<style>
	.post-card {
		--card-accent: var(--color-accent);
		background: var(--color-surface-elevated);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		transition:
			border-color var(--transition-fast),
			transform var(--transition-fast);
	}

	.post-card:hover {
		border-color: color-mix(in srgb, var(--card-accent) 50%, var(--color-border));
		transform: translateY(-1px);
	}

	.card-link {
		display: block;
		text-decoration: none;
		color: inherit;
		padding: var(--spacing-5);
	}

	.card-image {
		aspect-ratio: 16 / 10;
		overflow: hidden;
		border-radius: var(--radius);
		background: var(--color-surface);
		margin-bottom: var(--spacing-4);
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.card-body {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
	}

	.card-category {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-2);
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 500;
		color: var(--color-text-secondary);
	}

	.card-category-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--card-accent);
	}

	.card-title {
		font-family: var(--font-display);
		font-size: var(--font-size-base);
		font-weight: var(--font-weight-display, 590);
		line-height: 1.35;
		letter-spacing: -0.011em;
		margin: 0;
		color: var(--color-text);
		transition: color var(--transition-fast);
	}

	.post-card:hover .card-title {
		color: var(--color-text-secondary);
	}

	.card-excerpt {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-2);
		margin-top: var(--spacing-2);
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	.card-meta-dot {
		width: 2px;
		height: 2px;
		border-radius: 50%;
		background: currentColor;
	}
</style>
