---
import {
	projectLatLng,
	graticuleLngs,
	graticuleLats,
	DEFAULT_ATLAS_BOUNDS,
} from "../../utils/atlasGeometry";
import { getChronicleCategory } from "../../themes/chronicleCategories";
import { getCurrentLang } from "../../utils/lang";
import visitedCitiesData from "../../data/visited-cities.json";

interface Props {
	entries: any[];
}

const { entries } = Astro.props as Props;
const lang = getCurrentLang(Astro);
const isVi = lang === "vi";

interface VisitedCell {
	id: string;
	lat: number;
	lng: number;
	places: number;
	visits: number;
	firstDate: string;
	lastDate: string;
	city: string | null;
	country: string | null;
	display: string | null;
}

const visitedCities: VisitedCell[] = (visitedCitiesData as { cells?: VisitedCell[] }).cells ?? [];

interface PlacedEntry {
	id: string;
	title: string;
	locationName: string;
	country: string;
	category: string;
	hex: string;
	x: number;
	y: number;
}

const bounds = DEFAULT_ATLAS_BOUNDS;
const viewport = { widthPx: 1000, heightPx: 450 };

const placed: PlacedEntry[] = [];
const unplaced: { id: string; title: string }[] = [];

for (const e of entries) {
	const rawLoc = e.data.location;
	const cat = getChronicleCategory(e.data.category);
	const title = (isVi ? e.data.title_vi : e.data.title_en) ?? e.data.title ?? "";
	if (!rawLoc) {
		unplaced.push({ id: e.id, title });
		continue;
	}
	let parsed: { name?: string; city?: string; country?: string; lat?: number; lng?: number };
	try {
		parsed = typeof rawLoc === "string" ? JSON.parse(rawLoc) : rawLoc;
	} catch {
		unplaced.push({ id: e.id, title });
		continue;
	}
	if (typeof parsed.lat !== "number" || typeof parsed.lng !== "number") {
		unplaced.push({ id: e.id, title });
		continue;
	}
	const { x, y } = projectLatLng(
		{ lat: parsed.lat, lng: parsed.lng },
		bounds,
		viewport,
	);
	placed.push({
		id: e.id,
		title,
		locationName: parsed.name ?? parsed.city ?? "",
		country: parsed.country ?? "",
		category: cat.slug,
		hex: cat.hex,
		x,
		y,
	});
}

// Fan pins that share the same projected point (e.g. 4 pins at HCMC) so
// they don't stack invisibly. Offset in a small circle around the center.
const coordBuckets = new Map<string, PlacedEntry[]>();
for (const p of placed) {
	const key = `${Math.round(p.x)}_${Math.round(p.y)}`;
	const bucket = coordBuckets.get(key) || [];
	bucket.push(p);
	coordBuckets.set(key, bucket);
}
for (const bucket of coordBuckets.values()) {
	if (bucket.length <= 1) continue;
	const radius = 14;
	bucket.forEach((pin, i) => {
		const angle = (i / bucket.length) * Math.PI * 2 - Math.PI / 2;
		pin.x += Math.cos(angle) * radius;
		pin.y += Math.sin(angle) * radius;
	});
}

// Pick one representative pin per unique country to label on the canvas.
const countryLabelPoints = new Map<string, { x: number; y: number }>();
for (const p of placed) {
	if (!p.country) continue;
	if (!countryLabelPoints.has(p.country)) {
		countryLabelPoints.set(p.country, { x: p.x, y: p.y });
	}
}

const countryLongName: Record<string, string> = {
	GB: "United Kingdom",
	VN: "Việt Nam",
	US: "United States",
	JP: "Japan",
	FR: "France",
	DE: "Germany",
	IT: "Italy",
	SG: "Singapore",
	KR: "South Korea",
	TH: "Thailand",
};

const lngLines = graticuleLngs(bounds, 30);
const latLines = graticuleLats(bounds, 30);

// Group placed by country for the side list.
const byCountry = new Map<string, PlacedEntry[]>();
for (const p of placed) {
	const list = byCountry.get(p.country) || [];
	list.push(p);
	byCountry.set(p.country, list);
}
const countryGroups = [...byCountry.entries()].sort(([a], [b]) => a.localeCompare(b));

const heading = isVi ? "Bản đồ — những nơi đã đi qua" : "Atlas — places on the map";
const helperText = isVi
	? "Mỗi chấm là một sự kiện có toạ độ. Bấm để mở chi tiết."
	: "Each dot is a located event. Click to open the memory.";
---

<section class="cc-atlas" aria-labelledby="cc-atlas-heading">
	<header class="cc-atlas-header">
		<h2 id="cc-atlas-heading">{heading}</h2>
		<p class="cc-atlas-helper">{helperText}</p>
	</header>

	<div class="cc-atlas-body">
		<div class="cc-atlas-canvas-wrap">
			<svg
				class="cc-atlas-canvas"
				viewBox={`0 0 ${viewport.widthPx} ${viewport.heightPx}`}
				role="img"
				aria-label={heading}
				preserveAspectRatio="xMidYMid meet"
			>
				{lngLines.map((l) => {
					const { x } = projectLatLng({ lat: 0, lng: l }, bounds, viewport);
					return (
						<line
							x1={x}
							x2={x}
							y1={0}
							y2={viewport.heightPx}
							stroke="rgba(212,168,67,0.1)"
							stroke-width="0.5"
							stroke-dasharray="2 4"
						/>
					);
				})}
				{latLines.map((l) => {
					const { y } = projectLatLng({ lat: l, lng: 0 }, bounds, viewport);
					return (
						<line
							x1={0}
							x2={viewport.widthPx}
							y1={y}
							y2={y}
							stroke="rgba(212,168,67,0.1)"
							stroke-width="0.5"
							stroke-dasharray="2 4"
						/>
					);
				})}
				{visitedCities.map((vc) => {
					const pt = projectLatLng({ lat: vc.lat, lng: vc.lng }, bounds, viewport);
					// Radius scales with visits — log-ish so one mega-city doesn't drown small ones.
					const r = Math.max(4, Math.min(28, Math.sqrt(vc.visits) * 1.6));
					const title = vc.city
						? `${vc.city}${vc.country ? ", " + vc.country : ""} — ${vc.visits} visit${vc.visits === 1 ? "" : "s"} across ${vc.places} place${vc.places === 1 ? "" : "s"}`
						: `${vc.lat},${vc.lng} — ${vc.visits} visit${vc.visits === 1 ? "" : "s"}`;
					return (
						<g class="cc-atlas-city" data-city-id={vc.id} transform={`translate(${pt.x} ${pt.y})`}>
							<circle r={r} fill="rgba(42, 161, 152, 0.14)" stroke="rgba(42, 161, 152, 0.35)" stroke-width="0.5" />
							<title>{title}</title>
						</g>
					);
				})}
				{[...countryLabelPoints.entries()].map(([code, pt]) => (
					<text
						class="cc-atlas-country-label"
						x={pt.x}
						y={pt.y - 28}
						text-anchor="middle"
					>{countryLongName[code] ?? code}</text>
				))}
				{placed.map((p) => (
					<g class="cc-atlas-pin" data-id={p.id} transform={`translate(${p.x} ${p.y})`}>
						<circle r="10" fill={p.hex} opacity="0.15" />
						<circle r="5" fill={p.hex} />
						<title>{p.locationName} — {p.title}</title>
					</g>
				))}
			</svg>
		</div>

		<aside class="cc-atlas-list">
			{countryGroups.length === 0 && (
				<p class="cc-atlas-empty">{isVi ? "Chưa có địa điểm nào." : "No located events yet."}</p>
			)}
			{countryGroups.map(([country, list]) => (
				<div class="cc-atlas-country">
					<h3>{country}</h3>
					<ul>
						{list.map((p) => (
							<li class="cc-atlas-place" data-id={p.id} data-category={p.category}>
								<span class="cc-atlas-place-dot" style={`background:${p.hex};`}></span>
								<span class="cc-atlas-place-name">{p.locationName}</span>
								<span class="cc-atlas-place-title">{p.title}</span>
							</li>
						))}
					</ul>
				</div>
			))}
			{visitedCities.length > 0 && (
				<div class="cc-atlas-cities">
					<h3>{isVi ? "Thành phố ghé qua" : "Cities visited"}</h3>
					<ul>
						{visitedCities.slice(0, 20).map((vc) => (
							<li class="cc-atlas-city-row">
								<span class="cc-atlas-city-name">{vc.city ?? `${vc.lat}, ${vc.lng}`}</span>
								<span class="cc-atlas-city-country">{vc.country ?? ""}</span>
								<span class="cc-atlas-city-count">{vc.visits}×</span>
							</li>
						))}
					</ul>
					{visitedCities.length > 20 && (
						<p class="cc-atlas-cities-more">
							{isVi
								? `… và ${visitedCities.length - 20} thành phố khác`
								: `… and ${visitedCities.length - 20} more`}
						</p>
					)}
				</div>
			)}
		</aside>
	</div>

	{unplaced.length > 0 && (
		<footer class="cc-atlas-footer">
			<small>
				{isVi ? "Chưa định vị:" : "No location yet:"} {unplaced.map((u) => u.title).join(" · ")}
			</small>
		</footer>
	)}
</section>
