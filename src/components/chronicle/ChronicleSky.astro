---
import { parseChronicleDate } from "../../utils/chronicleDate";
import { monthToAngleDeg, ringRadiusForYear, fanCluster } from "../../utils/chronicleGeometry";
import { getChronicleCategory } from "../../themes/chronicleCategories";
import { getCurrentLang } from "../../utils/lang";

interface Props {
  entries: any[];
}

const { entries } = Astro.props as Props;
const lang = getCurrentLang(Astro);
const isVi = lang === "vi";

const parsedEntries = entries.map((e) => {
  const p = parseChronicleDate({
    event_date: e.data.event_date,
    date_precision: e.data.date_precision,
  });
  return { id: e.id, entry: e, parsed: p };
});

const populatedYears = [...new Set(parsedEntries.map((e) => e.parsed.year))]
  .sort((a, b) => a - b);

const scale = { innerPx: 70, outerPx: 210 };

const placements = parsedEntries.map((p) => {
  const radius = ringRadiusForYear(p.parsed.year, populatedYears, scale);
  const angleDeg = monthToAngleDeg(p.parsed.month);
  // Year-precision stars land at 0deg (top of ring) by convention.
  return { id: p.id, entry: p.entry, year: p.parsed.year, radius, angle: angleDeg ?? 0 };
});

const fanned = fanCluster(
  placements.map((p) => ({ id: p.id, angle: p.angle })),
  { thresholdDeg: 4, fanDeg: 3 },
);
const fannedById = new Map(fanned.map((f) => [f.id, f.angle]));
const final = placements.map((p) => ({ ...p, angle: fannedById.get(p.id)! }));

function polar(radius: number, angleDeg: number) {
  // angle 0 = top (12 o'clock), clockwise.
  const rad = ((angleDeg - 90) * Math.PI) / 180;
  return {
    x: Math.cos(rad) * radius,
    y: Math.sin(rad) * radius,
  };
}
---

<div class="cc-sky" id="cc-sky">
  <div class="cc-stars"></div>

  {populatedYears.map((year) => {
    const r = ringRadiusForYear(year, populatedYears, scale);
    return (
      <Fragment>
        <div
          class="cc-ring"
          data-year={year}
          style={`width:${r * 2}px;height:${r * 2}px;`}
        ></div>
        <div
          class="year-tick"
          data-year={year}
          style={`left:50%;top:calc(50% - ${r}px);transform:translate(-50%,-50%);`}
        >{year}</div>
      </Fragment>
    );
  })}

  {(() => {
    // Thread lines — SVG overlay that draws segments between stars sharing
    // a thread name. Rendered inside cc-sky (positioned relative), so SVG
    // coordinates use the same center-relative space. Container is hidden
    // by default; chronicle-client toggles visibility on the "threads" button.
    const threadSegments: { ax: number; ay: number; bx: number; by: number; thread: string; hex: string }[] = [];
    const byThread = new Map<string, { x: number; y: number; hex: string }[]>();
    for (const p of final) {
      const { x, y } = polar(p.radius, p.angle);
      const threadsRaw = p.entry.data.thread;
      if (!threadsRaw) continue;
      const cat = getChronicleCategory(p.entry.data.category);
      const list = String(threadsRaw).split(",").map((s: string) => s.trim()).filter(Boolean);
      for (const t of list) {
        if (!byThread.has(t)) byThread.set(t, []);
        byThread.get(t)!.push({ x, y, hex: cat.hex });
      }
    }
    for (const [thread, pts] of byThread) {
      pts.sort((a, b) => a.x - b.x);
      for (let i = 0; i < pts.length - 1; i++) {
        threadSegments.push({
          ax: pts[i].x, ay: pts[i].y,
          bx: pts[i + 1].x, by: pts[i + 1].y,
          thread, hex: pts[i].hex,
        });
      }
    }
    return threadSegments.length > 0 ? (
      <svg class="cc-thread-layer" aria-hidden="true" style={`position:absolute;inset:0;width:100%;height:100%;pointer-events:none;overflow:visible;`}>
        {threadSegments.map((s) => (
          <line
            x1={`calc(50% + ${s.ax}px)`}
            y1={`calc(50% + ${s.ay}px)`}
            x2={`calc(50% + ${s.bx}px)`}
            y2={`calc(50% + ${s.by}px)`}
            stroke={s.hex}
            stroke-width="1"
            stroke-dasharray="3 4"
            opacity="0.6"
            data-thread={s.thread}
          />
        ))}
      </svg>
    ) : null;
  })()}

  {final.map((p) => {
    const { x, y } = polar(p.radius, p.angle);
    const cat = getChronicleCategory(p.entry.data.category);
    const title = p.entry.data.title_en ?? p.entry.data.title_vi ?? p.entry.data.title;
    return (
      <button
        class="cc-star"
        data-id={p.entry.id}
        data-category={cat.slug}
        data-thread={p.entry.data.thread ?? ""}
        style={`left:calc(50% + ${x}px);top:calc(50% + ${y}px);--star:${cat.hex};`}
        aria-label={isVi ? `Mở sự kiện: ${title}` : `Open event: ${title}`}
      >
        <span class="cc-star-label">{p.year}</span>
      </button>
    );
  })}
</div>
