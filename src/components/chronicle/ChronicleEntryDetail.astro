---
import { getCurrentLang } from "../../utils/lang";

const lang = getCurrentLang(Astro);
const isVi = lang === "vi";
---

<div class="cc-modal" id="cc-modal" role="dialog" aria-modal="true" aria-labelledby="cc-modal-title">
  <div class="cc-modal-body">
    <button class="cc-modal-close" aria-label={isVi ? "Đóng" : "Close"}>×</button>
    <h3 id="cc-modal-title" data-slot="title">—</h3>
    <div class="cc-modal-date" data-slot="date" style="color:var(--chronicle-gold);font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.08em;margin-bottom:10px;"></div>
    <em data-slot="subtitle" style="display:block;color:#8a8f98;font-size:13px;margin-bottom:14px;"></em>
    <div data-slot="location" style="display:none;font-size:12px;color:#8a8f98;margin-bottom:12px;"></div>
    <div data-slot="links" style="display:flex;flex-direction:column;gap:6px;font-size:12px;"></div>
  </div>
</div>
