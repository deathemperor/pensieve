---
import type { Theme } from "../themes/types";

interface Props {
	theme: Theme;
}

const { theme } = Astro.props;
const p = theme.palette;
// Site is always dark. darkPalette overrides win wherever provided; we fall
// back to palette for accent-level tokens which don't typically differ by mode.
const dp = theme.darkPalette ?? {};
const pick = <K extends keyof typeof p>(key: K): string =>
	(dp as Record<string, string | undefined>)[key as string] ?? (p[key] as string);

const vars = `
	--color-bg: ${pick("bg")};
	--color-bg-subtle: ${pick("bgSubtle")};
	--color-text: ${pick("text")};
	--color-text-secondary: ${pick("textSecondary")};
	--color-muted: ${pick("muted")};
	--color-border: ${pick("border")};
	--color-border-subtle: ${pick("borderSubtle")};
	--color-surface: ${pick("surface")};
	--color-accent: ${pick("accent")};
	--color-accent-hover: ${pick("accentHover")};
	--color-on-accent: ${pick("onAccent")};
	--font-sans: ${theme.fonts.sans};
	--font-mono: ${theme.fonts.mono};
`.trim();

const backgroundBlock = theme.backgroundCSS
	? `\nbody { background: ${theme.backgroundCSS} fixed; }`
	: "";

const css = `:root {\n\t${vars.replace(/\n/g, "\n\t")}\n}${backgroundBlock}`;
---

{theme.fonts.googleFontsHref && (
	<link rel="stylesheet" href={theme.fonts.googleFontsHref} />
)}
<style is:inline set:html={css}></style>
