---
import type { Theme } from "../themes/types";

interface Props {
	theme: Theme;
}

const { theme } = Astro.props;
const p = theme.palette;
const dp = theme.darkPalette ?? {};

const lightVars = `
	--color-bg: ${p.bg};
	--color-bg-subtle: ${p.bgSubtle};
	--color-text: ${p.text};
	--color-text-secondary: ${p.textSecondary};
	--color-muted: ${p.muted};
	--color-border: ${p.border};
	--color-border-subtle: ${p.borderSubtle};
	--color-surface: ${p.surface};
	--color-accent: ${p.accent};
	--color-accent-hover: ${p.accentHover};
	--color-on-accent: ${p.onAccent};
	--font-sans: ${theme.fonts.sans};
	--font-mono: ${theme.fonts.mono};
`.trim();

const darkEntries = Object.entries(dp)
	.map(([k, v]) => {
		const cssVar =
			k === "bgSubtle"
				? "--color-bg-subtle"
				: k === "textSecondary"
					? "--color-text-secondary"
					: k === "borderSubtle"
						? "--color-border-subtle"
						: k === "accentHover"
							? "--color-accent-hover"
							: k === "onAccent"
								? "--color-on-accent"
								: `--color-${k.replace(/([A-Z])/g, "-$1").toLowerCase()}`;
		return `${cssVar}: ${v};`;
	})
	.join("\n\t\t");

const darkBlock = darkEntries
	? `\n@media (prefers-color-scheme: dark) {\n\t:root:not(.light) {\n\t\t${darkEntries}\n\t}\n}\n:root.dark {\n\t${darkEntries}\n}`
	: "";

const backgroundBlock = theme.backgroundCSS
	? `\nbody { background: ${theme.backgroundCSS} fixed; }`
	: "";

const css = `:root {\n\t${lightVars.replace(/\n/g, "\n\t")}\n}${darkBlock}${backgroundBlock}`;
---

{theme.fonts.googleFontsHref && (
	<link rel="stylesheet" href={theme.fonts.googleFontsHref} />
)}
<style is:inline set:html={css}></style>
