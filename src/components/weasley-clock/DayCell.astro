---
import DualDate from "./DualDate.astro";
import EventChip from "./EventChip.astro";
import type { FamilyOccurrence } from "../../utils/familyEvents";
import type { SyncedEventRecord } from "../../utils/weasleyClockEvents";

interface Props {
	date: Date;
	occurrences: FamilyOccurrence[];
	synced?: SyncedEventRecord[];
	isToday?: boolean;
	isDimmed?: boolean;
	variant?: "week" | "month";
}
const { date, occurrences, synced = [], isToday, isDimmed, variant = "week" } = Astro.props;

function chipCategoryFor(ev: FamilyOccurrence): "giỗ" | "birthday" | "anniversary" | "cultural" | "milestone" | "other" {
	switch (ev.event.event_type) {
		case "death_anniv": return "giỗ";
		case "birthday": return "birthday";
		case "wedding_anniv": return "anniversary";
		case "cultural": return "cultural";
		case "milestone": return "milestone";
		default: return "other";
	}
}
---
<div class={`wc-day ${isToday ? "wc-day--today" : ""} ${isDimmed ? "wc-day--dim" : ""} wc-day--${variant}`}>
	<header class="wc-day__head">
		<DualDate
			date={date}
			size={variant === "week" ? "lg" : "sm"}
			mode={variant === "month" ? "compact-month" : "full"}
		/>
	</header>
	<ul class="wc-day__events">
		{occurrences.map((occ) => (
			<li>
				<EventChip
					title={occ.event.title_vi || occ.event.title_en}
					subtitle={variant === "week" ? (occ.nth ? `${occ.nth}th · ${occ.event.relationship ?? ""}` : occ.event.relationship ?? "") : undefined}
					category={chipCategoryFor(occ)}
					size={variant === "week" ? "full" : "chip"}
				/>
			</li>
		))}
		{synced.filter((e) => !e.deleted).map((evt) => (
			<li>
				<EventChip
					title={evt.title ?? "(untitled)"}
					subtitle={variant === "week" ? (evt.location ?? undefined) : undefined}
					category="other"
					size={variant === "week" ? "full" : "chip"}
				/>
			</li>
		))}
	</ul>
</div>

<style>
	.wc-day { border: 1px solid #2a1f15; padding: 8px; min-height: 160px; background: #110c08; }
	.wc-day--month { min-height: 90px; padding: 4px 6px; }
	.wc-day--today { border: 2px solid #c9a961; background: #201810; }
	/* Dim prev/next-month cells in month view: opacity wins over the
	   --wc-ink CSS var inside DualDate, desaturates everything uniformly. */
	.wc-day--dim { opacity: 0.32; background: #0a0604; }
	.wc-day__head { margin-bottom: 6px; }
	.wc-day--month .wc-day__head { margin-bottom: 3px; }
	.wc-day__events { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 2px; }
</style>
