				z-index: 0;
				animation: wisp-float var(--wisp-duration) var(--wisp-delay) infinite linear;
			}

			.memory-wisps {
				position: fixed;
				inset: 0;
				pointer-events: none;
				z-index: 0;
				overflow: hidden;
			}

			.memory-wisps::before {
