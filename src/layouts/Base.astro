---
import { getMenu, getEmDashCollection } from "emdash";
import {
	WidgetArea,
	EmDashHead,
	EmDashBodyStart,
	EmDashBodyEnd,
} from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import LiveSearch from "emdash/ui/search";
import "../styles/theme.css";
import ThemeStyles from "../components/ThemeStyles.astro";
import type { Theme } from "../themes/types";
import { link } from "../utils/link";
import { allThemes } from "../themes";
import { categoryThemeMap } from "../themes/categoryThemes";
import { getCurrentLang, otherLang } from "../utils/lang";

const currentLang = getCurrentLang(Astro);
const flipLang = otherLang(currentLang);

interface Props {
	title: string;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	/** Pass content reference for plugin page contributions on content pages */
	content?: { collection: string; id: string; slug?: string | null };
	/** Optional per-category visual theme. Re-themes the whole page. */
	theme?: Theme | null;
	/** Deprecated — kept as a no-op for callers. All themes share one font stack now. */
	loadAllThemeFonts?: boolean;
	/** Root-level pages: show breadcrumb instead of Pensieve nav */
	breadcrumbs?: { label: string; href?: string }[];
}

const {
	title,
	description,
	image,
	canonical,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	content,
	theme = null,
	breadcrumbs,
} = Astro.props;
const siteTitle = "Pensieve";

// Breadcrumb icon registry — known section labels get icons, dynamic content does not
const breadcrumbIcons = {
	"Pensieve": '<svg class="breadcrumb-logomark" width="14" height="14" viewBox="0 0 32 32" aria-hidden="true"><ellipse cx="16" cy="10.5" rx="11" ry="2.75" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/><path d="M5 10.5 L5 14 C5 20.5 9.5 25 16 25 C22.5 25 27 20.5 27 14 L27 10.5" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/><ellipse cx="16" cy="10.5" rx="4.5" ry="1.1" fill="currentColor"/></svg>',
	"Room of Requirement": '<svg class="breadcrumb-logomark" width="14" height="14" viewBox="0 0 32 32" aria-hidden="true"><path d="M9 28 V10 Q16 2 23 10 V28" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/><circle cx="20" cy="18" r="1.5" fill="currentColor"/></svg>',
	"Trương": '<svg class="breadcrumb-logomark" width="14" height="14" viewBox="0 0 32 32" aria-hidden="true"><circle cx="16" cy="10" r="5" fill="none" stroke="currentColor" stroke-width="2.25"/><path d="M6 28 Q6 20 16 18 Q26 20 26 28" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round"/></svg>',
	"Memories": '<svg class="breadcrumb-logomark" width="14" height="14" viewBox="0 0 32 32" aria-hidden="true"><path d="M16 4 Q12 10 8 14 Q6 18 10 22 Q14 26 16 28 Q18 26 22 22 Q26 18 24 14 Q20 10 16 4Z" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/></svg>',
	"Ký Ức": '<svg class="breadcrumb-logomark" width="14" height="14" viewBox="0 0 32 32" aria-hidden="true"><path d="M16 4 Q12 10 8 14 Q6 18 10 22 Q14 26 16 28 Q18 26 22 22 Q26 18 24 14 Q20 10 16 4Z" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/></svg>',
	"Sorting Hat": '<svg class="breadcrumb-logomark" width="14" height="14" viewBox="0 0 32 32" aria-hidden="true"><path d="M6 26 Q10 22 16 14 Q18 10 14 4 Q18 8 22 14 Q26 22 26 26 Q20 24 16 24 Q12 24 6 26Z" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/></svg>',
	"Danh Mục": '<svg class="breadcrumb-logomark" width="14" height="14" viewBox="0 0 32 32" aria-hidden="true"><path d="M6 26 Q10 22 16 14 Q18 10 14 4 Q18 8 22 14 Q26 22 26 26 Q20 24 16 24 Q12 24 6 26Z" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/></svg>',
	"Enchantments": '<svg class="breadcrumb-logomark" width="14" height="14" viewBox="0 0 32 32" aria-hidden="true"><line x1="6" y1="26" x2="22" y2="10" stroke="currentColor" stroke-width="2.25" stroke-linecap="round"/><circle cx="24" cy="8" r="2" fill="currentColor"/><path d="M24 3 L24 5 M28 8 L26 8 M24 13 L24 11 M20 8 L22 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>',
	"Bùa Phép": '<svg class="breadcrumb-logomark" width="14" height="14" viewBox="0 0 32 32" aria-hidden="true"><line x1="6" y1="26" x2="22" y2="10" stroke="currentColor" stroke-width="2.25" stroke-linecap="round"/><circle cx="24" cy="8" r="2" fill="currentColor"/><path d="M24 3 L24 5 M28 8 L26 8 M24 13 L24 11 M20 8 L22 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>',
	"Priori Incantatem": '<svg class="breadcrumb-logomark" width="14" height="14" viewBox="0 0 32 32" aria-hidden="true"><line x1="6" y1="26" x2="20" y2="12" stroke="currentColor" stroke-width="2.25" stroke-linecap="round"/><circle cx="22" cy="10" r="2" fill="currentColor"/><path d="M22 6 Q26 4 28 2 M24 10 Q28 10 30 8 M22 14 Q26 16 28 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>',
	"Search": '<svg class="breadcrumb-logomark" width="14" height="14" viewBox="0 0 32 32" aria-hidden="true"><line x1="6" y1="26" x2="22" y2="10" stroke="currentColor" stroke-width="2.25" stroke-linecap="round"/><circle cx="24" cy="8" r="3" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>',
	"Tìm kiếm": '<svg class="breadcrumb-logomark" width="14" height="14" viewBox="0 0 32 32" aria-hidden="true"><line x1="6" y1="26" x2="22" y2="10" stroke="currentColor" stroke-width="2.25" stroke-linecap="round"/><circle cx="24" cy="8" r="3" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>',
	"Dark Arts": '<svg class="breadcrumb-logomark" width="14" height="14" viewBox="0 0 32 32" aria-hidden="true" style="color:#8b1a1a"><circle cx="16" cy="10" r="6" fill="none" stroke="currentColor" stroke-width="2.25"/><path d="M12 12 L14 10 M20 12 L18 10 M14 14 L18 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M16 16 Q14 22 10 28 M16 16 Q18 22 22 28" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>',
	"Hogwarts": '<svg class="breadcrumb-logomark" width="14" height="14" viewBox="0 0 32 32" aria-hidden="true"><path d="M8 28 V12 L16 4 L24 12 V28" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/><line x1="16" y1="4" x2="16" y2="1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><rect x="13" y="18" width="6" height="6" rx="0.5" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>',
	"The Library": '<svg class="breadcrumb-logomark" width="14" height="14" viewBox="0 0 32 32" aria-hidden="true"><path d="M6 4 h20 v24 H6 Z" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/><line x1="10" y1="9" x2="22" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="10" y1="14" x2="22" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="10" y1="19" x2="18" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>',
	"Thư Viện": '<svg class="breadcrumb-logomark" width="14" height="14" viewBox="0 0 32 32" aria-hidden="true"><path d="M6 4 h20 v24 H6 Z" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/><line x1="10" y1="9" x2="22" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="10" y1="14" x2="22" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="10" y1="19" x2="18" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>',
};

// Nav menu: primary items from seed + a hardcoded Categories link
const categoryMenuEntries = Object.entries(categoryThemeMap).map(([slug, themeSlug]) => {
	const t = allThemes.find((x) => x.slug === themeSlug);
	// Capitalize the category slug for display
	const label = slug
		.replace(/-/g, " ")
		.replace(/\b\w/g, (c) => c.toUpperCase());
	return {
		categorySlug: slug,
		label,
		accent: t?.palette.accent ?? "#666",
	};
});
// If title already includes site title (from getSeoMeta), use as-is
const fullTitle = title.includes(siteTitle) ? title : `${title} — ${siteTitle}`;

// Fetch primary menu defined in seed
const menu = await getMenu("primary");

// Fetch pages for footer
const { entries: pages } = await getEmDashCollection("pages");

// Build public page context for plugin contributions
// SEO data is passed here and rendered securely by EmDashHead
const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	description,
	canonical,
	image,
	content,
	seo: { ogImage: image, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});

// Check if user is logged in (for showing admin link)
const isLoggedIn = !!Astro.locals.user;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=JetBrains+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>
		<title>{fullTitle}</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="manifest" href="/manifest.json" />
		<meta name="theme-color" content="#08090a" />
		<link rel="apple-touch-icon" href="/icon-maskable.svg" />
		<link
			rel="alternate"
			type="application/rss+xml"
			title="Pensieve — Tiếng Việt"
			href={link("rss-vi.xml")}
		/>
		<link
			rel="alternate"
			type="application/rss+xml"
			title="Pensieve — English"
			href={link("rss-en.xml")}
		/>
		<EmDashHead page={pageCtx} />
		{/* Content Signals (contentsignals.org / IETF aipref) */}
		<meta name="ai-content-declaration" content="site-code:ai-generated; content:human-written" />
		<meta name="generator" content="Astro + Claude Code" />
		{theme && <ThemeStyles theme={theme} />}
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />
		<div class="memory-wisps" aria-hidden="true"><span class="wisp-extra"></span></div>
		{breadcrumbs ? (
			<header class="site-header breadcrumb-header">
				<nav class="breadcrumb-nav">
					<a href="/" class="breadcrumb-home">
						<svg class="breadcrumb-logomark" width="14" height="14" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
							<path d="M16 28 C16 22 15 18 16 13" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" />
							<path d="M16 15 C13 13 9 10 8 5 C13 6 16 11 16 15" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" />
							<path d="M16 11 C19 9 23 6 24 2 C19 3 16 7 16 11" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
						huuloc.com
					</a>
					{breadcrumbs.map((crumb) => {
						const svg = breadcrumbIcons[crumb.label];
						return (
							<>
								<span class="breadcrumb-sep">/</span>
								{crumb.href ? (
									<a href={crumb.href} class={`breadcrumb-link${svg ? " breadcrumb-with-icon" : ""}`}>
										{svg && <Fragment set:html={svg} />}
										{crumb.label}
									</a>
								) : (
									<span class={`breadcrumb-current${svg ? " breadcrumb-with-icon" : ""}`}>
										{svg && <Fragment set:html={svg} />}
										{crumb.label}
									</span>
								)}
							</>
						);
					})}
				</nav>
			</header>
		) : (
			<header class="site-header">
				<nav class="nav">
					<a href="/" class="site-title">
						<svg
							class="site-logomark"
							width="22"
							height="22"
							viewBox="0 0 32 32"
							xmlns="http://www.w3.org/2000/svg"
							aria-hidden="true"
						>
							<ellipse
								cx="16"
								cy="10.5"
								rx="11"
								ry="2.75"
								fill="none"
								stroke="currentColor"
								stroke-width="2.25"
								stroke-linecap="round"
								stroke-linejoin="round"
							></ellipse>
							<path
								d="M5 10.5 L5 14 C5 20.5 9.5 25 16 25 C22.5 25 27 20.5 27 14 L27 10.5"
								fill="none"
								stroke="currentColor"
								stroke-width="2.25"
								stroke-linecap="round"
								stroke-linejoin="round"
							></path>
							<ellipse
								cx="16"
								cy="10.5"
								rx="4.5"
								ry="1.1"
								fill="currentColor"
							></ellipse>
						</svg>
						<span>{siteTitle}</span>
					</a>
					<div class="nav-right">
						<LiveSearch
							placeholder={currentLang === "vi" ? "Accio ký ức..." : "Accio memories..."}
							class="site-search"
							inputClass="site-search-input"
							resultsClass="site-search-results"
							resultClass="site-search-result"
							collections={["posts", "pages"]}
						/>
						<div class="nav-links">
							{
								menu?.items.map((item) => (
									<a href={item.url} target={item.target}>
										{item.label}
									</a>
								))
							}
							<details class="nav-categories">
								<summary>
									{currentLang === "vi" ? "Mũ Phân Loại" : "Sorting Hat"} <span class="nav-arrow">▾</span>
								</summary>
								<div class="nav-dropdown">
									<a href={link("categories")} class="nav-dropdown-header">
										{currentLang === "vi" ? "Tất cả danh mục →" : "All categories →"}
									</a>
									{
										categoryMenuEntries.map((c) => (
											<a
												href={link(`category/${c.categorySlug}`)}
												class="nav-dropdown-item"
												style={`--cat-accent: ${c.accent};`}
											>
												<span class="nav-dot" />
												{c.label}
											</a>
										))
									}
								</div>
							</details>
						</div>
						{
							isLoggedIn && (
								<a href="/_emdash/admin" class="nav-admin">
									Admin
								</a>
							)
						}
						<details class="nav-lang">
							<summary>
								{currentLang === "vi" ? "VI" : "EN"} <span class="nav-arrow">▾</span>
							</summary>
							<div class="nav-dropdown">
								<a href="#" class="nav-dropdown-item" data-switch-lang="vi" data-active={currentLang === "vi"}>
									Tiếng Việt
								</a>
								<a href="#" class="nav-dropdown-item" data-switch-lang="en" data-active={currentLang === "en"}>
									English
								</a>
							</div>
						</details>
					</div>
				</nav>
			</header>
		)}

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-inner">
				<div class="footer-grid">
					<div class="footer-brand">
						<a href="/" class="footer-logo">{siteTitle}</a>
						<p class="footer-tagline">{currentLang === "vi" ? "Suy nghĩ được rút ra, câu chuyện được lưu giữ." : "Thoughts extracted, stories preserved."}</p>
					</div>
					<div class="footer-nav">
						<h4 class="footer-heading">{currentLang === "vi" ? "Bản Đồ Đạo Tặc" : "Marauder's Map"}</h4>
						<ul class="footer-links">
							<li><a href="/">{currentLang === "vi" ? "Trang chủ" : "Home"}</a></li>
							<li><a href={link("memories")}>{currentLang === "vi" ? "Tất cả ký ức" : "All Memories"}</a></li>
							{
								pages.slice(0, 3).map((page) => (
									<li>
										<a href={link(`pages/${page.data.slug || page.id}`)}>
											{page.data.title}
										</a>
									</li>
								))
							}
						</ul>
					</div>
					<div class="footer-nav">
						<h4 class="footer-heading">{currentLang === "vi" ? "Danh Bạ Cú" : "Owl Directory"}</h4>
						<ul class="footer-links">
							{
								menu?.items.map((item) => (
									<li>
										<a
											href={item.url}
											target={item.target}
											rel={
												item.target === "_blank"
													? "noopener noreferrer"
													: undefined
											}
										>
											{item.label}
										</a>
									</li>
								))
							}
							<li><a href={link("rss.xml")}>{currentLang === "vi" ? "Nguồn RSS" : "RSS Feed"}</a></li>
						</ul>
					</div>
					<div class="footer-widgets-section">
						<WidgetArea name="footer" />
					</div>
				</div>
				{!breadcrumbs && (
					<div class="footer-subscribe">
						<h4 class="footer-heading">{currentLang === "vi" ? "Cú Bưu Điện" : "Owl Post"}</h4>
						<p class="footer-subscribe-desc">{currentLang === "vi" ? "Nhận ký ức mới qua email" : "New memories delivered by owl"}</p>
						<form class="footer-subscribe-form" data-footer-subscribe>
							<input type="email" name="email" required placeholder={currentLang === "vi" ? "email của bạn" : "your\@email.com"} class="footer-subscribe-input" />
							<button type="submit" class="footer-subscribe-btn">{currentLang === "vi" ? "Gửi" : "Send"}</button>
						</form>
						<p class="footer-subscribe-status" data-footer-subscribe-status></p>
					</div>
				)}
				<div class="footer-categories">
					<span class="footer-categories-label">{currentLang === "vi" ? "Mũ Phân Loại" : "Sorting Hat"}</span>
					<div class="footer-categories-cloud">
						{
							categoryMenuEntries.map((c) => (
								<a
									href={link(`category/${c.categorySlug}`)}
									class="footer-cat-chip"
									style={`--cat-accent: ${c.accent};`}
								>
									{c.label}
								</a>
							))
						}
					</div>
				</div>
				<div class="footer-bottom">
					<p class="footer-copyright">
						© <span class="footer-name" role="button" tabindex="0" title="Expecto Patronum!">Trương Hữu Lộc</span>
					</p>
				</div>
			</div>
		</footer>

		<script>
			// Expecto Patronum — click name to summon stag
			const footerName = document.querySelector(".footer-name");
			if (footerName) {
				footerName.addEventListener("click", () => {
					window.SpellSounds?.sparkle();
					window.MagicalCreatures?.summon("stag");
				});
			}
		</script>

		<style is:global>
			*:where(:not([class*="emdash"]):not([class*="ec-"])),
			*:where(:not([class*="emdash"]):not([class*="ec-"]))::before,
			*:where(:not([class*="emdash"]):not([class*="ec-"]))::after {
				box-sizing: border-box;
			}

			body,
			h1,
			h2,
			h3,
			h4,
			h5,
			h6,
			p,
			ul,
			ol,
			figure,
			blockquote,
			dl,
			dd {
				margin: 0;
			}

			ul,
			ol {
				padding: 0;
			}

			/* All design tokens (colors, type, spacing, layout) live in
			   src/styles/theme.css. This block only adds EmDash-specific
			   search component overrides that need to read those vars. */
			:root {
				--emdash-search-bg: var(--color-bg);
				--emdash-search-text: var(--color-text);
				--emdash-search-muted: var(--color-muted);
				--emdash-search-border: var(--color-border);
				--emdash-search-hover: var(--color-surface);
				--emdash-search-highlight: var(--color-text);
			}

			html {
				scroll-behavior: smooth;
			}

			body {
				font-family: var(--font-sans);
				font-size: var(--font-size-base);
				line-height: var(--leading-relaxed);
				color: var(--color-text);
				background: var(--color-bg);
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				min-height: 100vh;
			}

			a:where(:not([class*="emdash"]):not([class*="ec-"])) {
				color: var(--color-accent);
				text-decoration: none;
				transition: color var(--transition-fast);
			}

			a:where(:not([class*="emdash"]):not([class*="ec-"])):hover {
				color: var(--color-accent-hover);
			}

			img {
				max-width: 100%;
				height: auto;
				display: block;
			}

			h1,
			h2,
			h3,
			h4,
			h5,
			h6 {
				font-family: var(--font-sans);
				line-height: var(--leading-tight);
				font-weight: 600;
				letter-spacing: var(--tracking-snug);
			}

			h1 {
				font-weight: 700;
				letter-spacing: var(--tracking-tight);
			}

			::selection {
				background: var(--color-accent);
				color: white;
			}

			/* Memory wisps — subtle floating particles in dark mode */
			@keyframes wisp-float {
				0% { transform: translateY(100vh) translateX(0); opacity: 0; }
				10% { opacity: var(--wisp-opacity); }
				90% { opacity: var(--wisp-opacity); }
				100% { transform: translateY(-10vh) translateX(var(--wisp-drift)); opacity: 0; }
			}

