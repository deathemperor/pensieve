				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				border-bottom: 1px solid var(--color-border-subtle);
			}

			/* Breadcrumb header for root-level pages.
			   Single-line layout: non-leaf crumbs keep their natural width,
			   the leaf (last crumb) flex-grows to fill remaining space and
			   truncates with ellipsis when it won't fit. Tooltip (title
			   attribute) surfaces the full text on hover/long-press. */
			.breadcrumb-nav {
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: var(--spacing-4) var(--spacing-8);
				display: flex;
				align-items: center;
				gap: var(--spacing-2);
				font-family: var(--font-mono);
				font-size: var(--font-size-xs);
				height: var(--nav-height);
				flex-wrap: nowrap;
				overflow: hidden;
			}

			/* Shrink order: home and separators stay full-width (they're
			   small and anchor the trail). Non-leaf text crumbs shrink
			   first with ellipsis when space is tight. The leaf shrinks
			   last and always keeps at least 6ch visible. */
			.breadcrumb-home,
			.breadcrumb-sep {
				flex-shrink: 0;
				white-space: nowrap;
			}

			.breadcrumb-link,
			.breadcrumb-current:not(.breadcrumb-leaf) {
				min-width: 2ch;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
				/* flex-shrink: 2 — shrinks twice as fast as the leaf,
				   so non-leaf crumbs give up space first. */
				flex-shrink: 2;
			}

			.breadcrumb-home {
				display: inline-flex;
				align-items: center;
				gap: 0.35em;
				color: var(--color-muted);
				text-decoration: none;
				transition: color var(--transition-fast);
			}

			.breadcrumb-home:hover {
				color: var(--color-text);
			}

			.breadcrumb-sep {
				color: var(--color-muted);
				opacity: 0.4;
			}

			.breadcrumb-link {
				color: var(--color-muted);
				text-decoration: none;
				transition: color var(--transition-fast);
			}

			.breadcrumb-link:hover {
				color: var(--color-text);
			}

			.breadcrumb-current {
				color: var(--color-text);
			}

			/* The leaf (current page) grows into remaining space. Keeps at
			   least 6ch visible so "Abc…" is always readable, even when
			   non-leaf crumbs have also shrunk. flex-shrink: 1 is lower
			   than non-leaf's 2, so non-leaf items shrink first. */
			.breadcrumb-leaf {
				flex: 1 1 auto;
				min-width: 6ch;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}

			/* On narrow viewports, drop the middle crumbs entirely — keep
			   only home / first-parent / leaf. Three '…' dots from ellipsis
			   truncation on middle crumbs read as glitches, not as a
			   deliberate pattern. The H1 right below always shows the full
			   title anyway, and users on mobile care most about "which
			   section" (first parent) and "what page" (leaf). */
			@media (max-width: 639px) {
				.breadcrumb-middle,
