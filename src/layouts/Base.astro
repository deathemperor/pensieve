				box-shadow: 0 0 16px rgba(94, 106, 210, 0.15);
			}

			.nixie-wand {
				width: 16px;
				height: 16px;
				transition: transform 0.3s ease;
			}

			.nixie:hover .nixie-wand {
				transform: rotate(-15deg);
			}

			.nixie-label {
				max-width: 0;
				overflow: hidden;
				white-space: nowrap;
				transition: max-width 0.3s ease, opacity 0.3s ease;
				opacity: 0;
			}

			.nixie:hover .nixie-label {
				max-width: 150px;
				opacity: 1;
			}

			@media (max-width: 900px) {
				.footer-grid {
					grid-template-columns: 1fr 1fr;
					gap: var(--spacing-8);
				}

				.footer-brand {
					grid-column: span 2;
					max-width: none;
				}
			}

			@media (max-width: 640px) {
				.site-header {
					position: relative;
					border-bottom: none;
				}

				.nav {
					flex-direction: row;
					flex-wrap: wrap;
					justify-content: space-between;
					align-items: center;
					height: auto;
					gap: var(--spacing-2);
					padding: var(--spacing-3) var(--spacing-4);
				}

				.site-title {
					font-size: var(--font-size-base);
				}

				.nav-right {
					display: contents;
				}

				.site-search {
					order: 0;
					max-width: 140px;
				}

				:global(.site-search-input) {
					width: 140px !important;
					padding: var(--spacing-1) var(--spacing-2) !important;
					font-size: var(--font-size-sm) !important;
				}

				.nav-links {
					order: 1;
					width: 100%;
					display: flex;
					column-gap: var(--spacing-3);
					row-gap: var(--spacing-1);
					flex-wrap: wrap;
					justify-content: flex-start;
				}

				.nav-admin {
					order: 2;
					position: absolute;
					right: var(--spacing-4);
					top: var(--spacing-3);
					font-size: var(--font-size-xs);
				}

				.footer-grid {
					grid-template-columns: 1fr;
				}

				.footer-brand {
					grid-column: span 1;
				}

				.footer-bottom {
					flex-direction: column;
					gap: var(--spacing-4);
					text-align: center;
				}

				.footer-controls {
					flex-wrap: wrap;
					justify-content: center;
				}
			}
		</style>

		<script>
			// ⌘K / Ctrl+K to focus search
			document.addEventListener("keydown", (e) => {
				if ((e.metaKey || e.ctrlKey) && e.key === "k") {
					e.preventDefault();
					const searchInput = document.querySelector(
						".site-search-input"
					) as HTMLInputElement;
					if (searchInput) {
						searchInput.focus();
					}
				}
			});
		</script>
		<EmDashBodyEnd page={pageCtx} />
		<script>
			function setLangCookie(lang: string) {
				document.cookie = `pref_lang=${lang};path=/;max-age=${60*60*24*365};samesite=lax`;
			}
			document.querySelectorAll<HTMLAnchorElement>('[data-switch-lang]').forEach(a => {
				a.addEventListener('click', (e) => {
					e.preventDefault();
					setLangCookie(a.dataset.switchLang!);
					// If link has a real href (not "#"), navigate there; otherwise reload
					if (a.href && !a.getAttribute('href')?.startsWith('#')) {
						location.href = a.href;
					} else {
						location.reload();
					}
				});
			});

			// Owl Post — footer subscribe form
			const fForm = document.querySelector('[data-footer-subscribe]') as HTMLFormElement | null;
			if (fForm) {
				const fStatus = document.querySelector('[data-footer-subscribe-status]') as HTMLElement;
				fForm.addEventListener('submit', async (e) => {
					e.preventDefault();
					const email = (fForm.querySelector('input[name=email]') as HTMLInputElement).value;
					fStatus.textContent = '';
					fStatus.style.color = '';
					try {
						const res = await fetch('/_emdash/api/plugins/pensieve-engage/subscribe', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({ email }),
						});
						const payload = await res.json();
						// Plugin runtime wraps handler returns as {data: ...} and framework
						// errors as {error: {code, message}}. Unwrap both.
						const handler = res.ok ? (payload.data || {}) : {};
						const envelopeError = res.ok ? null : payload.error;
						const isVi = document.documentElement.lang === 'vi';
						if (handler.success) {
							fStatus.textContent = isVi ? 'Cú đã bay!' : 'Owl dispatched!';
							fStatus.style.color = '#3fb950';
							fForm.reset();
						} else {
							const handlerErr = typeof handler.error === 'string' ? handler.error : handler.error?.message;
							const envErr = typeof envelopeError === 'string' ? envelopeError : envelopeError?.message;
							fStatus.textContent = handlerErr || envErr || (isVi ? 'Có lỗi xảy ra' : 'Something went wrong');
							fStatus.style.color = '#e5534b';
						}
					} catch {
						const isVi = document.documentElement.lang === 'vi';
						fStatus.textContent = isVi ? 'Không gửi được cú' : 'Failed to send owl';
						fStatus.style.color = '#e5534b';
					}
				});
			}
		</script>
		{/* Nixie — Claude Code house-elf buddy */}
		<a href="/room-of-requirement" class="nixie" aria-label="Built by Claude Code" title={currentLang === "vi" ? "Được phù phép bởi Claude Code" : "Conjured by Claude Code"}>
			<svg class="nixie-wand" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
				<line x1="4" y1="20" x2="18" y2="6" />
				<circle cx="19" cy="5" r="2" fill="currentColor" stroke="none" opacity="0.6" />
				<circle cx="19" cy="5" r="4" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.3" />
			</svg>
			<span class="nixie-label">{currentLang === "vi" ? "Phù phép bởi CC" : "Conjured by CC"}</span>
		</a>
		<script src="/js/spellsounds.js" is:inline></script>
		<script src="/js/creatures.js" is:inline></script>

	<!-- Site-wide Owl Post bar — sticky at bottom until the reader either
	     subscribes or dismisses. Dismissal persists via localStorage. -->
	<aside class="owl-bar" data-owl-bar hidden role="region" aria-label={currentLang === "vi" ? "Đăng ký Cú Bưu Điện" : "Subscribe to Owl Post"}>
		<div class="owl-bar-inner">
			<div class="owl-bar-copy">
				<strong class="owl-bar-title">{currentLang === "vi" ? "Cú Bưu Điện" : "Owl Post"}</strong>
				<span class="owl-bar-desc">
					{currentLang === "vi"
						? "Nhận ký ức mới qua email. Không spam."
						: "New memories delivered by owl. No spam, no dark magic."}
				</span>
			</div>
			<form class="owl-bar-form" data-owl-form>
				<input type="email" name="email" required
					placeholder={currentLang === "vi" ? "email của bạn" : "your@email.com"}
					class="owl-bar-input"
					aria-label={currentLang === "vi" ? "Địa chỉ email" : "Email address"} />
				<button type="submit" class="owl-bar-btn">{currentLang === "vi" ? "Đăng ký" : "Subscribe"}</button>
			</form>
			<p class="owl-bar-status" data-owl-status aria-live="polite"></p>
			<button type="button" class="owl-bar-close" data-owl-close aria-label={currentLang === "vi" ? "Đóng" : "Dismiss"}>×</button>
		</div>
	</aside>
	<script is:inline>
		(function () {
			const DISMISS_KEY = 'pensieve:owl-post-dismissed:v1';
			const bar = document.querySelector('[data-owl-bar]');
			if (!bar) return;
			if (location.pathname.startsWith('/_emdash')) return;
			if (localStorage.getItem(DISMISS_KEY)) return;
			setTimeout(() => {
				bar.hidden = false;
				requestAnimationFrame(() => bar.classList.add('owl-bar-in'));
			}, 800);
			const form = bar.querySelector('[data-owl-form]');
			const status = bar.querySelector('[data-owl-status]');
			const closeBtn = bar.querySelector('[data-owl-close]');
			const isVi = document.documentElement.lang === 'vi';
			function dismiss() {
				try { localStorage.setItem(DISMISS_KEY, String(Date.now())); } catch {}
				bar.classList.remove('owl-bar-in');
				setTimeout(() => { bar.hidden = true; }, 260);
			}
			closeBtn && closeBtn.addEventListener('click', dismiss);
			form && form.addEventListener('submit', async (e) => {
				e.preventDefault();
				const email = form.querySelector('input[name=email]').value;
				status.textContent = '';
				status.className = 'owl-bar-status';
				try {
					const res = await fetch('/_emdash/api/plugins/pensieve-engage/subscribe', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ email }),
					});
					const payload = await res.json();
					const handler = res.ok ? (payload.data || {}) : {};
					const envErr = res.ok ? null : payload.error;
					if (handler.success) {
						status.textContent = isVi ? 'Cú đã bay! Kiểm tra email chào mừng.' : 'Owl dispatched! Check for your welcome letter.';
						status.classList.add('success');
						form.reset();
						setTimeout(dismiss, 2400);
					} else {
						const fallback = isVi ? 'Có lỗi xảy ra' : 'Something went wrong';
						const hErr = typeof handler.error === 'string' ? handler.error : handler.error && handler.error.message;
						const eErr = typeof envErr === 'string' ? envErr : envErr && envErr.message;
						status.textContent = hErr || eErr || fallback;
						status.classList.add('error');
					}
				} catch {
					status.textContent = isVi ? 'Không gửi được cú' : 'Failed to send owl';
					status.classList.add('error');
				}
			});
		})();
	</script>
	</body>
</html>
