{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noImplicitAny": true,
		"forceConsistentCasingInFileNames": true,
		"lib": ["DOM", "ES2022"]
	},
	"include": ["main.ts", "src/**/*.ts"]
}
