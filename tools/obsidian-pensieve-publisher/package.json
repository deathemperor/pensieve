{
	"name": "obsidian-pensieve-publisher",
	"version": "0.2.0",
	"description": "Obsidian plugin — publish notes to Pensieve (EmDash CMS) + Facebook.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "node esbuild.config.mjs production",
		"typecheck": "tsc --noEmit",
		"release": "bash scripts/release.sh"
	},
	"keywords": ["obsidian", "plugin", "emdash", "pensieve"],
	"license": "MIT",
	"devDependencies": {
		"@types/node": "20.19.39",
		"builtin-modules": "3.3.0",
		"esbuild": "0.28.0",
		"obsidian": "latest",
		"typescript": "6.0.3"
	}
}
